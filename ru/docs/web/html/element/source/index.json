class=\"html5\"><a href=\"/ru/docs/Web/HTML/Element/wbr\"><code>&lt;wbr&gt;</code></a></li>\n </ol>\n </li><li>X Y Z\n <ol>\n  <li><s class=\"obsoleteElement\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/xmp\"><code>&lt;xmp&gt;</code> <small>(en-US)</small></a></s></li>\n </ol>\n    </li>\n   </ol>\n   </details></li>\n   </ol>\n  ","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p><strong>HTML-—Н–ї–µ–Љ–µ–љ—В&nbsp;<code>&lt;source&gt;</code> </strong>&nbsp;—Г–Ї–∞–Ј—Л–≤–∞–µ—В –љ–µ—Б–Ї–Њ–ї—М–Ї–Њ –Љ–µ–і–Є–∞-—А–µ—Б—Г—А—Б–Њ–≤ –і–ї—П —Н–ї–µ–Љ–µ–љ—В–Њ–≤&nbsp;<a href=\"/ru/docs/Web/HTML/Element/picture\"><code>&lt;picture&gt;</code></a>, <a href=\"/ru/docs/Web/HTML/Element/video\"><code>&lt;video&gt;</code></a> –Є&nbsp;<a href=\"/ru/docs/Web/HTML/Element/audio\"><code>&lt;audio&gt;</code></a>. –≠—В–Њ –њ—Г—Б—В–Њ–є —Н–ї–µ–Љ–µ–љ—В. –Ю–љ –Њ–±—Л—З–љ–Њ –Є—Б–њ–Њ–ї—М–Ј—Г–µ—В—Б—П –і–ї—П –Њ–±—Б–ї—Г–ґ–Є–≤–∞–љ–Є—П –Њ–і–љ–Њ–≥–Њ –Є —В–Њ–≥–Њ –ґ–µ –Љ–µ–і–Є–∞-–Ї–Њ–љ—В–µ–љ—В–∞ <a href=\"/en-US/docs/Web/Media/Formats\">–≤ –љ–µ—Б–Ї–Њ–ї—М–Ї–Є—Е —Д–Њ—А–Љ–∞—В–∞—Е, –њ–Њ–і–і–µ—А–ґ–Є–≤–∞–µ–Љ—Л—Е —А–∞–Ј–ї–Є—З–љ—Л–Љ–Є –±—А–∞—Г–Ј–µ—А–∞–Љ–Є</a>.</p>\n\n<table class=\"properties\">\n <tbody>\n  <tr>\n   <th scope=\"row\"><a href=\"/en-US/docs/Web/Guide/HTML/Content_categories\">–Ъ–∞—В–µ–≥–Њ—А–Є–Є –Ї–Њ–љ—В–µ–љ—В–∞</a></th>\n   <td>–Э–µ—В</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">–†–∞–Ј—А–µ—И—С–љ–љ—Л–є –Ї–Њ–љ—В–µ–љ—В</th>\n   <td>–Э–µ—В, —Н—В–Њ&nbsp; <a href=\"/ru/docs/Glossary/Empty_element\">–њ—Г—Б—В–Њ–є —Н–ї–µ–Љ–µ–љ—В</a>.</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">–Я—А–Њ–њ—Г—Б–Ї —В–µ–≥–Њ–≤</th>\n   <td>–Ф–Њ–ї–ґ–µ–љ –Є–Љ–µ—В—М –Њ—В–Ї—А—Л–≤–∞—О—Й–Є–є —В–µ–≥; –Ј–∞–Ї—А—Л–≤–∞—О—Й–Є–є —В–µ–≥ –љ–µ–Њ–±—П–Ј–∞—В–µ–ї–µ–љ.</td>\n  </tr>\n  <tr>\n   <th scope=\"row\"><dfn>–†–∞–Ј—А–µ—И—С–љ–љ—Л–µ —А–Њ–і–Є—В–µ–ї–Є</dfn></th>\n   <td>\n    <div id=\"sect1\">–Ь–µ–і–Є–∞-—Н–ї–µ–Љ–µ–љ—В—Л вАФ<a href=\"/ru/docs/Web/HTML/Element/audio\"><code>&lt;audio&gt;</code></a> –Є–ї–Є <a href=\"/ru/docs/Web/HTML/Element/video\"><code>&lt;video&gt;</code></a>вАФ–і–Њ–ї–ґ–µ–љ –±—Л—В—М –њ–Њ–Љ–µ—Й—С–љ –њ–µ—А–µ–і –ї—О–±—Л–Љ&nbsp;<a href=\"/en-US/docs/Web/Guide/HTML/Content_categories#flow_content\">–њ–Њ—В–Њ–Ї–Њ–≤—Л–Љ –Ї–Њ–љ—В–µ–љ—В–Њ–Љ</a>&nbsp;–Є–ї–Є —Н–ї–µ–Љ–µ–љ—В–Њ–Љ<a href=\"/ru/docs/Web/HTML/Element/track\"><code>&lt;track&gt;</code></a>.</div>\n\n    <div id=\"sect2\">–≠–ї–µ–Љ–µ–љ—В <a href=\"/ru/docs/Web/HTML/Element/picture\"><code>&lt;picture&gt;</code></a> , –і–Њ–ї–ґ–µ–љ –±—Л—В—М –њ–Њ–Љ–µ—Й—С–љ –њ–µ—А–µ–і —Н–ї–µ–Љ–µ–љ—В–Њ–Љ <a href=\"/ru/docs/Web/HTML/Element/img\"><code>&lt;img&gt;</code></a>.</div>\n   </td>\n  </tr>\n  <tr>\n   <th scope=\"row\">Permitted ARIA roles</th>\n   <td>–Э–µ—В</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">DOM interface</th>\n   <td><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/HTMLSourceElement\"><code>HTMLSourceElement</code> <small>(en-US)</small></a></td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"–∞—В—А–Є–±—Г—В—Л","title":"–Р—В—А–Є–±—Г—В—Л","isH3":false,"content":"<p>–≠—В–Њ—В —Н–ї–µ–Љ–µ–љ—В –≤–Ї–ї—О—З–∞–µ—В –≤ —Б–µ–±—П&nbsp;<a href=\"/en-US/docs/Web/HTML/Global_attributes\">—Г–љ–Є–≤–µ—А—Б–∞–ї—М–љ—Л–µ –∞—В—А–Є–±—Г—В—Л</a>.</p>\n\n<ol>\n <li>–∞–і—А–µ—Б–∞ –Є–Ј–Њ–±—А–∞–ґ–µ–љ–Є—П (URL);</li>\n <li>–і–µ—Б–Ї—А–Є–њ—В–Њ—А–∞ —И–Є—А–Є–љ—Л, –њ—А–µ–і—Б—В–∞–≤–ї—П—О—Й–µ–≥–Њ —Б–Њ–±–Њ–є —Ж–µ–ї–Њ–µ –њ–Њ–ї–Њ–ґ–Є—В–µ–ї—М–љ–Њ–µ —З–Є—Б–ї–Њ, –Ј–∞ –Ї–Њ—В–Њ—А—Л–Љ —Б–ї–µ–і—Г–µ—В&nbsp;<code>'w'</code>.&nbsp; –Ч–љ–∞—З–µ–љ–Є–µ–Љ –њ–Њ —Г–Љ–Њ–ї—З–∞–љ–Є—О, –µ—Б–ї–Є –Њ–љ–Њ –Њ—В—Б—Г—В—Б—В–≤—Г–µ—В, —П–≤–ї—П–µ—В—Б—П –±–µ—Б–Ї–Њ–љ–µ—З–љ–Њ—Б—В—М.</li>\n <li>–і–µ—Б–Ї—А–Є–њ—В–Њ—А–∞ –њ–ї–Њ—В–љ–Њ—Б—В–Є –њ–Є–Ї—Б–µ–ї–µ–є, –њ—А–µ–і—Б—В–∞–≤–ї—П—О—Й–µ–µ —Б–Њ–±–Њ–є –њ–Њ–ї–Њ–ґ–Є—В–µ–ї—М–љ–Њ–µ –і–µ—Б—П—В–Є—З–љ–Њ–µ —З–Є—Б–ї–Њ, –Ј–∞ –Ї–Њ—В–Њ—А—Л–Љ —Б–ї–µ–і—Г–µ—В&nbsp;<code>'x'</code>. –Ч–љ–∞—З–µ–љ–Є–µ–Љ –њ–Њ —Г–Љ–Њ–ї—З–∞–љ–Є—О,&nbsp;–µ—Б–ї–Є –Њ–љ–Њ –Њ—В—Б—Г—В—Б—В–≤—Г–µ—В, —П–≤–ї—П–µ—В—Б—П&nbsp;<code>1x</code>.</li>\n</ol>\n\n<dl>\n <dt id=\"sizes\"><a id=\"attr-sizes\" href=\"#attr-sizes\"><b><code>sizes</code></b></a> <svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg></dt>\n <dd>–°–њ–Є—Б–Њ–Ї —А–∞–Ј–Љ–µ—А–Њ–≤ –Є–Ј–Њ–±—А–∞–ґ–µ–љ–Є–є –і–ї—П —А–∞–Ј–љ—Л—Е —А–∞–Ј–Љ–µ—А–Њ–≤ —Б—В—А–∞–љ–Є—Ж. –Ю–љ —Б–Њ—Б—В–Њ–Є—В –Є–Ј —А–∞–Ј–і–µ–ї—С–љ–љ—Л—Е&nbsp;–Ј–∞–њ—П—В—Л–Љ–Є&nbsp;–Љ–µ–і–Є–∞–≤—Л—А–∞–ґ–µ–љ–Є–є —Б–Њ –Ј–љ–∞—З–µ–љ–Є—П–Љ–Є —И–Є—А–Є–љ—Л –Є–Ј–Њ–±—А–∞–ґ–µ–љ–Є—П. –≠—В–∞ –Є–љ—Д–Њ—А–Љ–∞—Ж–Є—П –Є—Б–њ–Њ–ї—М–Ј—Г–µ—В—Б—П –±—А–∞—Г–Ј–µ—А–Њ–Љ&nbsp;–њ–µ—А–µ–і –≤—Л–Ї–ї–∞–і–Ї–Њ–є —Б—В—А–∞–љ–Є—Ж—Л&nbsp;–і–ї—П –Њ–њ—А–µ–і–µ–ї–µ–љ–Є—П –Ї–Њ–љ–Ї—А–µ—В–љ–Њ–≥–Њ –Є–Ј–Њ–±—А–∞–ґ–µ–љ–Є—П, –Ј–∞–і–∞–љ–љ–Њ–≥–Њ –≤ –∞—В—А–Є–±—Г—В–µ&nbsp;<a href=\"/ru/docs/Web/HTML/Element/source#attr-srcset\" aria-current=\"page\"><code>srcset</code></a>. –Р—В—А–Є–±—Г—В&nbsp;<code>sizes</code> —А–∞–±–Њ—В–∞–µ—В —В–Њ–ї—М–Ї–Њ —В–Њ–≥–і–∞, –Ї–Њ–≥–і–∞ —Н–ї–µ–Љ–µ–љ—В&nbsp; <a href=\"/ru/docs/Web/HTML/Element/source\" aria-current=\"page\"><code>&lt;source&gt;</code></a> —А–∞—Б–њ–Њ–ї–Њ–ґ–µ–љ –≤–љ—Г—В—А–Є —Н–ї–µ–Љ–µ–љ—В–∞&nbsp;<a href=\"/ru/docs/Web/HTML/Element/picture\"><code>&lt;picture&gt;</code></a>.</dd>\n <dt id=\"src\"><a id=\"attr-src\" href=\"#attr-src\"><b><code>src</code></b></a></dt>\n <dd>–Ґ—А–µ–±—Г–µ–Љ—Л–є –і–ї—П —Н–ї–µ–Љ–µ–љ—В–Њ–≤&nbsp; <a href=\"/ru/docs/Web/HTML/Element/audio\"><code>&lt;audio&gt;</code></a> –Є&nbsp;<a href=\"/ru/docs/Web/HTML/Element/video\"><code>&lt;video&gt;</code></a> –∞–і—А–µ—Б –Љ–µ–і–Є–∞-—А–µ—Б—Г—А—Б–Њ–≤. –Ч–љ–∞—З–µ–љ–Є–µ —Н—В–Њ–≥–Њ –∞—В—А–Є–±—Г—В–∞ –Є–≥–љ–Њ—А–Є—А—Г–µ—В—Б—П –±—А–∞—Г–Ј–µ—А–Њ–Љ, –Ї–Њ–≥–і–∞ —Н–ї–µ–Љ–µ–љ—В&nbsp;<code>&lt;source&gt;</code> —А–∞–Ј–Љ–µ—Й—С–љ –≤–љ—Г—В—А–Є —Н–ї–µ–Љ–µ–љ—В–∞ <a href=\"/ru/docs/Web/HTML/Element/picture\"><code>&lt;picture&gt;</code></a>.</dd>\n <dt id=\"srcset\"><a id=\"attr-srcset\" href=\"#attr-srcset\"><b><code>srcset</code></b></a> <svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg></dt>\n <dd>–°–њ–Є—Б–Њ–Ї –Є–Ј –Њ–і–љ–Њ–є –Є–ї–Є –љ–µ—Б–Ї–Њ–ї—М–Ї–Є—Е —Б—В—А–Њ–Ї, —А–∞–Ј–і–µ–ї—С–љ–љ—Л—Е –Ј–∞–њ—П—В—Л–Љ–Є, –Њ–њ—А–µ–і–µ–ї—П—О—Й–Є–є –љ–∞–±–Њ—А –≤–Њ–Ј–Љ–Њ–ґ–љ—Л—Е –Є–Ј–Њ–±—А–∞–ґ–µ–љ–Є–є, –њ—А–µ–і—Б—В–∞–≤–ї–µ–љ–љ—Л—Е –і–ї—П –Њ—В–Њ–±—А–∞–ґ–µ–љ–Є—П –≤ –±—А–∞—Г–Ј–µ—А–µ. –Ъ–∞–ґ–і–∞—П —Б—В—А–Њ–Ї–∞ –Љ–Њ–ґ–µ—В —Б–Њ—Б—В–Њ—П—В—М –Є–Ј:</dd>\n <dd>\n <p>–Ъ–∞–ґ–і–∞—П —Б—В—А–Њ–Ї–∞ —Б–њ–Є—Б–Ї–∞ –і–Њ–ї–ґ–љ–∞ —Б–Њ–і–µ—А–ґ–∞—В—М –њ–Њ –Ї—А–∞–є–љ–µ–є –Љ–µ—А–µ –і–µ—Б–Ї—А–Є–њ—В–Њ—А —И–Є—А–Є–љ—Л –Є–ї–Є –і–µ—Б–Ї—А–Є–њ—В–Њ—А –њ–ї–Њ—В–љ–Њ—Б—В–Є –њ–Є–Ї—Б–µ–ї–µ–є.&nbsp;&nbsp;</p>\n\n <p>–С—А–∞—Г–Ј–µ—А –≤—Л–±–Є—А–∞–µ—В —Б–∞–Љ–Њ–µ –њ–Њ–і—Е–Њ–і—П—Й–µ–µ –Є–Ј–Њ–±—А–∞–ґ–µ–љ–Є–µ –і–ї—П –Њ—В–Њ–±—А–∞–ґ–µ–љ–Є—П –≤ –і–∞–љ–љ—Л–є –Љ–Њ–Љ–µ–љ—В –≤—А–µ–Љ–µ–љ–Є.</p>\n\n <p>–Р—В—А–Є–±—Г—В&nbsp;<code>srcset</code>&nbsp; —А–∞–±–Њ—В–∞–µ—В —В–Њ–ї—М–Ї–Њ –≤ —В–Њ–Љ —Б–ї—Г—З–∞–µ, –Ї–Њ–≥–і–∞ —Н–ї–µ–Љ–µ–љ—В&nbsp;<a href=\"/ru/docs/Web/HTML/Element/source\" aria-current=\"page\"><code>&lt;source&gt;</code></a> –љ–∞—Е–Њ–і–Є—В—Б—П –≤–љ—Г—В—А–Є —Н–ї–µ–Љ–µ–љ—В–∞&nbsp;<a href=\"/ru/docs/Web/HTML/Element/picture\"><code>&lt;picture&gt;</code></a>.</p>\n </dd>\n <dt id=\"type\"><a id=\"attr-type\" href=\"#attr-type\"><b><code>type</code></b></a></dt>\n <dd>MIME-—В–Є–њ —А–µ—Б—Г—А—Б–∞, –Њ–њ—Ж–Є–Њ–љ–∞–ї—М–љ–Њ —Б–Њ–і–µ—А–ґ–∞—Й–Є–є –њ–∞—А–∞–Љ–µ—В—А&nbsp;<code>codecs</code>. –Ф–ї—П –њ–Њ–ї—Г—З–µ–љ–Є—П –њ–Њ–ї–љ–Њ–є –Є–љ—Д–Њ—А–Љ–∞—Ж–Є–Є –њ–Њ —Г–Ї–∞–Ј–∞–љ–Є—О –Ї–Њ–і–µ–Ї–Њ–≤ —Б–Љ–Њ—В—А–Є—В–µ&nbsp;&nbsp;<a class=\"external\" href=\"https://tools.ietf.org/html/rfc4281\" rel=\" noopener\">RFC 4281</a>.&nbsp;</dd>\n <dt id=\"media\"><a id=\"attr-media\" href=\"#attr-media\"><b><code>media</code></b></a> <svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg></dt>\n <dd>–Ю–њ—А–µ–і–µ–ї—П–µ—В&nbsp;<a class=\"internal\" href=\"/en-US/docs/Web/CSS/Media_Queries/Using_media_queries\">–Љ–µ–і–Є–∞–≤—Л—А–∞–ґ–µ–љ–Є–µ</a>&nbsp;, —Б–Њ–≥–ї–∞—Б–љ–Њ –Ї–Њ—В–Њ—А–Њ–Љ—Г –±—Г–і–µ—В –≤—Л–≤–Њ–і–Є—В—М—Б—П –Є–Ј–Њ–±—А–∞–ґ–µ–љ–Є–µ. –†–∞–±–Њ—В–∞–µ—В&nbsp;—В–Њ–ї—М–Ї–Њ –≤ —Н–ї–µ–Љ–µ–љ—В–µ <a href=\"/ru/docs/Web/HTML/Element/picture\"><code>&lt;picture&gt;</code></a>.</dd>\n</dl>\n\n<p>–Х—Б–ї–Є –∞—В—А–Є–±—Г—В&nbsp;<code>type</code> –љ–µ —Г–Ї–∞–Ј–∞–љ, —В–Њ –Њ–љ –Ј–∞–њ—А–∞—И–Є–≤–∞–µ—В—Б—П —Б —Б–µ—А–≤–µ—А–∞ –Є –њ—А–Њ–≤–µ—А—П–µ—В—Б—П, –Љ–Њ–ґ–µ—В –ї–Є <a href=\"/ru/docs/Glossary/User_agent\">user agent</a>&nbsp;–µ–≥–Њ –Њ–±—А–∞–±–∞—В—Л–≤–∞—В—М. –Х—Б–ї–Є –Њ–љ –љ–µ –Љ–Њ–ґ–µ—В –±—Л—В—М –Њ–±—А–∞–±–Њ—В–∞–љ, –њ—А–Њ–≤–µ—А—П–µ—В—Б—П —Б–ї–µ–і—Г—О—Й–Є–є <code>&lt;source&gt;</code>. –Х—Б–ї–Є –∞—В—А–Є–±—Г—В <code>type</code> —Г–Ї–∞–Ј–∞–љ, –Њ–љ —Б—А–∞–≤–љ–Є–≤–∞–µ—В—Б—П —Б —В–Є–њ–∞–Љ–Є, –Ї–Њ—В–Њ—А—Л–µ –Љ–Њ–ґ–µ—В –њ–Њ–і–і–µ—А–ґ–Є–≤–∞—В—М <a href=\"/ru/docs/Glossary/User_agent\">user agent</a>вАЛвАЛвАЛвАЛвАЛ, –Є –µ—Б–ї–Є –Њ–љ –љ–µ —А–∞—Б–њ–Њ–Ј–љ–∞–љ, —Б–µ—А–≤–µ—А –і–∞–ґ–µ –љ–µ –Ј–∞–њ—А–∞—И–Є–≤–∞–µ—В—Б—П, –≤–Љ–µ—Б—В–Њ —Н—В–Њ–≥–Њ –њ—А–Њ–≤–µ—А—П–µ—В—Б—П —Б–ї–µ–і—Г—О—Й–Є–є —Н–ї–µ–Љ–µ–љ—В <code>&lt;source&gt;</code>.</p>"}},{"type":"prose","value":{"id":"–њ—А–Є–Љ–µ—А—Л","title":"–Я—А–Є–Љ–µ—А—Л","isH3":false,"content":"<p>This example demonstrates how to offer a video in Ogg format for users whose browsers support Ogg format, and a QuickTime format video for users whose browsers support that. If the <code>audio</code> or <code>video</code> element is not supported by the browser, a notice is displayed instead.&nbsp; If the browser supports the element but does not support any of the specified formats, an <code>error</code> event is raised and the default media controls (if enabled) will indicate an error. See also the list of <a href=\"/en-US/docs/Web/Media/Formats\">media formats supported by the audio and video elements</a> in various browsers.</p>\n\n<div class=\"code-example\"><pre class=\"brush: html notranslate\"><code><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>video</span> <span class=\"token attr-name\">controls</span><span class=\"token punctuation\">&gt;</span></span>\n  <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>source</span> <span class=\"token attr-name\">src</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>foo.webm<span class=\"token punctuation\">\"</span></span> <span class=\"token attr-name\">type</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>video/webm<span class=\"token punctuation\">\"</span></span><span class=\"token punctuation\">&gt;</span></span>\n  <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>source</span> <span class=\"token attr-name\">src</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>foo.ogg<span class=\"token punctuation\">\"</span></span> <span class=\"token attr-name\">type</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>video/ogg<span class=\"token punctuation\">\"</span></span><span class=\"token punctuation\">&gt;</span></span>\n  <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>source</span> <span class=\"token attr-name\">src</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>foo.mov<span class=\"token punctuation\">\"</span></span> <span class=\"token attr-name\">type</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>video/quicktime<span class=\"token punctuation\">\"</span></span><span class=\"token punctuation\">&gt;</span></span>\n  I'm sorry; your browser doesn't support HTML5 video.\n<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>video</span><span class=\"token punctuation\">&gt;</span></span>\n</code></pre></div>\n\n<p>For more examples, see <a class=\"internal\" href=\"/en-US/docs/Learn/HTML/Multimedia_and_embedding/Video_and_audio_content\">Using audio and video in Firefox</a>.</p>"}},{"type":"specifications","value":{"title":"–°–њ–µ—Ж–Є—Д–Є–Ї–∞—Ж–Є–Є","id":"—Б–њ–µ—Ж–Є—Д–Є–Ї–∞—Ж–Є–Є","isH3":false,"specifications":[{"bcdSpecificationURL":"https://html.spec.whatwg.org/multipage/embedded-content.html#the-source-element","title":"HTML Standard"}],"query":"html.elements.source"}},{"type":"browser_compatibility","value":{"title":"–С—А–∞—Г–Ј–µ—А–љ–∞—П —Б–Њ–≤–Љ–µ—Б—В–Є–Љ–Њ—Б—В—М","id":"–±—А–∞—Г–Ј–µ—А–љ–∞—П_—Б–Њ–≤–Љ–µ—Б—В–Є–Љ–Њ—Б—В—М","isH3":false,"query":"html.elements.source","dataURL":"/ru/docs/Web/HTML/Element/source/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"—Б–Љ–Њ—В—А–Є—В–µ_—В–∞–Ї–ґ–µ","title":"–°–Љ–Њ—В—А–Є—В–µ —В–∞–Ї–ґ–µ","isH3":false,"content":"<ul>\n <li>–≠–ї–µ–Љ–µ–љ—В <a href=\"/ru/docs/Web/HTML/Element/picture\"><code>&lt;picture&gt;</code></a>&nbsp;</li>\n <li>–≠–ї–µ–Љ–µ–љ—В <a href=\"/ru/docs/Web/HTML/Element/audio\"><code>&lt;audio&gt;</code></a>&nbsp;</li>\n <li>–≠–ї–µ–Љ–µ–љ—В <a href=\"/ru/docs/Web/HTML/Element/video\"><code>&lt;video&gt;</code></a>&nbsp;</li>\n</ul>\n\n<p></p><p></p>"}}],"toc":[{"text":"–Р—В—А–Є–±—Г—В—Л","id":"–∞—В—А–Є–±—Г—В—Л"},{"text":"–Я—А–Є–Љ–µ—А—Л","id":"–њ—А–Є–Љ–µ—А—Л"},{"text":"–°–њ–µ—Ж–Є—Д–Є–Ї–∞—Ж–Є–Є","id":"—Б–њ–µ—Ж–Є—Д–Є–Ї–∞—Ж–Є–Є"},{"text":"–С—А–∞—Г–Ј–µ—А–љ–∞—П —Б–Њ–≤–Љ–µ—Б—В–Є–Љ–Њ—Б—В—М","id":"–±—А–∞—Г–Ј–µ—А–љ–∞—П_—Б–Њ–≤–Љ–µ—Б—В–Є–Љ–Њ—Б—В—М"},{"text":"–°–Љ–Њ—В—А–Є—В–µ —В–∞–Ї–ґ–µ","id":"—Б–Љ–Њ—В—А–Є—В–µ_—В–∞–Ї–ґ–µ"}],"summary":"HTML-—Н–ї–µ–Љ–µ–љ—В¬†<source> ¬†—Г–Ї–∞–Ј—Л–≤–∞–µ—В –љ–µ—Б–Ї–Њ–ї—М–Ї–Њ –Љ–µ–і–Є–∞-—А–µ—Б—Г—А—Б–Њ–≤ –і–ї—П —Н–ї–µ–Љ–µ–љ—В–Њ–≤¬†<picture>, <video> –Є¬†<audio>. –≠—В–Њ –њ—Г—Б—В–Њ–є —Н–ї–µ–Љ–µ–љ—В. –Ю–љ –Њ–±—Л—З–љ–Њ –Є—Б–њ–Њ–ї—М–Ј—Г–µ—В—Б—П –і–ї—П –Њ–±—Б–ї—Г–ґ–Є–≤–∞–љ–Є—П –Њ–і–љ–Њ–≥–Њ –Є —В–Њ–≥–Њ –ґ–µ –Љ–µ–і–Є–∞-–Ї–Њ–љ—В–µ–љ—В–∞ –≤ –љ–µ—Б–Ї–Њ–ї—М–Ї–Є—Е —Д–Њ—А–Љ–∞—В–∞—Е, –њ–Њ–і–і–µ—А–ґ–Є–≤–∞–µ–Љ—Л—Е —А–∞–Ј–ї–Є—З–љ—Л–Љ–Є –±—А–∞—Г–Ј–µ—А–∞–Љ–Є.","popularity":0.0008,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"<source>: The Media or Image Source element","locale":"en-US","native":"English (US)"},{"title":"<source>","locale":"es","native":"Espa√±ol"},{"title":"<source>","locale":"fr","native":"Fran√Іais"},{"title":"<source>: гГ°гГЗгВ£гВҐгБЊгБЯгБѓзФїеГПгБЃгВљгГЉгВєи¶Бзі†","locale":"ja","native":"жЧ•жЬђи™Ю"},{"title":"source","locale":"pt-BR","native":"Portugu√™s (do¬†Brasil)"},{"title":"Source","locale":"zh-CN","native":"дЄ≠жЦЗ (зЃАдљУ)"}],"source":{"folder":"ru/web/html/element/source","github_url":"https://github.com/mdn/translated-content/blob/main/files/ru/web/html/element/source/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/ru/docs/Web","title":"–Т–µ–±-—В–µ—Е–љ–Њ–ї–Њ–≥–Є–Є –і–ї—П —А–∞–Ј—А–∞–±–Њ—В—З–Є–Ї–Њ–≤"},{"uri":"/ru/docs/Web/HTML","title":"HTML"},{"uri":"/ru/docs/Web/HTML/Element","title":"–≠–ї–µ–Љ–µ–љ—В"},{"uri":"/ru/docs/Web/HTML/Element/source","title":"–≠–ї–µ–Љ–µ–љ—В <source>"}],"pageTitle":"–≠–ї–µ–Љ–µ–љ—В <source> - HTML | MDN","noIndexing":false}}