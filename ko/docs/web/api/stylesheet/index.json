{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"StyleSheet","mdn_url":"/ko/docs/Web/API/StyleSheet","locale":"ko","native":"한국어","sidebarHTML":"<ol><li><strong><a href=\"/ko/docs/Web/API/CSS_Object_Model\">CSS Object Model</a></strong></li><li><strong><a href=\"/ko/docs/Web/API/StyleSheet\"><code>StyleSheet</code></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>Properties</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/StyleSheet/disabled\"><code>disabled</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/StyleSheet/href\"><code>href</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/StyleSheet/media\"><code>media</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/StyleSheet/ownerNode\"><code>ownerNode</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/StyleSheet/parentStyleSheet\"><code>parentStyleSheet</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/StyleSheet/title\"><code>title</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/StyleSheet/type\"><code>type</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Related pages for CSSOM</summary><ol><li><a href=\"/ko/docs/Web/API/AnimationEvent\"><code>AnimationEvent</code></a></li><li><a href=\"/ko/docs/Web/API/CSS\"><code>CSS</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CSSConditionRule\"><code>CSSConditionRule</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CSSGroupingRule\"><code>CSSGroupingRule</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CSSKeyframeRule\"><code>CSSKeyframeRule</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CSSKeyframesRule\"><code>CSSKeyframesRule</code> <small>(en-US)</small></a></li><li><a href=\"/ko/docs/Web/API/CSSMediaRule\"><code>CSSMediaRule</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CSSNamespaceRule\"><code>CSSNamespaceRule</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CSSPageRule\"><code>CSSPageRule</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CSSRule\"><code>CSSRule</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CSSRuleList\"><code>CSSRuleList</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CSSStyleDeclaration\"><code>CSSStyleDeclaration</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CSSStyleRule\"><code>CSSStyleRule</code> <small>(en-US)</small></a></li><li><a href=\"/ko/docs/Web/API/CSSStyleSheet\"><code>CSSStyleSheet</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CSSSupportsRule\"><code>CSSSupportsRule</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CaretPosition\"><code>CaretPosition</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/MediaQueryList\"><code>MediaQueryList</code> <small>(en-US)</small></a></li><li><a href=\"/ko/docs/Web/API/Screen\"><code>Screen</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/StyleSheetList\"><code>StyleSheetList</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/TransitionEvent\"><code>TransitionEvent</code> <small>(en-US)</small></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p class=\"summary\">An object implementing the <code>StyleSheet</code> interface represents a single style sheet. CSS style sheets will further implement the more specialized <a href=\"/ko/docs/Web/API/CSSStyleSheet\"><code>CSSStyleSheet</code></a> interface.</p>"}},{"type":"prose","value":{"id":"properties","title":"Properties","isH3":false,"content":"<dl>\n <dt id=\"stylesheet.disabled_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/StyleSheet/disabled\"><code>StyleSheet.disabled</code> <small>(en-US)</small></a></dt>\n <dd>Is a <a href=\"/ko/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code></a> representing whether the current stylesheet has been applied or not.</dd>\n <dt id=\"stylesheet.href_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/StyleSheet/href\"><code>StyleSheet.href</code> <small>(en-US)</small></a> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></dt>\n <dd>Returns a <a href=\"/ko/docs/Web/JavaScript/Reference/Global_Objects/String\"><code>DOMString</code></a> representing the location of the stylesheet.</dd>\n <dt id=\"stylesheet.media_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/StyleSheet/media\"><code>StyleSheet.media</code> <small>(en-US)</small></a> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></dt>\n <dd>Returns a <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/MediaList\"><code>MediaList</code> <small>(en-US)</small></a> representing the intended destination medium for style information.</dd>\n <dt id=\"stylesheet.ownernode_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/StyleSheet/ownerNode\"><code>StyleSheet.ownerNode</code> <small>(en-US)</small></a> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></dt>\n <dd>Returns a <a href=\"/ko/docs/Web/API/Node\"><code>Node</code></a> associating this style sheet with the current document.</dd>\n <dt id=\"stylesheet.parentstylesheet_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/StyleSheet/parentStyleSheet\"><code>StyleSheet.parentStyleSheet</code> <small>(en-US)</small></a> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></dt>\n <dd>Returns a <a href=\"/ko/docs/Web/API/StyleSheet\" aria-current=\"page\"><code>StyleSheet</code></a> including this one, if any; returns <code>null</code> if there aren't any.</dd>\n <dt id=\"stylesheet.title_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/StyleSheet/title\"><code>StyleSheet.title</code> <small>(en-US)</small></a> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></dt>\n <dd>Returns a <a href=\"/ko/docs/Web/JavaScript/Reference/Global_Objects/String\"><code>DOMString</code></a> representing the advisory title of the current style sheet.</dd>\n <dt id=\"stylesheet.type_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/StyleSheet/type\"><code>StyleSheet.type</code> <small>(en-US)</small></a><span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></dt>\n <dd>Returns a <a href=\"/ko/docs/Web/JavaScript/Reference/Global_Objects/String\"><code>DOMString</code></a> representing the style sheet language for this style sheet.</dd>\n</dl>"}},{"type":"prose","value":{"id":"specification","title":"Specifications","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Specification</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Comment</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://drafts.csswg.org/cssom/#stylesheet\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">CSS Object Model (CSSOM)<br><small lang=\"ko\">The definition of 'StyleSheet' in that specification.</small></a></td>\n   <td><span class=\"spec-wd\">Working Draft</span></td>\n   <td>No change from <a href=\"https://www.w3.org/TR/DOM-Level-2-Style/\" hreflang=\"en\" lang=\"en\" class=\"external\" title=\"The 'Document Object Model (DOM) Level 2 Style Specification' specification\" rel=\" noopener\">Document Object Model (DOM) Level 2 Style Specification</a>.</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.w3.org/TR/DOM-Level-2-Style/stylesheets.html#StyleSheets-StyleSheet\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">Document Object Model (DOM) Level 2 Style Specification<br><small lang=\"ko\">The definition of 'StyleSheet' in that specification.</small></a></td>\n   <td><span class=\"spec-obsolete\">Obsolete</span></td>\n   <td>Initial definition.</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"Browser compatibility","id":"browser_compatibility","isH3":false,"query":"api.StyleSheet","dataURL":"/ko/docs/Web/API/StyleSheet/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"see_also","title":"See also","isH3":false,"content":"<ul>\n <li><a href=\"/ko/docs/Web/API/CSSStyleSheet\"><code>CSSStyleSheet</code></a></li>\n</ul>"}}],"toc":[{"text":"Properties","id":"properties"},{"text":"Specifications","id":"specification"},{"text":"Browser compatibility","id":"browser_compatibility"},{"text":"See also","id":"see_also"}],"summary":"An object implementing the StyleSheet interface represents a single style sheet. CSS style sheets will further implement the more specialized CSSStyleSheet interface.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"StyleSheet","locale":"en-US","native":"English (US)"},{"title":"objeto Stylesheet","locale":"es","native":"Español"},{"title":"StyleSheet","locale":"fr","native":"Français"},{"title":"StyleSheet","locale":"ja","native":"日本語"},{"title":"StyleSheet","locale":"ru","native":"Русский"},{"title":"StyleSheet","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"ko/web/api/stylesheet","github_url":"https://github.com/mdn/translated-content/blob/main/files/ko/web/api/stylesheet/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/ko/docs/Web","title":"개발자를 위한 웹 기술"},{"uri":"/ko/docs/Web/API","title":"Web API"},{"uri":"/ko/docs/Web/API/StyleSheet","title":"StyleSheet"}],"pageTitle":"StyleSheet - Web API | MDN","noIndexing":false}}