urrently only available in English (US)\" href=\"/en-US/docs/Web/API/RadioNodeList\"><code>RadioNodeList</code> <small>(en-US)</small></a></li><li><a href=\"/ko/docs/Web/API/ValidityState\"><code>ValidityState</code></a></li><li><a href=\"/ko/docs/Web/API/Window\"><code>Window</code></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p>&nbsp;</p>\n\n<p>현재 창에서 폼을 제출하는 이벤트를 다루는 이벤트 핸들러</p>"}},{"type":"prose","value":{"id":"문법","title":"문법","isH3":false,"content":"<pre class=\"eval notranslate\">window.onsubmit = <em>funcRef</em>;\n</pre>"}},{"type":"prose","value":{"id":"매개_변수","title":"매개 변수","isH3":true,"content":"<ul>\n <li><code>funcRef</code>&nbsp;는 함수를 참조하는 변수이다.</li>\n</ul>"}},{"type":"prose","value":{"id":"예제","title":"예제","isH3":false,"content":"<pre class=\"eval notranslate\">&lt;html&gt;\n&lt;script&gt;\nfunction reg() {\n  window.captureEvents(Event.SUBMIT);\n  window.onsubmit = hit;\n}\n\nfunction hit() {\n  console.log('hit');\n}\n&lt;/script&gt;\n\n&lt;body onload=\"reg();\"&gt;\n&lt;form&gt;\n  &lt;input type=\"submit\" value=\"submit\" /&gt;\n&lt;/form&gt;\n&lt;div id=\"d\"&gt; &lt;/div&gt;\n&lt;/body&gt;\n&lt;/html&gt;\n</pre>"}},{"type":"prose","value":{"id":"알아두기","title":"알아두기","isH3":false,"content":"<p>제출 이벤트는 사용자가 폼 내부에 있는 제출 버튼(<code>&lt;input type=\"submit\"/&gt;</code>)을 눌렀을 때 발생한다.</p>"}},{"type":"prose","value":{"id":"명세","title":"명세","isH3":false,"content":"<table class=\"spectable standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Specification</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Comment</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://html.spec.whatwg.org/multipage/webappapis.html#handler-onsubmit\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML Living Standard<br><small lang=\"ko\">The definition of 'onsubmit' in that specification.</small></a></td>\n   <td><span class=\"spec-living\">Living Standard</span></td>\n   <td>&nbsp;</td>\n  </tr>\n </tbody>\n</table>"}}],"toc":[{"text":"문법","id":"문법"},{"text":"예제","id":"예제"},{"text":"알아두기","id":"알아두기"},{"text":"명세","id":"명세"}],"summary":"현재 창에서 폼을 제출하는 이벤트를 다루는 이벤트 핸들러","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"submit","locale":"de","native":"Deutsch"},{"title":"HTMLFormElement: submit event","locale":"en-US","native":"English (US)"},{"title":"GlobalEventHandlers.onsubmit","locale":"es","native":"Español"},{"title":"submit","locale":"fr","native":"Français"},{"title":"HTMLFormElement: submit イベント","locale":"ja","native":"日本語"},{"title":"HTMLFormElement: submit event","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"GlobalEventHandlers.onsubmit","locale":"ru","native":"Русский"},{"title":"HTMLFormElement: submit event","locale":"zh-CN","native":"中文 (简体)"},{"title":"submit","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"ko/web/api/htmlformelement/submit_event","github_url":"https://github.com/mdn/translated-content/blob/main/files/ko/web/api/htmlformelement/submit_event/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/ko/docs/Web","title":"개발자를 위한 웹 기술"},{"uri":"/ko/docs/Web/API","title":"Web API"},{"uri":"/ko/docs/Web/API/HTMLFormElement","title":"HTMLFormElement"},{"uri":"/ko/docs/Web/API/HTMLFormElement/submit_event","title":"GlobalEventHandlers.onsubmit"}],"pageTitle":"GlobalEventHandlers.onsubmit - Web API | MDN","noIndexing":false}}