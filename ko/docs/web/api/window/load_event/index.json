{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"load","mdn_url":"/ko/docs/Web/API/Window/load_event","locale":"ko","native":"한국어","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p><code>load</code>&nbsp;이벤트는 리소스와 그것에 의존하는&nbsp;리소스들의 로딩이 완료되면 실행됩니다.</p>\n\n<p>&nbsp;</p>"}},{"type":"prose","value":{"id":"예제","title":"예제","isH3":false,"content":""}},{"type":"prose","value":{"id":"window","title":"Window","isH3":true,"content":"<div class=\"code-example\"><pre class=\"brush: html notranslate\"><code><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>script</span><span class=\"token punctuation\">&gt;</span></span><span class=\"token script\"><span class=\"token language-javascript\">\n  window<span class=\"token punctuation\">.</span><span class=\"token function\">addEventListener</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"load\"</span><span class=\"token punctuation\">,</span> <span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">event</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n    console<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"All resources finished loading!\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n  <span class=\"token punctuation\">}</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n</span></span><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>script</span><span class=\"token punctuation\">&gt;</span></span></code></pre></div>"}},{"type":"prose","value":{"id":"script_엘리먼트","title":"<code>script</code> 엘리먼트","isH3":true,"content":"<div class=\"code-example\"><pre class=\"brush: html notranslate\"><code><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>script</span><span class=\"token punctuation\">&gt;</span></span><span class=\"token script\"><span class=\"token language-javascript\">\n  <span class=\"token keyword\">var</span> script <span class=\"token operator\">=</span> document<span class=\"token punctuation\">.</span><span class=\"token function\">createElement</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"script\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n  script<span class=\"token punctuation\">.</span><span class=\"token function\">addEventListener</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"load\"</span><span class=\"token punctuation\">,</span> <span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">event</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n    console<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"Script finished loading and executing\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n  <span class=\"token punctuation\">}</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n  script<span class=\"token punctuation\">.</span>src <span class=\"token operator\">=</span> <span class=\"token string\">\"http://example.com/example.js\"</span><span class=\"token punctuation\">;</span>\n  script<span class=\"token punctuation\">.</span>async <span class=\"token operator\">=</span> <span class=\"token boolean\">true</span><span class=\"token punctuation\">;</span>\n  document<span class=\"token punctuation\">.</span><span class=\"token function\">getElementsByTagName</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"script\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">[</span><span class=\"token number\">0</span><span class=\"token punctuation\">]</span><span class=\"token punctuation\">.</span>parentNode<span class=\"token punctuation\">.</span><span class=\"token function\">appendChild</span><span class=\"token punctuation\">(</span>script<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n</span></span><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>script</span><span class=\"token punctuation\">&gt;</span></span></code></pre></div>","titleAsText":"script 엘리먼트"}},{"type":"prose","value":{"id":"일반_정보","title":"일반 정보","isH3":false,"content":"<dl>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"스펙\">스펙</dt>\n <dd style=\"margin: 0 0 0 120px;\"><a class=\"external\" href=\"https://www.w3.org/TR/DOM-Level-3-Events/#event-type-load\" rel=\" noopener\">DOM L3</a></dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"인터페이스\">인터페이스</dt>\n <dd style=\"margin: 0 0 0 120px;\">UIEvent</dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"bubbles\">Bubbles</dt>\n <dd style=\"margin: 0 0 0 120px;\">No</dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"취소가능_여부\">취소가능 여부</dt>\n <dd style=\"margin: 0 0 0 120px;\">No</dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"타겟\">타겟</dt>\n <dd style=\"margin: 0 0 0 120px;\">Window,Document,Element</dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"기본_동작\">기본 동작</dt>\n <dd style=\"margin: 0 0 0 120px;\">None.</dd>\n</dl>"}},{"type":"prose","value":{"id":"속성","title":"속성","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">속성</th>\n   <th scope=\"col\">타입</th>\n   <th scope=\"col\">설명</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><code>target</code> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></td>\n   <td><code><a href=\"/ko/docs/Web/API/EventTarget\"><code>EventTarget</code></a></code></td>\n   <td>The event target (the topmost target in the DOM tree).</td>\n  </tr>\n  <tr>\n   <td><code>type</code> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></td>\n   <td><code><a href=\"/ko/docs/Web/JavaScript/Reference/Global_Objects/String\"><code>DOMString</code></a></code></td>\n   <td>The type of event.</td>\n  </tr>\n  <tr>\n   <td><code>bubbles</code> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></td>\n   <td><code><a href=\"/ko/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code></a></code></td>\n   <td>Whether the event normally bubbles or not.</td>\n  </tr>\n  <tr>\n   <td><code>cancelable</code> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></td>\n   <td><code><a href=\"/ko/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code></a></code></td>\n   <td>Whether the event is cancellable or not.</td>\n  </tr>\n  <tr>\n   <td><code>view</code> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></td>\n   <td><code><a class=\"page-not-created\" title=\"The documentation about this has not yet been written; please consider contributing!\"><code>WindowProxy</code></a></code></td>\n   <td><code><a href=\"/ko/docs/Web/API/Document/defaultView\" title=\"document.defaultView\"><code>document.defaultView</code></a></code> (<code>window</code> of the document)</td>\n  </tr>\n  <tr>\n   <td><code>detail</code> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></td>\n   <td><code>long</code> (<code>float</code>)</td>\n   <td>0.</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"스펙_정보","title":"스펙 정보","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">스펙</th>\n   <th scope=\"col\">상태</th>\n   <th scope=\"col\">코멘트</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://w3c.github.io/uievents/#event-type-load\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">UI Events<br><small lang=\"ko\">The definition of 'load' in that specification.</small></a></td>\n   <td><span class=\"spec-wd\">Working Draft</span></td>\n   <td>&nbsp;</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://html.spec.whatwg.org/multipage/parsing.html#the-end:event-load\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML Living Standard<br><small lang=\"ko\">The definition of 'Load event' in that specification.</small></a></td>\n   <td><span class=\"spec-living\">Living Standard</span></td>\n   <td>\n    <p>이것은 문서 로딩이 끝날때&nbsp;수행되는 단계와 연결되는 섹션과 연결됩니다. 'load' 이벤트는&nbsp;많은 엘리먼트들에서도 발생합니다. 그리고 스펙 문서에서는 많은 곳에서&nbsp;\"<a href=\"https://html.spec.whatwg.org/multipage/parsing.html#delay-the-load-event\" class=\"external\" rel=\" noopener\">load이벤트를 지연할 수 있는</a>\" 것들을 언급한다는 것을 주의하십시오.</p>\n   </td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"관련_이벤트","title":"관련 이벤트","isH3":false,"content":"<ul>\n <li><code><a href=\"/ko/docs/Web/API/Window/DOMContentLoaded_event\" title=\"/ko/docs/Web/Reference/Events/DOMContentLoaded\">DOMContentLoaded</a></code></li>\n <li><code><a href=\"/en-US/docs/Web/API/Document/readystatechange_event\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">readystatechange (en-US)</a></code></li>\n <li><code><a href=\"/ko/docs/Web/API/Window/load_event\" title=\"/ko/docs/Web/Reference/Events/load\">load</a></code></li>\n <li><code><a href=\"/en-US/docs/Web/API/Window/beforeunload_event\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">beforeunload (en-US)</a></code></li>\n <li><code><a href=\"/en-US/docs/Web/API/Window/unload_event\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">unload (en-US)</a></code></li>\n</ul>"}}],"toc":[{"text":"예제","id":"예제"},{"text":"일반 정보","id":"일반_정보"},{"text":"속성","id":"속성"},{"text":"스펙 정보","id":"스펙_정보"},{"text":"관련 이벤트","id":"관련_이벤트"}],"summary":"load 이벤트는 리소스와 그것에 의존하는 리소스들의 로딩이 완료되면 실행됩니다.","popularity":0.0004,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"load","locale":"de","native":"Deutsch"},{"title":"Window: load event","locale":"en-US","native":"English (US)"},{"title":"load","locale":"es","native":"Español"},{"title":"load","locale":"fr","native":"Français"},{"title":"Window: load イベント","locale":"ja","native":"日本語"},{"title":"load","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"load","locale":"ru","native":"Русский"},{"title":"load","locale":"zh-CN","native":"中文 (简体)"},{"title":"load","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"ko/web/api/window/load_event","github_url":"https://github.com/mdn/translated-content/blob/main/files/ko/web/api/window/load_event/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/ko/docs/Web","title":"개발자를 위한 웹 기술"},{"uri":"/ko/docs/Web/API","title":"Web API"},{"uri":"/ko/docs/Web/API/Window","title":"Window"},{"uri":"/ko/docs/Web/API/Window/load_event","title":"load"}],"pageTitle":"load - Web API | MDN","noIndexing":false}}