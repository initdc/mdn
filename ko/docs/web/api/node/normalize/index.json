ent</em>.normalize();\n</pre>"}},{"type":"prose","value":{"id":"example","title":"예제","isH3":false,"content":"<div class=\"code-example\"><pre class=\"brush:js notranslate\"><code><span class=\"token keyword\">var</span> wrapper <span class=\"token operator\">=</span> document<span class=\"token punctuation\">.</span><span class=\"token function\">createElement</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"div\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n\nwrapper<span class=\"token punctuation\">.</span><span class=\"token function\">appendChild</span><span class=\"token punctuation\">(</span> document<span class=\"token punctuation\">.</span><span class=\"token function\">createTextNode</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"Part 1 \"</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\nwrapper<span class=\"token punctuation\">.</span><span class=\"token function\">appendChild</span><span class=\"token punctuation\">(</span> document<span class=\"token punctuation\">.</span><span class=\"token function\">createTextNode</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"Part 2 \"</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n\n<span class=\"token comment\">// 이 때, wrapper.childNodes.length === 2</span>\n<span class=\"token comment\">// wrapper.childNodes[0].textContent === \"Part 1 \"</span>\n<span class=\"token comment\">// wrapper.childNodes[1].textContent === \"Part 2 \"</span>\n\nwrapper<span class=\"token punctuation\">.</span><span class=\"token function\">normalize</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n\n<span class=\"token comment\">// 이제, wrapper.childNodes.length === 1</span>\n<span class=\"token comment\">// wrapper.childNodes[0].textContent === \"Part 1 Part 2 \"</span></code></pre></div>"}},{"type":"prose","value":{"id":"specification","title":"명세","isH3":false,"content":"<ul>\n <li><a class=\"external\" href=\"https://www.w3.org/TR/DOM-Level-2-Core/core.html#ID-normalize\" rel=\" noopener\">DOM Level 2 Core: Node.normalize</a></li>\n</ul>"}},{"type":"browser_compatibility","value":{"title":"브라우저 호환성","id":"브라우저_호환성","isH3":false,"query":"api.Node.normalize","dataURL":"/ko/docs/Web/API/Node/normalize/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"see_also","title":"함께 보기","isH3":false,"content":"<ul>\n <li><a href=\"/ko/docs/Web/API/Text/splitText\" title=\"DOM/Text.splitText\"><code>Text.splitText</code></a></li>\n</ul>"}}],"toc":[{"text":"문법","id":"syntax"},{"text":"예제","id":"example"},{"text":"명세","id":"specification"},{"text":"브라우저 호환성","id":"브라우저_호환성"},{"text":"함께 보기","id":"see_also"}],"summary":"Node.normalize() 메소드는 지정된 노드와 하위 트리의 모든 노드를 \"정규화된\" 형태로 놓습니다. 정규화된 하위 트리의 텍스트 노드는 비어있지 않으며 인접한 텍스트 노드도 존재하지 않습니다.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Node.normalize()","locale":"de","native":"Deutsch"},{"title":"Node.normalize()","locale":"en-US","native":"English (US)"},{"title":"element.normalize","locale":"fr","native":"Français"},{"title":"Node.normalize()","locale":"ja","native":"日本語"},{"title":"element.normalize","locale":"pl","native":"Polski"},{"title":"Node.normalize()","locale":"ru","native":"Русский"},{"title":"Node.normalize()","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"ko/web/api/node/normalize","github_url":"https://github.com/mdn/translated-content/blob/main/files/ko/web/api/node/normalize/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents"