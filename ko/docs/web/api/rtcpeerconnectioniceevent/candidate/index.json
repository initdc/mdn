CE candidate (transport address: '\"</span> <span class=\"token operator\">+</span>\n    ev<span class=\"token punctuation\">.</span>candidate<span class=\"token punctuation\">.</span>candidate <span class=\"token operator\">+</span>\n    <span class=\"token string\">\"') has been added to this connection.\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token punctuation\">}</span></code></pre></div>"}},{"type":"prose","value":{"id":"specifications","title":"명세","isH3":false,"content":"<table class=\"standard-table\" style=\"height: 49px; width: 1000px;\">\n <thead>\n  <tr>\n   <th scope=\"col\">명세</th>\n   <th scope=\"col\">상태</th>\n   <th scope=\"col\">코멘트</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"https://w3c.github.io/webrtc-pc/#dom-rtcpeerconnectioniceevent-candidate\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">WebRTC 1.0: Real-time Communication Between Browsers<br><small lang=\"ko\">The definition of 'RTCPeerConnectionIceEvent.candidate' in that specification.</small></a></td>\n   <td><span class=\"spec-cr\">Candidate Recommendation</span></td>\n   <td>Initial specification.</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"브라우저 호환성","id":"브라우저_호환성","isH3":false,"query":"api.RTCPeerConnectionIceEvent.candidate","dataURL":"/ko/docs/Web/API/RTCPeerConnectionIceEvent/candidate/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"참조","title":"참조","isH3":false,"content":"<ul>\n <li><code><a href=\"/ko/docs/Web/Reference/Events/icecandidate\" title=\"This is a link to an unwritten page\" class=\"page-not-created\">icecandidate</a></code></li>\n <li><a href=\"/ko/docs/Web/API/RTCPeerConnection\"><code>RTCPeerConnection</code></a></li>\n</ul>"}}],"toc":[{"text":"Syntax","id":"syntax"},{"text":"예시","id":"예시"},{"text":"명세","id":"specifications"},{"text":"