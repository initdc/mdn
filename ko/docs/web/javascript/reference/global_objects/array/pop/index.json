/Array/push\"><code>Array.prototype.push()</code></a></li>\n <li><a href=\"/ko/docs/Web/JavaScript/Reference/Global_Objects/Array/shift\"><code>Array.prototype.shift()</code></a></li>\n <li><a href=\"/ko/docs/Web/JavaScript/Reference/Global_Objects/Array/unshift\"><code>Array.prototype.unshift()</code></a></li>\n <li><a href=\"/ko/docs/Web/JavaScript/Reference/Global_Objects/Array/splice\"><code>Array.prototype.splice()</code></a></li>\n</ul>"}}],"toc":[{"text":"구문","id":"구문"},{"text":"설명","id":"설명"},{"text":"예제","id":"예제"},{"text":"명세","id":"명세"},{"text":"브라우저 호환성","id":"브라우저_호환성"},{"text":"같이 보기","id":"같이_보기"}],"summary":"pop() 메서드는 배열에서 마지막 요소를 제거하고 그 요소를 반환합니다.","popularity":0.001,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Array.prototype.pop()","locale":"de","native":"Deutsch"},{"title":"Array.prototype.pop()","locale":"en-US","native":"English (US)"},{"title":"Array.prototype.pop()","locale":"es","native":"Español"},{"title":"Array.prototype.pop()","locale":"fr","native":"Français"},{"title":"Array.prototype.pop()","locale":"ja","native":"日本語"},{"title":"Array.prototype.pop()","locale":"pl","native":"Polski"},{"title":"Array.prototype.pop()","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Array.prototype.pop()","locale":"ru","native":"Русский"},{"title":"Array.prototype.pop()","locale":"zh-CN","native":"中文 (简体)"},{"title":"Array.prototype.pop()","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"ko/web/javascript/reference/global_objects/array/pop","github_url":"https://github.com/mdn/translated-content/blob/main/files/ko/web/javascript/reference/global_objects/array/pop/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/ko/docs/Web","title":"개발자를 위한 웹 기술"},{"uri":"/ko/docs/Web/JavaScript","title":"JavaScript"},{"uri":"/ko/docs/Web/JavaScript/Reference","title":"JavaScript 참고서"},{"uri":"/ko/docs/We