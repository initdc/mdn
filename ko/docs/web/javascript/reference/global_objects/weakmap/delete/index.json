2/#sec-weakmap.prototype.delete\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript (ECMA-262)<br><small lang=\"ko\">The definition of 'WeakMap.prototype.delete' in that specification.</small></a></td>\n   <td><span class=\"spec-living\">Living Standard</span></td>\n   <td>&nbsp;</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"브라우저 호환성","id":"브라우저_호환성","isH3":false,"query":"javascript.builtins.WeakMap.delete","dataURL":"/ko/docs/Web/JavaScript/Reference/Global_Objects/WeakMap/delete/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"같이_보기","title":"같이 보기","isH3":false,"content":"<ul>\n <li><a href=\"/ko/docs/Web/JavaScript/Reference/Global_Objects/WeakMap\"><code>WeakMap</code></a></li>\n</ul>"}}],"toc":[{"text":"구문","id":"구문"},{"text":"예제","id":"예제"},{"text":"명세","id":"명세"},{"text":"브라우저 호환성","id":"브라우저_호환성"},{"text":"같이 보기","id":"같이_보기"}],"summary":"delete() 메소드는 WeakMap 객체의 특정 요소를 제거합니다.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"WeakMap.prototype.delete()","locale":"en-US","native":"English (US)"},{"title":"WeakMap.prototype.delete()","locale":"es","native":"Español"},{"title":"WeakMap.prototype.delete()","locale":"fr","native":"Français"},{"title":"WeakMap.prototype.delete()","locale":"ja","native":"日本語"},{"title":"WeakMap.prototype.delete()","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"WeakMap.prototype.delete()","locale":"ru","native":"Русский"},{"title":"WeakMap.prototype.delete()","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"ko/web/javascript/reference/global_objects/weakmap/delete","github_url":"https://github.com/mdn/translated-content/blob/main/files/ko/web/javascript/reference/global_objects/weakmap/delete/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":