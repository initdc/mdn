{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"SourceBuffer.changeType()","mdn_url":"/ja/docs/Web/API/SourceBuffer/changeType","locale":"ja","native":"日本語","sidebarHTML":"<ol><li><strong><a href=\"/ja/docs/Web/API/Media_Source_Extensions_API\">Media Source Extensions API</a></strong></li><li><strong><a href=\"/ja/docs/Web/API/SourceBuffer\"><code>SourceBuffer</code></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>プロパティ</summary><ol><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><a href=\"/ja/docs/Web/API/SourceBuffer/appendWindowEnd\"><code>appendWindowEnd</code></a></li><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><a href=\"/ja/docs/Web/API/SourceBuffer/appendWindowStart\"><code>appendWindowStart</code></a></li><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><a href=\"/ja/docs/Web/API/SourceBuffer/audioTracks\"><code>audioTracks</code></a></li><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><a href=\"/ja/docs/Web/API/SourceBuffer/buffered\"><code>buffered</code></a></li><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><a href=\"/ja/docs/Web/API/SourceBuffer/mode\"><code>mode</code></a></li><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><a href=\"/ja/docs/Web/API/SourceBuffer/textTracks\"><code>textTracks</code></a></li><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><a href=\"/ja/docs/Web/API/SourceBuffer/timestampOffset\"><code>timestampOffset</code></a></li><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><a href=\"/ja/docs/Web/API/SourceBuffer/updating\"><code>updating</code></a></li><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><a href=\"/ja/docs/Web/API/SourceBuffer/videoTracks\"><code>videoTracks</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>メソッド</summary><ol><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><a href=\"/ja/docs/Web/API/SourceBuffer/abort\"><code>abort()</code></a></li><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><a href=\"/ja/docs/Web/API/SourceBuffer/appendBuffer\"><code>appendBuffer()</code></a></li><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a href=\"/ja/docs/Web/API/SourceBuffer/appendBufferAsync\"><code>appendBufferAsync()</code></a></li><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><a href=\"/ja/docs/Web/API/SourceBuffer/appendStream\"><code>appendStream()</code></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><em><code>changeType()</code></em></li><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><a href=\"/ja/docs/Web/API/SourceBuffer/remove\"><code>remove()</code></a></li><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a href=\"/ja/docs/Web/API/SourceBuffer/removeAsync\"><code>removeAsync()</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>継承</summary><ol><li><a href=\"/ja/docs/Web/API/EventTarget\"><code>EventTarget</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Media Source Extensions に関連するページ</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/HTMLVideoElement/getVideoPlaybackQuality\"><code>HTMLVideoElement.getVideoPlaybackQuality()</code> <small>(en-US)</small></a></li><li><a href=\"/ja/docs/Web/API/MediaSource\"><code>MediaSource</code></a></li><li><a href=\"/ja/docs/Web/API/SourceBufferList\"><code>SourceBufferList</code></a></li><li><a class=\"page-not-created\" title=\"この項目についての文書はまだ書かれていません。書いてみませんか？\"><code>TextTrack.sourceBuffer</code></a></li><li><a href=\"/ja/docs/Web/API/URL/createObjectURL\"><code>URL.createObjectURL()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/VideoPlaybackQuality\"><code>VideoPlaybackQuality</code> <small>(en-US)</small></a></li><li><a href=\"/ja/docs/Web/API/VideoTrack/sourceBuffer\"><code>VideoTrack.sourceBuffer</code></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p><span class=\"seoSummary\"><a href=\"/ja/docs/Web/API/SourceBuffer\"><code>SourceBuffer</code></a> インターフェイスの <strong><code>changeType() </code></strong>メソッドは、今後&nbsp; <a href=\"/ja/docs/Web/API/SourceBuffer/appendBuffer\" title=\"appendBuffer()\"><code>appendBuffer()</code></a> を呼び出すときに新しいメディアデータが準拠することを期待する MIME タイプを設定します。</span> これにより、コーデックまたはコンテナタイプを途中で変更できます。</p>\n\n<p>これが役立つ1つのシナリオは、リソース制約の変化に応じて1つのコーデックから別のコーデックに移行することにより、帯域幅の可用性の変化にメディアソースを適応させることです。</p>"}},{"type":"prose","value":{"id":"syntax","title":"構文","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><em>sourceBuffer</em>.changeType(<em>type</em>);</pre>"}},{"type":"prose","value":{"id":"parameters","title":"パラメーター","isH3":true,"content":"<dl>\n <dt id=\"type\"><code>type</code></dt>\n <dd>将来のバッファが準拠する MIME タイプを指定する <a href=\"/ja/docs/conflicting/Web/JavaScript/Reference/Global_Objects/String_6fa58bba0570d663099f0ae7ae8883ab\"><code>DOMString</code></a>。</dd>\n</dl>"}},{"type":"prose","value":{"id":"return_value","title":"戻り値","isH3":true,"content":"<p><a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/undefined\"><code>undefined</code></a>。</p>"}},{"type":"prose","value":{"id":"exceptions","title":"例外","isH3":true,"content":"<dl>\n <dt id=\"typeerror\"><code>TypeError</code></dt>\n <dd>指定された文字列は、有効な MIME タイプではなく、空です。</dd>\n <dt id=\"invalidstateerror\"><code>InvalidStateError</code></dt>\n <dd><a href=\"/ja/docs/Web/API/SourceBuffer\"><code>SourceBuffer</code></a> は、親メディアソースの <a href=\"/ja/docs/Web/API/MediaSource/sourceBuffers\" title=\"sourceBuffers\"><code>sourceBuffers</code></a> リストのメンバーではありません。 または、バッファの <a href=\"/ja/docs/Web/API/SourceBuffer/updating\" title=\"updating\"><code>updating</code></a> プロパティは、以前にキューに入れられた <a href=\"/ja/docs/Web/API/SourceBuffer/appendBuffer\" title=\"appendBuffer()\"><code>appendBuffer()</code></a> または <a href=\"/ja/docs/Web/API/SourceBuffer/remove\" title=\"remove()\"><code>remove()</code></a> がまだ処理中であることを示しています。</dd>\n <dt id=\"notsupportederror\"><code>NotSupportedError</code></dt>\n <dd>指定された MIME タイプはサポートされていないか、<a href=\"/ja/docs/Web/API/MediaSource/sourceBuffers\"><code>MediaSource.sourceBuffers</code></a> リストにある <a href=\"/ja/docs/Web/API/SourceBuffer\"><code>SourceBuffer</code></a> オブジェクトのタイプではサポートされていません。</dd>\n</dl>"}},{"type":"prose","value":{"id":"usage_notes","title":"使用上の注意","isH3":false,"content":"<p>親 <a href=\"/ja/docs/Web/API/MediaSource\"><code>MediaSource</code></a> が <code>\"ended\"</code> <a href=\"/ja/docs/Web/API/MediaSource/readyState\" title=\"readyState\"><code>readyState</code></a> にある場合に、<code>changeType()</code> を呼び出すと、メディアソースが <code>\"open\"</code> <code>readyState</code> に遷移し、親メディアソースで <code><a href=\"/ja/docs/Web/Reference/Events/sourceopen\" title=\"This is a link to an unwritten page\" class=\"page-not-created\">sourceopen</a></code> という名前の単純なイベントが発生します。</p>"}},{"type":"prose","value":{"id":"specifications","title":"仕様","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">仕様</th>\n   <th scope=\"col\">状態</th>\n   <th scope=\"col\">コメント</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://w3c.github.io/media-source/#dom-sourcebuffer-changetype\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">Media Source Extensions<br><small lang=\"ja\">SourceBuffer.changeType の定義</small></a></td>\n   <td><span class=\"spec-rec\">勧告</span></td>\n   <td>初期定義</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"ブラウザーの互換性","id":"browser_compatibility","isH3":false,"query":"api.SourceBuffer.changeType","dataURL":"/ja/docs/Web/API/SourceBuffer/changeType/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect2\">\n\n\n<p></p><p></p>\n</div>"}},{"type":"prose","value":{"id":"see_also","title":"関連情報","isH3":false,"content":"<ul>\n <li><a href=\"/ja/docs/Web/API/MediaSource\"><code>MediaSource</code></a></li>\n <li><a href=\"/ja/docs/Web/API/SourceBufferList\"><code>SourceBufferList</code></a></li>\n</ul>"}}],"toc":[{"text":"構文","id":"syntax"},{"text":"使用上の注意","id":"usage_notes"},{"text":"仕様","id":"specifications"},{"text":"ブラウザーの互換性","id":"browser_compatibility"},{"text":"関連情報","id":"see_also"}],"summary":"SourceBuffer インターフェイスの changeType() メソッドは、今後  appendBuffer() を呼び出すときに新しいメディアデータが準拠することを期待する MIME タイプを設定します。","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"SourceBuffer.changeType()","locale":"en-US","native":"English (US)"}],"source":{"folder":"ja/web/api/sourcebuffer/changetype","github_url":"https://github.com/mdn/translated-content/blob/main/files/ja/web/api/sourcebuffer/changetype/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/ja/docs/Web","title":"開発者向けのウェブ技術"},{"uri":"/ja/docs/Web/API","title":"Web API"},{"uri":"/ja/docs/Web/API/SourceBuffer","title":"SourceBuffer"},{"uri":"/ja/docs/Web/API/SourceBuffer/changeType","title":"SourceBuffer.changeType()"}],"pageTitle":"SourceBuffer.changeType() - Web API | MDN","noIndexing":false}}