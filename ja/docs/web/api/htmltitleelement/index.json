\n</table>"}},{"type":"browser_compatibility","value":{"title":"ブラウザ実装状況","id":"browser_compatibility","isH3":false,"query":"api.HTMLTitleElement","dataURL":"/ja/docs/Web/API/HTMLTitleElement/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"see_also","title":"関連情報","isH3":false,"content":"<ul>\n <li><a href=\"/ja/docs/Web/HTML/Element/title\"><code>&lt;title&gt;</code></a> - <code>HTMLTitleElement</code> インタフェースを持つ HTML 要素</li>\n</ul>"}}],"toc":[{"text":"プロパティ","id":"properties"},{"text":"メソッド","id":"methods"},{"text":"仕様","id":"specifications"},{"text":"ブラウザ実装状況","id":"browser_compatibility"},{"text":"関連情報","id":"see_also"}],"summary":"title オブジェクトは、文書のタイトルを含む HTMLTitleElement インタフェースを公開します。この要素は HTMLElement インタフェースの全てのプロパティ及びメソッドを継承します。","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"HTMLTitleElement","locale":"en-US","native":"English (US)"},{"title":"HTMLTitleElement","locale":"ko","native":"한국어"}],"source":{"folder":"ja/web/api/htmltitleelement","github_url":"https://github.com/mdn/translated-content/blob/main/files/ja/web/api/htmltitleelement/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/ja/docs/Web","title":"開発者向けのウェブ技術"},{"uri":"/ja/docs/Web/API","title":"Web API"},{"uri":"/ja/docs/Web/API/HTMLTitleElement","title":"HTMLTitleElement"}],"pageTitle":"HTMLTitleElement - Web API | MDN","noIndexing":false}}