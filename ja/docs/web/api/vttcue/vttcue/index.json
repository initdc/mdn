{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"VTTCue()","mdn_url":"/ja/docs/Web/API/VTTCue/VTTCue","locale":"ja","native":"日本語","sidebarHTML":"<ol><li><strong><a href=\"/ja/docs/Web/API/WebVTT_API\">WebVTT API</a></strong></li><li><strong><a href=\"/ja/docs/Web/API/VTTCue\"><code>VTTCue</code></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>コンストラクター</summary><ol><li><em><code>VTTCue()</code></em></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>プロパティ</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/VTTCue/align\"><code>align</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/VTTCue/line\"><code>line</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/VTTCue/lineAlign\"><code>lineAlign</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/VTTCue/position\"><code>position</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/VTTCue/positionAlign\"><code>positionAlign</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/VTTCue/region\"><code>region</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/VTTCue/size\"><code>size</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/VTTCue/snapToLines\"><code>snapToLines</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/VTTCue/text\"><code>text</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/VTTCue/vertical\"><code>vertical</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>メソッド</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/VTTCue/getCueAsHTML\"><code>getCueAsHTML()</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>継承</summary><ol><li><a href=\"/ja/docs/Web/API/TextTrackCue\"><code>TextTrackCue</code></a></li><li><a href=\"/ja/docs/Web/API/EventTarget\"><code>EventTarget</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>WebVTT に関連するページ</summary><ol><li><a href=\"/ja/docs/Web/API/TextTrack\"><code>TextTrack</code></a></li><li><a href=\"/ja/docs/Web/API/TextTrackCue\"><code>TextTrackCue</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/TextTrackCueList\"><code>TextTrackCueList</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/TextTrackList\"><code>TextTrackList</code> <small>(en-US)</small></a></li><li><a href=\"/ja/docs/Web/API/TrackEvent\"><code>TrackEvent</code></a></li><li><a href=\"/ja/docs/Web/API/VTTRegion\"><code>VTTRegion</code></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>\n\n<p><span class=\"seoSummary\"><strong><code>VTTCue()</code></strong> コンストラクタは新しい <a href=\"/ja/docs/Web/API/VTTCue\"><code>VTTCue</code></a> オブジェクトを返します。</span></p>"}},{"type":"prose","value":{"id":"syntax","title":"構文","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"> <em>vttCue</em> = new VTTCue(<em>startTime</em>, <em>endTime</em>, <em>text</em>);</pre>"}},{"type":"prose","value":{"id":"parameters","title":"パラメーター","isH3":true,"content":"<dl>\n <dt id=\"starttime\"><em>startTime</em></dt>\n <dd>これは、キューを表示し始める動画の時間を表す <code>double</code> 型です。</dd>\n <dt id=\"endtime\"><em>endTime</em></dt>\n <dd>これは、キューを表示しなくなる動画の時間を表す <code>double</code> 型です。</dd>\n <dt id=\"text\"><em>text</em></dt>\n <dd>これは表示するテキストを表す <a href=\"/ja/docs/conflicting/Web/JavaScript/Reference/Global_Objects/String_6fa58bba0570d663099f0ae7ae8883ab\"><code>DOMString</code></a> です。</dd>\n</dl>"}},{"type":"prose","value":{"id":"example","title":"例","isH3":false,"content":"<div class=\"code-example\"><pre class=\"brush: js  language-js notranslate\"><code><span class=\"token comment\">// 2から3秒の間に表示するキューを作成し、指定されたテキストを使用します。</span>\n<span class=\"token keyword\">var</span> cue <span class=\"token operator\">=</span> <span class=\"token keyword\">new</span> <span class=\"token class-name\">VTTCue</span><span class=\"token punctuation\">(</span><span class=\"token number\">2</span><span class=\"token punctuation\">,</span> <span class=\"token number\">3</span><span class=\"token punctuation\">,</span> <span class=\"token string\">'かっこいい文章を表示する'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span></code></pre></div>"}},{"type":"prose","value":{"id":"specifications","title":"仕様","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">仕様</th>\n   <th scope=\"col\">状態</th>\n   <th scope=\"col\">コメント</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://w3c.github.io/webvtt/#dom-vttcue-vttcue\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">WebVTT: The Web Video Text Tracks Format<br><small lang=\"ja\">VTTCue() の定義</small></a></td>\n   <td><span class=\"spec-cr\">勧告候補</span></td>\n   <td>&nbsp;</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"ブラウザーの互換性","id":"browser_compatibility","isH3":false,"query":"api.VTTCue.VTTCue","dataURL":"/ja/docs/Web/API/VTTCue/VTTCue/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}}],"toc":[{"text":"構文","id":"syntax"},{"text":"例","id":"example"},{"text":"仕様","id":"specifications"},{"text":"ブラウザーの互換性","id":"browser_compatibility"}],"summary":"VTTCue() コンストラクタは新しい VTTCue オブジェクトを返します。","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"VTTCue()","locale":"en-US","native":"English (US)"}],"source":{"folder":"ja/web/api/vttcue/vttcue","github_url":"https://github.com/mdn/translated-content/blob/main/files/ja/web/api/vttcue/vttcue/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/ja/docs/Web","title":"開発者向けのウェブ技術"},{"uri":"/ja/docs/Web/API","title":"Web API"},{"uri":"/ja/docs/Web/API/VTTCue","title":"VTTCue"},{"uri":"/ja/docs/Web/API/VTTCue/VTTCue","title":"VTTCue()"}],"pageTitle":"VTTCue() - Web API | MDN","noIndexing":false}}