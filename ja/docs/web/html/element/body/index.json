{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"<body>: 文書の本文要素","mdn_url":"/ja/docs/Web/HTML/Element/body","locale":"ja","native":"日本語","sidebarHTML":"\n  <ol>\n   \n    \n   <li><details><summary>HTML Elements</summary><ol>\n   <li>A\n <ol>\n  <li><a href=\"/ja/docs/Web/HTML/Element/a\"><code>&lt;a&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/abbr\"><code>&lt;abbr&gt;</code></a></li>\n  <li><s class=\"obsoleteElement\"><a href=\"/ja/docs/Web/HTML/Element/acronym\"><code>&lt;acronym&gt;</code></a></s></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/address\"><code>&lt;address&gt;</code></a></li>\n  <li><s class=\"obsoleteElement deprecatedElement\"><a href=\"/ja/docs/Web/HTML/Element/applet\"><code>&lt;applet&gt;</code></a></s></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/area\"><code>&lt;area&gt;</code></a></li>\n  <li class=\"html5\"><a href=\"/ja/docs/Web/HTML/Element/article\"><code>&lt;article&gt;</code></a></li>\n  <li class=\"html5\"><a href=\"/ja/docs/Web/HTML/Element/aside\"><code>&lt;aside&gt;</code></a></li>\n  <li class=\"html5\"><a href=\"/ja/docs/Web/HTML/Element/audio\"><code>&lt;audio&gt;</code></a></li>\n </ol>\n </li><li>B\n <ol>\n  <li><a href=\"/ja/docs/Web/HTML/Element/b\"><code>&lt;b&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/base\"><code>&lt;base&gt;</code></a></li>\n  <li><s class=\"obsoleteElement deprecatedElement\"><a href=\"/ja/docs/conflicting/Web/CSS/CSS_Fonts\"><code>&lt;basefont&gt;</code></a></s></li>\n  <li class=\"html5\"><a href=\"/ja/docs/Web/HTML/Element/bdi\"><code>&lt;bdi&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/bdo\"><code>&lt;bdo&gt;</code></a></li>\n  <li><s class=\"nonStdElement\"><a href=\"/ja/docs/Web/HTML/Element/bgsound\"><code>&lt;bgsound&gt;</code></a></s></li>\n  <li><s class=\"obsoleteElement\"><a href=\"/ja/docs/Web/HTML/Element/big\"><code>&lt;big&gt;</code></a></s></li>\n  <li><s class=\"nonStdElement\"><a href=\"/