{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"<details>: 詳細折りたたみ要素","mdn_url":"/ja/docs/Web/HTML/Element/details","locale":"ja","native":"日本語","sidebarHTML":"\n  <ol>\n   \n            <li><a href=\"/ja/docs/Web/HTML/Element/details\"><code>&lt;details&gt;</code></a></li>\n  \n            <li><a href=\"/ja/docs/Web/HTML/Element/menu\"><code>&lt;menu&gt;</code></a></li>\n  \n            <li><a href=\"/ja/docs/Web/HTML/Element/summary\"><code>&lt;summary&gt;</code></a></li>\n  \n    \n   <li><details><summary>HTML Elements</summary><ol>\n   <li>A\n <ol>\n  <li><a href=\"/ja/docs/Web/HTML/Element/a\"><code>&lt;a&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/abbr\"><code>&lt;abbr&gt;</code></a></li>\n  <li><s class=\"obsoleteElement\"><a href=\"/ja/docs/Web/HTML/Element/acronym\"><code>&lt;acronym&gt;</code></a></s></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/address\"><code>&lt;address&gt;</code></a></li>\n  <li><s class=\"obsoleteElement deprecatedElement\"><a href=\"/ja/docs/Web/HTML/Element/applet\"><code>&lt;applet&gt;</code></a></s></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/area\"><code>&lt;area&gt;</code></a></li>\n  <li class=\"html5\"><a href=\"/ja/docs/Web/HTML/Element/article\"><code>&lt;article&gt;</code></a></li>\n  <li class=\"html5\"><a href=\"/ja/docs/Web/HTML/Element/aside\"><code>&lt;aside&gt;</code></a></li>\n  <li class=\"html5\"><a href=\"/ja/docs/Web/HTML/Element/audio\"><code>&lt;audio&gt;</code></a></li>\n </ol>\n </li><li>B\n <ol>\n  <li><a href=\"/ja/docs/Web/HTML/Element/b\"><code>&lt;b&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/base\"><code>&lt;base&gt;</code></a></li>\n  <li><s class=\"obsoleteElement deprecatedElement\"><a href=\"/ja/docs/conflicting/Web/CSS/CSS_Fonts\"><code>&lt;basefont&gt;</code></a></s></li>\n  <li class=\"html5\"><a href=\"/ja/docs/Web/HTML/Element/bdi\"><code>&lt;bdi&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/bdo\"><code>&lt;bdo&gt;</code></a></li>\n  <li><s class=\"nonStdElement\"><a href=\"/ja/docs/Web/HTML/Element/bgsound\"><code>&lt;bgsound&gt;</code></a></s></li>\n  <li><s class=\"obsoleteElement\"><a href=\"/ja/docs/Web/HTML/Element/big\"><code>&lt;big&gt;</code></a></s></li>\n  <li><s class=\"nonStdElement\"><a href=\"/ja/docs/Web/HTML/Element/blink\"><code>&lt;blink&gt;</code></a></s></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/blockquote\"><code>&lt;blockquote&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/body\"><code>&lt;body&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/br\"><code>&lt;br&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/button\"><code>&lt;button&gt;</code></a></li>\n </ol>\n </li><li>C\n <ol>\n  <li class=\"html5\"><a href=\"/ja/docs/Web/HTML/Element/canvas\"><code>&lt;canvas&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/caption\"><code>&lt;caption&gt;</code></a></li>\n  <li><s class=\"obsoleteElement deprecatedElement\"><a href=\"/ja/docs/Web/HTML/Element/center\"><code>&lt;center&gt;</code></a></s></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/cite\"><code>&lt;cite&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/code\"><code>&lt;code&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/col\"><code>&lt;col&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/colgroup\"><code>&lt;colgroup&gt;</code></a></li>\n  <li class=\"webcomp\"><a href=\"/ja/docs/Web/HTML/Element/content\"><code>&lt;content&gt;</code></a></li>\n </ol>\n </li><li>D\n <ol>\n  <li class=\"html5\"><a href=\"/ja/docs/Web/HTML/Element/data\"><code>&lt;data&gt;</code></a></li>\n  <li class=\"html5\"><a href=\"/ja/docs/Web/HTML/Element/datalist\"><code>&lt;datalist&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/dd\"><code>&lt;dd&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/del\"><code>&lt;del&gt;</code></a></li>\n  <li class=\"html5\"><a href=\"/ja/docs/Web/HTML/Element/details\"><code>&lt;details&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/dfn\"><code>&lt;dfn&gt;</code></a></li>\n  <li class=\"html5\"><a href=\"/ja/docs/Web/HTML/Element/dialog\"><code>&lt;dialog&gt;</code></a></li>\n  <li><s class=\"obsoleteElement deprecatedElement\"><a href=\"/ja/docs/Web/HTML/Element/dir\"><code>&lt;dir&gt;</code></a></s></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/div\"><code>&lt;div&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/dl\"><code>&lt;dl&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/dt\"><code>&lt;dt&gt;</code></a></li>\n </ol>\n </li><li>E\n <ol>\n  <li><a href=\"/ja/docs/Web/HTML/Element/em\"><code>&lt;em&gt;</code></a></li>\n  <li class=\"html5\"><a href=\"/ja/docs/Web/HTML/Element/embed\"><code>&lt;embed&gt;</code></a></li>\n </ol>\n </li><li>F\n <ol>\n  <li><a href=\"/ja/docs/Web/HTML/Element/fieldset\"><code>&lt;fieldset&gt;</code></a></li>\n  <li class=\"html5\"><a href=\"/ja/docs/Web/HTML/Element/figcaption\"><code>&lt;figcaption&gt;</code></a></li>\n  <li class=\"html5\"><a href=\"/ja/docs/Web/HTML/Element/figure\"><code>&lt;figure&gt;</code></a></li>\n  <li><s class=\"deprecatedElement obsoleteElement\"><a href=\"/ja/docs/Web/HTML/Element/font\"><code>&lt;font&gt;</code></a></s></li>\n  <li class=\"html5\"><a href=\"/ja/docs/Web/HTML/Element/footer\"><code>&lt;footer&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/form\"><code>&lt;form&gt;</code></a></li>\n  <li><s class=\"obsoleteElement\"><a href=\"/ja/docs/Web/HTML/Element/frame\"><code>&lt;frame&gt;</code></a></s></li>\n  <li><s class=\"obsoleteElement\"><a href=\"/ja/docs/Web/HTML/Element/frameset\"><code>&lt;frameset&gt;</code></a></s></li>\n </ol>\n </li><li>G H\n <ol>\n  <li><a href=\"/ja/docs/Web/HTML/Element/Heading_Elements\"><code>&lt;heading_elements&gt;</code></a></li>\n  <li><a href=\"/ja/docs/Web/HTML/Element/head\"><code>&lt;head&gt;</code></a></li>\n  <li class=\"h