{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"round","mdn_url":"/ja/docs/Web/XPath/Functions/round","locale":"ja","native":"日本語","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><div style=\"background:#f5f5f5; margin: 5px 0;\" id=\"sect1\">\n    <b><a href=\"/ja/docs/Web/XSLT/Transforming_XML_with_XSLT/The_Netscape_XSLT_XPath_Reference\">XSLT/XPath リファレンス</a></b>: <a href=\"/ja/docs/Web/XSLT/Element\">XSLT 要素</a>, <a href=\"/ja/docs/Web/EXSLT\">EXSLT 関数</a>, <a href=\"/ja/docs/Web/XPath/Functions\">XPath 関数</a>, <a href=\"/ja/docs/Web/XPath/Axes\">XPath 軸</a>\n</div><p></p>\n\n<p><code>round</code> 関数は、与えられた数値に最も近い整数を返します。</p>"}},{"type":"prose","value":{"id":"syntax","title":"構文","isH3":true,"content":"<pre class=\"eval notranslate\">round(<em>decimal</em> )\n</pre>"}},{"type":"prose","value":{"id":"arguments","title":"引数","isH3":true,"content":"<dl>\n <dt id=\"decimal\"><em><code>decimal</code></em></dt>\n <dd>丸められる小数。</dd>\n</dl>"}},{"type":"prose","value":{"id":"returns","title":"返値","isH3":true,"content":"<p><em><code>decimal</code></em>よりも小さいか、大きいか、等しい、最も近い整数。</p>"}},{"type":"prose","value":{"id":"notes","title":"注","isH3":true,"content":"<ul>\n <li>-0.5 は負のゼロに丸められます。 0.4 は正のゼロに丸められます。</li>\n</ul>"}},{"type":"prose","value":{"id":"defined","title":"定義","isH3":true,"content":"<p><a href=\"https://www.w3.org/TR/xpath#function-round\" class=\"external\" rel=\" noopener\">XPath 1.0 4.4</a></p>"}},{"type":"prose","value":{"id":"gecko_support","title":"Gecko での対応","isH3":true,"content":"<p>対応済み。</p>"}}],"toc":[],"summary":"round 関数は、与えられた数値に最も近い整数を返します。","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"round","locale":"en-US","native":"English (US)"},{"title":"round","locale":"fr","native":"Français"},{"title":"round","locale":"ko","native":"한국어"},{"title":"round","locale":"pl","native":"Polski"}],"source":{"folder":"ja/web/xpath/functions