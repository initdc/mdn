ript/Reference/Global_Objects/Object/__defineGetter__\"><code>Object.prototype.__defineGetter__()</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineSetter__\"><code>Object.prototype.__defineSetter__()</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupGetter__\"><code>Object.prototype.__lookupGetter__()</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupSetter__\"><code>Object.prototype.__lookupSetter__()</code></a></li><li><a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwnProperty\"><code>Object.prototype.hasOwnProperty()</code></a></li><li><a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/Object/isPrototypeOf\"><code>Object.prototype.isPrototypeOf()</code></a></li><li><a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/Object/propertyIsEnumerable\"><code>Object.prototype.propertyIsEnumerable()</code></a></li><li><a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/Object/setPrototypeOf\"><code>Object.setPrototypeOf()</code></a></li><li><a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/Object/toLocaleString\"><code>Object.prototype.toLocaleString()</code></a></li><li><a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a></li><li><a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/Object/valueOf\"><code>Object.prototype.valueOf()</code></a></li></ol></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p><strong><code>Math.E</code></strong> プロパティは自然対数の底 (e)、約 2.718 を表します。</p>\n\n<p><math display=\"block\"><semantics><mrow><mstyle mathvariant=\"monospace\"><mi>Math.E</mi></mstyle><mo>=</mo><mi>e</mi><mo>≈</mo><mn>2.718</mn></mrow><annotation encoding=\"TeX\">\\mathtt{\\mi{Math.E}} = e \\approx 2.718</annotation></semantics></math></p>\n\n<div id=\"sect2\"><iframe class=\"interactive\" height=\"490\" src=\"https://interactive-examples.mdn.mozilla.net/pages/js/math-e.html\" title=\"MDN Web Docs Interactive Example\" loading=\"lazy\"></iframe></div>\n\n\n\n<div id=\"sect4\"><table class=\"standard-table\">\n  <thead>\n    <tr>\n      <th class=\"header\" colspan=\"2\"><code>Math.E</code> のプロパティ属性</th>\n    </tr>\n  </thead>\n  <tbody>\n    <tr>\n      <td>書込可能</td>\n      <td>不可</td>\n    </tr>\n    <tr>\n      <td>列挙可能</td>\n      <td>不可</td>\n    </tr>\n    <tr>\n      <td>設定可能</td>\n      <td>不可</td>\n    </tr>\n  </tbody>\n</table></div>"}},{"type":"prose","value":{"id":"description","title":"解説","isH3":false,"content":"<p><code>E</code> は <code>Math</code> オブジェクトの静的プロパティなので、 <code>Math</code> オブジェクトを生成してプロパティとして使用するのではなく、常に <code>Math.E</code> として使用するようにしてください (<code>Math</code> はコンストラクターではありません)。</p>"}},{"type":"prose","value":{"id":"examples","title":"例","isH3":false,"content":""}},{"type":"prose","value":{"id":"using_math.e","title":"Math.E の使用","isH3":true,"content":"<p>以下の関数は、e を返します。</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">function</span> <span class=\"token function\">getNapier</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n  <span class=\"token keyword\">return</span> Math<span class=\"token punctuation\">.</span><span class=\"token constant\">E</span><span class=\"token punctuation\">;</span>\n<span class=\"token punctuation\">}</span>\n\n<span class=\"token function\">getNapier</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// 2.718281828459045</span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"specifications","title":"仕様書","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">仕様書</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"https://tc39.es/ecma262/#sec-math.e\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript (ECMA-262)<br><small lang=\"ja\">Math.E の定義</small></a></td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"ブラウザーの互換性","id":"browser_compatibility","isH3":false,"query":"javascript.builtins.Math.E","dataURL":"/ja/docs/Web/JavaScript/Reference/Global_Objects/Math/E/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"see_also","title":"関連情報","isH3":false,"content":"<ul>\n <li><a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/Math/exp\"><code>Math.exp()</code></a></li>\n <li><a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/Math/log\"><code>Math.log()</code></a></li>\n <li><a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/Math/log1p\"><code>Math.log1p()</code></a></li>\n</ul>"}}],"toc":[{"text":"解説","id":"description"},{"text":"例","id":"examples"},{"text":"仕様書","id":"specifications"},{"text":"ブラウザーの互換性","id":"browser_compatibility"},{"text":"関連情報","id":"see_also"}],"summary":"Math.E プロパティは自然対数の底 (e)、約 2.718 を表します。","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Math.E","locale":"de","native":"Deutsch"},{"title":"Math.E","locale":"en-US","native":"English (US)"},{"title":"Math.E","locale":"es","native":"Español"},{"title":"Math.E","locale":"fr","native":"Français"},{"title":"Math.E","locale":"ko","native":"한국어"},{"title":"Math.E","locale":"pl","nati