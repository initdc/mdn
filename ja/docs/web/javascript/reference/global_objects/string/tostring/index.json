xamples.mdn.mozilla.net/pages/js/string-tostring.html\" title=\"MDN Web Docs Interactive Example\" loading=\"lazy\"></iframe></div>"}},{"type":"prose","value":{"id":"syntax","title":"構文","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><code><var>str</var>.toString()</code></pre>"}},{"type":"prose","value":{"id":"return_value","title":"返値","isH3":true,"content":"<p>呼び出したオブジェクトを表す文字列です。</p>"}},{"type":"prose","value":{"id":"description","title":"詳細","isH3":false,"content":"<p>その <a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/String\"><code>String</code></a> オブジェクトは、<a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/Object\"><code>Object</code></a> の <code>toString</code> メソッドを上書きします。つまり、<a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a> を継承しません。<a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/String\"><code>String</code></a> オブジェクトの&nbsp;<code>toString()</code> メソッドは、そのオブジェクトを表す文字列を返します（ <a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/String/valueOf\"><code>String.prototype.valueOf()</code></a> と同等です）。</p>"}},{"type":"prose","value":{"id":"examples","title":"例","isH3":false,"content":""}},{"type":"prose","value":{"id":"using_tostring","title":"<code>toString</code> メソッドを使う","isH3":true,"content":"<p>以下の例は、<a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/String\"><code>String</code></a> オブジェクトを表す文字列の値を表示します。</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> x <span class=\"token operator\">=</span> <span class=\"token keyword\">new</span> <span class=\"token class-name\">String</span><span class=\"token punctuation\">(</span><span class=\"token string\">'Hello world'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n\n<span class=\"token function\">alert</span><span class=\"token punctuation\">(</span>x<span class=\"token punctuation\">.</span><span class=\"token function\">toString</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">)</span> <span class=\"token comment\">// 'Hello world' を表示します</span>\n</code></pre></div>","titleAsText":"toString メソッドを使う"}},{"type":"prose","value":{"id":"specifications","title":"仕様","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">仕様書</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://tc39.es/ecma262/#sec-string.prototype.tostring\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript (ECMA-262)<br><small lang=\"ja\">String.prototype.toString の定義</small></a></td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"ブラウザー実装状況","id":"browser_compatibility","isH3":false,"query":"javascript.builtins.String.toString","dataURL":"/ja/docs/Web/JavaScript/Reference/Global_Objects/String/toString/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"see_also","title":"関連情報","isH3":false,"content":"<ul>\n <li><a href=\"/ja/docs/conflicting/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toSource()</code></a></li>\n <li><a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/String/valueOf\"><code>String.prototype.valueOf()</code></a></li>\n</ul>"}}],"toc":[{"text":"構文","id":"syntax"},{"text":"詳細","id":"description"},{"text":"例","id":"examples"},{"text":"仕様","id":"specifications"},{"text":"ブラウザー実装状況","id":"browser_compatibility"},{"text":"関連情報","id":"see_also"}],"summary":"toString() メソッドは指定されたオブジェクトを表す文字列を返します。","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"String.prototype.toString()","locale":"en-US","native":"English (US)"},{"title":"String.prototype.toString()","locale":"es","native":"Español"},{"title":"String.prototype.toString()","locale":"