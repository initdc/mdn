/Window/message_event\"><code>message</code></a></li><li><a href=\"/ja/docs/Web/API/Window/messageerror_event\"><code>messageerror</code></a></li><li><a href=\"/ja/docs/Web/API/Window/offline_event\"><code>offline</code></a></li><li><a href=\"/ja/docs/Web/API/Window/online_event\"><code>online</code></a></li><li><a href=\"/ja/docs/Web/API/Window/orientationchange_event\"><code>orientationchange</code></a></li><li><a href=\"/ja/docs/Web/API/Window/pagehide_event\"><code>pagehide</code></a></li><li><a href=\"/ja/docs/Web/API/Window/pageshow_event\"><code>pageshow</code></a></li><li><a href=\"/ja/docs/Web/API/Window/paste_event\"><code>paste</code></a></li><li><a href=\"/ja/docs/Web/API/Window/popstate_event\"><code>popstate</code></a></li><li><a href=\"/ja/docs/Web/API/Window/rejectionhandled_event\"><code>rejectionhandled</code></a></li><li><a href=\"/ja/docs/Web/API/Window/storage_event\"><code>storage</code></a></li><li><a href=\"/ja/docs/Web/API/Window/unhandledrejection_event\"><code>unhandledrejection</code></a></li><li><a href=\"/ja/docs/Web/API/Window/unload_event\"><code>unload</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Window/vrdisplayactivate_event\"><code>vrdisplayactivate</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Window/vrdisplayblur_event\"><code>vrdisplayblur</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/ja/docs/Web/API/Window/vrdisplayconnect_event\"><code>vrdisplayconnect</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Window/vrdisplaydeactivate_event\"><code>vrdisplaydeactivate</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/ja/docs/Web/API/Window/vrdisplaydisconnect_event\"><code>vrdisplaydisconnect</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/ja/docs/Web/API/Window/vrdisplayfocus_event\"><code>vrdisplayfocus</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Window/vrdisplaypointerrestricted_event\"><code>vrdisplaypointerrestricted</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Window/vrdisplaypointerunrestricted_event\"><code>vrdisplaypointerunrestricted</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/ja/docs/Web/API/Window/vrdisplaypresentchange_event\"><code>vrdisplaypresentchange</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>継承</summary><ol><li><a href=\"/ja/docs/Web/API/EventTarget\"><code>EventTarget</code></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>\n\n<p><code><strong>GlobalEventHandlers.onresize</strong></code> プロパティは、<code><a href=\"/en-US/docs/Web/API/Window/resize_event\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">resize (en-US)</a></code> イベントを受信するとトリガーされる <code><a href=\"/ja/docs/Web/Reference/Events/Event_handlers\" title=\"This is a link to an unwritten page\" class=\"page-not-created\">event handler</a></code> を含みます。</p>"}},{"type":"prose","value":{"id":"syntax","title":"構文","isH3":false,"content":"<pre class=\"eval notranslate\">window.onresize = <em>funcRef</em>;\n</pre>"}},{"type":"prose","value":{"id":"parameters","title":"引数","isH3":true,"content":"<ul>\n <li><code>funcRef</code>: 関数への参照</li>\n</ul>"}},{"type":"prose","value":{"id":"example","title":"例","isH3":false,"content":"<pre class=\"notranslate\">window.onresize = doFunc;\n</pre>\n\n<pre class=\"notranslate\">&lt;html&gt;\n&lt;head&gt;\n\n&lt;title&gt;onresize test&lt;/title&gt;\n\n&lt;/head&gt;\n\n&lt;body&gt;\n&lt;p&gt;Resize the browser window to fire the resize event.&lt;/p&gt;\n\n&lt;p&gt;Window height: &lt;span id=\"height\"&gt;&lt;/span&gt;&lt;/p&gt;\n&lt;p&gt;Window width: &lt;span id=\"width\"&gt;&lt;/span&gt;&lt;/p&gt;\n\n&lt;script type=\"text/javascript\"&gt;\n  var heightOutput = document.querySelector('#height');\n  var widthOutput = document.querySelector('#width');\n\n  function resize() {\n    heightOutput.textContent = window.innerHeight;\n    widthOutput.textContent = window.innerWidth;\n  }\n\n  window.onresize = resize;\n&lt;/script&gt;\n&lt;/body&gt;\n&lt;/html&gt;\n</pre>"}},{"type":"prose","value":{"id":"notes","title":"注記","isH3":false,"content":"<p>ブラウザウィンドウのサイズが変更された後に <code>resize</code> イベントが発生します。</p>"}},{"type":"prose","value":{"id":"specification","title":"仕様","isH3":false,"content":"<table class=\"spectable standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">使用</th>\n   <th scope=\"col\">ステータス</th>\n   <th scope=\"col\">コメント</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://html.spec.whatwg.org/multipage/webappapis.html#handler-onresize\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML Living Standard<br><small lang=\"ja\">onresize の定義</small></a></td>\n   <td><span class=\"spec-living\">現行の標準</span></td>\n   <td>&nbsp;</td>\n  </tr>\n </tbody>\n</table>"}}],"toc":[{"text":"構文","id":"syntax"},{"text":"例","id":"example"},{"text":"注記","id":"notes"},{"text":"仕様","id":"specification"}],"summary":"GlobalEventHandlers.onresize プロパティは、resize (en-US) イベントを受信するとトリガーされる event handler を含みます。","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"window.onresize","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"ja/conflicting/web/api/window/resize_event","github_url":"https://github.com/mdn/translated-content/blob/main/files/ja/conflicting/web/api/window/resize_event/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/ja/docs/conflicting/Web/API/Window","title":"Window.mozPaintCount"},{"uri":"/ja/docs/conflicting/Web/API/Window/resize_event","title":"window.onresize"}],"pageTitle":"window.onresize | MDN","noIndexing":true}}