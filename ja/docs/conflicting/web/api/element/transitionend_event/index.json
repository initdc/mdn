lement/gesturestart_event\"><code>gesturestart</code> <small>(en-US)</small></a></li><li><a href=\"/ja/docs/Web/API/Element/keydown_event\"><code>keydown</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/ja/docs/Web/API/Element/keypress_event\"><code>keypress</code></a></li><li><a href=\"/ja/docs/Web/API/Element/keyup_event\"><code>keyup</code></a></li><li><a href=\"/ja/docs/Web/API/Element/mousedown_event\"><code>mousedown</code></a></li><li><a href=\"/ja/docs/Web/API/Element/mouseenter_event\"><code>mouseenter</code></a></li><li><a href=\"/ja/docs/Web/API/Element/mouseleave_event\"><code>mouseleave</code></a></li><li><a href=\"/ja/docs/Web/API/Element/mousemove_event\"><code>mousemove</code></a></li><li><a href=\"/ja/docs/Web/API/Element/mouseout_event\"><code>mouseout</code></a></li><li><a href=\"/ja/docs/Web/API/Element/mouseover_event\"><code>mouseover</code></a></li><li><a href=\"/ja/docs/Web/API/Element/mouseup_event\"><code>mouseup</code></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Element/mousewheel_event\"><code>mousewheel</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Element/MozMousePixelScroll_event\"><code>MozMousePixelScroll</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Element/msContentZoom_event\"><code>msContentZoom</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Element/MSGestureChange_event\"><code>MSGestureChange</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Element/MSGestureEnd_event\"><code>MSGestureEnd</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Element/MSGestureHold_event\"><code>MSGestureHold</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Element/MSGestureStart_event\"><code>MSGestureStart</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Element/MSGestureTap_event\"><code>MSGestureTap</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Element/MSInertiaStart_event\"><code>MSInertiaStart</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Element/MSManipulationStateChanged_event\"><code>MSManipulationStateChanged</code> <small>(en-US)</small></a></li><li><a href=\"/ja/docs/Web/API/Element/paste_event\"><code>paste</code></a></li><li><a href=\"/ja/docs/Web/API/Element/pointercancel_event\"><code>pointercancel</code></a></li><li><a href=\"/ja/docs/Web/API/Element/pointerdown_event\"><code>pointerdown</code></a></li><li><a href=\"/ja/docs/Web/API/Element/pointerenter_event\"><code>pointerenter</code></a></li><li><a href=\"/ja/docs/Web/API/Element/pointerleave_event\"><code>pointerleave</code></a></li><li><a href=\"/ja/docs/Web/API/Element/pointermove_event\"><code>pointermove</code></a></li><li><a href=\"/ja/docs/Web/API/Element/pointerout_event\"><code>pointerout</code></a></li><li><a href=\"/ja/docs/Web/API/Element/pointerover_event\"><code>pointerover</code></a></li><li><a href=\"/ja/docs/Web/API/Element/pointerup_event\"><code>pointerup</code></a></li><li><a href=\"/ja/docs/Web/API/Element/scroll_event\"><code>scroll</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Element/securitypolicyviolation_event\"><code>securitypolicyviolation</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/ja/docs/Web/API/Element/show_event\"><code>show</code></a></li><li><a href=\"/ja/docs/Web/API/Element/touchcancel_event\"><code>touchcancel</code></a></li><li><a href=\"/ja/docs/Web/API/Element/touchend_event\"><code>touchend</code></a></li><li><a href=\"/ja/docs/Web/API/Element/touchmove_event\"><code>touchmove</code></a></li><li><a href=\"/ja/docs/Web/API/Element/touchstart_event\"><code>touchstart</code></a></li><li><a href=\"/ja/docs/Web/API/Element/transitioncancel_event\"><code>transitioncancel</code></a></li><li><em><code>transitionend</code></em></li><li><a href=\"/ja/docs/Web/API/Element/transitionrun_event\"><code>transitionrun</code></a></li><li><a href=\"/ja/docs/Web/API/Element/transitionstart_event\"><code>transitionstart</code></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Element/webkitmouseforcechanged_event\"><code>webkitmouseforcechanged</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Element/webkitmouseforcedown_event\"><code>webkitmouseforcedown</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Element/webkitmouseforceup_event\"><code>webkitmouseforceup</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Element/webkitmouseforcewillbegin_event\"><code>webkitmouseforcewillbegin</code> <small>(en-US)</small></a></li><li><a href=\"/ja/docs/Web/API/Element/wheel_event\"><code>wheel</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>継承</summary><ol><li><a href=\"/ja/docs/Web/API/Node\"><code>Node</code></a></li><li><a href=\"/ja/docs/Web/API/EventTarget\"><code>EventTarget</code></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p><strong><code>ontransitionend</code></strong> は <a href=\"/ja/docs/Web/API/GlobalEventHandlers\"><code>GlobalEventHandlers</code></a> ミックスインのプロパティで、 <code><a href=\"/en-US/docs/Web/API/Element/transitionend_event\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">transitionend (en-US)</a></code> イベントを処理するイベントハンドラー (<code><a href=\"/ja/docs/Web/Reference/Events/Event_handlers\" title=\"This is a link to an unwritten page\" class=\"page-not-created\">event handler</a></code>) です。</p>\n\n<p><code>transitionend</code> イベントは、 <a href=\"/ja/docs/Web/CSS/CSS_Transitions\">CSS トランジション</a>が完了すると発生します。</p>\n\n<div class=\"note notecard\" id=\"sect2\">\n<p>トランジションの実行が完了する前に対象ノードからトランジションが削除された場合、 <code><a href=\"/en-US/docs/Web/API/Element/transitionend_event\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">transitionend (en-US)</a></code> イベントは生成されません。これは、対象に適用される <a href=\"/ja/docs/Web/CSS/transition-property\"><code>transition-property</code></a> 属性の値を変更することで発生します。もう一つは、 <a href=\"/ja/docs/Web/CSS/display\"><code>display</code></a> 属性が <code>none</code> に設定されている場合です。</p>\n</div>"}},{"type":"prose","value":{"id":"syntax","title":"構文","isH3":false,"content":"<pre class=\"syntaxbox notranslate\">var <var>transitionEndHandler</var> = <var>target</var>.ontransitionend;\n\n<var>target</var>.ontransitionend = <var><a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/Function\"><code>Function</code></a></var>\n</pre>"}},{"type":"prose","value":{"id":"value","title":"値","isH3":true,"content":"<p>関数 (<a href=\"/ja/docs/Web/JavaScript/Reference/Global_Objects/Function\"><code>Function</code></a>) で、 CSS トランジションの完了を示す <code><a href=\"/en-US/docs/Web/API/Element/transitionend_event\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">transitionend (en-US)</a></code> イベントが <code><var>target</var></code> 上で発生した場合に呼び出されるものです。対象となるオブジェクトは HTML 要素 (<a href=\"/ja/docs/Web/API/HTMLElement\"><code>HTMLElement</code></a>)、文書 (<a href=\"/ja/docs/Web/API/Document\"><code>Document</code></a>)、ウィンドウ (<a href=\"/ja/docs/Web/API/Window\"><code>Window</code></a>) です。この関数は単一の引数、発生したイベントを記述する <a href=\"/ja/docs/Web/API/TransitionEvent\"><code>TransitionEvent</code></a> を単一の引数として受け取ります。イベントの <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/TransitionEvent/elapsedTime\"><code>TransitionEvent.elapsedTime</code> <small>(en-US)</small></a> プロパティの値は、 <a href=\"/ja/docs/Web/CSS/transition-duration\"><code>transition-duration</code></a> の値と同じでなければなりません。</p>\n\n<div class=\"note notecard\" id=\"sect3\">\n<p><code>elapsedTime</code> には、トランジション効果が始まる前の時間は含まれていません。つまり、 <a href=\"/ja/docs/Web/CSS/transition-delay\"><code>transition-delay</code></a> の値は、待ち時間が終了してアニメーションが始まるまでは 0 である <code>elapsedTime</code> の値に影響しません。</p>\n</div>"}},{"type":"prose","value":{"id":"example","title":"例","isH3":false,"content":"<p>この例では、<code><a href=\"/ja/docs/Web/Reference/Events/transitionrun\" title=\"This is a link to an unwritten page\" class=\"page-not-created\">transitionrun</a></code> イベントと <code><a href=\"/en-US/docs/Web/API/Element/transitionend_event\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">transitionend (en-US)</a></code> イベントを使用して、トランジションの開始と終了を検出し、トランジション中にテキスト更新が発生するようにしています。これは、アニメーションやその他のエフェクトを起動して、反応を連鎖させるために使用することもできます。</p>"}},{"type":"prose","value":{"id":"html","title":"HTML","isH3":true,"content":"<p>これは単純に <a href=\"/ja/docs/Web/HTML/Element/div\"><code>&lt;div&gt;</code></a> を作成するだけで、以下の CSS でスタイルを変更して、ボックスの大きさを変更したり色を変更したりします。</p>\n\n<div class=\"code-example\"><pre class=\"brush: html; notranslate\"><code><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>div</span> <span class=\"token attr-name\">class</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>box<span class=\"token punctuation\">\"</span></span><span class=\"token punctuation\">&gt;</span></span><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>div</span><span class=\"token punctuation\">&gt;</span></span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"css","title":"CSS","isH3":true,"content":"<p>以下の CSS は、ボックスのスタイルを設定し、ボックスの色と大きさを変化させ、マウスカーソルがボックスの上に乗っている間にボックスが回転するようなトランジション効果を適用しています。</p>\n\n<div class=\"code-example\"><pre class=\"brush: css; highlight:[13,14] notranslate\"><code><span class=\"token selector\">.box</span> <span class=\"token punctuation\">{</span>\n  <span class=\"token property\">margin-left</span><span class=\"token punctuation\">:</span> 70px<span class=\"token punctuation\">;</span>\n  <span class=\"token property\">margin-top</span><span class=\"token punctuation\">:</span> 30px<span class=\"token punctuation\">;</span>\n  <span class=\"token property\">border-style</span><span class=\"token punctuation\">:</span> solid<span class=\"token punctuation\">;</span>\n  <span class=\"token property\">border-width</span><span class=\"token punctuation\">:</span> 1px<span class=\"token punctuation\">;</span>\n  <span class=\"token property\">display</span><span class=\"token punctuation\">:</span> block<span class=\"token punctuation\">;</span>\n  <span class=\"token property\">width</span><span class=\"token punctuation\">:</span> 100px<span class=\"token punctuation\">;</span>\n  <span class=\"token property\">height</span><span class=\"token punctuation\">:</span> 100px<span class=\"token punctuation\">;</span>\n  <span class=\"token property\">background-color</span><span class=\"token punctuation\">:</span> #0000FF<span class=\"token punctuation\">;</span>\n  <span class=\"token property\">color</span><span class=\"token punctuation\">:</span> #FFFFFF<span class=\"token punctuation\">;</span>\n  <span class=\"token property\">padding</span><span class=\"token punctuation\">:</span> 20px<span class=\"token punctuation\">;</span>\n  <span class=\"token property\">font</span><span class=\"token punctuation\">:</span> bold 1.6em <span class=\"token string\">\"Helvetica\"</span><span class=\"token punctuation\">,</span> <span class=\"token string\">\"Arial\"</span><span class=\"token punctuation\">,</span> sans-serif<span class=\"token punctuation\">;</span>\n  <span class=\"token property\">transition</span><span class=\"token punctuation\">:</span> width 2s<span class=\"token punctuation\">,</span> height 2s<span class=\"token punctuation\">,</span> background-color 2s<span class=\"token punctuation\">,</span> transform 2s<span class=\"token punctuation\">,</span> color 2s<span class=\"token punctuation\">;</span>\n<span class=\"token punctuation\">}</span>\n\n<span class=\"token selector\">.box:hover</span> <span class=\"token punctuation\">{</span>\n  <span class=\"token property\">background-color</span><span class=\"token punctuation\">:</span> #FFCCCC<span class=\"token punctuation\">;</span>\n  <span class=\"token property\">color</span><span class=\"token punctuation\">:</span> #000000<span class=\"token punctuation\">;</span>\n  <span class=\"token property\">width</span><span class=\"token punctuation\">:</span> 200px<span class=\"token punctuation\">;</span>\n  <span class=\"token property\">height</span><span class=\"token punctuation\">:</span> 200px<span class=\"token punctuation\">;</span>\n  <span class=\"token property\">transform</span><span class=\"token punctuation\">:</span> <span class=\"token function\">rotate</span><span class=\"token punctuation\">(</span>180deg<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token punctuation\">}</span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"javascript","title":"JavaScript","isH3":true,"content":"<p>次に、トランジションの開始時と終了時にボックスのテキストコンテンツを変更するためにイベントハンドラ－を設定します。</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">let</span> box <span class=\"token operator\">=</span> document<span class=\"token punctuation\">.</span><span class=\"token function\">querySelector</span><span class=\"token punctuation\">(</span><span class=\"token string\">\".box\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\nbox<span class=\"token punctuation\">.</span><span class=\"token function-variable function\">ontransitionrun</span> <span class=\"token operator\">=</span> <span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">event</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n  box<span class=\"token punctuation\">.</span>innerHTML <span class=\"token operator\">=</span> <span class=\"token string\">\"Zooming...\"</span><span class=\"token punctuation\">;</span>\n<span class=\"token punctuation\">}</span>\nbox<span class=\"token punctuation\">.</span><span class=\"token function-variable function\">ontransitionend</span> <span class=\"token operator\">=</span> <span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">event</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n  box<span class=\"token punctuation\">.</span>innerHTML <span class=\"token operator\">=</span> <span class=\"token string\">\"Done!\"</span><span class=\"token punctuation\">;</span>\n<span class=\"token punctuation\">}</span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"result","title":"結果","isH3":true,"content":"<p>結果のコンテンツは次のようになります。</p>\n\n<p><iframe class=\"sample-code-frame\" title=\"Example sample\" id=\"frame_example\" width=\"600\" height=\"280\" src=\"https://yari-demos.prod.mdn.mozit.cloud/ja/docs/conflicting/Web/API/Element/transitionend_event/_sample_.example.html\" loading=\"lazy\"></iframe></p>\n\n<p>マウスカーソルをボックスの上に置いてから、マウスを移動させるとどうなるかに注目してください。</p>"}},{"type":"prose","value":{"id":"specification","title":"仕様書","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">仕様書</th>\n   <th scope=\"col\">状態</th>\n   <th scope=\"col\">備考</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"https://drafts.csswg.org/css-transitions/#dom-globaleventhandlers-ontransitionend\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">CSS Transitions<br><small lang=\"ja\">ontransitionend の定義</small></a></td>\n   <td><span class=\"spec-wd\">草案</span></td>\n   <td></td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"ブラウザーの互換性","id":"browser_compatibility","isH3":false,"query":"api.GlobalEventHandlers.ontransitionend","dataURL":"/ja/docs/conflicting/Web/API/Element/transitionend_event/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"see_also","title":"関連情報","isH3":false,"content":"<ul>\n <li>このハンドラーを起動する <code><a href=\"/en-US/docs/Web/API/Element/transitionend_event\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">transitionend (en-US)</a></code> イベント</li>\n <li><a href=\"/ja/docs/Web/API/TransitionEvent\"><code>TransitionEvent</code></a></li>\n <li>トランジションが開始したときに発生する <code><a href=\"/ja/docs/Web/Reference/Events/transitionrun\" title=\"This is a link to an unwritten page\" class=\"page-not-created\">transitionrun</a></code> イベント</li>\n</ul>"}}],"toc":[{"text":"構文","id":"syntax"},{"text":"例","id":"example"},{"text":"仕様書","id":"specification"},{"text":"ブラウザーの互換性","id":"browser_compatibili