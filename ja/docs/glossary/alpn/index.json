{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"ALPN","mdn_url":"/ja/docs/Glossary/ALPN","locale":"ja","native":"日本語","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p><strong>Application-Layer <a href=\"/ja/docs/Glossary/Protocol\">Protocol</a> Negotiation</strong> (<strong>ALPN</strong>) は、&nbsp;<a href=\"/ja/docs/Glossary/TLS\">TLS</a> 拡張であり、追加のラウンドトリップを必要とせずに、暗号化された接続をネゴシエートするアプリケーションレイヤープロトコルを示します。</p>\n\n<table class=\"standard-table\">\n <caption>重要なプロトコル識別子:</caption>\n <thead>\n  <tr>\n   <th scope=\"col\">プロトコル</th>\n   <th scope=\"col\">識別シーケンス</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"/ja/docs/Glossary/HTTP\">HTTP</a>/1.1</td>\n   <td><code>0x68 0x74 0x74 0x70 0x2F 0x31 0x2E 0x31</code> (\"http/1.1\")</td>\n  </tr>\n  <tr>\n   <td><a href=\"/ja/docs/Glossary/HTTP_2\">HTTP/2</a></td>\n   <td><code>0x68 0x32</code> (\"h2\")</td>\n  </tr>\n  <tr>\n   <td>HTTP/2 over cleartext <a href=\"/ja/docs/Glossary/TCP\">TCP</a></td>\n   <td><code>0x68 0x32 0x63</code> (\"h2c\")</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"仕様","title":"仕様","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">仕様</th>\n   <th scope=\"col\">ステータス</th>\n   <th scope=\"col\">備考</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"https://datatracker.ietf.org/doc/html/rfc7301\" class=\"external\" rel=\" noopener\">RFC 7301</a></td>\n   <td><span class=\"spec-RFC\">IETF RFC</span></td>\n   <td>初回定義</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"関連項目","title":"関連項目","isH3":false,"content":"<ul>\n <li><a href=\"https://www.iana.org/assignments/tls-extensiontype-values/tls-extensiontype-values.xhtml#alpn-protocol-ids\" class=\"external\" rel=\" noopener\">IANA 登録&nbsp;ALPN 識別子</a></li>\n</ul>"}}],"toc":[{"text":"仕様","id":"仕様"},{"text":"関連項目","id":"関連項目"}],"summary":"Application-Layer Protocol Nego