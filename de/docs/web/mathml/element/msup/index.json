ML/Element/msub\">&lt;msub&gt;</a></li>\n        \n            <li><a href=\"/de/docs/Web/MathML/Element/msubsup\">&lt;msubsup&gt;</a></li>\n        \n            <li><a href=\"/de/docs/Web/MathML/Element/msup\">&lt;msup&gt;</a></li>\n        \n            <li><a href=\"/de/docs/Web/MathML/Element/mtable\">&lt;mtable&gt;</a></li>\n        \n            <li><a href=\"/de/docs/Web/MathML/Element/mtd\">&lt;mtd&gt;</a></li>\n        \n            <li><a href=\"/de/docs/Web/MathML/Element/mtext\">&lt;mtext&gt;</a></li>\n        \n            <li><a href=\"/de/docs/Web/MathML/Element/mtr\">&lt;mtr&gt;</a></li>\n        \n            <li><a href=\"/de/docs/Web/MathML/Element/munder\">&lt;munder&gt;</a></li>\n        \n            <li><a href=\"/de/docs/Web/MathML/Element/munderover\">&lt;munderover&gt;</a></li>\n        \n\n        \n    </ol>\n","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p class=\"summary\">Das Element <code>&lt;msup&gt;</code> wird in MathML eingesetzt, um einen Ausdruck mit einem Exponenten (einer hochgestellten Zahl) zu versehen.</p>"}},{"type":"prose","value":{"id":"syntax","title":"Syntax","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><code>&lt;msup&gt;<em>base superscript</em>&lt;/msup&gt;</code></pre>"}},{"type":"prose","value":{"id":"attribute","title":"Attribute","isH3":false,"content":"<dl>\n <dt id=\"attr-class-id-style\">class, id, style</dt>\n <dd>Zur Einbindung von <a href=\"/de/docs/Web/CSS\">CSS-Stylesheets</a> und zur direkten Anwendung von CSS-Angaben.</dd>\n <dt id=\"attr-href\">href</dt>\n <dd>Mit diesem Attribut kann ein Link gesetzt werden.</dd>\n <dt id=\"attr-mathbackground\">mathbackground</dt>\n <dd>Die Hintergrundfarbe. Folgende Notationen sind erlaubt: <code><a href=\"/de/docs/Web/CSS/Farben#rgb()\">#rgb</a></code>, <code><a href=\"/de/docs/Web/CSS/Farben#rgb()\">#rrggbb</a></code> und <a href=\"/de/docs/Web/CSS/Farben#Werte\">HTML-Farbnamen</a>.</dd>\n <dt id=\"attr-mathcolor\">mathcolor</dt>\n <dd>Die Textfarbe. Folgende Notationen sind erlaubt: <code><a href=\"/de/docs/Web/CSS/Farben#rgb()\">#rgb</a></code>, <code><a href=\"/de/docs/Web/CSS/Farben#rgb()\">#rrggbb</a></code> und <a href=\"/de/docs/Web/CSS/Farben#Werte\">HTML-Farbnamen</a>.</dd>\n <dt id=\"attr-superscriptshift\">superscriptshift</dt>\n <dd><a href=\"/en-US/docs/Web/MathML/Attribute/Values#lengths\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">Maßangabe (en-US)</a> des Mindestabstandes, um den der Exponent von der Grundlinie des Ausdrucks <em>angehoben</em> wird.</dd>\n</dl>"}},{"type":"prose","value":{"id":"beispiele","title":"Beispiele","isH3":false,"content":"<p>Beispiel: <img alt=\"x1\" src=\"/files/3203/msup.png\" style=\"margin-left: 10px; vertical-align: middle;\" loading=\"lazy\"></p>\n\n<p>Darstellung in Deinem Browser: <math> <msup> <mi>X</mi> <mn>2</mn> </msup> </math></p>\n\n<div class=\"code-example\"><pre class=\"brush: html notranslate\"><code><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>math</span><span class=\"token punctuation\">&gt;</span></span>\n\n  <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>msup</span><span class=\"token punctuation\">&gt;</span></span>\n    <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>mi</span><span class=\"token punctuation\">&gt;</span></span>X<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>mi</span><span class=\"token punctuation\">&gt;</span></span>\n    <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>mn</span><span class=\"token punctuation\">&gt;</span></span>2<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>mn</span><span class=\"token punctuation\">&gt;</span></span>\n  <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>msup</span><span class=\"token punctuation\">&gt;</span></span>\n\n<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>math</span><span class=\"token punctuation\">&gt;</span></span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"spezifikationen","title":"Spezifikationen","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">Standard</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Bemerkung</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"https://www.w3.org/TR/MathML3/chapter3.html#presm.msup\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">MathML 3.0<br><small lang=\"de\">Die Definition von 'msup' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-rec\">Empfehlung</span></td>\n   <td>Current specification</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.w3.org/TR/MathML2/chapter3.html#presm.msup\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">MathML 2.0<br><small lang=\"de\">Die Definition von 'msup' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-rec\">Empfehlung</span></td>\n   <td>Initial specification</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"browserkompatibilität","title":"Browserkompatibilität","isH3":false,"content":"<p></p><div class=\"notecard note\" id=\"sect2\"><strong><a href=\"https://github.com/mdn/browser-compat-data\" class=\"external\" rel=\" noopener\">Wir konvertieren die Kompatibilitätsdaten in ein maschinenlesbares JSON Format</a></strong>.\n            Diese Kompatibilitätstabelle liegt noch im alten Format vor,\n            denn die darin enthaltenen Daten wurden noch nicht konvertiert.\n            <strong><a href=\"/en-US/docs/MDN/Structures/Compatibility_tables\" class=\"only-in-en-us\" title=\"Currently only avai