ructures/Compatibility_tables\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">Finde heraus wie du helfen kannst! (en-US)</a></strong></div>\n\n<div class=\"htab\" id=\"sect4\">\n    <a id=\"AutoCompatibilityTable\" name=\"AutoCompatibilityTable\"></a>\n    <ul>\n        <li class=\"selected\"><a href=\"#compat-desktop\">Desktop</a></li>\n        <li><a href=\"#compat-mobile\">Mobile</a></li>\n    </ul>\n</div><p></p>\n\n<div id=\"compat-desktop\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Merkmal</th>\n   <th>Chrome</th>\n   <th>Firefox (Gecko)</th>\n   <th>Internet Explorer</th>\n   <th>Opera</th>\n   <th>Safari</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td>1.0 (1.7 oder früher)</td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td>5.1</td>\n  </tr>\n  <tr>\n   <td><code>align</code></td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td>1.0 (1.7 oder früher)</td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n  </tr>\n  <tr>\n   <td><code>alignmentscope</code></td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n  </tr>\n  <tr>\n   <td><code>columnalign</code></td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td>1.0 (1.7 oder früher)</td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td>5.1