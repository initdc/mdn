{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"XML: Extensible Markup Language","mdn_url":"/de/docs/Web/XML","locale":"de","native":"Deutsch","sidebarHTML":"\n<ol></ol>\n","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>\n\n<p class=\"summary\">The <strong>Extensible Markup Language</strong> is&nbsp;a&nbsp;strict serialisation of&nbsp;the&nbsp;<a href=\"/en-US/docs/Web/API/Document_Object_Model\">Document Object Model</a>.</p>\n\n<p></p><div class=\"row topicpage-table\" id=\"sect1\">\n    <div class=\"section\" id=\"sect2\"><dl><dl><dt <=\"\" dl=\"\" id=\"sect3\"></dt></dl></dl></div>\n    <div class=\"section\" id=\"sect4\"><dl><dt class=\"landingPageList\" id=\"xml_einführung\"><a href=\"/de/docs/Web/XML/XML_introduction\">XML_Einführung</a></dt><dd class=\"landingPageList\">XML ist eine Auszeichnungssprache ähnlich wie HTML. XML steht für <strong>Extensible Markup Language</strong> (Erweiterbare Auszeichnungssprache) und ist eine <a class=\"external\" href=\"https://www.w3.org/\" rel=\" noopener\">Standardisierte</a> Spezifikation, die für allgemeingültige Zwecke genutzt werden kann. Das bedeutet, dass, im Gegensatz zu anderen Auszeichnungssprachen, XML nicht vordefiniert ist, sodass eigene Tags definiert werden müssen. Die hauptsächliche Aufgabe der Sprache besteht darin, Daten über unterschiedliche Systeme auszutauschen, so wie im Internet.</dd></dl></div>\n    </div><p></p>"}}],"toc":[],"summary":"The Extensible Markup Language is a strict serialisation of the Document Object Model.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"XML: Extensible Markup Language","locale":"en-US","native":"English (US)"},{"title":"XML: Extensible Markup Language","locale":"es","native":"Español"},{"title":"XML: Extensible Markup Language","locale":"fr","native":"Français"},{"title":"XML: Extensible Markup Language","locale":"ja","native":"日本語"},{"title":"XML: Extensible Markup Language","locale":"ko","native":"한국어"},{"title":"XML: Rozszerzalny Język Znaczników","locale":"pl","native":"Polski"},{"title":"XML: Extensible Markup Language","locale":"ru","native":"Русский"},{"title":"XML (可扩展标记语言)","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"de/web/xml","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/xml/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/XML","title":"XML: Extensible Markup Language"}],"pageTitle":"XML: Extensible Markup Language | MDN","noIndexing":false}}