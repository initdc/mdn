ntly only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/select\"><code>&lt;select&gt;</code> <small>(en-US)</small></a></li>\n  <li class=\"webcomp\"><a href=\"/de/docs/Web/HTML/Element/Shadow\"><code>&lt;shadow&gt;</code></a></li>\n  <li class=\"html5\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/slot\"><code>&lt;slot&gt;</code> <small>(en-US)</small></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/small\"><code>&lt;small&gt;</code> <small>(en-US)</small></a></li>\n  <li class=\"html5\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/source\"><code>&lt;source&gt;</code> <small>(en-US)</small></a></li>\n  <li><s class=\"nonStdElement\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/spacer\"><code>&lt;spacer&gt;</code> <small>(en-US)</small></a></s></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/span\"><code>&lt;span&gt;</code> <small>(en-US)</small></a></li>\n  <li><s class=\"obsoleteElement deprecatedElement\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/strike\"><code>&lt;strike&gt;</code> <small>(en-US)</small></a></s></li>\n  <li><a href=\"/de/docs/Web/HTML/Element/strong\"><code>&lt;strong&gt;</code></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/style\"><code>&lt;style&gt;</code> <small>(en-US)</small></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/sub\"><code>&lt;sub&gt;</code> <small>(en-US)</small></a></li>\n  <li class=\"html5\"><a href=\"/de/docs/Web/HTML/Element/summary\"><code>&lt;summary&gt;</code></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/sup\"><code>&lt;sup&gt;</code> <small>(en-US)</small></a></li>\n </ol>\n </li><li>T\n <ol>\n  <li><a href=\"/de/docs/Web/HTML/Element/table\"><code>&lt;table&gt;</code></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/tbody\"><code>&lt;tbody&gt;</code> <small>(en-US)</small></a></li>\n  <li><a href=\"/de/docs/Web/HTML/Element/td\"><code>&lt;td&gt;</code></a></li>\n  <li class=\"webcomp\"><a href=\"/de/docs/Web/HTML/Element/template\"><code>&lt;template&gt;</code></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/textarea\"><code>&lt;textarea&gt;</code> <small>(en-US)</small></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/tfoot\"><code>&lt;tfoot&gt;</code> <small>(en-US)</small></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/th\"><code>&lt;th&gt;</code> <small>(en-US)</small></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/thead\"><code>&lt;thead&gt;</code> <small>(en-US)</small></a></li>\n  <li class=\"html5\"><a href=\"/de/docs/Web/HTML/Element/time\"><code>&lt;time&gt;</code></a></li>\n  <li><a href=\"/de/docs/Web/HTML/Element/title\"><code>&lt;title&gt;</code></a></li>\n  <li><a href=\"/de/docs/Web/HTML/Element/tr\"><code>&lt;tr&gt;</code></a></li>\n  <li class=\"html5\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/track\"><code>&lt;track&gt;</code> <small>(en-US)</small></a></li>\n  <li><s class=\"obsoleteElement\"><a href=\"/de/docs/Web/HTML/Element/tt\"><code>&lt;tt&gt;</code></a></s></li>\n </ol>\n </li><li>U\n <ol>\n  <li><a href=\"/de/docs/Web/HTML/Element/u\"><code>&lt;u&gt;</code></a></li>\n  <li><a href=\"/de/docs/Web/HTML/Element/ul\"><code>&lt;ul&gt;</code></a></li>\n </ol>\n </li><li>V\n <ol>\n  <li><a href=\"/de/docs/Web/HTML/Element/var\"><code>&lt;var&gt;</code></a></li>\n  <li class=\"html5\"><a href=\"/de/docs/Web/HTML/Element/video\"><code>&lt;video&gt;</code></a></li>\n </ol>\n </li><li>W\n <ol>\n  <li class=\"html5\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/wbr\"><code>&lt;wbr&gt;</code> <small>(en-US)</small></a></li>\n </ol>\n </li><li>X Y Z\n <ol>\n  <li><s class=\"obsoleteElement\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/xmp\"><code>&lt;xmp&gt;</code> <small>(en-US)</small></a></s></li>\n </ol>\n    </li>\n   </ol>\n   </details></li>\n   </ol>\n  ","body":[{"type":"prose","value":{"id":"summary","title":"Zusammenfassung","isH3":false,"content":"<p>Das HTML Element&nbsp;<em>line break</em> <code>&lt;br&gt;</code>&nbsp;produziert einen Zeilenumbruch in (Fließ-)Text (Wagenrücklauf). Es ist z.B nützlich beim Notieren eines Gedichtes oder einer Adresse, wo die Aufteilung der Zeilen&nbsp;von Bedeutung ist.</p>"}},{"type":"prose","value":{"id":"usage_context","title":"Gebrauch","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <td>Zulässiger Inhalt</td>\n   <td>Keiner, es handelt sich um ein \"void\" Element.</td>\n  </tr>\n  <tr>\n   <td>Tag Platzierung</td>\n   <td>Muss ein Start-Tag und darf kein Ende-Tag besitzen. In XHTML Dokumenten wird das Element als <code>&lt;br/&gt;</code> notiert.</td>\n  </tr>\n  <tr>\n   <td>Zulässige Elternelemente</td>\n   <td>Alle Elemente die <a href=\"/en-US/docs/Web/Guide/HTML/Content_categories#phrasing_content\" title=\"HTML/Content categories#phrasing content\">formulierten Inhalt</a> akzeptieren.</td>\n  </tr>\n  <tr>\n   <td>Normatives Dokument</td>\n   <td><a class=\"external\" href=\"https://www.w3.org/TR/html5/text-level-semantics.html#the-br-element\" title=\"http://www.w3.org/TR/html5/text-level-semantics.html#the-br-element\" rel=\" noopener\">HTML5, section 4.6.23</a>; <a class=\"external\" href=\"https://www.w3.org/TR/html401/struct/text.html#h-9.3.2.1\" rel=\" noopener\">HTML 4.01, section 9.3.2</a></td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"attributes","title":"Attribute","isH3":false,"content":"<p>Wie alle anderen HTML Elemente&nbsp;besitzt dieses Element die <a href=\"/en-US/docs/Web/HTML/Global_attributes\" title=\"HTML/Global attributes\">globalen Attribute</a>.</p>\n\n<dl>\n <dt id=\"clear\"><a id=\"attr-clear\" href=\"#attr-clear\"><b><code>clear</code></b></a> <span class=\"notecard inline deprecated\" title=\"\">Unerwünscht <a href=\"/de/docs/Web/HTML\">HTML4.01</a></span> <span title=\"\" class=\"notecard inline obsolete\">Veraltet seit <a href=\"/de/docs/HTML/HTML5\" class=\"page-not-created\" title=\"This is a link to an unwritten page\">HTML5</a></span></dt>\n <dd>Zeigt an, wo die nächste Zeile nach dem Zeilenumbruch beginnt.\n <div class=\"note notecard\" id=\"sect1\">\n <p><strong>Gebrauchshinweis: </strong>Dieses Attribut ist veraltet in <span class=\"badge inline html-version\"><a href=\"/de/docs/HTML/HTML5\" class=\"page-not-created\" title=\"This is a link to an unwritten page\">HTML5</a></span> und <strong>sollte nicht verwendet werden</strong>. Stattdessen sollte die CSS-Eigenschaft <a href=\"/de/docs/Web/CSS/clear\"><code>clear</code></a> verwendet werden.</p>\n </div>\n </dd>\n</dl>"}},{"type":"prose","value":{"id":"example","title":"Beispiel","isH3":false,"content":"<div class=\"code-example\"><pre class=\"brush: html notranslate\"><code>Mozilla Foundation<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>br</span><span class=\"token punctuation\">&gt;</span></span>\n1981 Landings Drive<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>br</span><span class=\"token punctuation\">&gt;</span></span>\nBuilding K<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>br</span><span class=\"token punctuation\">&gt;</span></span>\nMountain View, CA 94043-0801<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>br</span><span class=\"token punctuation\">&gt;</span></span>\nUSA\n</code></pre></div>\n\n<p>Ausgabe:</p>\n\n<p>Mozilla Foundation<br>\n 1981 Landings Drive<br>\n Building K<br>\n Mountain View, CA 94043-0801<br>\n USA</p>"}},{"type":"prose","value":{"id":"dom_interface","title":"DOM_Interface","isH3":false,"content":"<ul>\n <li><a href=\"/en-US/docs/Web/API/HTMLBRElement\" title=\"DOM/HTMLBRElement\">HTMLBRElement</a></li>\n</ul>"}},{"type":"prose","value":{"id":"notes","title":"Anmerkungen","isH3":false,"content":"<p><code>&lt;br&gt;</code> <em>nicht</em> verwenden um die Lücken zwischen Text zu vergrößern; stattdessen sollte die <a href=\"/en-US/docs/Web/CSS\" title=\"CSS\">CSS</a> <a href=\"/de/docs/Web/CSS/margin\"><code>margin</code></a> Eigenschaft oder das <a href=\"/de/docs/Web/HTML/Element/p\"><code>&lt;p&gt;</code></a> Element verwendet werden.</p>"}},{"type":"prose","value":{"id":"browser_compatibility","title":"Browser Kompatibilität","isH3":false,"content":"<p></p><div class=\"notecard note\" id=\"sect2\"><strong><a href=\"https://github.com/mdn/browser-compat-data\" class=\"external\" rel=\" noopener\">Wir konvertieren die Kompatibilitätsdaten in ein maschinenlesbares JSON Format</a></strong>.\n            Diese Kompatibilitätstabelle liegt noch im alten Format vor,\n            denn die darin enthaltenen Daten wurden noch nicht konvertiert.\n            <strong><a href=\"/en-US/docs/MDN/Structures/Compatibility_tables\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">Finde heraus wie du helfen kannst! (en-US)</a></strong></div>\n\n<div class=\"htab\" id=\"sect3\">\n    <a id=\"AutoCompatibilityTable\" name=\"AutoCompatibilityTable\"></a>\n    <ul>\n        <li class=\"selected\"><a href=\"#compat-desktop\">Desktop</a></li>\n        <li><a href=\"#compat-mobile\">Mobile</a></li>\n    </ul>\n</div><p></p>\n\n<div id=\"compat-desktop\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Chrome</th>\n   <th>Firefox (Gecko)</th>\n   <th>Internet Explorer</th>\n   <th>Opera</th>\n   <th>Safari (WebKit)</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td>1.0</td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<div id=\"compat-mobile\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Android</th>\n   <th>Firefox Mobile (Gecko)</th>\n   <th>IE Phone</th>\n   <th>Opera Mobile</th>\n   <th>Safari Mobile</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n  </tr>\n </tbody>\n</table>\n</div>"}},{"type":"prose","value":{"id":"see_also","title":"Siehe auch","isH3":false,"content":"<ul>\n <li><a href=\"/de/docs/Web/HTML/Element/address\"><code>&lt;address&gt;</code></a> element</li>\n <li><a href=\"/de/docs/Web/HTML/Element/p\"><code>&lt;p&gt;</code></a> element</li>\n</ul>\n\n<div id=\"sect4\"></div>"}}],"toc":[{"text":"Zusammenfassung","id":"summary"},{"text":"Gebrauch","id":"usage_context"},{"text":"Attribute","id":"attributes"},{"text":"Beispiel","id":"example"},{"text":"DOM_Interface","id":"dom_interface"},{"text":"Anmerkungen","id":"notes"},{"text":"Browser Kompatibilität","id":"browser_compatibility"},{"text":"Siehe auch","id":"see_also"}],"summary":"Das HTML Element line break <br> produziert einen Zeilenumbruch in (Fließ-)Text (Wagenrücklauf). Es ist z.B nützlich beim Notieren eines Gedichtes oder einer Adresse, wo die Aufteilung der Zeilen von Bedeutung ist.","popularity":0.0017,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"<br>: The Line Break element","locale":"en-US","native":"English (US)"},{"title":"<br>","locale":"es","native":"Español"},{"title":"<br> : l'élément de saut de ligne","locale":"fr","native":"Français"},{"title":"<br>: 改行要素","locale":"ja","native":"日本語"},{"title":"<br>: 줄바꿈 요소","locale":"ko","native":"한국어"},{"title":"br","locale":"pl","native":"Polski"},{"title":"<br>","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"<br>","locale":"ru","native":"Русский"},{"title":"<br>","locale":"zh-CN","native":"中文 (简体)"},{"title":"<br>（斷行元素）","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"de/web/html/element/br","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/html/element/br/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/HTML","title":"HTML: HyperText Markup Language"},{"uri":"/de/docs/Web/HTML/Element","title":"Element"},{"uri":"/de/docs/Web/HTML/Element/br","title":"<br>"}],"pageTitle":"<br> - HTML: HyperText Markup Language | MDN","noIndexing":false}}