eb/HTML/Element/sub\"><code>&lt;sub&gt;</code> <small>(en-US)</small></a></li>\n  <li class=\"html5\"><a href=\"/de/docs/Web/HTML/Element/summary\"><code>&lt;summary&gt;</code></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/sup\"><code>&lt;sup&gt;</code> <small>(en-US)</small></a></li>\n </ol>\n </li><li>T\n <ol>\n  <li><a href=\"/de/docs/Web/HTML/Element/table\"><code>&lt;table&gt;</code></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/tbody\"><code>&lt;tbody&gt;</code> <small>(en-US)</small></a></li>\n  <li><a href=\"/de/docs/Web/HTML/Element/td\"><code>&lt;td&gt;</code></a></li>\n  <li class=\"webcomp\"><a href=\"/de/docs/Web/HTML/Element/template\"><code>&lt;template&gt;</code></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/textarea\"><code>&lt;textarea&gt;</code> <small>(en-US)</small></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/tfoot\"><code>&lt;tfoot&gt;</code> <small>(en-US)</small></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/th\"><code>&lt;th&gt;</code> <small>(en-US)</small></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/thead\"><code>&lt;thead&gt;</code> <small>(en-US)</small></a></li>\n  <li class=\"html5\"><a href=\"/de/docs/Web/HTML/Element/time\"><code>&lt;time&gt;</code></a></li>\n  <li><a href=\"/de/docs/Web/HTML/Element/title\"><code>&lt;title&gt;</code></a></li>\n  <li><a href=\"/de/docs/Web/HTML/Element/tr\"><code>&lt;tr&gt;</code></a></li>\n  <li class=\"html5\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/track\"><code>&lt;track&gt;</code> <small>(en-US)</small></a></li>\n  <li><s class=\"obsoleteElement\"><a href=\"/de/docs/Web/HTML/Element/tt\"><code>&lt;tt&gt;</code></a></s></li>\n </ol>\n </li><li>U\n <ol>\n  <li><a href=\"/de/docs/Web/HTML/Element/u\"><code>&lt;u&gt;</code></a></li>\n  <li><a href=\"/de/docs/Web/HTML/Element/ul\"><code>&lt;ul&gt;</code></a></li>\n </ol>\n </li><li>V\n <ol>\n  <li><a href=\"/de/docs/Web/HTML/Element/var\"><code>&lt;var&gt;</code></a></li>\n  <li class=\"html5\"><a href=\"/de/docs/Web/HTML/Element/video\"><code>&lt;video&gt;</code></a></li>\n </ol>\n </li><li>W\n <ol>\n  <li class=\"html5\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/wbr\"><code>&lt;wbr&gt;</code> <small>(en-US)</small></a></li>\n </ol>\n </li><li>X Y Z\n <ol>\n  <li><s class=\"obsoleteElement\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/xmp\"><code>&lt;xmp&gt;</code> <small>(en-US)</small></a></s></li>\n </ol>\n    </li>\n   </ol>\n   </details></li>\n   </ol>\n  ","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p><span class=\"seoSummary\">The <strong>HTML <code>&lt;td&gt;</code>&nbsp;Element</strong> definiert eine Zelle in einer Datentabelle. Es ist Teil des &nbsp;<em>table model</em>.</span></p>\n\n<div id=\"sect2\"><iframe class=\"interactive\" height=\"655\" src=\"https://interactive-examples.mdn.mozilla.net/pages/tabbed/td.html\" title=\"MDN Web Docs Interactive Example\" loading=\"lazy\"></iframe></div>\n\n<p class=\"hidden\">The source for this interactive example is stored in a GitHub repository. If you'd like to contribute to the interactive examples project, please clone <a href=\"https://github.com/mdn/interactive-examples\" class=\"external\" rel=\" noopener\">https://github.com/mdn/interactive-examples </a> and send us a pull request.</p>\n\n<table class=\"properties\">\n <tbody>\n  <tr>\n   <th scope=\"row\"><a href=\"/en-US/docs/Web/Guide/HTML/Content_categories\">Content categories</a></th>\n   <td>Sectioning root.</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">Erlaubter Inhalt</th>\n   <td><a href=\"/en-US/docs/Web/Guide/HTML/Content_categories#flow_content\">Flow content</a>.</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">Tag Wegfall</th>\n   <td>Der Start-Tag ist erforderlich.<br>\n    Der Ende Tag kann weggelassen werden, wenn direkt ein <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/th\"><code>&lt;th&gt;</code> <small>(en-US)</small></a>&nbsp; oder&nbsp; ein <a href=\"/de/docs/Web/HTML/Element/td\" aria-current=\"page\"><code>&lt;td&gt;</code></a> folgt oder wenn in seinem 'parent element' keine weiteren Daten enthalten sind.</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">Erlaubte parents</th>\n   <td>Ein <a href=\"/de/docs/Web/HTML/Element/tr\"><code>&lt;tr&gt;</code></a> Element.</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">Erlaubte ARIA Funktionen</th>\n   <td>Alle</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">DOM Interface</th>\n   <td><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/HTMLTableCellElement\"><code>HTMLTableDataCellElement</code> <small>(en-US)</small></a></td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"eigenschaften","title":"Eigenschaften","isH3":false,"content":"<p>Dieses Element enthält die&nbsp;<a href=\"/en-US/docs/Web/HTML/Global_attributes\">global&nbsp;attributes</a>.</p>\n\n<dl>\n <dt id=\"abbr\"><a id=\"attr-abbr\" href=\"#attr-abbr\"><b><code>abbr</code></b></a> <span title=\"\" class=\"notecard inline obsolete\">Veraltet seit <a href=\"/de/docs/HTML/HTML5\" class=\"page-not-created\" title=\"This is a link to an unwritten page\">HTML5</a></span></dt>\n <dd>Dieses Attribut&nbsp;enthält eine Kurzbeschreibung des Inhalts der Zelle.&nbsp;Einige user-agents, wie z.B Sparchausgabe Apps, können diese Beschreibung vor dem Inhalt selbst anzeigen.\n <div class=\"note notecard\" id=\"sect3\"><strong>Hinweis:</strong>&nbsp;Verwenden Sie diese Eigenschaft nicht mehr, da&nbsp;sie von dem neuesten Standard nicht mehr unterstützt wird. Alternativ können Sie die Kurzbeschreibung in die Zelle selbst stellen und den vollständigen Inhalt in die <strong>title</strong>-Eigenschaft schreiben.</div>\n </dd>\n <dt id=\"align\"><a id=\"attr-align\" href=\"#attr-align\"><b><code>align</code></b></a> <span title=\"\" class=\"notecard inline obsolete\">Veraltet seit <a href=\"/de/docs/HTML/HTML5\" class=\"page-not-created\" title=\"This is a link to an unwritten page\">HTML5</a></span></dt>\n <dd>Diese Listen Attribute legen fest, we der Zellinhalt waagerecht ausgerichtet wird.&nbsp;Mögliche Werte sind:\n <ul>\n  <li><code>left</code>: Der Inhalt wird links in der Zelle ausgerichtet.</li>\n  <li><code>center</code>: Der inhalt wird innerhalb der Zelle zentriert.</li>\n  <li><code>right</code>: Der Inhalt wird innerhalb der Zelle rechts ausgerichtet.</li>\n  <li><code>justify</code> (nur bei Text): Der Inhalt wird über die gesamte Breite der Zelle gedehnt.</li>\n  <li><code>char</code> (nur bei Text):&nbsp; Der Inhalt wird mit minimalem Offset an einem Zeichen innerhalb der des&nbsp;&nbsp;<code>&lt;th&gt;</code>&nbsp;Elementes ausgerichtet.&nbsp;Das Zeichen wird durch die <a href=\"/de/docs/Web/HTML/Element/td#attr-char\" aria-current=\"page\"><code>char</code></a>&nbsp; und&nbsp; <a href=\"/de/docs/Web/HTML/Element/td#attr-charoff\" aria-current=\"page\"><code>charoff</code></a> definiert. <span class=\"notecard inline warning\">Nicht implementiert (siehe <a href=\"https://bugzilla.mozilla.org/show_bug.cgi?id=2212\" class=\"external\" rel=\" noopener\">Bug&nbsp;2212</a>)</span>.</li>\n </ul>\n\n <p>Der Default Wert, wenn das Attribut nicht spezifiziert wird ist&nbsp;<code>left</code>.</p>\n\n <div class=\"note notecard\" id=\"sect4\"><strong>Hinweis: </strong>Verwenden Sie diese Eigenschaft nicht mehr, da&nbsp;sie von dem neuesten Standard nicht mehr unterstützt wird.\n\n <ul>\n  <li>Um den gleichen Effekt wie mit den&nbsp;&nbsp;<code>left</code>, <code>center</code>, <code>right</code> oder&nbsp;<code>justify</code> Werten zu erhalten, verwenden Sie die CSS <a href=\"/de/docs/Web/CSS/text-align\"><code>text-align</code></a> Eigenschaft für dieses Element.</li>\n  <li>Um den gleichen Effekt wie bei dem&nbsp;<code>char</code>&nbsp;Wert zu erzielen, geben Sie der&nbsp;<a href=\"/de/docs/Web/CSS/text-align\"><code>text-align</code></a> Eigenschaft die gleichen Werte, die Sie auch für das <a href=\"/de/docs/Web/HTML/Element/td#attr-char\" aria-current=\"page\"><code>char</code></a> Attribut verwendet hätten.<br>\n   <span class=\"notecard inline warning\">Nicht implementiert</span> in CSS3.</li>\n </ul>\n </div>\n </dd>\n <dt id=\"axis\"><a id=\"attr-axis\" href=\"#attr-axis\"><b><code>axis</code></b></a> <span title=\"\" class=\"notecard inline obsolete\">Veraltet seit <a href=\"/de/docs/HTML/HTML5\" class=\"page-not-created\" title=\"This is a link to an unwritten page\">HTML5</a></span></dt>\n <dd>&nbsp;Dieses Attribute enthält eine Liste von strings, durch Leerzeichen getrennt. Jeder String ist die&nbsp;<code>id</code>&nbsp; einer Gruppe von Zellen, die diesen Text als Header enthalten.\n <div class=\"note notecard\" id=\"sect5\"><strong>Hinweis:</strong> Verwenden Sie diese Eigenschaft nicht mehr, da&nbsp;sie von dem neuesten Standard nicht mehr unterstützt wird.</div>\n </dd>\n <dt id=\"bgcolor\"><a id=\"attr-bgcolor\" href=\"#attr-bgcolor\"><b><code>bgcolor</code></b></a> <svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg></dt>\n <dd>Dieses Attribut definiert die Hintergrundfarbe jeder Zelle in einer Spalte. Es enthält einen 6-stelligen Hexadezimal-Code in&nbsp;<a href=\"https://www.w3.org/Graphics/Color/sRGB\" class=\"external\" rel=\" noopener\">sRGB</a>&nbsp;definiert mit einem vorangestellten '#'. Für dieses Attribut&nbsp;sind die folgenden 16 Werte mit string-Werten vordefiniert:\n <table>\n  <tbody>\n   <tr>\n    <td style=\"background-color: black; width: 24px; height: 24px; border: 1px solid black;\"></td>\n    <td><code>black</code> = \"#000000\"</td>\n    <td style=\"background-color: green; width: 24px; height: 24px; border: 1px solid black;\"></td>\n    <td><code>green</code> = \"#008000\"</td>\n   </tr>\n   <tr>\n    <td style=\"background-color: silver; width: 24px; height: 24px; border: 1px solid black;\"></td>\n    <td><code>silver</code> = \"#C0C0C0\"</td>\n    <td style=\"background-color: lime; width: 24px; height: 24px; border: 1px solid black;\"></td>\n    <td><code>lime</code> = \"#00FF00\"</td>\n   </tr>\n   <tr>\n    <td style=\"background-color: gray; width: 24px; height: 24px; border: 1px solid black;\"></td>\n    <td><code>gray</code> = \"#808080\"</td>\n    <td style=\"background-color: olive; width: 24px; height: 24px; border: 1px solid black;\"></td>\n    <td><code>olive</code> = \"#808000\"</td>\n   </tr>\n   <tr>\n    <td style=\"background-color: white; width: 24px; height: 24px; border: 1px solid black;\"></td>\n    <td><code>white</code> = \"#FFFFFF\"</td>\n    <td style=\"background-color: yellow; width: 24px; height: 24px; border: 1px solid black;\"></td>\n    <td><code>yellow</code> = \"#FFFF00\"</td>\n   </tr>\n   <tr>\n    <td style=\"background-color: maroon; width: 24px; height: 24px; border: 1px solid black;\"></td>\n    <td><code>maroon</code> = \"#800000\"</td>\n    <td style=\"background-color: navy; width: 24px; height: 24px; border: 1px solid black;\"></td>\n    <td><code>navy</code> = \"#000080\"</td>\n   </tr>\n   <tr>\n    <td style=\"background-color: red; width: 24px; height: 24px; border: 1px solid black;\"></td>\n    <td><code>red</code> = \"#FF0000\"</td>\n    <td style=\"background-color: blue; width: 24px; height: 24px; border: 1px solid black;\"></td>\n    <td><code>blue</code> = \"#0000FF\"</td>\n   </tr>\n   <tr>\n    <td style=\"background-color: purple; width: 24px; height: 24px; border: 1px solid black;\"></td>\n    <td><code>purple</code> = \"#800080\"</td>\n    <td style=\"background-color: teal; width: 24px; height: 24px; border: 1px solid black;\"></td>\n    <td><code>teal</code> = \"#008080\"</td>\n   </tr>\n   <tr>\n    <td style=\"background-color: fuchsia; width: 24px; height: 24px; border: 1px solid black;\"></td>\n    <td><code>fuchsia</code> = \"#FF00FF\"</td>\n    <td style=\"background-color: aqua; width: 24px; height: 24px; border: 1px solid black;\"></td>\n    <td><code>aqua</code> = \"#00FFFF\"</td>\n   </tr>\n  </tbody>\n </table>\n\n <div class=\"note notecard\" id=\"sect6\"><strong>Hinweis:</strong> Verwnden Sie dieses Attribut nicht, da es kein Standard ist und nur in einigen Versionen des&nbsp;Microsoft Internet Explorers implementiert ist: Das <a href=\"/de/docs/Web/HTML/Element/td\" aria-current=\"page\"><code>&lt;td&gt;</code></a> Element sollte mittels&nbsp;<a href=\"/en-US/docs/Web/CSS\">CSS</a>&nbsp;formatiert&nbsp;werden Um den gleichen Effekt zu erhalten verwenden Sie stattdessen die <a href=\"/de/docs/Web/CSS/background-color\"><code>background-color</code></a> Eigenschaft in <a href=\"/en-US/docs/Web/CSS\">CSS</a>.</div>\n </dd>\n</dl>\n\n<dl>\n <dt id=\"char\"><a id=\"attr-char\" href=\"#attr-char\"><b><code>char</code></b></a> <span title=\"\" class=\"notecard inline obsolete\">Veraltet seit <a href=\"/de/docs/HTML/HTML5\" class=\"page-not-created\" title=\"This is a link to an unwritten page\">HTML5</a></span></dt>\n <dd>&nbsp;Der Inhalt der Zelle wird an einem Zeichen ausgerichtet. Typische Zeichen sind ein (.) oder (,) um Währungswerte auszurichten. Wenn <a href=\"/de/docs/Web/HTML/Element/td#attr-align\" aria-current=\"page\"><code>align</code></a> nicht als&nbsp;<code>char</code>, gesetzt ist, wird dieses Attribute&nbsp;ignoriert\n <div class=\"note notecard\" id=\"sect7\"><strong>Hinweis:&nbsp;</strong>&nbsp;Verwenden Sie diese Eigenschaft nicht mehr, da&nbsp;sie von dem neuesten Standard nicht mehr unterstützt wird.&nbsp; Um den gleichen Effekt zu erzielen können Sie das Zeichen auch als ersten Wert der&nbsp;<a href=\"/de/docs/Web/CSS/text-align\"><code>text-align</code></a> Eigenschaft definieren.&nbsp;<br>\n <span class=\"notecard inline warning\">Nicht implementiert</span> in CSS3.</div>\n </dd>\n <dt id=\"charoff\"><a id=\"attr-charoff\" href=\"#attr-charoff\"><b><code>charoff</code></b></a> <span title=\"\" class=\"notecard inline obsolete\">Veraltet seit <a href=\"/de/docs/HTML/HTML5\" class=\"page-not-created\" title=\"This is a link to an unwritten page\">HTML5</a></span></dt>\n <dd>Dieses Attribut&nbsp;wird verwendet um die Daten einer Spalte rechts von dem Zeichen auszurichten, das durch das&nbsp;<strong>char</strong>&nbsp;Attribut spezifiziert wurde. Sein Wert spezifiziert die Anzahl der Zeichen um die die Daten nach rechts verschoben werden.\n <div class=\"note notecard\" id=\"sect8\"><strong>Hinweis: </strong>Verwenden Sie diese Eigenschaft nicht mehr, da&nbsp;sie von dem neuesten Standard nicht mehr unterstützt wird.</div>\n </dd>\n <dt id=\"colspan\"><a id=\"attr-colspan\" href=\"#attr-colspan\"><b><code>colspan</code></b></a></dt>\n <dd>Dieses Attribut enhält eine&nbsp;nicht negative ganze Zahl, die festlegt über wieviele Spalten einer Tabelle sich diese Zelle erstreckt. Der Default-Wert ist&nbsp;<code>1</code>. Größere Werte als&nbsp;1000 werden nicht akzeptiert und auf den Default-Wert zurückgesetzt (1).</dd>\n <dt id=\"headers\"><a id=\"attr-headers\" href=\"#attr-headers\"><b><code>headers</code></b></a></dt>\n <dd>Diese Attribut enthält eine durch Leerzeichen getrennte Liste von Strings, von denen jeder mit dem <strong>id</strong>&nbsp;Attribut des&nbsp;<a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/th\"><code>&lt;th&gt;</code> <small>(en-US)</small></a> Elementes korrespondiert.</dd>\n <dt id=\"height\"><a id=\"attr-height\" href=\"#attr-height\"><b><code>height</code></b></a> <span class=\"notecard inline deprecated\" title=\"\">Unerwünscht <a href=\"/de/docs/Web/HTML\">HTML4</a></span>, <span title=\"\" class=\"notecard inline obsolete\">Veraltet seit <a href=\"/de/docs/HTML/HTML5\" class=\"page-not-created\" title=\"This is a link to an unwritten page\">HTML5</a></span></dt>\n <dd>Dieses Attribut&nbsp;wird verwendet um die Höhe einer Zelle festzulegen.\n <div class=\"note notecard\" id=\"sect9\"><strong>Hinweis:</strong> DVerwenden Sie diese Eigenschaft nicht mehr, da&nbsp;sie von dem neuesten Standard nicht mehr unterstützt wird.&nbsp;Verwenden Sie stattdessen die&nbsp; <a href=\"/de/docs/Web/CSS/height\"><code>height</code></a> Eigenschaft.</div>\n </dd>\n <dt id=\"rowspan\"><a id=\"attr-rowspan\" href=\"#attr-rowspan\"><b><code>rowspan</code></b></a></dt>\n <dd>Dieses Attribut enthält einen nicht negativen ganzahligen Integer Wert, der festlegt, über wieviele Reihen sich eine Zelle erstreckt. Der Default-Wert ist&nbsp;<code>1</code>; wenn der Wert auf&nbsp;<code>0</code>&nbsp; gesetzt wird, erstreckt sich die Größe der Zelle über den Rest der Tabelle zu der die Zelle gehört&nbsp;auch wenn die Attribute&nbsp;(<a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/thead\"><code>&lt;thead&gt;</code> <small>(en-US)</small></a>, <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/tbody\"><code>&lt;tbody&gt;</code> <small>(en-US)</small></a>, <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/tfoot\"><code>&lt;tfoot&gt;</code> <small>(en-US)</small></a>), implizit definiert sind. Werte über&nbsp;65534 werden auf 65534 gesetzt.</dd>\n <dt id=\"scope\"><a id=\"attr-scope\" href=\"#attr-scope\"><b><code>scope</code></b></a> <span title=\"\" class=\"notecard inline obsolete\">Veraltet seit <a href=\"/de/docs/HTML/HTML5\" class=\"page-not-created\" title=\"This is a link to an unwritten page\">HTML5</a></span></dt>\n <dd>Dieses Listen Attribut definiert die Zellen, auf die sich das Header-Element bezieht,&nbsp;dass in dem <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/th\"><code>&lt;th&gt;</code> <small>(en-US)</small></a> Element, definiert wurde.\n <div class=\"note notecard\" id=\"sect10\"><strong>Hinweis:</strong> Verwenden Sie diese Eigenschaft nicht mehr, da&nbsp;sie von dem neuesten Standard nicht mehr unterstützt wird. Verwenden Sie diesesAttributenur mit dem&nbsp; <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/th\"><code>&lt;th&gt;</code> <small>(en-US)</small></a> Element um eine Reihe oder eine Spalte für die dieses der Header ist zu definieren.</div>\n </dd>\n <dt id=\"valign\"><a id=\"attr-valign\" href=\"#attr-valign\"><b><code>valign</code></b></a> <span title=\"\" class=\"notecard inline obsolete\">Veraltet seit <a href=\"/de/docs/HTML/HTML5\" class=\"page-not-created\" title=\"This is a link to an unwritten page\">HTML5</a></span></dt>\n <dd>Dieses Attribut legt fest, wie ein Text vertikal innerhalb einer Zelle ausgerichtet ist. Mögliche Werte für dieses Attribut sind:\n <ul>\n  <li><code>baseline</code>: Positioniert den Text mit der&nbsp;<a href=\"https://en.wikipedia.org/wiki/Baseline_%28typography%29\" class=\"external\" rel=\" noopener\">baseline</a>&nbsp;der Zeichen am unteren Rand&nbsp;der aus und nicht mit dem&nbsp;unteren Ende der Zeichen. Gibt es keine Zeichen mit Anhängen unterhalb der Zeichengrundlinie, so hat dieser Wert den gleichen Effekt wie&nbsp;<code>bottom</code>.</li>\n  <li><code>bottom</code>: Positioniert den Text am unteren Rand&nbsp;in der Zelle</li>\n  <li><code>middle</code>: Zentriert den Text vertikal in der Zelle.</li>\n  <li>and <code>top</code>: Positioniert den Text am oberen Rand der Zelle.</li>\n </ul>\n\n <div class=\"note notecard\" id=\"sect11\"><strong>Hinweis:</strong> Verwenden Sie diese Eigenschaft nicht mehr, da&nbsp;sie von dem neuesten Standard nicht mehr unterstützt wird.&nbsp;<br>\n Verwenden Sie stattdessen die&nbsp;CSS <a href=\"/de/docs/Web/CSS/vertical-align\"><code>vertical-align</code></a> Eigenschaft.</div>\n </dd>\n <dt id=\"width\"><a id=\"attr-width\" href=\"#attr-width\"><b><code>width</code></b></a> <span class=\"notecard inline deprecated\" title=\"\">Unerwünscht <a href=\"/de/docs/Web/HTML\">HTML4</a></span>, <span title=\"\" class=\"notecard inline obsolete\">Veraltet seit <a href=\"/de/docs/HTML/HTML5\" class=\"page-not-created\" title=\"This is a link to an unwritten page\">HTML5</a></span></dt>\n <dd>Dieses Attribut defieniert die benötigte Breite der Zelle.&nbsp; Zusätzlicher Platz kann mit Hilfe der&nbsp;<a href=\"/en-US/docs/Web/API/HTMLTableElement/cellSpacing\">cellspacing</a> and <a href=\"/en-US/docs/Web/API/HTMLTableElement/cellPadding\">cellpadding</a> Eigenschaftenerreicht werden. Mit Hilfe des&nbsp;<a href=\"/de/docs/Web/HTML/Element/col\"><code>&lt;col&gt;</code></a> Elementes kann ebenfalls zusätzliche Breite erzeugt werden. Allerdings wird eine Zelle, die zu schmal für die passende Darstellung ihres Inhaltes, bei der Darstellung automatisch auf die richtige Breite&nbsp;erweitert.\n <div class=\"note notecard\" id=\"sect12\"><strong>Note:</strong> Verwenden Sie diese Eigenschaft nicht mehr, da&nbsp;sie von dem neuesten Standard nicht mehr unterstützt wird.&nbsp;<br>\n Verwenden Sie stattdessen die&nbsp;CSS <a href=\"/de/docs/Web/CSS/width\"><code>width</code></a> Eigenschaft.</div>\n </dd>\n</dl>"}},{"type":"prose","value":{"id":"beispiele","title":"Beispiele","isH3":false,"content":"<p>Siehe <a href=\"/de/docs/Web/HTML/Element/table\"><code>&lt;table&gt;</code></a> für Beispiele für&nbsp;<code>&lt;td&gt;</code>.</p>"}},{"type":"prose","value":{"id":"spezifikationen","title":"Spezifikationen","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">Specification</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Comment</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"https://html.spec.whatwg.org/multipage/tables.html#the-td-element\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML Living Standard<br><small lang=\"de\">Die Definition von 'td element' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-living\">Lebender Standard</span></td>\n   <td></td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.w3.org/TR/html52/tabular-data.html#the-td-element\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML5<br><small lang=\"de\">Die Definition von 'td element' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-rec\">Empfehlung</span></td>\n   <td></td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"Browser Kompatibilität","id":"browser_kompatibilität","isH3":false,"query":"html.elements.td","dataURL":"/de/docs/Web/HTML/Element/td/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"sieh_auch","title":"Sieh auch","isH3":false,"content":"<ul>\n <li>Other table-related HTML Elements: <a href=\"/de/docs/Web/HTML/Element/caption\"><code>&lt;caption&gt;</code></a>, <a href=\"/de/docs/Web/HTML/Element/col\"><code>&lt;col&gt;</code></a>, <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/colgroup\"><code>&lt;colgroup&gt;</code> <small>(en-US)</small></a>, <a href=\"/de/docs/Web/HTML/Element/table\"><code>&lt;table&gt;</code></a>, <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/tbody\"><code>&lt;tbody&gt;</code> <small>(en-US)</small></a>, <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/tfoot\"><code>&lt;tfoot&gt;</code> <small>(en-US)</small></a>, <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/th\"><code>&lt;th&gt;</code> <small>(en-US)</small></a>, <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/thead\"><code>&lt;thead&gt;</code> <small>(en-US)</small></a>, <a href=\"/de/docs/Web/HTML/Element/tr\"><code>&lt;tr&gt;</code></a>.</li>\n</ul>"}}],"toc":[{"text":"Eigenschaften","id":"eigenschaften"},{"text":"Beispiele","id":"beispiele"},{"text":"Spezifikationen","id":"spezifikationen"},{"text":"Browser Kompatibilität","id":"browser_kompatibilität"},{"text":"Sieh auch","id":"sieh_auch"}],"summary":"The HTML <td> Element definiert eine Zelle in einer Datentabelle. Es ist Teil des  table model.","popularity":0.0007,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"<td>: The Table Data Cell element","locale":"en-US","native":"English (US)"},{"title":"<td>","locale":"es","native":"Español"},{"title":"<td> : l'élément de cellule de tableau","locale":"fr","native":"Français"},{"title":"<td>: 表データセル要素","locale":"ja","native":"日本語"},{"title":"<td>","locale":"ko","native":"한국어"},{"title":"<td>: элемент ячейки таблицы данных","locale":"ru","native":"Русский"},{"title":"<td>：表格数据单元格元素","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"de/web/html/element/td","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/html/element/td/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/HTML","title":"HTML: HyperText M