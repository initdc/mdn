Element/section\"><code>&lt;section&gt;</code></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/select\"><code>&lt;select&gt;</code> <small>(en-US)</small></a></li>\n  <li class=\"webcomp\"><a href=\"/de/docs/Web/HTML/Element/Shadow\"><code>&lt;shadow&gt;</code></a></li>\n  <li class=\"html5\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/slot\"><code>&lt;slot&gt;</code> <small>(en-US)</small></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/small\"><code>&lt;small&gt;</code> <small>(en-US)</small></a></li>\n  <li class=\"html5\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/source\"><code>&lt;source&gt;</code> <small>(en-US)</small></a></li>\n  <li><s class=\"nonStdElement\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/spacer\"><code>&lt;spacer&gt;</code> <small>(en-US)</small></a></s></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/span\"><code>&lt;span&gt;</code> <small>(en-US)</small></a></li>\n  <li><s class=\"obsoleteElement deprecatedElement\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/strike\"><code>&lt;strike&gt;</code> <small>(en-US)</small></a></s></li>\n  <li><a href=\"/de/docs/Web/HTML/Element/strong\"><code>&lt;strong&gt;</code></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/style\"><code>&lt;style&gt;</code> <small>(en-US)</small></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/sub\"><code>&lt;sub&gt;</code> <small>(en-US)</small></a></li>\n  <li class=\"html5\"><a href=\"/de/docs/Web/HTML/Element/summary\"><code>&lt;summary&gt;</code></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/sup\"><code>&lt;sup&gt;</code> <small>(en-US)</small></a></li>\n </ol>\n </li><li>T\n <ol>\n  <li><a href=\"/de/docs/Web/HTML/Element/table\"><code>&lt;table&gt;</code></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/tbody\"><code>&lt;tbody&gt;</code> <small>(en-US)</small></a></li>\n  <li><a href=\"/de/docs/Web/HTML/Element/td\"><code>&lt;td&gt;</code></a></li>\n  <li class=\"webcomp\"><a href=\"/de/docs/Web/HTML/Element/template\"><code>&lt;template&gt;</code></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/textarea\"><code>&lt;textarea&gt;</code> <small>(en-US)</small></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/tfoot\"><code>&lt;tfoot&gt;</code> <small>(en-US)</small></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/th\"><code>&lt;th&gt;</code> <small>(en-US)</small></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/thead\"><code>&lt;thead&gt;</code> <small>(en-US)</small></a></li>\n  <li class=\"html5\"><a href=\"/de/docs/Web/HTML/Element/time\"><code>&lt;time&gt;</code></a></li>\n  <li><a href=\"/de/docs/Web/HTML/Element/title\"><code>&lt;title&gt;</code></a></li>\n  <li><a href=\"/de/docs/Web/HTML/Element/tr\"><code>&lt;tr&gt;</code></a></li>\n  <li class=\"html5\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/track\"><code>&lt;track&gt;</code> <small>(en-US)</small></a></li>\n  <li><s class=\"obsoleteElement\"><a href=\"/de/docs/Web/HTML/Element/tt\"><code>&lt;tt&gt;</code></a></s></li>\n </ol>\n </li><li>U\n <ol>\n  <li><a href=\"/de/docs/Web/HTML/Element/u\"><code>&lt;u&gt;</code></a></li>\n  <li><a href=\"/de/docs/Web/HTML/Element/ul\"><code>&lt;ul&gt;</code></a></li>\n </ol>\n </li><li>V\n <ol>\n  <li><a href=\"/de/docs/Web/HTML/Element/var\"><code>&lt;var&gt;</code></a></li>\n  <li class=\"html5\"><a href=\"/de/docs/Web/HTML/Element/video\"><code>&lt;video&gt;</code></a></li>\n </ol>\n </li><li>W\n <ol>\n  <li class=\"html5\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/wbr\"><code>&lt;wbr&gt;</code> <small>(en-US)</small></a></li>\n </ol>\n </li><li>X Y Z\n <ol>\n  <li><s class=\"obsoleteElement\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/xmp\"><code>&lt;xmp&gt;</code> <small>(en-US)</small></a></s></li>\n </ol>\n    </li>\n   </ol>\n   </details></li>\n   </ol>\n  ","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p>Das <strong>HTML <code>&lt;time&gt;</code>-Element</strong> repräsentiert entweder Zeitangaben im 24-Stunden-Format oder ein präzises Datum im <a href=\"http://de.wikipedia.org/wiki/Gregorianischer_Kalender\" class=\"external\" rel=\" noopener\">gregorianischen Kalender</a> (mit optionalen Zeit- und Zeitzonen-Informationen).</p>\n\n<p>Dieses Element erlaubt es, Daten und Zeiten in einem maschinell lesbaren Format darzustellen. Dies kann hilfreich für User Agents sein, die eine beliebige Art der Terminplanung für den Kalender des Benutzers anbieten.</p>\n\n<div class=\"note notecard\" id=\"sect1\"><strong>Hinweis zur Verwendung: </strong>Dieses Element ist nicht geeignet, wenn ein genaues Datum nicht berechnet werden kann oder das Datum vor der Einführung des gregorianischen Kalenders liegt (aufgrund von Schwierigkeiten, diese Daten zu berechnen).</div>\n\n<table class=\"properties\">\n <tbody>\n  <tr>\n   <th scope=\"row\"><a href=\"/en-US/docs/Web/Guide/HTML/Content_categories\" title=\"HTML/Content_categories\">Content categories</a></th>\n   <td><a href=\"/en-US/docs/Web/Guide/HTML/Content_categories#flow_content\" title=\"HTML/Content_categories#Flow_content\">Flow content</a>, <a href=\"/en-US/docs/Web/Guide/HTML/Content_categories#phrasing_content\" title=\"HTML/Content categories#Phrasing content\">phrasing content</a>, palpable content.</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">Permitted content</th>\n   <td><a href=\"/en-US/docs/Web/Guide/HTML/Content_categories#phrasing_content\" title=\"HTML/Content categories#Phrasing content\">Phrasing content</a>, aber keine verschachtelten <code>time</code>-Elemente.</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">Tag omission</th>\n   <td>Keine; sowohl End- als auch Starttag sind Pflicht.</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">Permitted parent elements</th>\n   <td>Jedes Element, das <a href=\"/en-US/docs/Web/Guide/HTML/Content_categories#phrasing_content\" title=\"HTML/Content categories#Phrasing content\">phrasing content</a> akzeptiert.</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">DOM interface</th>\n   <td><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/HTMLTimeElement\"><code>HTMLTimeElement</code> <small>(en-US)</small></a></td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"attribute","title":"Attribute","isH3":false,"content":"<p>Wie alle anderen HTML-Elemente, unterstützt dieses Element <a href=\"/en-US/docs/Web/HTML/Global_attributes\">globale Attribute</a>.</p>\n\n<dl>\n <dt id=\"datetime\"><a id=\"attr-datetime\" href=\"#attr-datetime\"><b><code>datetime</code></b></a></dt>\n <dd>Dieses Attribut gibt Zeit und Datum des Elements an und muss ein <a href=\"https://www.w3.org/TR/html-markup/datatypes.html#common.data.datetime\" class=\"external\" rel=\" noopener\">gültiges Datum mit optionalem Zeit-String</a> sein. Wenn der Wert nicht als Datum mit optionalem Zeit-String geparst werden kann, wird diesem Element kein gültiger Zeitstempel zugeordnet.</dd>\n</dl>"}},{"type":"prose","value":{"id":"beispiele","title":"Beispiele","isH3":false,"content":""}},{"type":"prose","value":{"id":"simple_example","title":"Einfaches Beispiel","isH3":true,"content":"<div class=\"code-example\"><pre class=\"brush: html notranslate\"><code><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>p</span><span class=\"token punctuation\">&gt;</span></span>Das Konzert startet um <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>time</span><span class=\"token punctuation\">&gt;</span></span>20:00<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>time</span><span class=\"token punctuation\">&gt;</span></span> Uhr.<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>p</span><span class=\"token punctuation\">&gt;</span></span>\n</code></pre></div>\n\n<p>Die Ausgabe des obigen HTML ist:</p>\n\n<p>Das Konzert startet um 20:00 Uhr.</p>"}},{"type":"prose","value":{"id":"datetime_example","title":"<code>datetime</code>-Beispiel","isH3":true,"content":"<div class=\"code-example\"><pre class=\"brush: html notranslate\"><code><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>p</span><span class=\"token punctuation\">&gt;</span></span>Das Konzert findet am <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>time</span> <span class=\"token attr-name\">datetime</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>2001-05-15 19:00<span class=\"token punctuation\">\"</span></span><span class=\"token punctuation\">&gt;</span></span>15. Mai<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>time</span><span class=\"token punctuation\">&gt;</span></span> statt.<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>p</span><span class=\"token punctuation\">&gt;</span></span>\n</code></pre></div>\n\n<p>Die Ausgabe des obigen HTML ist:</p>\n\n<p>Das Konzert findet am 15. Mai statt.</p>","titleAsText":"datetime-Beispiel"}},{"type":"prose","value":{"id":"specifications","title":"Spezifikationen","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">Spezifikation</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Kommentar</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"https://html.spec.whatwg.org/multipage/#the-time-element\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML Living Standard<br><small lang=\"de\">Die Definition von '&lt;time&gt;' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-living\">Lebender Standard</span></td>\n   <td>Keine Änderung zu <a href=\"https://www.w3.org/TR/html51/\" hreflang=\"en\" lang=\"en\" class=\"external\" title=\"Die 'HTML 5.1' Spezifikation\" rel=\" noopener\">HTML 5.1</a></td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.w3.org/TR/html51/grouping-content.html#the-time-element\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML 5.1<br><small lang=\"de\">Die Definition von '&lt;main&gt;' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-rec\">Empfehlung</span></td>\n   <td>Keine Änderung zu <a href=\"https://www.w3.org/TR/html52/\" hreflang=\"en\" lang=\"en\" class=\"external\" title=\"Die 'HTML5' Spezifikation\" rel=\" noopener\">HTML5</a></td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.w3.org/TR/html52/grouping-content.html#the-time-element\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML5<br><small lang=\"de\">Die Definition von '&lt;main&gt;' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-rec\">Empfehlung</span></td>\n   <td>Ursprüngliche Definition</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"browser-kompatibilität","title":"Browser-Kompatibilität","isH3":false,"content":"<p></p><div class=\"notecard note\" id=\"sect2\"><strong><a href=\"https://github.com/mdn/browser-compat-data\" class=\"external\" rel=\" noopener\">Wir konvertieren die Kompatibilitätsdaten in ein maschinenlesbares JSON Format</a></strong>.\n            Diese Kompatibilitätstabelle liegt noch im alten Format vor,\n            denn die darin enthaltenen Daten wurden noch nicht konvertiert.\n            <strong><a href=\"/en-US/docs/MDN/Structures/Compatibility_tables\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">Finde heraus wie du helfen kannst! (en-US)</a></strong></div>\n\n<div class=\"htab\" id=\"sect3\">\n    <a id=\"AutoCompatibilityTable\" name=\"AutoCompatibilityTable\"></a>\n    <ul>\n        <li class=\"selected\"><a href=\"#compat-desktop\">Desktop</a></li>\n        <li><a href=\"#compat-mobile\">Mobile</a></li>\n    </ul>\n</div><p></p>\n\n<div id=\"compat-desktop\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Chrome</th>\n   <th>Firefox (Gecko)</th>\n   <th>Internet Explorer</th>\n   <th>Opera</th>\n   <th>Safari</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td><a href=\"/en-US/docs/Mozilla/Firefox/Releases/22\" title=\"Veröffentlicht am 2013-06-25.\">22.0</a> (22.0)</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td>11.50<br>\n    Removed in 15.0</td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<div id=\"compat-mobile\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Android</th>\n   <th>Chrome for Android</th>\n   <th>Firefox Mobile (Gecko)</th>\n   <th>IE Mobile</th>\n   <th>Opera Mobile</th>\n   <th>Safari Mobile</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td>22.0 (22.0)</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td>11.50<br>\n    Entfernt in 15.0</td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n  </tr>\n </tbody>\n</table>\n</div>"}},{"type":"prose","value":{"id":"see_also","title":"Siehe auch","isH3":false,"content":"<ul>\n <li>Das<a href=\"/de/docs/Web/HTML/Element/data\"><code>&lt;data&gt;</code></a>-Element erlaubt die Auszeichnung anderer Werte.</li>\n</ul>\n\n<p></p><p></p>"}}],"toc":[{"text":"Attribute","id":"attribute"},{"text":"Beispiele","id":"beispiele"},{"text":"Spezifikationen","id":"specifications"},{"text":"Browser-Kompatibilität","id":"browser-kompatibilität"},{"text":"Siehe auch","id":"see_also"}],"summary":"Das HTML <time>-Element repräsentiert entweder Zeitangaben im 24-Stunden-Format oder ein präzises Datum im gregorianischen Kalender (mit optionalen Zeit- und Zeitzonen-Informationen).","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"<time>: The (Date) Time element","locale":"en-US","native":"English (US)"},{"title":"time","locale":"es","native":"Español"},{"title":"<time>","locale":"fr","native":"Français"},{"title":"<time>","locale":"ja","native":"日本語"},{"title":"<time>","locale":"ko","native":"한국어"},{"title":"<time>","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"<time>","locale":"ru","native":"Русский"},{"title":"<time>","locale":"zh-CN","native":"中文 (简体)"},{"title":"<time>","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"de/web/html/element/time","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/html/element/time/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/HTML","title":"HTML: HyperText Markup Language"},{"uri":"/de/docs/Web/HTML/Element","title":"Element"},{"uri":"/de/docs/Web/HTML/Element/time","title":"<time>"}],"pageTitle":"<time> - HTML: HyperText Markup Language | MDN","noIndexing":false}}