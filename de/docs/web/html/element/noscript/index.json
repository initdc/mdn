ML/Element/sub\"><code>&lt;sub&gt;</code> <small>(en-US)</small></a></li>\n  <li class=\"html5\"><a href=\"/de/docs/Web/HTML/Element/summary\"><code>&lt;summary&gt;</code></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/sup\"><code>&lt;sup&gt;</code> <small>(en-US)</small></a></li>\n </ol>\n </li><li>T\n <ol>\n  <li><a href=\"/de/docs/Web/HTML/Element/table\"><code>&lt;table&gt;</code></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/tbody\"><code>&lt;tbody&gt;</code> <small>(en-US)</small></a></li>\n  <li><a href=\"/de/docs/Web/HTML/Element/td\"><code>&lt;td&gt;</code></a></li>\n  <li class=\"webcomp\"><a href=\"/de/docs/Web/HTML/Element/template\"><code>&lt;template&gt;</code></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/textarea\"><code>&lt;textarea&gt;</code> <small>(en-US)</small></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/tfoot\"><code>&lt;tfoot&gt;</code> <small>(en-US)</small></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/th\"><code>&lt;th&gt;</code> <small>(en-US)</small></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/thead\"><code>&lt;thead&gt;</code> <small>(en-US)</small></a></li>\n  <li class=\"html5\"><a href=\"/de/docs/Web/HTML/Element/time\"><code>&lt;time&gt;</code></a></li>\n  <li><a href=\"/de/docs/Web/HTML/Element/title\"><code>&lt;title&gt;</code></a></li>\n  <li><a href=\"/de/docs/Web/HTML/Element/tr\"><code>&lt;tr&gt;</code></a></li>\n  <li class=\"html5\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/track\"><code>&lt;track&gt;</code> <small>(en-US)</small></a></li>\n  <li><s class=\"obsoleteElement\"><a href=\"/de/docs/Web/HTML/Element/tt\"><code>&lt;tt&gt;</code></a></s></li>\n </ol>\n </li><li>U\n <ol>\n  <li><a href=\"/de/docs/Web/HTML/Element/u\"><code>&lt;u&gt;</code></a></li>\n  <li><a href=\"/de/docs/Web/HTML/Element/ul\"><code>&lt;ul&gt;</code></a></li>\n </ol>\n </li><li>V\n <ol>\n  <li><a href=\"/de/docs/Web/HTML/Element/var\"><code>&lt;var&gt;</code></a></li>\n  <li class=\"html5\"><a href=\"/de/docs/Web/HTML/Element/video\"><code>&lt;video&gt;</code></a></li>\n </ol>\n </li><li>W\n <ol>\n  <li class=\"html5\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/wbr\"><code>&lt;wbr&gt;</code> <small>(en-US)</small></a></li>\n </ol>\n </li><li>X Y Z\n <ol>\n  <li><s class=\"obsoleteElement\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/xmp\"><code>&lt;xmp&gt;</code> <small>(en-US)</small></a></s></li>\n </ol>\n    </li>\n   </ol>\n   </details></li>\n   </ol>\n  ","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p>Das <strong>HTML Element <code>&lt;noscript&gt;</code> </strong>definiert einen HTML Abschnitt, der eingefügt werden soll, wenn ein Skripttyp auf der Seite nicht unterstützt wird oder wenn Skripting nicht aktiviert ist.</p>\n\n<table class=\"properties\">\n <tbody>\n  <tr>\n   <th scope=\"row\"><a href=\"/en-US/docs/Web/Guide/HTML/Content_categories\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">lnhaltskategorien (en-US)</a></th>\n   <td><a href=\"/en-US/docs/Web/Guide/HTML/Content_categories#metadata_content\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">Metadaten (en-US)</a>, <a href=\"/en-US/docs/Web/Guide/HTML/Content_categories#flow_content\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">flow content (en-US)</a>, <a href=\"/en-US/docs/Web/Guide/HTML/Content_categories#phrasing_content\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">phrasing content (en-US)</a>.</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">Erlaubter Inhalt</th>\n   <td>Wenn skripten deaktiviert ist und es ein Element im <a href=\"/de/docs/Web/API/HTMLHeadElement\"><code>&lt;head&gt;</code></a> Element ist: ohne bestimmte Reihenfolge, mehrere oder kein <a href=\"/de/docs/Web/HTML/Element/link\"><code>&lt;link&gt;</code></a> Elemente, kein oder mehrere <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/style\"><code>&lt;style&gt;</code> <small>(en-US)</small></a> Elemente, und kein oder mehrere <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/meta\"><code>&lt;meta&gt;</code> <small>(en-US)</small></a> Elemente.<br>\n    Wenn skripten deaktiviert ist und es kein Element im <a href=\"/de/docs/Web/API/HTMLHeadElement\"><code>&lt;head&gt;</code></a> Element ist: jedes nicht-darstellbare Element, aber kein <code>&lt;noscript&gt;</code> Element darf unter den Unterelementen sein.<br>\n    Sonst: flow content oder phrasing content.</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">Tageinschränkungen</th>\n   <td>Keine, sowohl das Anfangs- als auch das End-Tag sind erforderlich.</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">Erlaubte Überelemente</th>\n   <td>Jedes Element, welches <a href=\"/en-US/docs/Web/Guide/HTML/Content_categories#phrasing_content\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">phrasing content (en-US)</a> erlaubt, wenn es kein <code>&lt;noscript&gt;</code> Element ist, oder in einem <a href=\"/de/docs/Web/API/HTMLHeadElement\"><code>&lt;head&gt;</code></a> Element (ausser für ein HTML Dokument), hier auch: nur, wenn es kein <code>&lt;noscript&gt;</code> Element ist.</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">Erlaubte ARIA Rollen</th>\n   <td>Keine</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">DOM Schnittstelle</th>\n   <td><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/HTMLElement\"><code>HTMLElement</code> <small>(en-US)</small></a></td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"attribute","title":"Attribute","isH3":false,"content":"<p><span style=\"line-height: 21px;\">Dieses Element inkludiert </span><a href=\"/en-US/docs/Web/HTML/Global_attributes\" style=\"line-height: 21px;\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">globale Attribute (en-US)</a><span style=\"line-height: 21px;\">.</span></p>"}},{"type":"prose","value":{"id":"beispiel","title":"Beispiel","isH3":false,"content":"<div class=\"code-example\"><pre class=\"brush: html notranslate\"><code><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>noscript</span><span class=\"token punctuation\">&gt;</span></span>\n  <span class=\"token comment\">&lt;!-- Anker Link zu einer externe Datei --&gt;</span>\n  <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>a</span> <span class=\"token attr-name\">href</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>http://www.mozilla.com/<span class=\"token punctuation\">\"</span></span><span class=\"token punctuation\">&gt;</span></span>Externer Link<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>a</span><span class=\"token punctuation\">&gt;</span></span>\n<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>noscript</span><span class=\"token punctuation\">&gt;</span></span>\n<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>p</span><span class=\"token punctuation\">&gt;</span></span>Rockt!<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>p</span><span class=\"token punctuation\">&gt;</span></span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"resultat_wenn_skripten_aktiviert_ist","title":"Resultat wenn skripten aktiviert ist","isH3":true,"content":"<p>Rockt!</p>"}},{"type":"prose","value":{"id":"resultat_wenn_skripten_deaktiviert_ist","title":"Resultat wenn skripten deaktiviert ist","isH3":true,"content":"<p><a class=\"external\" href=\"http://www.mozilla.com/\" rel=\" noopener\">Externer Link</a></p>\n\n<p>Rockt!</p>"}},{"type":"prose","value":{"id":"specifications","title":"Spezifikationen","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">Spezifikation</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Kommentar</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"https://html.spec.whatwg.org/multipage/scripting-1.html#the-noscript-element\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML Living Standard<br><small lang=\"de\">Die Definition von '&lt;noscript&gt;' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-living\">Lebender Standard</span></td>\n   <td>&nbsp;</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.w3.org/TR/html52/the-noscript-element.html#the-noscript-element\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML5<br><small lang=\"de\">Die Definition von '&lt;noscript&gt;' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-rec\">Empfehlung</span></td>\n   <td>&nbsp;</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.w3.org/TR/html401/scripts.html#h-18.3.1\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML 4.01 Specification<br><small lang=\"de\">Die Definition von '&lt;noscript&gt;' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-rec\">Empfehlung</span></td>\n   <td>&nbsp;</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"Browserkompatibilität","id":"browserkompatibilität","isH3":false,"query":"html.elements.noscript","dataURL":"/de/docs/Web/HTML/Element/noscript/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}}],"toc":[{"text":"Attribute","id":"attribute"},{"text":"Beispiel","id":"beispiel"},{"text":"Spezifikationen","id":"specifications"},{"text":"Browserkompatibilität","id":"browserkompatibilität"}],"summary":"Das HTML Element <noscript> definiert einen HTML Abschnitt, der eingefügt werden soll, wenn ein Skripttyp auf der Seite nicht unterstützt wird oder wenn Skripting nicht aktiviert ist.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"<noscript>: The Noscript element","locale":"en-US","native":"English (US)"},{"title":"noscript","locale":"es","native":"Español"},{"title":"<noscript>","locale":"fr","native":"Français"},{"title":"<noscript>","locale":"ja","native":"日本語"},{"title":"<noscript>","locale":"ko","native":"한국어"},{"title":"<noscript>","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"<noscript>","locale":"ru","native":"Русский"},{"title":"<noscript>","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"de/web/html/element/noscript","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/html/element/noscript/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/HTML","title":"HTML: HyperText Markup Language"},{"uri":"/de/docs/Web/HTML/Element","title":"Element"},{"uri":"/de/docs/Web/HTML/Element/noscript","title":"<noscript>"}],"pageTitle":"<noscript> - HTML: HyperText Markup Language | MDN","noInd