/Global_Objects/Object/__lookupGetter__\"><code>Object.prototype.__lookupGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupSetter__\"><code>Object.prototype.__lookupSetter__()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/assign\"><code>Object.assign()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/create\"><code>Object.create()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/defineProperties\"><code>Object.defineProperties()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/defineProperty\"><code>Object.defineProperty()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/entries\"><code>Object.entries()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/freeze\"><code>Object.freeze()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/fromEntries\"><code>Object.fromEntries()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/getOwnPropertyDescriptor\"><code>Object.getOwnPropertyDescriptor()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/getOwnPropertyDescriptors\"><code>Object.getOwnPropertyDescriptors()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/getOwnPropertyNames\"><code>Object.getOwnPropertyNames()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/getOwnPropertySymbols\"><code>Object.getOwnPropertySymbols()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/getPrototypeOf\"><code>Object.getPrototypeOf()</code></a></li><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwn\"><code>Object.hasOwn()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwnProperty\"><code>Object.prototype.hasOwnProperty()</code></a></li><li><em><code>Object.is()</code></em></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/isExtensible\"><code>Object.isExtensible()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/isFrozen\"><code>Object.isFrozen()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/isPrototypeOf\"><code>Object.prototype.isPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/isSealed\"><code>Object.isSealed()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/keys\"><code>Object.keys()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/preventExtensions\"><code>Object.preventExtensions()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/propertyIsEnumerable\"><code>Object.prototype.propertyIsEnumerable()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/seal\"><code>Object.seal()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/setPrototypeOf\"><code>Object.setPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/toLocaleString\"><code>Object.prototype.toLocaleString()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/valueOf\"><code>Object.prototype.valueOf()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/values\"><code>Object.values()</code></a></li></ol></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>"}},{"type":"prose","value":{"id":"zusammenfassung","title":"Zusammenfassung","isH3":false,"content":"<p>Die&nbsp;<code><strong>Object.is()</strong></code> Methode entscheidet, ob zwei Werte <a href=\"/en-US/docs/Web/JavaScript/Equality_comparisons_and_sameness\">die gleichen Werte sind</a>.</p>"}},{"type":"prose","value":{"id":"syntax","title":"Syntax","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><code>var <var>isSame</var> = Object.is(<var>value1</var>, <var>value2</var>);</code></pre>"}},{"type":"prose","value":{"id":"parameters","title":"Parameter","isH3":true,"content":"<dl>\n <dt id=\"value1\"><code>value1</code></dt>\n <dd>Der erste Wert zum vergleichen.</dd>\n <dt id=\"value2\"><code>value2</code></dt>\n <dd>Der zweite Wert zum vergleichen.</dd>\n</dl>"}},{"type":"prose","value":{"id":"beschreibung","title":"Beschreibung","isH3":false,"content":"<p><span class=\"short_text\" id=\"result_box\" lang=\"en\"><span><code>Object.is()</code>&nbsp;bestimmt, ob zwei Werte&nbsp;<a href=\"/en-US/docs/Web/JavaScript/Equality_comparisons_and_sameness\" title=\"/en-US/docs/Web/JavaScript/Guide/Sameness\"><dfn>gleich sind</dfn></a>. </span></span><span class=\"short_text\" lang=\"en\"><span>Dabei gelten zwei Werte genau dann als gleich, wenn eine der folgenden Bedingungen zutrifft:</span></span></p>\n\n<ul>\n <li><span class=\"short_text\" lang=\"en\"><span>beide sind&nbsp;<code>undefined</code></span></span></li>\n <li><span class=\"short_text\" lang=\"en\"><span>beide sind&nbsp;<code>null</code></span></span></li>\n <li><span class=\"short_text\" lang=\"en\"><span>beide sind&nbsp;<code>true</code> oder beide sind&nbsp;<code>false</code></span></span></li>\n <li><span class=\"short_text\" lang=\"en\"><span>beide sind Strings mit selber Länge und den selben Zeichen</span></span></li>\n <li><span class=\"short_text\" lang=\"en\"><span>beide sind das selbe Objekt</span></span></li>\n <li><span class=\"short_text\" lang=\"en\"><span>beide sind Zahlen und eine der folgenden Bedingungen trifft zu:</span></span>\n  <ul>\n   <li>beide sind&nbsp;<code>+0</code></li>\n   <li>beide sind&nbsp;<code>-0</code></li>\n   <li>beide sind&nbsp;<code>NaN</code></li>\n   <li>beide sind nicht Null, beide sind nicht&nbsp;<code>NaN</code> und beide haben den selben Zahlenwert</li>\n  </ul>\n </li>\n</ul>\n\n<p>Dies ist&nbsp;<em>nicht</em> das selbe wie der&nbsp;<code>==</code>-Operator. Dieser verwendet verschiedene, situationsabhängige Typ-Umwandlungen auf beiden Seiten bevor auf Gleichheit getestet wird (was z.B. dazu führt, dass der Ausdruck&nbsp;<code>\"\" == false</code>&nbsp;zu&nbsp;<code>true</code> ausgewertet wird).&nbsp;<code>Object.is</code> hingegen wandelt keinen der beiden Werte um.</p>\n\n<p>Es ist ebenfalls nicht das selbe wie der strikte&nbsp;<code>===</code>-Operator. Dieser – ebenso wie der&nbsp;<code>==</code>-Operator – behandelt zum Beispiel&nbsp;<code>+0</code> und&nbsp;<code>-0</code> als identisch während&nbsp;<code>NaN</code> und&nbsp;<code>NaN</code>&nbsp;als nicht identisch behandelt werden.</p>"}},{"type":"prose","value":{"id":"beispiele","title":"Beispiele","isH3":false,"content":"<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code>Object<span class=\"token punctuation\">.</span><span class=\"token function\">is</span><span class=\"token punctuation\">(</span><span class=\"token string\">'foo'</span><span class=\"token punctuation\">,</span> <span class=\"token string\">'foo'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>     <span class=\"token comment\">// true</span>\nObject<span class=\"token punctuation\">.</span><span class=\"token function\">is</span><span class=\"token punctuation\">(</span>window<span class=\"token punctuation\">,</span> window<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>   <span class=\"token comment\">// true</span>\n\nObject<span class=\"token punctuation\">.</span><span class=\"token function\">is</span><span class=\"token punctuation\">(</span><span class=\"token string\">'foo'</span><span class=\"token punctuation\">,</span> <span class=\"token string\">'bar'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>     <span class=\"token comment\">// false</span>\nObject<span class=\"token punctuation\">.</span><span class=\"token function\">is</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">[</span><span class=\"token punctuation\">]</span><span class=\"token punctuation\">,</span> <span class=\"token punctuation\">[</span><span class=\"token punctuation\">]</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>           <span class=\"token comment\">// false</span>\n\n<span class=\"token keyword\">var</span> test <span class=\"token operator\">=</span> <span class=\"token punctuation\">{</span> <span class=\"token literal-property property\">a</span><span class=\"token operator\">:</span> <span class=\"token number\">1</span> <span class=\"token punctuation\">}</span><span class=\"token punctuation\">;</span>\nObject<span class=\"token punctuation\">.</span><span class=\"token function\">is</span><span class=\"token punctuation\">(</span>test<span class=\"token punctuation\">,</span> test<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>       <span class=\"token comment\">// true</span>\n\nObject<span class=\"token punctuation\">.</span><span class=\"token function\">is</span><span class=\"token punctuation\">(</span><span class=\"token keyword\">null</span><span class=\"token punctuation\">,</span> <span class=\"token keyword\">null</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>       <span class=\"token comment\">// true</span>\n\n<span class=\"token comment\">// Special Cases</span>\nObject<span class=\"token punctuation\">.</span><span class=\"token function\">is</span><span class=\"token punctuation\">(</span><span class=\"token number\">0</span><span class=\"token punctuation\">,</span> <span class=\"token operator\">-</span><span class=\"token number\">0</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>            <span class=\"token comment\">// false</span>\nObject<span class=\"token punctuation\">.</span><span class=\"token function\">is</span><span class=\"token punctuation\">(</span><span class=\"token operator\">-</span><span class=\"token number\">0</span><span class=\"token punctuation\">,</span> <span class=\"token operator\">-</span><span class=\"token number\">0</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>           <span class=\"token comment\">// true</span>\nObject<span class=\"token punctuation\">.</span><span class=\"token function\">is</span><span class=\"token punctuation\">(</span><span class=\"token number\">NaN</span><span class=\"token punctuation\">,</span> <span class=\"token number\">0</span><span class=\"token operator\">/</span><span class=\"token number\">0</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>         <span class=\"token comment\">// true</span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"polyfill","title":"Polyfill","isH3":false,"content":"<p><code>Object.</code> ist eine vorgeschlagene Ergänzung des ECMA-262 Standard; als solcher könnte dieser nicht von allen Browser verstanden werden.&nbsp;Du kannst drum herum arbeiten, indem du den folgenden Code an den Anfang deines Scripts packst. Das erlaubt dir die&nbsp;<code>Object.is Methode</code> zu verwenden, auch wenn es keine eingebaute Unterstützung dafür gibt.</p>\n\n<pre class=\"notranslate\"><code>if (!Object.is) {\n  Object.is = function(x, y) {\n    // SameValue algorithm\n    if (x === y) { // Steps 1-5, 7-10\n      // Steps 6.b-6.e: +0 != -0\n      return x !== 0 || 1 / x === 1 / y;\n    } else {\n     // Step 6.a: NaN == NaN\n     return x !== x &amp;&amp; y !== y;\n    }\n  };\n}</code></pre>"}},{"type":"prose","value":{"id":"spezifikationen","title":"Spezifikationen","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Spezifikation</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Kommentar</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.ecma-international.org/ecma-262/6.0/#sec-object.is\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript 2015 (6th Edition, ECMA-262)<br><small lang=\"de\">Die Definition von 'Object.is' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-standard\">Standard</span></td>\n   <td>Initial definition.</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"Browserkompatibilität","id":"browserkompatibilität","isH3":false,"query":"javascript.builtins.Object.is","dataURL":"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/is/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect2\">\n\n\n<p></p><p></p>\n</div>"}},{"type":"prose","value":{"id":"siehe_auch","title":"Siehe auch","isH3":false,"content":"<ul>\n <li><a href=\"/en-US/docs/Web/JavaScript/Equality_comparisons_and_sameness\">JavaScript Guide: Sameness</a> — ein Vergleich aller drei eingebauten Gleichheitseinrichtungen</li>\n</ul>"}}],"toc":[{"text":"Zusammenfassung","id":"zusammenfassung"},{"text":"Syntax","id":"syntax"},{"text":"Beschreibung","id":"beschreibung"},{"text":"Beispiele","id":"beispiele"},{"text":"Polyfill","id":"polyfill"},{"text":"Spezifikationen","id":"spezifikationen"},{"text":"Browserkompatibilität","id":"browserkompatibilität"},{"text":"Siehe auch","id":"siehe_auch"}],"summary":"Die Object.is() Methode entscheidet, ob zwei Werte die gleichen Werte sind.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Object.is()","locale":"en-US","native":"English (US)"},{"title":"Object.is()","locale":"es","native":"Español"},{"title":"Object.is()","locale":"fr","native":"Français"},{"title":"Object.is()","locale":"ja","native":"日本語"},{"title":"Object.is()","locale":"ko","native":"한국어"},{"title":"Object.is()","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Object.is()","locale":"ru","native":"Русский"},{"title":"Object.is()","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"de/web/javascript/reference/global_objects/object/is","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/javascript/reference/global_objects/object/is/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/JavaScript","title":"JavaScript"},{"uri":"/de/docs/Web/JavaScript/Reference","title":"JavaScript-Referenz"},{"uri":"/de/docs/Web/JavaScript/Reference/Global_Objects","title":"Globale Objekte"},{"uri":"/de/docs/Web/JavaScript/Reference/Global_Objects/Object","title":"Object"},{"uri":"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/is","title":"Object.is()"}],"pageTitle":"Object.is() - JavaScript | MDN","noIndexing":false}}