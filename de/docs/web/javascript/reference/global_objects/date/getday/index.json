mall></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/propertyIsEnumerable\"><code>Object.prototype.propertyIsEnumerable()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/setPrototypeOf\"><code>Object.setPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/toLocaleString\"><code>Object.prototype.toLocaleString()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/valueOf\"><code>Object.prototype.valueOf()</code></a></li></ol></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p><span class=\"seoSummary\">Die <strong><code>getDay()</code></strong> Methode gibt den Tag der Woche eines Datums gemäß der Ortszeit zurück, wobei Sonntag durch den Wert 0 repräsentiert wird.</span> Für den Tag des Monats gibt es die Methode <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Date/getDate\"><code>getDate()</code> <small>(en-US)</small></a></p>\n\n<div id=\"sect2\"><iframe class=\"interactive\" height=\"490\" src=\"https://interactive-examples.mdn.mozilla.net/pages/js/date-getday.html\" title=\"MDN Web Docs Interactive Example\" loading=\"lazy\"></iframe></div>"}},{"type":"prose","value":{"id":"syntax","title":"Syntax","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><code><var>dateObj</var>.getDay()</code></pre>"}},{"type":"prose","value":{"id":"rückgabewert","title":"Rückgabewert","isH3":true,"content":"<p>Eine ganze Zahl zwischen 0 und 6, die den Tag der Woche des gegebenden Datums repräsentiert: 0 für Sonntag, 1 für Montag, 2 für Dienstag und so weiter.</p>"}},{"type":"prose","value":{"id":"beispiele","title":"Beispiele","isH3":false,"content":""}},{"type":"prose","value":{"id":"einsatz_von_getday","title":"Einsatz von <code>getDay()</code>","isH3":true,"content":"<p>Im zweiten Statement wird die Variable <code>weekday</code> mit dem Wert 1 initialisiert. Dabei wird der Wert des <a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Date\"><code>Date</code></a> object <code>Xmas95</code> benutzt. 25. Dezember 1995 ist ein Montag.</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> Xmas95 <span class=\"token operator\">=</span> <span class=\"token keyword\">new</span> <span class=\"token class-name\">Date</span><span class=\"token punctuation\">(</span><span class=\"token string\">'December 25, 1995 23:15:30'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token keyword\">var</span> weekday <span class=\"token operator\">=</span> Xmas95<span class=\"token punctuation\">.</span><span class=\"token function\">getDay</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n\nconsole<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span>weekday<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// 1</span>\n</code></pre></div>","titleAsText":"Einsatz von getDay()"}},{"type":"prose","value":{"id":"spezifikationen","title":"Spezifikationen","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">Spezifikation</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"https://tc39.es/ecma262/#sec-date.prototype.getday\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript (ECMA-262)<br><small lang=\"de\">Die Definition von 'Date.prototype.getDay' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-living\">Lebender Standard</span></td>\n   <td></td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"Browserkompatibilität","id":"browserkompatibilität","isH3":false,"query":"javascript.builtins.Date.getDay","dataURL":"/de/docs/Web/JavaScript/Reference/Global_Objects/Date/getDay/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"siehe_auch","title":"Siehe auch","isH3":false,"content":"<ul>\n <li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Date/getUTCDate\"><code>Date.prototype.getUTCDate()</code></a></li>\n <li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Date/getUTCDay\"><code>Date.prototype.getUTCDay()</code></a></li>\n <li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Date/setDate\"><code>Date.prototype.setDate()</code></a></li>\n</ul>"}}],"toc":[{"text":"Syntax","id":"syntax"},{"text":"Beispiele","id":"beispiele"},{"text":"Spezifikationen","id":"spezifikationen"},{"text":"Browserkompatibilität","id":"browserkompatibilität"},{"text":"Siehe auch","id":"siehe_auch"}],"summary":"Die getDay() Methode gibt den Tag der Woche eines Datums gemäß der Ortszeit zurück, wobei Sonntag durch den Wert 0 repräsentiert wird.","popularity":0.0006,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Date.prototype.getDay()","locale":"en-US","native":"English (US)"},{"title":"Date.prototype.getDay()","locale":"es","native":"Español"},{"title":"Date.prototype.getDay()","locale":"fr","native":"Français"},{"title":"Date.prototype.getDay()","locale":"ja","native":"日本語"},{"title":"Date.prototype.getDay()","locale"