{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"Intl.PluralRules","mdn_url":"/de/docs/Web/JavaScript/Reference/Global_Objects/Intl/PluralRules","locale":"de","native":"Deutsch","sidebarHTML":"<ol><li><strong><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects\">Standard-Objekte</a></strong></li><li><strong><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Intl\"><code>Intl</code></a></strong></li><li data-default-state=\"open\"><a href=\"#\"><strong>Eigenschaften</strong></a><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Intl/@@toStringTag\"><code>Intl[@@toStringTag]</code> <small>(en-US)</small></a></li></ol></li><li data-default-state=\"open\"><a href=\"#\"><strong>Methoden</strong></a><ol><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Intl/getCanonicalLocales\"><code>Intl.getCanonicalLocales()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Intl/supportedValuesOf\"><code>Intl.supportedValuesOf()</code> <small>(en-US)</small></a></li></ol></li><li><strong>Ähnliche Seiten:</strong></li><li><strong><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Intl/Collator\"><code>Intl.Collator</code></a></strong></li><li><strong><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Intl/DateTimeFormat\"><code>Intl.DateTimeFormat</code></a></strong></li><li><strong><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Intl/ListFormat\"><code>Intl.ListFormat</code> <small>(en-US)</small></a></strong></li><li><strong><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Intl/NumberFormat\"><code>Intl.NumberFormat</code></a></strong></li><li><strong><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Intl/PluralRules\"><code>Intl.PluralRules</code></a></strong></li><li><strong><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Intl/RelativeTimeFormat\"><code>Intl.RelativeTimeFormat</code> <small>(en-US)</small></a></strong></li><li><strong><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Intl/Segmenter\"><code>Intl.Segmenter</code> <small>(en-US)</small></a></strong></li><li><strong>Vererbung:</strong></li><li><strong><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object\"><code>Object</code></a></strong></li><li><a href=\"#\"><strong>Eigenschaften</strong></a><ol><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/constructor\"><code>Object.prototype.constructor</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/proto\"><code>Object.prototype.__proto__</code></a></li></ol></li><li><a href=\"#\"><strong>Methoden</strong></a><ol><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineGetter__\"><code>Object.prototype.__defineGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineSetter__\"><code>Object.prototype.__defineSetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupGetter__\"><code>Object.prototype.__lookupGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupSetter__\"><code>Object.prototype.__lookupSetter__()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwnProperty\"><code>Object.prototype.hasOwnProperty()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/isPrototypeOf\"><code>Object.prototype.isPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/propertyIsEnumerable\"><code>Object.prototype.propertyIsEnumerable()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/setPrototypeOf\"><code>Object.setPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/toLocaleString\"><code>Object.prototype.toLocaleString()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/valueOf\"><code>Object.prototype.valueOf()</code></a></li></ol></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p>The <strong><code>Intl.PluralRules</code></strong> object is a constructor for objects that enable plural sensitive formatting and plural language language rules.</p>"}},{"type":"prose","value":{"id":"syntax","title":"Syntax","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><code>new Intl.PluralRules([<var>locales</var>[, <var>options</var>]])\nIntl.PluralRules.call(<var>this</var>[, <var>locales</var>[, <var>options</var>]])\n</code></pre>"}},{"type":"prose","value":{"id":"parameters","title":"Parameters","isH3":true,"content":"<dl>\n <dt id=\"locales\"><code>locales</code></dt>\n <dd>\n <p>Optional. A string with a BCP 47 language tag, or an array of such strings. For the general form and interpretation of the <code>locales</code> argument, see the <a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Intl#locale_identification_and_negotiation\">Intl page</a>.</p>\n </dd>\n <dt id=\"options\"><code>options</code></dt>\n <dd>\n <p>Optional. An object with some or all of the following properties:</p>\n\n <dl>\n  <dt id=\"localematcher\"><code>localeMatcher</code></dt>\n  <dd>The locale matching algorithm to use. Possible values are <code>\"lookup\"</code> and <code>\"best fit\"</code>; the default is <code>\"best fit\"</code>. For information about this option, see the <a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Intl#locale_negotiation\">Intl page</a>.</dd>\n  <dt id=\"type\"><code>type</code></dt>\n  <dd>The type to use. Possible values are:\n  <ul>\n   <li><code>\"cardinal\"</code> for cardinal numbers (refering to the quantity of things). This is the default value.</li>\n   <li><code>\"ordinal\"</code> for ordinal number (refering to the ordering or ranking of things, e.g. \"1st\", \"2nd\", \"3rd\" in English).</li>\n  </ul>\n  </dd>\n </dl>\n </dd>\n</dl>"}},{"type":"prose","value":{"id":"description","title":"Description","isH3":false,"content":""}},{"type":"prose","value":{"id":"properties","title":"Properties","isH3":true,"content":"<dl>\n <dt id=\"intl.pluralrules.prototype_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Intl/PluralRules\"><code>Intl.PluralRules.prototype</code> <small>(en-US)</small></a></dt>\n <dd>Allows the addition of properties to all objects.</dd>\n</dl>"}},{"type":"prose","value":{"id":"methods","title":"Methods","isH3":true,"content":"<dl>\n <dt id=\"intl.pluralrules.supportedlocalesof\"><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Intl/PluralRules/supportedLocalesOf\"><code>Intl.PluralRules.supportedLocalesOf()</code></a></dt>\n <dd>Returns an array containing those of the provided locales that are supported without having to fall back to the runtime's default locale.</dd>\n</dl>"}},{"type":"prose","value":{"id":"pluralrules_instances","title":"<code>PluralRules</code> instances","isH3":false,"content":"","titleAsText":"PluralRules instances"}},{"type":"prose","value":{"id":"properties_2","title":"Properties","isH3":true,"content":"<p><code>PluralRules</code> instances inherit the following properties from their prototype:</p>\n\n<div id=\"sect2\">{{page('/en-US/docs/Web/JavaScript/Reference/Global_Objects/PluralRules/prototype', 'Properties')}}</div>"}},{"type":"prose","value":{"id":"methods_2","title":"Methods","isH3":true,"content":"<p><code>PluralRules</code> instances inherit the following methods from their prototype:</p>\n\n<div id=\"sect3\">{{page('/en-US/docs/Web/JavaScript/Reference/Global_Objects/PluralRules/prototype', 'Methods')}}</div>"}},{"type":"prose","value":{"id":"examples","title":"Examples","isH3":false,"content":""}},{"type":"prose","value":{"id":"basic_usage","title":"Basic usage","isH3":true,"content":"<p>In basic use without specifying a locale, a formatted string in the default locale and with default options is returned. This is useful to distinguish between singular and plural forms, e.g. \"dog\" and \"dogs\".</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> pr <span class=\"token operator\">=</span> <span class=\"token keyword\">new</span> <span class=\"token class-name\">Intl<span class=\"token punctuation\">.</span>PluralRules</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n\npr<span class=\"token punctuation\">.</span><span class=\"token function\">select</span><span class=\"token punctuation\">(</span><span class=\"token number\">0</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// → 'other' if in US English locale</span>\n\npr<span class=\"token punctuation\">.</span><span class=\"token function\">select</span><span class=\"token punctuation\">(</span><span class=\"token number\">1</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// → 'one' if in US English locale</span>\n\npr<span class=\"token punctuation\">.</span><span class=\"token function\">select</span><span class=\"token punctuation\">(</span><span class=\"token number\">2</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// → 'other' if in US English locale</span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"using_locales","title":"Using <code>locales</code>","isH3":true,"content":"<p>This example shows some of the variations in localized plural rules. In order to get the format of the language used in the user interface of your application, make sure to specify that language (and possibly some fallback languages) using the <code>locales</code> argument:</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token comment\">// Arabic has different plural rules</span>\n\n<span class=\"token keyword\">new</span> <span class=\"token class-name\">Intl<span class=\"token punctuation\">.</span>PluralRules</span><span class=\"token punctuation\">(</span><span class=\"token string\">'ar-EG'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">.</span><span class=\"token function\">select</span><span class=\"token punctuation\">(</span><span class=\"token number\">0</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// → 'zero'</span>\n<span class=\"token keyword\">new</span> <span class=\"token class-name\">Intl<span class=\"token punctuation\">.</span>PluralRules</span><span class=\"token punctuation\">(</span><span class=\"token string\">'ar-EG'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">.</span><span class=\"token function\">select</span><span class=\"token punctuation\">(</span><span class=\"token number\">1</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// → 'one'</span>\n<span class=\"token keyword\">new</span> <span class=\"token class-name\">Intl<span class=\"token punctuation\">.</span>PluralRules</span><span class=\"token punctuation\">(</span><span class=\"token string\">'ar-EG'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">.</span><span class=\"token function\">select</span><span class=\"token punctuation\">(</span><span class=\"token number\">2</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// → 'two'</span>\n<span class=\"token keyword\">new</span> <span class=\"token class-name\">Intl<span class=\"token punctuation\">.</span>PluralRules</span><span class=\"token punctuation\">(</span><span class=\"token string\">'ar-EG'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">.</span><span class=\"token function\">select</span><span class=\"token punctuation\">(</span><span class=\"token number\">6</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// → 'few'</span>\n<span class=\"token keyword\">new</span> <span class=\"token class-name\">Intl<span class=\"token punctuation\">.</span>PluralRules</span><span class=\"token punctuation\">(</span><span class=\"token string\">'ar-EG'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">.</span><span class=\"token function\">select</span><span class=\"token punctuation\">(</span><span class=\"token number\">18</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// → 'many'</span>\n</code></pre></div>","titleAsText":"Using locales"}},{"type":"prose","value":{"id":"using_options","title":"Using <code>options</code>","isH3":true,"content":"<p>The results can be customized using the <code>options</code> argument, which has one property called <code>type</code> which you can set to <code>ordinal</code>. This is useful to figure out the ordinal indicator, e.g. \"1st\", \"2nd\", \"3rd\", \"4th\", \"42nd\" and so forth.</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> pr <span class=\"token operator\">=</span> <span class=\"token keyword\">new</span> <span class=\"token class-name\">Intl<span class=\"token punctuation\">.</span>PluralRules</span><span class=\"token punctuation\">(</span><span class=\"token string\">'en-US'</span><span class=\"token punctuation\">,</span> <span class=\"token punctuation\">{</span> <span class=\"token literal-property property\">type</span><span class=\"token operator\">:</span> <span class=\"token string\">'ordinal'</span> <span class=\"token punctuation\">}</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n\npr<span class=\"token punctuation\">.</span><span class=\"token function\">select</span><span class=\"token punctuation\">(</span><span class=\"token number\">0</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// → 'other'</span>\npr<span class=\"token punctuation\">.</span><span class=\"token function\">select</span><span class=\"token punctuation\">(</span><span class=\"token number\">1</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// → 'one'</span>\npr<span class=\"token punctuation\">.</span><span class=\"token function\">select</span><span class=\"token punctuation\">(</span><span class=\"token number\">2</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// → 'two'</span>\npr<span class=\"token punctuation\">.</span><span class=\"token function\">select</span><span class=\"token punctuation\">(</span><span class=\"token number\">3</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// → 'few'</span>\npr<span class=\"token punctuation\">.</span><span class=\"token function\">select</span><span class=\"token punctuation\">(</span><span class=\"token number\">4</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// → 'other'</span>\npr<span class=\"token punctuation\">.</span><span class=\"token function\">select</span><span class=\"token punctuation\">(</span><span class=\"token number\">42</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// → 'two'</span>\n</code></pre></div>","titleAsText":"Using options"}},{"type":"prose","value":{"id":"specifications","title":"Specifications","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Specification</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Comment</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://rawgit.com/caridy/intl-plural-rules-spec/master/index.html\" class=\"external\" rel=\" noopener\">Intl Plural Rules Draft</a></td>\n   <td><span class=\"spec-living\">Lebender Standard</span></td>\n   <td>Initial definition</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"Browser compatibility","id":"browser_compatibility","isH3":false,"query":"javascript.builtins.Intl.PluralRules","dataURL":"/de/docs/Web/JavaScript/Reference/Global_Objects/Intl/PluralRules/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect4\">\n\n\n<p></p><p></p>\n</div>"}},{"type":"prose","value":{"id":"see_also","title":"See also","isH3":false,"content":"<div id=\"sect5\"><ul>\n  <li>Introduction: <a href=\"https://norbertlindenberg.com/2012/12/ecmascript-internationalization-api/index.html\" class=\"external\" rel=\" noopener\">The ECMAScript Internationalization API</a></li>\n  <li>Constructors\n    <ul>\n      <li><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Intl/Collator\"><code>Intl.Collator()</code></a></li>\n      <li><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Intl/DateTimeFormat\"><code>Intl.DateTimeFormat()</code></a></li>\n      <li><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Intl/ListFormat\"><code>Intl.ListFormat()</code></a></li>\n      <li><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Intl/NumberFormat\"><code>Intl.NumberFormat()</code></a></li>\n      <li><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Intl/PluralRules\"><code>Intl.PluralRules()</code></a></li>\n      <li><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Intl/RelativeTimeFormat\"><code>Intl.RelativeTimeFormat()</code></a></li>\n      <li><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Intl/Locale\"><code>Intl.Locale()</code></a></li>\n      <li><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Intl/Segmenter\"><code>Intl.Segmenter()</code></a></li>\n    </ul>\n  </li>\n  <li>Methods\n    <ul>\n      <li><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/String/localeCompare\"><code>String.prototype.localeCompare()</code></a></li>\n      <li><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Number/toLocaleString\"><code>Number.prototype.toLocaleString()</code></a></li>\n      <li><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Date/toLocaleString\"><code>Date.prototype.toLocaleString()</code></a></li>\n      <li><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Date/toLocaleDateString\"><code>Date.prototype.toLocaleDateString()</code></a></li>\n      <li><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Date/toLocaleTimeString\"><code>Date.prototype.toLocaleTimeString()</code></a></li>\n    </ul>\n  </li>\n</ul></div>"}}],"toc":[{"text":"Syntax","id":"syntax"},{"text":"Description","id":"description"},{"text":"<code>PluralRules</code> instances","id":"pluralrules_instances"},{"text":"Examples","id":"examples"},{"text":"Specifications","id":"specifications"},{"text":"Browser compatibility","id":"browser_compatibility"},{"text":"See also","id":"see_also"}],"summary":"The Intl.PluralRules object is a constructor for objects that enable plural sensitive formatting and plural language language rules.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Intl.PluralRules","locale":"en-US","native":"English (US)"},{"title":"Intl.PluralRules","locale":"fr","native":"Français"},{"title":"Intl.PluralRules","locale":"ja","native":"日本語"},{"title":"Intl.PluralRules","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"de/web/javascript/reference/global_objects/intl/pluralrules","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/javascript/reference/global_objects/intl/pluralrules/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/JavaScript","title":"JavaScript"},{"uri":"/de/docs/Web/JavaScript/Reference","title":"JavaScript-Referenz"},{"uri":"/de/docs/Web/JavaScript/Reference/Global_Objects","title":"Globale Objekte"},{"uri":"/de/docs/Web/JavaScript/Reference/Global_Objects/Intl","title":"Intl"},{"uri":"/de/docs/Web/JavaScript/Reference/Global_Objects/Intl/PluralRules","title":"Intl.PluralRules"}],"pageTitle":"Intl.PluralRules - JavaScript | MDN","noIndexing":false}}