nglish (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineSetter__\"><code>Object.prototype.__defineSetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupGetter__\"><code>Object.prototype.__lookupGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupSetter__\"><code>Object.prototype.__lookupSetter__()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwnProperty\"><code>Object.prototype.hasOwnProperty()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/isPrototypeOf\"><code>Object.prototype.isPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/propertyIsEnumerable\"><code>Object.prototype.propertyIsEnumerable()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/setPrototypeOf\"><code>Object.setPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/toLocaleString\"><code>Object.prototype.toLocaleString()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/valueOf\"><code>Object.prototype.valueOf()</code></a></li></ol></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p>Die <code><strong>toString()</strong></code> gibt einen String, der eine <a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code></a> Objekt repräsentiert, zurück.</p>\n\n<div id=\"sect2\"><iframe class=\"interactive\" height=\"490\" src=\"https://interactive-examples.mdn.mozilla.net/pages/js/boolean-tostring.html\" title=\"MDN Web Docs Interactive Example\" loading=\"lazy\"></iframe></div>"}},{"type":"prose","value":{"id":"syntax","title":"Syntax","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><code><var>bool</var>.toString()</code></pre>"}},{"type":"prose","value":{"id":"rückgabewert","title":"Rückgabewert","isH3":true,"content":"<p>Eine String-Repräsentation des <a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code></a> Objektes.</p>"}},{"type":"prose","value":{"id":"beschreibung","title":"Beschreibung","isH3":false,"content":"<p>Das <a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code></a> Objekt überschreibt die <code>toString</code> Methode des <a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object\"><code>Object</code></a> Objektes. Es erbt nicht von <a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a>. Für <a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code></a> Objekte gibt die <code>toString</code> Methode einen String, der das Objekt repräsentiert, zurück.</p>\n\n<p>JavaScript ruft die <code>toString</code> Methode automatisch auf, wenn ein <a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code></a> Objekt als Text dargestellt wird oder wenn ein <a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code></a> mit einem String konkatiniert wird.</p>\n\n<p>Für <a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code></a> Objekte und Werte gibt die eingebaute <code>toString</code> Methode die Strings \"<code>true</code>\" oder \"<code>false</code>\", abhängig vom Wert des Boolean, zurück.</p>"}},{"type":"prose","value":{"id":"beispiele","title":"Beispiele","isH3":false,"content":""}},{"type":"prose","value":{"id":"einsatz_von_tostring","title":"Einsatz von <code>toString</code>","isH3":true,"content":"<p>Im folgenden Beispiel gibt der Aufruf <code>flag.toString()</code> den Wert \"<code>true</code>\" zurück:</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> flag <span class=\"token operator\">=</span> <span class=\"token keyword\">new</span> <span class=\"token class-name\">Boolean</span><span class=\"token punctuation\">(</span><span class=\"token boolean\">true</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token keyword\">var</span> myVar <span class=\"token operator\">=</span> flag<span class=\"token punctuation\">.</span><span class=\"token function\">toString</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n</code></pre></div>","titleAsText":"Einsatz von toString"}},{"type":"prose","value":{"id":"spezifikationen","title":"Spezifikationen","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Spezifikation</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Kommentar</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.ecma-international.org/publications/files/ECMA-ST-ARCH/ECMA-262,%201st%20edition,%20June%201997.pdf\" hreflang=\"en\" lang=\"en\" class=\"external\" title=\"Die 'ECMAScript 1st Edition (ECMA-262)' Spezifikation\" rel=\" noopener\">ECMAScript 1st Edition (ECMA-262)</a></td>\n   <td><span class=\"spec-standard\">Standard</span></td>\n   <td>Initiale Definition.</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.ecma-international.org/ecma-262/5.1/#sec-15.6.4.2\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript 5.1 (ECMA-262)<br><small lang=\"de\">Die Definition von 'Boolean.prototype.toString' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-standard\">Standard</span></td>\n   <td>&nbsp;</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.ecma-international.org/ecma-262/6.0/#sec-boolean.prototype.tostring\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript 2015 (6th Edition, ECMA-262)<br><small lang=\"de\">Die Definition von 'Boolean.prototype.toString' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-standard\">Standard</span></td>\n   <td>&nbsp;</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://tc39.es/ecma262/#sec-boolean.prototype.tostring\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript (ECMA-262)<br><small lang=\"de\">Die Definition von 'Boolean.prototype.toString' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-living\">Lebender Standard</span></td>\n   <td>&nbsp;</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"Browserkompatibilität","id":"browserkompatibilität","isH3":false,"query":"javascript.builtins.Boolean.toString","dataURL":"/de/docs/Web/JavaScript/Reference/Global_Objects/Boolean/toString/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect3\">\n\n\n<p></p><p></p>\n</div>"}},{"type":"prose","value":{"id":"siehe_auch","title":"Siehe auch","isH3":false,"content":"<ul>\n <li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a></li>\n</ul>"}}],"toc":[{"text":"Syntax","id":"syntax"},{"text":"Beschreibung","id":"beschreibung"},{"text":"Beispiele","id":"beispiele"},{"text":"Spezifikationen","id":"spezifikationen"},{"text":"Browserkompatibilität","id":"browserkompatibilität"},{"text":"Siehe auch","id":"siehe_auch"}],"summary":"Die toString() gibt einen String, der eine Boolean Objekt repräsentiert, zurück.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Boolean.prototype.toString()","locale":"en-US","native":"English (US)"},{"title":"Boolean.prototype.toSource()","locale":"es","native":"Español"},{"title":"Boolean.prototype.toString()","locale":"fr","native":"Français"},{"title":"Boolean.prototype.toString()","locale":"ja","native":"日本語"},{"title":"Boolean.prototype.toString()","locale":"ko","native":"한국어"},{"title":"Boolean.prototype.toString()","locale":"pl","native":"Polski"},{"title":"Boolean.prototype.toString()","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Boolean.prototype.toString()","locale":"ru","native":"Русский"},{"title":"Boolean.prototype.toString()","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"de/web/javascript/reference/global_objects/boolean/tostring","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/javascript/reference/global_objects/boolean/tostring/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/JavaScript","title":"JavaScript"},{"uri":"/de/docs/Web/JavaScript/Reference","title":"JavaScript-Referenz"},{"uri":"/de/docs/Web/JavaScript/Reference/Global_Objects","title":"Globale Objekte"},{"uri":"/de/docs/Web/JavaScript/Ref