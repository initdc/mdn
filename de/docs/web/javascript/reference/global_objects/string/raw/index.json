n</div>"}},{"type":"prose","value":{"id":"see_also","title":"See also","isH3":false,"content":"<ul>\n <li><a href=\"/de/docs/Web/JavaScript/Reference/Template_literals\">Template strings</a></li>\n <li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/String\"><code>String</code></a></li>\n <li><a href=\"/de/docs/Web/JavaScript/Reference/Lexical_grammar\">Lexical grammar</a></li>\n</ul>"}}],"toc":[{"text":"Syntax","id":"syntax"},{"text":"Beschreibung","id":"beschreibung"},{"text":"Beispiele","id":"beispiele"},{"text":"Spezifikationen","id":"spezifikationen"},{"text":"Browserkompatibilität","id":"browserkompatibilität"},{"text":"See also","id":"see_also"}],"summary":"Einen rohen, unveränderbaren String des template Strings.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"String.raw()","locale":"en-US","native":"English (US)"},{"title":"String.raw()","locale":"es","native":"Español"},{"title":"String.raw()","locale":"fr","native":"Français"},{"title":"String.raw()","locale":"ja","native":"日本語"},{"title":"String.raw()","locale":"ko","native":"한국어"},{"title":"String.raw()","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"String.raw()","locale":"ru","native":"Русский"},{"title":"String.raw()","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"de/web/javascript/reference/global_objects/string/raw","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/javascript/reference/global_objects/string/raw/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/JavaScript","title":"JavaScript"},{"uri":"/de/docs/Web/JavaScript/Reference","title":"JavaScript-Referenz"},{"uri":"/de/docs/Web/JavaScript/Reference/Global_Objects","title":"Globale Objekte"},{"uri":"/de/docs/Web/JavaScript/Reference/Global_Objects/St