<a href=\"#\"><strong>Eigenschaften</strong></a><ol><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/arguments\"><code>Function.prototype.arguments</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/caller\"><code>Function.prototype.caller</code></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/displayName\"><code>Function.prototype.displayName</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/length\"><code>Function.prototype.length</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/name\"><code>Function.prototype.name</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Function/prototype\"><code>Function.prototype.prototype</code> <small>(en-US)</small></a></li></ol></li><li><a href=\"#\"><strong>Methoden</strong></a><ol><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/apply\"><code>Function.prototype.apply()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/bind\"><code>Function.prototype.bind()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/call\"><code>Function.prototype.call()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/toString\"><code>Function.prototype.toString()</code></a></li></ol></li><li><strong><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object\"><code>Object</code></a></strong></li><li><a href=\"#\"><strong>Eigenschaften</strong></a><ol><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/constructor\"><code>Object.prototype.constructor</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/proto\"><code>Object.prototype.__proto__</code></a></li></ol></li><li><a href=\"#\"><strong>Methoden</strong></a><ol><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineGetter__\"><code>Object.prototype.__defineGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineSetter__\"><code>Object.prototype.__defineSetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupGetter__\"><code>Object.prototype.__lookupGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupSetter__\"><code>Object.prototype.__lookupSetter__()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwnProperty\"><code>Object.prototype.hasOwnProperty()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/isPrototypeOf\"><code>Object.prototype.isPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/propertyIsEnumerable\"><code>Object.prototype.propertyIsEnumerable()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/setPrototypeOf\"><code>Object.setPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/toLocaleString\"><code>Object.prototype.toLocaleString()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/valueOf\"><code>Object.prototype.valueOf()</code></a></li></ol></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p><strong><code>match()</code></strong>&nbsp;gibt zurück, wo ein regulärer&nbsp;Ausdruck in einem String enthalten ist.&nbsp;</p>"}},{"type":"prose","value":{"id":"syntax","title":"Syntax","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><var>str</var>.match(<var>regexp</var>)</pre>"}},{"type":"prose","value":{"id":"parameter","title":"Parameter","isH3":true,"content":"<dl>\n <dt id=\"regexp\"><code>regexp</code></dt>\n <dd>Ein&nbsp;regulärer&nbsp;Ausdruck. Falls <code>regexp</code>&nbsp;kein Objekt vom Typ&nbsp;<a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/RegExp\"><code>RegExp</code></a> ist wird es mit Hilfe von&nbsp;<code>new RegExp(obj)</code>&nbsp;konvertiert. Falls dieser Parameter nicht übergeben wird, wird ein&nbsp;<a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Array\"><code>Array</code></a> mit einem leeren <a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/String\"><code>String</code></a>&nbsp;zurückgegben: [\"\"].</dd>\n</dl>"}},{"type":"prose","value":{"id":"rückgabewert","title":"Rückgabewert","isH3":true,"content":"<p>Es wird ein&nbsp;<a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Array\"><code>Array</code></a> zurückgegeben, das als erstes Element den gesamten übereinstimmenden String enthält, gefolgt von allen weiteren Treffern, die in Klammern&nbsp;angegeben wurden. Falls keine&nbsp;Übereinstimmungen gefunden wurden, wird&nbsp;<a href=\"/de/docs/Web/JavaScript/Reference/Operators/null\"><code>null</code></a> zurückgegeben.</p>"}},{"type":"prose","value":{"id":"beschreibung","title":"Beschreibung","isH3":false,"content":"<p>Falls der&nbsp;reguläre&nbsp;Ausdruck nicht den Modifikator&nbsp;<code>g</code>&nbsp;enthält, verhält sich&nbsp;<strong><code>match()</code>&nbsp;</strong>wie&nbsp;<a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/RegExp/exec\"><code>RegExp.exec()</code> <small>(en-US)</small></a>. Im&nbsp;zurückgegebenen <a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Array\"><code>Array</code></a> sind zusätzlich die&nbsp;propertys <code>input</code>&nbsp;und&nbsp;<code>index</code> &nbsp;enthalten.&nbsp;<code>input</code>&nbsp;ist gleich dem zu durchsuchenden String,&nbsp;<code>index</code>&nbsp;enthält den Index der Übereinstimmung.</p>\n\n<p>Falls der <code>g</code>&nbsp;Modifikator im&nbsp;regulären&nbsp;Ausdruck enthalten ist, wird ein&nbsp;<a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Array\"><code>Array</code></a> mit allen übereinstimmenden Substrings zurückgegeben.</p>"}},{"type":"prose","value":{"id":"beispiele","title":"Beispiele","isH3":false,"content":""}},{"type":"prose","value":{"id":"verwendung_von_match","title":"Verwendung von&nbsp;<code>match()</code>","isH3":true,"content":"<p>Im folgenden Beispiel wird <strong><code>match()</code></strong>&nbsp;verwendet um&nbsp;<code>'Kapitel'</code>&nbsp;und anschließend eine oder mehrere Zahlen, gefolgt von einem Punkt und einer Zahl, 0 oder mehrmals zu finden. Der&nbsp;reguläre&nbsp;Ausdruck enthält den <code>i</code> Modifikator und unterscheidet&nbsp;somit nicht zwischen Groß- und Kleinschreibung.</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> str <span class=\"token operator\">=</span> <span class=\"token string\">'Fuer mehr Informationen siehe Kapitel 3.4.5.1'</span><span class=\"token punctuation\">;</span>\n<span class=\"token keyword\">var</span> re <span class=\"token operator\">=</span> <span class=\"token regex\"><span class=\"token regex-delimiter\">/</span><span class=\"token regex-source language-regex\">siehe (kapitel \\d+(\\.\\d)*)</span><span class=\"token regex-delimiter\">/</span><span class=\"token regex-flags\">i</span></span><span class=\"token punctuation\">;</span>\n<span class=\"token keyword\">var</span> found <span class=\"token operator\">=</span> str<span class=\"token punctuation\">.</span><span class=\"token function\">match</span><span class=\"token punctuation\">(</span>re<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n\nconsole<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span>found<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n\n<span class=\"token comment\">// gibt folgendes auf der Konsole aus:</span>\n<span class=\"token comment\">//   [ 'siehe Kapitel 3.4.5.1',</span>\n<span class=\"token comment\">//     'Kapitel 3.4.5.1',</span>\n<span class=\"token comment\">//     '.1',</span>\n<span class=\"token comment\">//     index: 22,</span>\n<span class=\"token comment\">//     input: 'Fuer mehr Informationen siehe Kapitel 3.4.5.1' ]</span>\n</code></pre></div>","titleAsText":"Verwendung von match()"}},{"type":"prose","value":{"id":"verwendung_von_match_mit_den_i_und_g_modifikatoren","title":"Verwendung von&nbsp;<code>match()</code>&nbsp;mit den <code>i</code> und <code>g</code>&nbsp;Modifikatoren","isH3":true,"content":"<p>Die Buchstaben von A - E und von a - e werden auf der Konsole ausgegeben.</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> str <span class=\"token operator\">=</span> <span class=\"token string\">'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz'</span><span class=\"token punctuation\">;</span>\n<span class=\"token keyword\">var</span> regexp <span class=\"token operator\">=</span> <span class=\"token regex\"><span class=\"token regex-delimiter\">/</span><span class=\"token regex-source language-regex\">[A-E]</span><span class=\"token regex-delimiter\">/</span><span class=\"token regex-flags\">gi</span></span><span class=\"token punctuation\">;</span>\n<span class=\"token keyword\">var</span> matches_array <span class=\"token operator\">=</span> str<span class=\"token punctuation\">.</span><span class=\"token function\">match</span><span class=\"token punctuation\">(</span>regexp<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n\nconsole<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span>matches_array<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// ['A', 'B', 'C', 'D', 'E', 'a', 'b', 'c', 'd', 'e']</span>\n</code></pre></div>","titleAsText":"Verwendung von match() mit den i und g Modifikatoren"}},{"type":"prose","value":{"id":"match_ohne_parameter","title":"<code>match()</code>&nbsp;ohne Parameter","isH3":true,"content":"<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> str <span class=\"token operator\">=</span> <span class=\"token string\">\"Nichts kommt von nichts.\"</span><span class=\"token punctuation\">;</span>\n\nstr<span class=\"token punctuation\">.</span><span class=\"token function\">match</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// [\"\"]</span></code></pre></div>","titleAsText":"match() ohne Parameter"}},{"type":"prose","value":{"id":"verwendung_mit_einem_nicht_regulären_ausdruck","title":"Verwendung mit einem nicht&nbsp;regulären&nbsp;Ausdruck","isH3":true,"content":"<p>Falls ein String oder eine Zahl anstatt eines&nbsp;regulären&nbsp;Ausdrucks übergeben wird, wird der Parameter in einen&nbsp;<a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/RegExp\"><code>regulären&nbsp;Ausdruck</code></a> konvertiert. Ist es eine positive Zahl mit Vorzeichen, wird das positive Vorzeichen ignoriert.</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> str1 <span class=\"token operator\">=</span> <span class=\"token string\">\"NaN bedeutet not a number. Infinity enthält -Infinity and +Infinity in JavaScript.\"</span><span class=\"token punctuation\">,</span>\n    str2 <span class=\"token operator\">=</span> <span class=\"token string\">\"Zahlen: 1, 6, 3\"</span><span class=\"token punctuation\">,</span>\n    str3 <span class=\"token operator\">=</span> <span class=\"token string\">\"null ist ein Datentyp.\"</span><span class=\"token punctuation\">;</span>\n\nstr1<span class=\"token punctuation\">.</span><span class=\"token function\">match</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"number\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>   <span class=\"token comment\">// [\"number\"]</span>\nstr1<span class=\"token punctuation\">.</span><span class=\"token function\">match</span><span class=\"token punctuation\">(</span><span class=\"token number\">NaN</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>        <span class=\"token comment\">// [\"NaN\"]</span>\nstr1<span class=\"token punctuation\">.</span><span class=\"token function\">match</span><span class=\"token punctuation\">(</span><span class=\"token number\">Infinity</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>   <span class=\"token comment\">// [\"Infinity\"]</span>\nstr1<span class=\"token punctuation\">.</span><span class=\"token function\">match</span><span class=\"token punctuation\">(</span><span class=\"token operator\">+</span><span class=\"token number\">Infinity</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>  <span class=\"token comment\">// [\"Infinity\"]</span>\nstr1<span class=\"token punctuation\">.</span><span class=\"token function\">match</span><span class=\"token punctuation\">(</span><span class=\"token operator\">-</span><span class=\"token number\">Infinity</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>  <span class=\"token comment\">// [\"-Infinity\"]</span>\nstr2<span class=\"token punctuation\">.</span><span class=\"token function\">match</span><span class=\"token punctuation\">(</span><span class=\"token number\">6</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>          <span class=\"token comment\">// [\"6\"]</span>\nstr2<span class=\"token punctuation\">.</span><span class=\"token function\">match</span><span class=\"token punctuation\">(</span><span class=\"token operator\">+</span><span class=\"token number\">3</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>         <span class=\"token comment\">// [\"3\"]</span>\nstr3<span class=\"token punctuation\">.</span><span class=\"token function\">match</span><span class=\"token punctuation\">(</span><span class=\"token keyword\">null</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>       <span class=\"token comment\">// [\"null\"]</span></code></pre></div>","titleAsText":"Verwendung mit einem nicht regulären Ausdruck"}},{"type":"prose","value":{"id":"spezifikationen","title":"Spezifikationen","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Spezifikation</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Extras</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.ecma-international.org/publications/files/ECMA-ST-ARCH/ECMA-262,%203rd%20edition,%20December%201999.pdf\" hreflang=\"en\" lang=\"en\" class=\"external\" title=\"Die 'ECMAScript 3rd Edition (ECMA-262)' Spezifikation\" rel=\" noopener\">ECMAScript 3rd Edition (ECMA-262)</a></td>\n   <td><span class=\"spec-standard\">Standard</span></td>\n   <td>Anfangsdefinition. Implementiert in JavaScript 1.2.</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.ecma-international.org/ecma-262/5.1/#sec-15.5.4.10\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript 5.1 (ECMA-262)<br><small lang=\"de\">Die Definition von 'String.prototype.match' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-standard\">Standard</span></td>\n   <td></td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.ecma-international.org/ecma-262/6.0/#sec-string.prototype.match\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript 2015 (6th Edition, ECMA-262)<br><small lang=\"de\">Die Definition von 'String.prototype.match' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-standard\">Standard</span></td>\n   <td></td>\n  </tr>\n  <tr>\n   <td><a href=\"https://tc39.es/ecma262/#sec-string.prototype.match\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript (ECMA-262)<br><small lang=\"de\">Die Definition von 'String.prototype.match' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-living\">Lebender Standard</span></td>\n   <td></td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"Browser-Kompatibilität","id":"browser-kompatibilität","isH3":false,"query":"javascript.builtins.String.match","dataURL":"/de/docs/Web/JavaScript/Reference/Global_Objects/String/match/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"siehe_auch","title":"Siehe auch","isH3":false,"content":"<ul>\n <li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/RegExp\"><code>RegExp</code></a></li>\n <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/RegExp/exec\"><code>RegExp.prototype.exec()</code> <small>(en-US)</small></a></li>\n <li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/RegExp/test\"><code>RegExp.prototype.test()</code></a></li>\n</ul>"}}],"toc":[{"text":"Syntax","id":"syntax"},{"text":"Beschreibung","id":"beschreibung"},{"text":"Beispiele","id":"beispiele"},{"text":"Spezifikationen","id":"spezifikationen"},{"text":"Browser-Kompatibilität","id":"browser-kompatibilität"},{"text":"Siehe auch","id":"siehe_auch"}],"summary":"match() gibt zurück, wo ein regulärer Ausdruck in einem String enthalten ist.","popularity":0.0019,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"String.prototype.match()","locale":"en-US","native":"English (US)"},{"title":"String.prototype.match()","locale":"es","native":"Español"},{"title":"String.prototype.match()","locale":"fr","native":"Français"},{"title":"String.prototype.match()","locale":"ja","native":"日本語"},{"title":"String.prototype.match()","locale":"ko","native":"한국어"},{"title":"String.prototype.match()","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"String.prototype.match()","locale":"ru","native":"Русский"},{"title":"String.prototype.match()","locale":"zh-CN","native":"中文 (简体)"},{"title":"String.prototype.match()","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"de/web/javascript/reference/global_objects/string/match","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/javascript/reference/global_objects/string/match/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/JavaScript","title":"JavaScript"},{"uri":"/de/docs/Web/JavaScript/Reference","title":"JavaScript-Referenz"},{"uri":"/de/docs/Web/JavaScript/Reference/Global_Objects","title":"Globale Objekte"},{"uri":"/de/docs/Web/JavaScript/Reference/Global_Objects/String","title":"String"},{"uri":"/de/docs/Web/JavaScript/Reference/Global_Objects/String/match","title":"String.prototype.match()"}],"pageTitle":"String.prototype.match() - JavaScript | MDN","noIndexing":false}}