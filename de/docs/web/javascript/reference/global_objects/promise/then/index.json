{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"Promise.prototype.then()","mdn_url":"/de/docs/Web/JavaScript/Reference/Global_Objects/Promise/then","locale":"de","native":"Deutsch","sidebarHTML":"<ol><li><strong><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects\">Standard-Objekte</a></strong></li><li><strong><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Promise\"><code>Promise</code></a></strong></li><li data-default-state=\"open\"><a href=\"#\"><strong>Methoden</strong></a><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Promise/@@species\"><code>get Promise[@@species]</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Promise/all\"><code>Promise.all()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Promise/allSettled\"><code>Promise.allSettled()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Promise/any\"><code>Promise.any()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Promise/catch\"><code>Promise.prototype.catch()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Promise/finally\"><code>Promise.prototype.finally()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Promise/race\"><code>Promise.race()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Promise/reject\"><code>Promise.reject()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Promise/resolve\"><code>Promise.resolve()</code> <small>(en-US)</small></a></li><li><em><code>Promise.prototype.then()</code></em></li></ol></li><li><strong>Vererbung:</strong></li><li><strong><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function\"><code>Function</code></a></strong></li><li><a href=\"#\"><strong>Eigenschaften</strong></a><ol><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/arguments\"><code>Function.prototype.arguments</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/caller\"><code>Function.prototype.caller</code></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/displayName\"><code>Function.prototype.displayName</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/length\"><code>Function.prototype.length</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/name\"><code>Function.prototype.name</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Function/prototype\"><code>Function.prototype.prototype</code> <small>(en-US)</small></a></li></ol></li><li><a href=\"#\"><strong>Methoden</strong></a><ol><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/apply\"><code>Function.prototype.apply()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/bind\"><code>Function.prototype.bind()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/call\"><code>Function.prototype.call()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/toString\"><code>Function.prototype.toString()</code></a></li></ol></li><li><strong><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object\"><code>Object</code></a></strong></li><li><a href=\"#\"><strong>Eigenschaften</strong></a><ol><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/constructor\"><code>Object.prototype.constructor</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/proto\"><code>Object.prototype.__proto__</code></a></li></ol></li><li><a href=\"#\"><strong>Methoden</strong></a><ol><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineGetter__\"><code>Object.prototype.__defineGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineSetter__\"><code>Object.prototype.__defineSetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupGetter__\"><code>Object.prototype.__lookupGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupSetter__\"><code>Object.prototype.__lookupSetter__()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwnProperty\"><code>Object.prototype.hasOwnProperty()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/isPrototypeOf\"><code>Object.prototype.isPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/propertyIsEnumerable\"><code>Object.prototype.propertyIsEnumerable()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/setPrototypeOf\"><code>Object.setPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/toLocaleString\"><code>Object.prototype.toLocaleString()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/valueOf\"><code>Object.prototype.valueOf()</code></a></li></ol></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<div id=\"sect2\">Die <strong>then()</strong>-Methode gibt ein&nbsp;<code>Promise</code>-Objekt zurück. Sie benötigt zwei Argumente, jeweils eine Callback-Funktion für den Erfolg und den Fehlschlag des&nbsp;<code>Promise</code>.</div>\n\n<div id=\"sect3\">&nbsp;</div>"}},{"type":"prose","value":{"id":"syntax","title":"Syntax","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><var>p.then(onFulfilled, onRejected)</var>;\n\np.then(function(value) {\n   // fulfillment\n  }, function(reason) {\n  // rejection\n});\n</pre>"}},{"type":"prose","value":{"id":"parameter","title":"Parameter","isH3":true,"content":"<dl>\n <dt id=\"onfulfilled\">onFulfilled</dt>\n <dd>Eine <a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function\"><code>Function</code></a>, welche aufgerufen wird, wenn der&nbsp;<code>Promise</code> erfüllt wurde. Die Funktion hat ein Argument, den Rückgabewert&nbsp;<code>value</code>.</dd>\n <dt id=\"onrejected\">onRejected&nbsp;<span class=\"badge inline optional\">Optional</span></dt>\n <dd>Eine <a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function\"><code>Function</code></a>, welche aufgerufen wird, wenn der&nbsp;<code>Promise</code> fehlschlägt. Die Funktion hat ein Argument, den Grund für den Fehlschlag:&nbsp;<code>reason</code>. Ist keine Funktion definiert, so wird sie intern durch die \"Thrower\" Funktion ersetzt (Dieser gibt einen Fehler als&nbsp;Argument&nbsp;zurück)</dd>\n</dl>"}},{"type":"prose","value":{"id":"beschreibung","title":"Beschreibung","isH3":false,"content":"<p>Die&nbsp;<code>then</code>- und <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Promise/catch\"><code>Promise.prototype.catch()</code> <small>(en-US)</small></a>-Methoden, können, da sie&nbsp;Promises&nbsp;zurückgeben<font face=\"Consolas, Liberation Mono, Courier, monospace\">, verkettetet werden&nbsp;</font>— ein Vorgehen, das <em>composition</em> genannt wird.</p>"}},{"type":"prose","value":{"id":"beispiele","title":"Beispiele","isH3":false,"content":""}},{"type":"prose","value":{"id":"benutzen_der_then-methode","title":"Benutzen der&nbsp;<code>then</code>-Methode","isH3":true,"content":"<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> p1 <span class=\"token operator\">=</span> <span class=\"token keyword\">new</span> <span class=\"token class-name\">Promise</span><span class=\"token punctuation\">(</span><span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">resolve<span class=\"token punctuation\">,</span> reject</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n  <span class=\"token function\">resolve</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"Success!\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n  <span class=\"token comment\">// or</span>\n  <span class=\"token comment\">// reject (\"Error!\");</span>\n<span class=\"token punctuation\">}</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n\np1<span class=\"token punctuation\">.</span><span class=\"token function\">then</span><span class=\"token punctuation\">(</span><span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">value</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n  console<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span>value<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// Success!</span>\n<span class=\"token punctuation\">}</span><span class=\"token punctuation\">,</span> <span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">reason</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n  console<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span>reason<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// Error!</span>\n<span class=\"token punctuation\">}</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n</code></pre></div>","titleAsText":"Benutzen der then-Methode"}},{"type":"prose","value":{"id":"verketten","title":"Verketten","isH3":true,"content":"<p>Da die <code>then</code>-Methode einen <code>Promise</code> zurückliefert, können <code>then</code>-Aufrufe leicht verkettet werden.</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> p2 <span class=\"token operator\">=</span> <span class=\"token keyword\">new</span> <span class=\"token class-name\">Promise</span><span class=\"token punctuation\">(</span><span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">resolve<span class=\"token punctuation\">,</span> reject</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n  <span class=\"token function\">resolve</span><span class=\"token punctuation\">(</span><span class=\"token number\">1</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token punctuation\">}</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n\np2<span class=\"token punctuation\">.</span><span class=\"token function\">then</span><span class=\"token punctuation\">(</span><span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">value</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n  console<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span>value<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// 1</span>\n  <span class=\"token keyword\">return</span> value <span class=\"token operator\">+</span> <span class=\"token number\">1</span><span class=\"token punctuation\">;</span>\n<span class=\"token punctuation\">}</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">.</span><span class=\"token function\">then</span><span class=\"token punctuation\">(</span><span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">value</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n  console<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span>value<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// 2</span>\n<span class=\"token punctuation\">}</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n\np2<span class=\"token punctuation\">.</span><span class=\"token function\">then</span><span class=\"token punctuation\">(</span><span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">value</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n  console<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span>value<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// 1</span>\n<span class=\"token punctuation\">}</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"spezifikationen","title":"Spezifikationen","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Spezifikation</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Kommentar</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.ecma-international.org/ecma-262/6.0/#sec-promise.prototype.then\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript 2015 (6th Edition, ECMA-262)<br><small lang=\"de\">Die Definition von 'Promise.prototype.then' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-standard\">Standard</span></td>\n   <td>Initiale Definition in einem ECMAScript-Standard.</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"browserkompatibilität","title":"Browserkompatibilität","isH3":false,"content":"<p></p><div class=\"notecard note\" id=\"sect4\"><strong><a href=\"https://github.com/mdn/browser-compat-data\" class=\"external\" rel=\" noopener\">Wir konvertieren die Kompatibilitätsdaten in ein maschinenlesbares JSON Format</a></strong>.\n            Diese Kompatibilitätstabelle liegt noch im alten Format vor,\n            denn die darin enthaltenen Daten wurden noch nicht konvertiert.\n            <strong><a href=\"/en-US/docs/MDN/Structures/Compatibility_tables\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">Finde heraus wie du helfen kannst! (en-US)</a></strong></div>\n\n<div class=\"htab\" id=\"sect5\">\n    <a id=\"AutoCompatibilityTable\" name=\"AutoCompatibilityTable\"></a>\n    <ul>\n        <li class=\"selected\"><a href=\"#compat-desktop\">Desktop</a></li>\n        <li><a href=\"#compat-mobile\">Mobile</a></li>\n    </ul>\n</div><p></p>\n\n<div id=\"compat-desktop\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Chrome</th>\n   <th>Firefox (Gecko)</th>\n   <th>Internet Explorer</th>\n   <th>Opera</th>\n   <th>Safari</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td>32</td>\n   <td><a href=\"/en-US/docs/Mozilla/Firefox/Releases/29\" title=\"Veröffentlicht am 2014-04-29.\">29.0</a> (29.0) [1]</td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td>19</td>\n   <td>7.1</td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<div id=\"compat-mobile\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Android</th>\n   <th>Firefox Mobile (Gecko)</th>\n   <th>IE Mobile</th>\n   <th>Opera Mobile</th>\n   <th>Safari Mobile</th>\n   <th>Chrome for Android</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td>29.0 (29.0) [1]</td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td><span style=\"color:#f00;\">Nicht unterstützt</span></td>\n   <td>8</td>\n   <td>32</td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<p>[1] Gecko 24 besitzt, unter dem Namen Future,&nbsp;eine experimentielle Implementation von Promise. In Gecko 25 wurde der Name final festgelegt aber standardmäßig durch die Einstellung&nbsp;<code>dom.promise.enabled&nbsp;</code>deaktiviert. Durch&nbsp;<a href=\"https://bugzilla.mozilla.org/show_bug.cgi?id=918806\" class=\"external\" rel=\" noopener\">Bug 918806</a> wurden Promises in Gecko 29 standardmäßig aktiviert.</p>"}},{"type":"prose","value":{"id":"siehe_auch","title":"Siehe auch","isH3":false,"content":"<ul>\n <li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Promise\"><code>Promise</code></a></li>\n <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Promise/catch\"><code>Promise.prototype.catch()</code> <small>(en-US)</small></a></li>\n</ul>"}}],"toc":[{"text":"Syntax","id":"syntax"},{"text":"Beschreibung","id":"beschreibung"},{"text":"Beispiele","id":"beispiele"},{"text":"Spezifikationen","id":"spezifikationen"},{"text":"Browserkompatibilität","id":"browserkompatibilität"},{"text":"Siehe auch","id":"siehe_auch"}],"summary":"Die then- und Promise.prototype.catch() (en-US)-Methoden, können, da sie Promises zurückgeben, verkettetet werden — ein Vorgehen, das composition genannt wird.","popularity":0.0009,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Promise.prototype.then()","locale":"en-US","native":"English (US)"},{"title":"Promise.prototype.then()","locale":"es","native":"Español"},{"title":"Promise.prototype.then()","locale":"fr","native":"Français"},{"title":"Promise.prototype.then()","locale":"ja","native":"日本語"},{"title":"Promise.prototype.then()","locale":"ko","native":"한국어"},{"title":"Promise.prototype.then()","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Promise.prototype.then()","locale":"ru","native":"Русский"},{"title":"Promise.prototype.then()","locale":"zh-CN","native":"中文 (简体)"},{"title":"Promise.prototype.then()","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"de/web/javascript/reference/global_objects/promise/then","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/javascript/reference/global_objects/promise/then/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/JavaScript","title":"JavaScript"},{"uri":"/de/docs/Web/JavaScript/Reference","title":"JavaScript-Referenz"},{"uri":"/de/docs/Web/JavaScript/Reference/Global_Objects","title":"Globale Objekte"},{"uri":"/de/docs/Web/JavaScript/Reference/Global_Objects/Promise","title":"Promise"},{"uri":"/de/docs/Web/JavaScript/Reference/Global_Objects/Promise/then","title":"Promise.prototype.then()"}],"pageTitle":"Promise.prototype.then() - JavaScript | MDN","noIndexing":false}}