{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"Generator","mdn_url":"/de/docs/Web/JavaScript/Reference/Global_Objects/Generator","locale":"de","native":"Deutsch","sidebarHTML":"<ol><li><strong><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects\">Standard-Objekte</a></strong></li><li><strong><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Generator\"><code>Generator</code></a></strong></li><li data-default-state=\"open\"><a href=\"#\"><strong>Methoden</strong></a><ol><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Generator/next\"><code>Generator.prototype.next()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Generator/return\"><code>Generator.prototype.return()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Generator/throw\"><code>Generator.prototype.throw()</code></a></li></ol></li><li><strong>Vererbung:</strong></li><li><strong><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function\"><code>Function</code></a></strong></li><li><a href=\"#\"><strong>Eigenschaften</strong></a><ol><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/arguments\"><code>Function.prototype.arguments</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/caller\"><code>Function.prototype.caller</code></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/displayName\"><code>Function.prototype.displayName</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/length\"><code>Function.prototype.length</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/name\"><code>Function.prototype.name</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Function/prototype\"><code>Function.prototype.prototype</code> <small>(en-US)</small></a></li></ol></li><li><a href=\"#\"><strong>Methoden</strong></a><ol><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/apply\"><code>Function.prototype.apply()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/bind\"><code>Function.prototype.bind()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/call\"><code>Function.prototype.call()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function/toString\"><code>Function.prototype.toString()</code></a></li></ol></li><li><strong><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object\"><code>Object</code></a></strong></li><li><a href=\"#\"><strong>Eigenschaften</strong></a><ol><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/constructor\"><code>Object.prototype.constructor</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/proto\"><code>Object.prototype.__proto__</code></a></li></ol></li><li><a href=\"#\"><strong>Methoden</strong></a><ol><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineGetter__\"><code>Object.prototype.__defineGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineSetter__\"><code>Object.prototype.__defineSetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupGetter__\"><code>Object.prototype.__lookupGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupSetter__\"><code>Object.prototype.__lookupSetter__()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwnProperty\"><code>Object.prototype.hasOwnProperty()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/isPrototypeOf\"><code>Object.prototype.isPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/propertyIsEnumerable\"><code>Object.prototype.propertyIsEnumerable()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/setPrototypeOf\"><code>Object.setPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/toLocaleString\"><code>Object.prototype.toLocaleString()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a></li><li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Object/valueOf\"><code>Object.prototype.valueOf()</code></a></li></ol></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p>Das <code><strong>Generator</strong></code> Objekt wird von der <a href=\"/de/docs/Web/JavaScript/Reference/Statements/function*\">Generator Function</a> zurückgegeben und entspricht beidem, dem <a href=\"/de/docs/Web/JavaScript/Reference/Iteration_protocols#the_iterable_protocol\">Iterable Protokoll</a> und dem <a href=\"/de/docs/Web/JavaScript/Reference/Iteration_protocols#the_iterator_protocol\">Iterator Protokoll</a>.</p>"}},{"type":"prose","value":{"id":"syntax","title":"Syntax","isH3":false,"content":"<pre class=\"syntaxbox notranslate\">function* gen() {\n  yield 1;\n  yield 2;\n  yield 3;\n}\n\nvar g = gen(); // \"Generator { }\"</pre>"}},{"type":"prose","value":{"id":"methoden","title":"Methoden","isH3":false,"content":"<dl>\n <dt id=\"generator.prototype.next\"><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Generator/next\"><code>Generator.prototype.next()</code></a></dt>\n <dd>Gibt einen Wert vom Generator zurück (ausgelöst durch <a href=\"/de/docs/Web/JavaScript/Reference/Operators/yield\"><code>yield</code></a>).</dd>\n <dt id=\"generator.prototype.return\"><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Generator/return\"><code>Generator.prototype.return()</code></a></dt>\n <dd>Gibt den gegebene Wert zurück und beendet den Generator.</dd>\n <dt id=\"generator.prototype.throw\"><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Generator/throw\"><code>Generator.prototype.throw()</code></a></dt>\n <dd>Erzeugt einen Fehler im Generator (beendet auch den Generator, wenn der Fehler nicht im Generator abgefangen wird).</dd>\n</dl>"}},{"type":"prose","value":{"id":"beispiele","title":"Beispiele","isH3":false,"content":""}},{"type":"prose","value":{"id":"ein_unendlicher_iterator","title":"Ein unendlicher Iterator","isH3":true,"content":"<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">function</span><span class=\"token operator\">*</span> <span class=\"token function\">idMaker</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n    <span class=\"token keyword\">var</span> index <span class=\"token operator\">=</span> <span class=\"token number\">0</span><span class=\"token punctuation\">;</span>\n    <span class=\"token keyword\">while</span><span class=\"token punctuation\">(</span><span class=\"token boolean\">true</span><span class=\"token punctuation\">)</span>\n        <span class=\"token keyword\">yield</span> index<span class=\"token operator\">++</span><span class=\"token punctuation\">;</span>\n<span class=\"token punctuation\">}</span>\n\n<span class=\"token keyword\">var</span> gen <span class=\"token operator\">=</span> <span class=\"token function\">idMaker</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// \"Generator { }\"</span>\n\nconsole<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span>gen<span class=\"token punctuation\">.</span><span class=\"token function\">next</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">.</span>value<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// 0</span>\nconsole<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span>gen<span class=\"token punctuation\">.</span><span class=\"token function\">next</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">.</span>value<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// 1</span>\nconsole<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span>gen<span class=\"token punctuation\">.</span><span class=\"token function\">next</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">.</span>value<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// 2</span>\n<span class=\"token comment\">// ...</span></code></pre></div>"}},{"type":"prose","value":{"id":"veraltete_generatorobjekte","title":"Veraltete Generatorobjekte","isH3":false,"content":"<p>Firefox (SpiderMonkey) hat eine frühe Version der Generatoren in <a href=\"/de/docs/Web/JavaScript/New_in_JavaScript/1.7\" class=\"page-not-created\" title=\"This is a link to an unwritten page\">JavaScript 1.7</a> implementiert, bei der kein Stern (*) in der Funktionsdeklaration nötig war (man benutzte nur das <code>yield</code> Schlüsselwort im Funktionsrumpf). Seit Firefox 58 (Released am 23. Januar 2018) sind diese veralteten Generatoren entfernt (<a href=\"https://bugzilla.mozilla.org/show_bug.cgi?id=1083482\" class=\"external\" rel=\" noopener\">Bug&nbsp;1083482</a>).</p>"}},{"type":"prose","value":{"id":"veraltete_generator_methoden","title":"Veraltete Generator Methoden","isH3":true,"content":"<dl>\n <dt id=\"generator.prototype.next_2\"><code>Generator.prototype.next() </code><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg></dt>\n <dd>Gibt einen Wert vom <a href=\"/de/docs/Web/JavaScript/Reference/Operators/yield\"><code>yield</code></a> Ausdruck zurück. Diese korrespondiert mit der <code>next()</code> Methode in ES2015 Generator Objekt.</dd>\n <dt id=\"generator.prototype.close\"><code>Generator.prototype.close()</code> <svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg></dt>\n <dd>Beendet einen Generator, so dass der Aufruf von <code>next()</code> zu einem <a class=\"page-not-created\" title=\"Die Beschreibung hierüber wurde bisher noch nicht geschrieben. Bitte überlege, mitzuwirken!\"><code>StopIteration</code></a> Fehler führt. Diese korrespondiert mit der <code>return()</code> Methode in ES2015 Generator Objekt.</dd>\n <dt id=\"generator.prototype.send\"><code>Generator.prototype.send()</code> <svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg></dt>\n <dd>Wird benutzt, um einen Wert zum Generator zu senden. Der wert wird vom <a href=\"/de/docs/Web/JavaScript/Reference/Operators/yield\"><code>yield</code></a> Ausdruck zurückgegeben und gibt einen Wert vom nächsten <a href=\"/de/docs/Web/JavaScript/Reference/Operators/yield\"><code>yield</code></a> Ausdruck zurück. Diese korrespondiert mit der <code>next(x)</code> Methode in ES2015 Generator Objekt.</dd>\n <dt id=\"generator\"><strong><code>Generator.</code></strong><code>prototype.</code><strong><code>throw()</code> </strong> <svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg></dt>\n <dd>Erzeugt einen Fehler im Generator. Diese korrespondiert mit der <code>throw()</code> Methode in ES2015 Generator Objekt.</dd>\n</dl>"}},{"type":"prose","value":{"id":"veraltete_generator_beispiele","title":"Veraltete Generator Beispiele","isH3":true,"content":"<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">function</span> <span class=\"token function\">fibonacci</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n  <span class=\"token keyword\">var</span> a <span class=\"token operator\">=</span> <span class=\"token keyword\">yield</span> <span class=\"token number\">1</span><span class=\"token punctuation\">;</span>\n  <span class=\"token keyword\">yield</span> a <span class=\"token operator\">*</span> <span class=\"token number\">2</span><span class=\"token punctuation\">;</span>\n<span class=\"token punctuation\">}</span>\n\n<span class=\"token keyword\">var</span> it <span class=\"token operator\">=</span> <span class=\"token function\">fibonacci</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\nconsole<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span>it<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>          <span class=\"token comment\">// \"Generator {  }\"</span>\nconsole<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span>it<span class=\"token punctuation\">.</span><span class=\"token function\">next</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>   <span class=\"token comment\">// 1</span>\nconsole<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span>it<span class=\"token punctuation\">.</span><span class=\"token function\">send</span><span class=\"token punctuation\">(</span><span class=\"token number\">10</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// 20</span>\nconsole<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span>it<span class=\"token punctuation\">.</span><span class=\"token function\">close</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>  <span class=\"token comment\">// undefined</span>\nconsole<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span>it<span class=\"token punctuation\">.</span><span class=\"token function\">next</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>   <span class=\"token comment\">// throws StopIteration (as the generator is now closed)</span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"spezifikationen","title":"Spezifikationen","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Spezifikation</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Kommentar</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.ecma-international.org/ecma-262/6.0/#sec-generator-objects\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript 2015 (6th Edition, ECMA-262)<br><small lang=\"de\">Die Definition von 'Generator objects' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-standard\">Standard</span></td>\n   <td>Initiale Definition.</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://tc39.es/ecma262/#sec-generator-objects\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript (ECMA-262)<br><small lang=\"de\">Die Definition von 'Generator objects' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-living\">Lebender Standard</span></td>\n   <td>&nbsp;</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"Browserkompatibilität","id":"browserkompatibilität","isH3":false,"query":"javascript.builtins.Generator","dataURL":"/de/docs/Web/JavaScript/Reference/Global_Objects/Generator/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"siehe_auch","title":"Siehe auch","isH3":false,"content":""}},{"type":"prose","value":{"id":"veraltete_generatoren","title":"Veraltete Generatoren","isH3":true,"content":"<ul>\n <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Deprecated_and_obsolete_features\">Die veraltete Generator Function <small>(en-US)</small></a></li>\n <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Deprecated_and_obsolete_features\">Der veraltete Generator Functionsausdruck <small>(en-US)</small></a></li>\n <li><a class=\"page-not-created\" title=\"Die Beschreibung hierüber wurde bisher noch nicht geschrieben. Bitte überlege, mitzuwirken!\"><code>StopIteration</code></a></li>\n <li><a href=\"/de/docs/Web/JavaScript/Reference/Deprecated_and_obsolete_features/The_legacy_Iterator_protocol\">The legacy Iterator protocol</a></li>\n</ul>"}},{"type":"prose","value":{"id":"es2015_generatoren","title":"ES2015 Generatoren","isH3":true,"content":"<ul>\n <li><a href=\"/de/docs/Web/JavaScript/Reference/Functions\">Functions</a></li>\n <li><a href=\"/de/docs/Web/JavaScript/Reference/Statements/function\"><code>function</code></a></li>\n <li><a href=\"/de/docs/Web/JavaScript/Reference/Operators/function\"><code>function Ausdruck</code></a></li>\n <li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/Function\"><code>Function</code></a></li>\n <li><a href=\"/de/docs/Web/JavaScript/Reference/Statements/function*\"><code>function*</code></a></li>\n <li><a href=\"/de/docs/Web/JavaScript/Reference/Operators/function*\"><code>function* Ausdruck</code></a></li>\n <li><a href=\"/de/docs/Web/JavaScript/Reference/Global_Objects/GeneratorFunction\"><code>GeneratorFunction</code></a></li>\n <li><a href=\"/en-US/docs/Web/JavaScript/Reference/Iteration_protocols\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">The Iterator protocol (en-US)</a></li>\n</ul>"}}],"toc":[{"text":"Syntax","id":"syntax"},{"text":"Methoden","id":"methoden"},{"text":"Beispiele","id":"beispiele"},{"text":"Veraltete Generatorobjekte","id":"veraltete_generatorobjekte"},{"text":"Spezifikationen","id":"spezifikationen"},{"text":"Browserkompatibilität","id":"browserkompatibilität"},{"text":"Siehe auch","id":"siehe_auch"}],"summary":"Das Generator Objekt wird von der Generator Function zurückgegeben und entspricht beidem, dem Iterable Protokoll und dem Iterator Protokoll.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Generator","locale":"en-US","native":"English (US)"},{"title":"Generador","locale":"es","native":"Español"},{"title":"Generator","locale":"fr","native":"Français"},{"title":"Generator","locale":"ja","native":"日本語"},{"title":"Generator","locale":"ko","native":"한국어"},{"title":"Generator","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Generator","locale":"ru","native":"Русский"},{"title":"Generator","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"de/web/javascript/reference/global_objects/generator","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/javascript/reference/global_objects/generator/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/JavaScript","title":"JavaScript"},{"uri":"/de/docs/Web/JavaScript/Reference","title":"JavaScript-Referenz"},{"uri":"/de/docs/Web/JavaScript/Reference/Global_Objects","title":"Globale Objekte"},{"uri":"/de/docs/Web/JavaScript/Reference/Global_Objects/Generator","title":"Generator"}],"pageTitle":"Generator - JavaScript | MDN","noIndexing":false}}