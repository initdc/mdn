td>\n   <td>12</td>\n   <td>5.1</td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<div id=\"compat-mobile\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Android</th>\n   <th>Chrome for Android</th>\n   <th>Firefox Mobile (Gecko)</th>\n   <th>IE Mobile</th>\n   <th>Opera Mobile</th>\n   <th>Safari Mobile</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td>25</td>\n   <td>4.0 (2.0)</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td>12</td>\n   <td>8.0</td>\n  </tr>\n </tbody>\n</table>\n</div>"}},{"type":"prose","value":{"id":"siehe_auch","title":"Siehe auch","isH3":false,"content":"<ul>\n <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/WebGLContextEvent\"><code>WebGLContextEvent</code> <small>(en-US)</small></a></li>\n <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/WebGLRenderingContext/isContextLost\"><code>WebGLRenderingContext.isContextLost()</code> <small>(en-US)</small></a></li>\n <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/WEBGL_lose_context\"><code>WEBGL_lose_context</code> <small>(en-US)</small></a>, <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/WEBGL_lose_context/loseContext\"><code>WEBGL_lose_context.loseContext()</code> <small>(en-US)</small></a>, <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/WEBGL_lose_context/restoreContext\"><code>WEBGL_lose_context.restoreContext()</code> <small>(en-US)</small></a></li>\n</ul>"}}],"toc":[{"text":"Beispiel","id":"beispiel"},{"text":"Vererbung","id":"vererbung"},{"text":"Spezifikationen","id":"s