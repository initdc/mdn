{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"File.type","mdn_url":"/de/docs/Web/API/File/type","locale":"de","native":"Deutsch","sidebarHTML":"<ol><li><strong><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/File_API\">File API <small>(en-US)</small></a></strong></li><li><strong><a href=\"/de/docs/Web/API/File\"><code>File</code></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>Konstruktor</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/File/File\"><code>File()</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Eigenschaften</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/File/lastModified\"><code>lastModified</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/File/lastModifiedDate\"><code>lastModifiedDate</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/API/File/name\"><code>name</code></a></li><li><em><code>type</code></em></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/File/webkitRelativePath\"><code>webkitRelativePath</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Vererbung:</summary><ol><li><a href=\"/de/docs/Web/API/Blob\"><code>Blob</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Ähnliche Seiten zu File API</summary><ol><li><a href=\"/de/docs/Web/API/Blob\"><code>Blob</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/FileList\"><code>FileList</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/API/FileReader\"><code>FileReader</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/FileReaderSync\"><code>FileReaderSync</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/API/URL/createObjectURL\"><code>URL.createObjectURL()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/URL/revokeObjectURL\"><code>URL.revokeObjectURL()</code> <small>(en-US)</small></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p>Gibt den Internet Media Typ (<a href=\"/en-US/docs/Web/HTTP/Basics_of_HTTP/MIME_types\">MIME</a>) einer Datei zurück, welche durch ein <a href=\"/de/docs/Web/API/File\"><code>File</code></a> Objekt dargestellt wird.</p>"}},{"type":"prose","value":{"id":"syntax","title":"Syntax","isH3":false,"content":"<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> name <span class=\"token operator\">=</span> file<span class=\"token punctuation\">.</span>type<span class=\"token punctuation\">;</span></code></pre></div>"}},{"type":"prose","value":{"id":"wert","title":"Wert","isH3":false,"content":"<p>Eine Zeichenkette, welche den Internet Media Typ (MIME) enthält und den Typ der Datei angibt, zum Beispiel \"image/png\" für ein PNG Bild</p>"}},{"type":"prose","value":{"id":"beispiel","title":"Beispiel","isH3":false,"content":"<div class=\"code-example\"><pre class=\"brush: html notranslate\"><code><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>input</span> <span class=\"token attr-name\">type</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>file<span class=\"token punctuation\">\"</span></span> <span class=\"token attr-name\">multiple</span> <span class=\"token special-attr\"><span class=\"token attr-name\">onchange</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span><span class=\"token value javascript language-javascript\"><span class=\"token function\">showType</span><span class=\"token punctuation\">(</span><span class=\"token keyword\">this</span><span class=\"token punctuation\">)</span></span><span class=\"token punctuation\">\"</span></span></span><span class=\"token punctuation\">&gt;</span></span>\n</code></pre></div>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">function</span> <span class=\"token function\">showType</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">fileInput</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n  <span class=\"token keyword\">var</span> files <span class=\"token operator\">=</span> fileInput<span class=\"token punctuation\">.</span>files<span class=\"token punctuation\">;</span>\n\n  <span class=\"token keyword\">for</span> <span class=\"token punctuation\">(</span><span class=\"token keyword\">var</span> i <span class=\"token operator\">=</span> <span class=\"token number\">0</span><span class=\"token punctuation\">;</span> i <span class=\"token operator\">&lt;</span> files<span class=\"token punctuation\">.</span>length<span class=\"token punctuation\">;</span> i<span class=\"token operator\">++</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n    <span class=\"token keyword\">var</span> name <span class=\"token operator\">=</span> files<span class=\"token punctuation\">[</span>i<span class=\"token punctuation\">]</span><span class=\"token punctuation\">.</span>name<span class=\"token punctuation\">;</span>\n    <span class=\"token keyword\">var</span> type <span class=\"token operator\">=</span> files<span class=\"token punctuation\">[</span>i<span class=\"token punctuation\">]</span><span class=\"token punctuation\">.</span>type<span class=\"token punctuation\">;</span>\n    <span class=\"token function\">alert</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"Filename: \"</span> <span class=\"token operator\">+</span> name <span class=\"token operator\">+</span> <span class=\"token string\">\" , Type: \"</span> <span class=\"token operator\">+</span> type<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n  <span class=\"token punctuation\">}</span>\n<span class=\"token punctuation\">}</span></code></pre></div>\n\n<p><strong>Hinweis:</strong> Basierend auf der aktuellen Implementierung, lesen Browser nicht wirklich den Bytestrom einer Datei, um ihren Medientyp zu bestimmen. Es wird aufgrund der Dateiendung angenommen; eine PNG-Bilddatei, die in .txt umbenannt wird, würde \"<em>text/plain</em>\" und nicht \"<em>image/png</em>\" ergeben. Darüber hinaus ist <code>file.type</code> im Allgemeinen nur für gängige Dateitypen wie Bilder, HTML-Dokumente, Audio und Video zuverlässig. Seltene Dateierweiterungen würden eine leere Zeichenkette zurückgeben. Die Client-Konfiguration (z.B. die Windows-Registrierung) kann auch bei gängigen Typen zu unerwarteten Werten führen. <strong>Entwicklern wird empfohlen, sich nicht auf diese Eigenschaft als einziges Validierungsschema zu verlassen.</strong></p>"}},{"type":"prose","value":{"id":"spezifikation","title":"Spezifikation","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">Spezifikation</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Kommentar</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"https://w3c.github.io/FileAPI/#dfn-type\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">File API<br><small lang=\"de\">Die Definition von 'type' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-wd\">Arbeitsentwurf</span></td>\n   <td>Initiale Definition.</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"Browser-Kompatibilität","id":"browser-kompatibilität","isH3":false,"query":"api.File.type","dataURL":"/de/docs/Web/API/File/type/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"siehe_auch","title":"Siehe auch","isH3":false,"content":"<ul>\n <li><a href=\"/en-US/docs/Web/API/File_API/Using_files_from_web_applications\">Using files from web applications</a></li>\n <li>Blog Post: <a href=\"https://textslashplain.com/2018/07/26/be-skeptical-of-client-reported-mime-content-types/\" class=\"external\" rel=\" noopener\">Be skeptical of client-reported MIME types</a></li>\n</ul>"}}],"toc":[{"text":"Syntax","id":"syntax"},{"text":"Wert","id":"wert"},{"text":"Beispiel","id":"beispiel"},{"text":"Spezifikation","id":"spezifikation"},{"text":"Browser-Kompatibilität","id":"browser-kompatibilität"},{"text":"Siehe auch","id":"siehe_auch"}],"summary":"Gibt den Internet Media Typ (MIME) einer Datei zurück, welche durch ein File Objekt dargestellt wird.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"File.type","locale":"en-US","native":"English (US)"},{"title":"File.type","locale":"ja","native":"日本語"},{"title":"File.type","locale":"ko","native":"한국어"},{"title":"File.type","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"de/web/api/file/type","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/api/file/type/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/API","title":"Web API Referenz"},{"uri":"/de/docs/Web/API/File","title":"File"},{"uri":"/de/docs/Web/API/File/type","title":"File.type"}],"pageTitle":"File.type - Web API Referenz | MDN","noIndexing":false}}