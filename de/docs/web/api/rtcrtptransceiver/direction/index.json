{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"RTCRtpTransceiver.direction","mdn_url":"/de/docs/Web/API/RTCRtpTransceiver/direction","locale":"de","native":"Deutsch","sidebarHTML":"<ol><li><strong><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/WebRTC_API\">WebRTC API <small>(en-US)</small></a></strong></li><li><strong><a href=\"/de/docs/Web/API/RTCRtpTransceiver\"><code>RTCRtpTransceiver</code></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>Eigenschaften</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCRtpTransceiver/currentDirection\"><code>currentDirection</code> <small>(en-US)</small></a></li><li><em><code>direction</code></em></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCRtpTransceiver/mid\"><code>mid</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCRtpTransceiver/receiver\"><code>receiver</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCRtpTransceiver/sender\"><code>sender</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCRtpTransceiver/stopped\"><code>stopped</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Methoden</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCRtpTransceiver/setCodecPreferences\"><code>setCodecPreferences()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCRtpTransceiver/stop\"><code>stop()</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Ähnliche Seiten zu WebRTC</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/MediaDevices/getUserMedia\"><code>MediaDevices.getUserMedia()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Navigator/mediaDevices\"><code>Navigator.mediaDevices</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCCertificate\"><code>RTCCertificate</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCDTMFSender\"><code>RTCDTMFSender</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCDTMFToneChangeEvent\"><code>RTCDTMFToneChangeEvent</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCDataChannel\"><code>RTCDataChannel</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCDataChannelEvent\"><code>RTCDataChannelEvent</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCDtlsTransport\"><code>RTCDtlsTransport</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCErrorEvent\"><code>RTCErrorEvent</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/API/RTCIceCandidate\"><code>RTCIceCandidate</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCIceTransport\"><code>RTCIceTransport</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCPeerConnection\"><code>RTCPeerConnection</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCPeerConnectionIceErrorEvent\"><code>RTCPeerConnectionIceErrorEvent</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCPeerConnectionIceEvent\"><code>RTCPeerConnectionIceEvent</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCRtpReceiver\"><code>RTCRtpReceiver</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCRtpSender\"><code>RTCRtpSender</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCSctpTransport\"><code>RTCSctpTransport</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCSessionDescription\"><code>RTCSessionDescription</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCStatsReport\"><code>RTCStatsReport</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCTrackEvent\"><code>RTCTrackEvent</code> <small>(en-US)</small></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p><span class=\"seoSummary\">Das&nbsp;<a href=\"/de/docs/Web/API/RTCRtpTransceiver\"><code>RTCRtpTransceiver</code></a> <code><strong>direction</strong></code>&nbsp;Attribut gibt als&nbsp;String&nbsp;die bevorzugte Transceiver-Richtung an.&nbsp;Es muss sich hierbei um einen Wert des</span>&nbsp;<a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCRtpTransceiver/direction\"><code>RTCRtpTransceiverDirection</code> <small>(en-US)</small></a> Enum handeln.</p>\n\n<p>Die tatsächliche, aktuelle Richtung des Transceivers kann über das&nbsp;<a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCRtpTransceiver/currentDirection\"><code>currentDirection</code> <small>(en-US)</small></a> Attribut abgelesen werden.</p>"}},{"type":"prose","value":{"id":"syntax","title":"Syntax","isH3":false,"content":"<pre class=\"syntaxbox notranslate\">var <em>direction</em> = <em>RTCRtpTransceiver</em>.direction</pre>"}},{"type":"prose","value":{"id":"value","title":"Value","isH3":true,"content":"<p>Ein <a href=\"/de/docs/conflicting/Web/JavaScript/Reference/Global_Objects/String\"><code>DOMString</code></a>, dessen Wert einem Wert des&nbsp;<code>RTCRtpTransceiverDirection</code>&nbsp;Enum /&nbsp;Aufzählungstypen entspricht und die bevorzugte Transceiver-Richtung angibt. {{page(\"/en-US/docs/Web/API/RTCRtpTransceiverDirection\", \"Values\")}}</p>"}},{"type":"prose","value":{"id":"exceptions","title":"Exceptions","isH3":true,"content":"<p>Wird der&nbsp;<code>direction</code>&nbsp;Wert eines Transceivers gesetzt, können folgende Fehler auftreten:</p>\n\n<dl>\n <dt id=\"invalidstateerror\"><code>InvalidStateError</code></dt>\n <dd>Der Receiver des Transceivers&nbsp;<a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCPeerConnection\"><code>RTCPeerConnection</code> <small>(en-US)</small></a> wurde bereits geschlossen und befindet sich nun im <code>closed</code>&nbsp;Zustand oder der&nbsp;<a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCRtpReceiver\"><code>RTCRtpReceiver</code> <small>(en-US)</small></a> wurde gestoppt und befinet sich im&nbsp;<code>stopped</code>&nbsp;Zustand.</dd>\n</dl>"}},{"type":"prose","value":{"id":"hinweise_zur_nutzung","title":"Hinweise zur Nutzung","isH3":false,"content":""}},{"type":"prose","value":{"id":"ändern_der_übertragungsrichtung","title":"Ändern der Übertragungsrichtung","isH3":true,"content":"<p>Wird der Wert des&nbsp;<code>direction</code>&nbsp;Attributes geändert, wird eine&nbsp;<code>InvalidStateError</code>&nbsp;Ausnahme geworfen, insofern die RTCPeerConnection bereits geschlossen wurde oder aber der jeweils betroffene Receiver oder Sender&nbsp;bereits gestoppt wurde.</p>\n\n<p>Wenn der neu gesetzte Wert für&nbsp;<code>direction</code>&nbsp;sich vom aktuellen Wert unterscheidet, muss die Übertragung mit dem Peer neu verhandelt werden, es wird also ein&nbsp;<code><a href=\"/de/docs/Web/Reference/Events/negotiationneeded\" title=\"This is a link to an unwritten page\" class=\"page-not-created\">negotiationneeded</a></code> Event auf der&nbsp;<a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCPeerConnection\"><code>RTCPeerConnection</code> <small>(en-US)</small></a> ausgelöst.</p>"}},{"type":"prose","value":{"id":"transceiver-richtung_in_sdp","title":"Transceiver-Richtung in SDP","isH3":true,"content":"<p>Der&nbsp;<code>direction</code>&nbsp;Wert wird von&nbsp;<a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCPeerConnection/createOffer\"><code>RTCPeerConnection.createOffer()</code> <small>(en-US)</small></a> bzw.&nbsp;<a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCPeerConnection/createAnswer\"><code>RTCPeerConnection.createAnswer()</code> <small>(en-US)</small></a> genutzt, um die entsprechenden SDP-Nachrichten&nbsp;zu generieren. SDP stellt die Richtung über eine Attribut-Zeile&nbsp;(a-line) dar. Wenn die Richtung des Transceivers&nbsp;als&nbsp;<code>\"sendrecv\"</code>&nbsp;definiert wurde, so enthält die hierzu erzeugte SDP-Nachricht folgende Attribut-Zeile:</p>\n\n<pre class=\"notranslate\">a=sendrecv</pre>"}},{"type":"prose","value":{"id":"specifications","title":"Specifications","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Specification</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Comment</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://w3c.github.io/webrtc-pc/#dom-rtcrtptransceiver-direction\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">WebRTC 1.0: Real-time Communication Between Browsers<br><small lang=\"de\">Die Definition von 'RTCRtpTransceiver.direction' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-cr\">Anwärter Empfehlung</span></td>\n   <td></td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"Browser compatibility","id":"browser_compatibility","isH3":false,"query":"api.RTCRtpTransceiver.direction","dataURL":"/de/docs/Web/API/RTCRtpTransceiver/direction/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect2\">\n\n\n<p></p><p></p>\n</div>"}},{"type":"prose","value":{"id":"see_also","title":"See also","isH3":false,"content":"<ul>\n <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RTCRtpTransceiver/currentDirection\"><code>RTCRtpTransceiver.currentDirection</code> <small>(en-US)</small></a></li>\n</ul>"}}],"toc":[{"text":"Syntax","id":"syntax"},{"text":"Hinweise zur Nutzung","id":"hinweise_zur_nutzung"},{"text":"Specifications","id":"specifications"},{"text":"Browser compatibility","id":"browser_compatibility"},{"text":"See also","id":"see_also"}],"summary":"Das RTCRtpTransceiver direction Attribut gibt als String die bevorzugte Transceiver-Richtung an. Es muss sich hierbei um einen Wert des","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"RTCRtpTransceiver.direction","locale":"en-US","native":"English (US)"},{"title":"RTCRtpTransceiver.direction","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"de/web/api/rtcrtptransceiver/direction","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/api/rtcrtptransceiver/direction/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/API","title":"Web API Referenz"},{"uri":"/de/docs/Web/API/RTCRtpTransceiver","title":"RTCRtpTransceiver"},{"uri":"/de/docs/Web/API/RTCRtpTransceiver/direction","title":"RTCRtpTransceiver.direction"}],"pageTitle":"RTCRtpTransceiver.direction - Web API Referenz | MDN","noIndexing":false}}