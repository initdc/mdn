s/Web/API/Document/pointercancel_event\"><code>pointercancel</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointerdown_event\"><code>pointerdown</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointerenter_event\"><code>pointerenter</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointerleave_event\"><code>pointerleave</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointerlockchange_event\"><code>pointerlockchange</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointerlockerror_event\"><code>pointerlockerror</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointermove_event\"><code>pointermove</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointerout_event\"><code>pointerout</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointerover_event\"><code>pointerover</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointerup_event\"><code>pointerup</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/API/Document/readystatechange_event\"><code>readystatechange</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/scroll_event\"><code>scroll</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/selectionchange_event\"><code>selectionchange</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/selectstart_event\"><code>selectstart</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/touchcancel_event\"><code>touchcancel</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/touchend_event\"><code>touchend</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/touchmove_event\"><code>touchmove</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/touchstart_event\"><code>touchstart</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/visibilitychange_event\"><code>visibilitychange</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Vererbung:</summary><ol><li><a href=\"/de/docs/Web/API/Node\"><code>Node</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/EventTarget\"><code>EventTarget</code> <small>(en-US)</small></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>\n\n<p>Die&nbsp;<code><strong>Document.dir</strong></code> Eigenschaft ist ein <a href=\"/de/docs/conflicting/Web/JavaScript/Reference/Global_Objects/String\"><code>DOMString</code></a>, welcher die&nbsp;direktionaler&nbsp;Bedeutung von einem Text eines Dokuments repräsentiert. Entweder von links nach rechts (Standard) oder rechts nach links. Mögliche Werte sind&nbsp;<code>'rtl'</code> rechts nach links, und&nbsp;<code>'ltr',</code> links nach rechts.</p>"}},{"type":"prose","value":{"id":"syntax","title":"Syntax","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><em>dirStr</em> = <em>document.</em>dir;\n<em>document.dir</em> = <em>dirStr;</em>\n</pre>"}},{"type":"prose","value":{"id":"specifications","title":"Spezifikationen","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">Spezifikationen</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Kommentar</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"https://html.spec.whatwg.org/multipage/dom.html#the-dir-attribute:dom-dir\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML Living Standard<br><small lang=\"de\">Die Definition von 'Document.dir' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-living\">Lebender Standard</span></td>\n   <td>Initiale Spezifikation</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"browserkompatibilität","title":"Browserkompatibilität","isH3":false,"content":"<p></p><div class=\"notecard note\" id=\"sect1\"><strong><a href=\"https://github.com/mdn/browser-compat-data\" class=\"external\" rel=\" noopener\">Wir konvertieren die Kompatibilitätsdaten in ein maschinenlesbares JSON Format</a></strong>.\n            Diese Kompatibilitätstabelle liegt noch im alten Format vor,\n            denn die darin enthaltenen Daten wurden noch nicht konvertiert.\n            <strong><a href=\"/en-US/docs/MDN/Structures/Compatibility_tables\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">Finde heraus wie du helfen kannst! (en-US)</a></strong></div>\n\n<div class=\"htab\" id=\"sect2\">\n    <a id=\"AutoCompatibilityTable\" name=\"AutoCompatibilityTable\"></a>\n    <ul>\n        <li class=\"selected\"><a href=\"#compat-desktop\">Desktop</a></li>\n        <li><a href=\"#compat-mobile\">Mobile</a></li>\n    </ul>\n</div><p></p>\n\n<div id=\"compat-desktop\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Chrome</th>\n   <th>Edge</th>\n   <th>Firefox (Gecko)</th>\n   <th>Internet Explorer</th>\n   <th>Opera</th>\n   <th>Safari (WebKit)</th>\n  </tr>\n  <tr>\n   <td>Basis Unterstützung</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span> [1]</td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<div id=\"compat-mobile\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Android</th>\n   <th>Edge</th>\n   <th>Firefox Mobile (Gecko)</th>\n   <th>IE&nbsp;Phone</th>\n   <th>Opera Mobile</th>\n   <th>Safari Mobile</th>\n  </tr>\n  <tr>\n   <td>Basis Unterstützung</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span> [1]</td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<p>[1] Vor Firefox 23, hat die&nbsp;<code>Document.dir</code> Eigenschaft \"ltr\" wiedergegeben. unabhängig der Einstellung von dem dir-Attribut im Haupt-Element (root) <a href=\"/de/docs/Web/HTML/Element/html\"><code>&lt;html&gt;</code></a>. Und wenn eine Richtung im&nbsp;<code>&lt;html&gt;</code> gesetzt war, hatte die Veränderung der Sichtbarkeit keinen Effekt&nbsp;(obwohl der spätere Abruf des <code>Document.dir</code> wird behaupten, dass die Direktionalität geändert wurde). Wenn ein solches Attribut nicht im&nbsp;<code>&lt;html&gt;</code> gesetzt ist und die Eigenschaft geändert wurde, werden beide sichtbaren direktionale geändert und die&nbsp;<code>document.dir</code> &nbsp;Eigenschaft wird die Änderung korrekt wiedergeben.</p>"}},{"type":"prose","value":{"id":"siehe_auch","title":"Siehe auch","isH3":false,"content":"<ul>\n <li><a class=\"external\" href=\"http://msdn.microsoft.com/en-us/library/ms533731.aspx\" rel=\"freelink noopener\">http://msdn.microsoft.com/en-us/library/ms533731.aspx</a></li>\n</ul>"}}],"toc":[{"text":"Syntax","id":"syntax"},{"text":"Spezifikationen","id":"specifications"},{"text":"Browserkompatibilität","id":"browserkompatibilität"},{"text":"Siehe auch","id":"siehe_auch"}],"summary":"Die Document.dir Eigenschaft ist ein DOMString, welcher die direktionaler Bedeutung von einem Text eines Dokuments repräsentiert. Entweder von links nach rechts (Standard) oder rechts nach links. Mögliche Werte sind 'rtl' rechts nach links, und 'ltr', links nach rechts.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Document.dir","locale":"en-US","native":"English (US)"},{"title":"Document.dir","locale":"es","native":"Español"},{"title":"Document.dir","locale":"fr","native":"Français"},{"title":"Document.dir","locale":"ja","native":"日本語"},{"title":"Document.dir","locale":"ru","native":"Русский"},{"title":"Document.dir","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"de/web/api/document/dir","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/api/document/dir/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/API","title":"Web API Referenz"},{"uri":"/de/docs/Web/API/Document","title":"Document"},{"uri":"/de/docs/Web/API/Document/dir","title":"Document.dir"}],"pageTitle":"Document.dir - Web API Referenz | MDN","noIndexing":false}}