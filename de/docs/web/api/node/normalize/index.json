"token punctuation\">(</span> document<span class=\"token punctuation\">.</span><span class=\"token function\">createTextNode</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"Teil 1 \"</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\nwrapper<span class=\"token punctuation\">.</span><span class=\"token function\">appendChild</span><span class=\"token punctuation\">(</span> document<span class=\"token punctuation\">.</span><span class=\"token function\">createTextNode</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"Teil 2 \"</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n\n<span class=\"token comment\">// Her wäre: wrapper.childNodes.length === 2</span>\n<span class=\"token comment\">// wrapper.childNodes[0].textContent === \"Teil 1 \"</span>\n<span class=\"token comment\">// wrapper.childNodes[1].textContent === \"Teil 2 \"</span>\n\nwrapper<span class=\"token punctuation\">.</span><span class=\"token function\">normalize</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n\n<span class=\"token comment\">// Jetzt: wrapper.childNodes.length === 1</span>\n<span class=\"token comment\">// wrapper.childNodes[0].textContent === \"Teil 1 Teil 2 \"</span></code></pre></div>"}},{"type":"prose","value":{"id":"specification","title":"Spezifikation","isH3":false,"content":"<ul>\n <li><a class=\"external\" href=\"https://www.w3.org/TR/DOM-Level-2-Core/core.html#ID-normalize\" rel=\" noopener\">DOM Level 2 Core: Node.normalize</a></li>\n</ul>"}},{"type":"prose","value":{"id":"see_also","title":"Verwandte Themen","isH3":false,"content":"<ul>\n <li><a href=\"/en-US/docs/Web/API/Text/splitText\" title=\"DOM/Text.splitText\"><code>Text.splitText</code></a></li>\n</ul>"}}],