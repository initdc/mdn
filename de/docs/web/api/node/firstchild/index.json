{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"Node.firstChild","mdn_url":"/de/docs/Web/API/Node/firstChild","locale":"de","native":"Deutsch","sidebarHTML":"<ol><li><strong><a href=\"/de/docs/Web/API/Node\"><code>Node</code></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>Eigenschaften</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/baseURI\"><code>baseURI</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/API/Node/childNodes\"><code>childNodes</code></a></li><li><em><code>firstChild</code></em></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/isConnected\"><code>isConnected</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/API/Node/lastChild\"><code>lastChild</code></a></li><li><a href=\"/de/docs/Web/API/Node/nextSibling\"><code>nextSibling</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/nodeName\"><code>nodeName</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/nodeType\"><code>nodeType</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/API/Node/nodeValue\"><code>nodeValue</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/ownerDocument\"><code>ownerDocument</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/parentElement\"><code>parentElement</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/API/Node/parentNode\"><code>parentNode</code></a></li><li><a href=\"/de/docs/Web/API/Node/previousSibling\"><code>previousSibling</code></a></li><li><a href=\"/de/docs/Web/API/Node/textContent\"><code>textContent</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Methoden</summary><ol><li><a href=\"/de/docs/Web/API/Node/appendChild\"><code>appendChild()</code></a></li><li><a href=\"/de/docs/Web/API/Node/cloneNode\"><code>cloneNode()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/compareDocumentPosition\"><code>compareDocumentPosition()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/contains\"><code>contains()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/getRootNode\"><code>getRootNode()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/API/Node/hasChildNodes\"><code>hasChildNodes()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/insertBefore\"><code>insertBefore()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/isDefaultNamespace\"><code>isDefaultNamespace()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/isEqualNode\"><code>isEqualNode()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/isSameNode\"><code>isSameNode()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/isSupported\"><code>isSupported()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/lookupNamespaceURI\"><code>lookupNamespaceURI()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/lookupPrefix\"><code>lookupPrefix()</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/API/Node/normalize\"><code>normalize()</code></a></li><li><a href=\"/de/docs/Web/API/Node/removeChild\"><code>removeChild()</code></a></li><li><a href=\"/de/docs/Web/API/Node/replaceChild\"><code>replaceChild()</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Vererbung:</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/EventTarget\"><code>EventTarget</code> <small>(en-US)</small></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"allgemein","title":"Allgemein","isH3":false,"content":"<p><code>firstChild</code> gibt den ersten Kindknoten (<code>childNode</code>) eines Datenknotens zurück.</p>"}},{"type":"prose","value":{"id":"syntax","title":"Syntax","isH3":false,"content":"<pre class=\"eval notranslate\">var ersterKindknoten = element.firstChild;\n</pre>\n\n<p>Die Variable <var>ersterKindknoten</var> enthält einen Datenknoten.</p>"}},{"type":"prose","value":{"id":"beispiel","title":"Beispiel","isH3":false,"content":"<p>Folgendes HTML-Dokument ist gegeben:</p>\n\n<div class=\"code-example\"><pre class=\"brush:html notranslate\"><code><span class=\"token doctype\"><span class=\"token punctuation\">&lt;!</span><span class=\"token doctype-tag\">DOCTYPE</span> <span class=\"token name\">html</span><span class=\"token punctuation\">&gt;</span></span>\n<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>html</span><span class=\"token punctuation\">&gt;</span></span>\n  <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>body</span><span class=\"token punctuation\">&gt;</span></span>\n    <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>h3</span><span class=\"token punctuation\">&gt;</span></span>Texte<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>h3</span><span class=\"token punctuation\">&gt;</span></span>\n    <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>p</span><span class=\"token punctuation\">&gt;</span></span>Hier steht Text!<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>p</span><span class=\"token punctuation\">&gt;</span></span>\n  <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>body</span><span class=\"token punctuation\">&gt;</span></span>\n<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>html</span><span class=\"token punctuation\">&gt;</span></span>\n</code></pre></div>\n\n<p>Um auf das erste Kindelement zuzugreifen, kann man folgenden Code verwenden:</p>\n\n<div class=\"code-example\"><pre class=\"brush:javascript notranslate\"><code><span class=\"token keyword\">var</span> ersterKindknoten <span class=\"token operator\">=</span> document<span class=\"token punctuation\">.</span>body<span class=\"token punctuation\">.</span>firstChild<span class=\"token punctuation\">;</span>\n</code></pre></div>\n\n<p>In diesem Fall ist der erste Kindknoten ein Textknoten, da sich zwischen dem Schlusstag des <code>Paragraphs</code> und dem Start-Tag von <code>&lt;body&gt;</code> ein Zeilenumbruch und vier Leerzeichen befinden.</p>"}},{"type":"prose","value":{"id":"anmerkungen","title":"Anmerkungen","isH3":false,"content":"<ul>\n <li>Gibt <code>null</code> zurück, wenn der gegebene Datenknoten keine Kindknoten hat.</li>\n <li><code>firstChild</code> berücksichtigt wie bereits erwähnt auch <code>TextNodes</code>. Daher wird jede Art von Whitespace innerhalb eines Elements als Kindknoten interpretiert. Im obigen Beispiel geschieht das durch die Einrückungen im HTML-Dokument. Falls Sie Textknoten als Rückgabewert ausschließen, und nur HTML-Elemente erhalten wollen, verwenden Sie statt <code>firstChild</code> bitte <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Element/firstElementChild\"><code>Element.firstElementChild</code> <small>(en-US)</small></a>.</li>\n</ul>"}},{"type":"prose","value":{"id":"spezifikationen","title":"Spezifikationen","isH3":false,"content":"<ul>\n <li><a class=\"external\" href=\"https://www.w3.org/TR/REC-DOM-Level-1/level-one-core.html#attribute-firstChild\" rel=\" noopener\">DOM Level 1 Core: firstChild</a> (en)</li>\n <li><a class=\"external\" href=\"https://www.w3.org/TR/DOM-Level-2-Core/core.html#ID-169727388\" rel=\" noopener\">DOM Level 2 Core: firstChild</a> (en)</li>\n</ul>"}},{"type":"prose","value":{"id":"siehe_auch","title":"Siehe auch:","isH3":false,"content":"<ul>\n <li><a href=\"/de/docs/Web/API/Node\"><code>Node</code></a></li>\n <li><a href=\"/de/docs/Web/API/Node/lastChild\"><code>Node.lastChild</code></a></li>\n <li><a href=\"/de/docs/Web/API/Node/previousSibling\"><code>Node.previousSibling</code></a></li>\n <li><a href=\"/de/docs/Web/API/Node/childNodes\"><code>Node.childNodes</code></a></li>\n</ul>\n\n<p></p>"}}],"toc":[{"text":"Allgemein","id":"allgemein"},{"text":"Syntax","id":"syntax"},{"text":"Beispiel","id":"beispiel"},{"text":"Anmerkungen","id":"anmerkungen"},{"text":"Spezifikationen","id":"spezifikationen"},{"text":"Siehe auch:","id":"siehe_auch"}],"summary":"firstChild gibt den ersten Kindknoten (childNode) eines Datenknotens zurück.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Node.firstChild","locale":"en-US","native":"English (US)"},{"title":"element.firstChild","locale":"fr","native":"Français"},{"title":"Node.firstChild","locale":"ja","native":"日本語"},{"title":"element.firstChild","locale":"ko","native":"한국어"},{"title":"element.firstChild","locale":"pl","native":"Polski"},{"title":"Node.firstChild","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Node.firstChild","locale":"ru","native":"Русский"},{"title":"Node.firstChild","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"de/web/api/node/firstchild","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/api/node/firstchild/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/API","title":"Web API Referenz"},{"uri":"/de/docs/Web/API/Node","title":"Node"},{"uri":"/de/docs/Web/API/Node/firstChild","title":"Node.firstChild"}],"pageTitle":"Node.firstChild - Web API Referenz | MDN","noIndexing":false}}