PI/TextDecoder\"><code>TextDecoder</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/TextEncoder\"><code>TextEncoder</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/TimeRanges\"><code>TimeRanges</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/TreeWalker\"><code>TreeWalker</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLDocument\"><code>XMLDocument</code> <small>(en-US)</small></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\">\n<div id=\"sect2\"></div>\n</div>\n\n<p>Die <code><strong>Node.hasChildNodes()</strong></code> Methode liefert einen <strong>Boolean</strong> Wert der anzeigt ob die aktuelle <a href=\"/de/docs/Web/API/Node\"><code>Node</code></a> <a href=\"/en-US/docs/Web/API/Node/childNodes\" title=\"DOM/Node.childNodes\">child nodes</a> hat oder nicht.</p>"}},{"type":"prose","value":{"id":"syntax","title":"Syntax","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><code><em>result</em> = <em>node</em>.hasChildNodes();</code></pre>\n\n<dl>\n <dt id=\"result\"><code>result</code></dt>\n <dd>enthält den return Wert <code>true</code> oder <code>false</code>.</dd>\n</dl>"}},{"type":"prose","value":{"id":"example","title":"Beispiele","isH3":false,"content":"<p>Das nächste Beispiel entfernt die erste child node innerhalb dem element mit der id <code>\"foo\"</code> wenn foo child nodes enthält.</p>\n\n<div class=\"code-example\"><pre class=\"brush:js notranslate\"><code><span class=\"token keyword\">var</span> foo <span class=\"token operator\">=</span> document<span class=\"token punctuation\">.</span><span class=\"token function\">getElementById</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"foo\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token keyword\">if</span> <span class=\"token punctuation\">(</span>foo<span class=\"token punctuation\">.</span><span class=\"token function\">hasChildNodes</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n    <span class=\"token comment\">// do something with 'foo.childNodes'</span>\n<span class=\"token punctuation\">}</span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"polyfill","title":"Polyfill","isH3":false,"content":"<div class=\"code-example\"><pre class=\"brush:js notranslate\"><code><span class=\"token punctuation\">;</span><span class=\"token punctuation\">(</span><span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">prototype</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n    prototype<span class=\"token punctuation\">.</span>hasChildNodes <span class=\"token operator\">=</span> prototype<span class=\"token punctuation\">.</span>hasChildNodes <span class=\"token operator\">||</span> <span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n        <span class=\"token keyword\">return</span> <span class=\"token operator\">!</span><span class=\"token operator\">!</span><span class=\"token keyword\">this</span><span class=\"token punctuation\">.</span>firstChild<span class=\"token punctuation\">;</span>\n    <span class=\"token punctuation\">}</span>\n<span class=\"token punctuation\">}</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">(</span><span class=\"token class-name\">Node</span><span class=\"token punctuation\">.</span>prototype<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"zusammenfassung","title":"Zusammenfassung","isH3":false,"content":"<p>Es gibt unterschiedliche Wege herauszufinden ob die node eine child node enthält.</p>\n\n<ul>\n <li>node.hasChildNodes()</li>\n <li>node.firstChild !=&nbsp;null (or just node.firstChild)</li>\n <li>node.childNodes &amp;&amp; node.childNodes.length (or&nbsp;node.childNodes.length &gt; 0)</li>\n</ul>"}},{"type":"prose","value":{"id":"specification","title":"Spezifikation","isH3":false,"content":"<ul>\n <li><a href=\"https://dom.spec.whatwg.org/#dom-node-haschildnodes\" class=\"external\" rel=\" noopener\">WHATWG: hasChildNodes</a></li>\n <li><a class=\"external\" href=\"https://www.w3.org/TR/2000/REC-DOM-Level-2-Core-20001113/core.html#ID-810594187\" rel=\" noopener\">hasChildNodes</a></li>\n</ul>"}},{"type":"prose","value":{"id":"browser_kompatibilität","title":"Browser Kompatibilität","isH3":false,"content":"<p></p><div class=\"notecard note\" id=\"sect3\"><strong><a href=\"https://github.com/mdn/browser-compat-data\" class=\"external\" rel=\" noopener\">Wir konvertieren die Kompatibilitätsdaten in ein maschinenlesbares JSON Format</a></strong>.\n            Diese Kompatibilitätstabelle liegt noch im alten Format vor,\n            denn die darin enthaltenen Daten wurden noch nicht konvertiert.\n            <strong><a href=\"/en-US/docs/MDN/Structures/Compatibility_tables\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">Finde heraus wie du helfen kannst! (en-US)</a></strong></div>\n\n<div class=\"htab\" id=\"sect4\">\n    <a id=\"AutoCompatibilityTable\" name=\"AutoCompatibilityTable\"></a>\n    <ul>\n        <li class=\"selected\"><a href=\"#compat-desktop\">Desktop</a></li>\n        <li><a href=\"#compat-mobile\">Mobile</a></li>\n    </ul>\n</div><p></p>\n\n<div id=\"compat-desktop\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Chrome</th>\n   <th>Edge</th>\n   <th>Firefox (Gecko)</th>\n   <th>Internet Explorer</th>\n   <th>Opera</th>\n   <th>Safari</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td>7.0</td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<div id=\"compat-mobile\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Android</th>\n   <th>Edge</th>\n   <th>Firefox Mobile (Gecko)</th>\n   <th>IE Mobile</th>\n   <th>Opera Mobile</th>\n   <th>Safari Mobile</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n   <td><span style=\"color: #888\" title=\"Bitte mit der frühsten Version des Supports updaten.\">(Ja)</span></td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<p>&nbsp;</p>"}},{"type":"prose","value":{"id":"see_also","title":"Siehe auch","isH3":false,"content":"<ul>\n <li><a href=\"/de/docs/Web/API/Node/childNodes\"><code>Node.childNodes</code></a></li>\n <li><a class=\"page-not-created\" title=\"Die Beschreibung hierüber wurde bisher noch nicht geschrieben. Bitte überlege, mitzuwirken!\"><code>Node.hasAttributes</code></a></li>\n</ul>"}}],"toc":[{"text":"Syntax","id":"syntax"},{"text":"Beispiele","id":"example"},{"text":"Polyfill","id":"polyfill"},{"text":"Zusammenfassung","id":"zusammenfassung"},{"text":"Spezifikation","id":"specification"},{"text":"Browser Kompatibilität","id":"browser_kompatibilität"},{"text":"Siehe auch","id":"see_also"}],"summary":"Die Node.hasChildNodes() Methode liefert einen Boolean Wert der anzeigt ob die aktuelle Node child nodes hat oder nicht.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Node.hasChildNodes()","locale":"en-US","native":"English (US)"},{"title":"Node.hasChildNodes()","locale":"es","native":"Español"},{"title":"element.hasChildNodes","locale":"fr","native":"Français"},{"title":"Node.hasChildNodes()","locale":"ja","native":"日本語"},{"title":"Node.hasChildNodes()","locale":"ko","native":"한국어"},{"title":"element.hasChildNodes","locale":"pl","native":"Polski"},{"title":"Node.hasChildNodes()","locale":"ru","native":"Русский"},{"title":"Node.hasChildNodes","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"de/web/api/node/haschildnodes","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/api/node/haschildnodes/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/API","title":"Web API Referenz"},{"uri":"/de/docs/Web/API/Node","title":"Node"},{"uri":"/de/docs/Web/API/Node/hasChildNodes","title":"Node.hasChildNodes()"}],"pageTitle":"