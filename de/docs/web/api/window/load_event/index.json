{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"load","mdn_url":"/de/docs/Web/API/Window/load_event","locale":"de","native":"Deutsch","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p>Das&nbsp;<code>load</code> Ereignis&nbsp;wird ausgelöst,&nbsp;sobald eine Ressource und die von ihr abhängigen Ressourcen das Laden beendet haben.</p>"}},{"type":"prose","value":{"id":"general_info","title":"General info","isH3":false,"content":"<dl>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"spezifikation\">Spezifikation</dt>\n <dd style=\"margin: 0 0 0 120px;\"><a class=\"external\" href=\"https://www.w3.org/TR/DOM-Level-3-Events/#event-type-load\" rel=\" noopener\">DOM L3</a></dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"schnittstelle\">Schnittstelle</dt>\n <dd style=\"margin: 0 0 0 120px;\">UIEvent</dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"bubbles\">bubbles</dt>\n <dd style=\"margin: 0 0 0 120px;\">Nein</dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"cancelable\">cancelable</dt>\n <dd style=\"margin: 0 0 0 120px;\">Nein</dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"ziel\">Ziel</dt>\n <dd style=\"margin: 0 0 0 120px;\">Window,Document,Element</dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"default_action\">Default Action</dt>\n <dd style=\"margin: 0 0 0 120px;\">None.</dd>\n</dl>"}},{"type":"prose","value":{"id":"properties","title":"Properties","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">Property</th>\n   <th scope=\"col\">Type</th>\n   <th scope=\"col\">Description</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><code>target</code> <span title=\"Dieser Wert kann nicht verändert werden.\" class=\"badge inline readonly\">Schreibgeschützt </span></td>\n   <td><a href=\"/en-US/docs/Web/API/EventTarget\" title=\"EventTarget is an interface implemented by objects that can receive events and may have listeners for them.\"><code>EventTarget</code></a></td>\n   <td>The event target (the topmost target in the DOM tree).</td>\n  </tr>\n  <tr>\n   <td><code>type</code> <span title=\"Dieser Wert kann nicht verändert werden.\" class=\"badge inline readonly\">Schreibgeschützt </span></td>\n   <td><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/String\" title=\"DOMString is a UTF-16 String. As JavaScript already uses such strings, DOMString is mapped directly to a String.\"><code>DOMString</code></a></td>\n   <td>The type of event.</td>\n  </tr>\n  <tr>\n   <td><code>bubbles</code> <span title=\"Dieser Wert kann nicht verändert werden.\" class=\"badge inline readonly\">Schreibgeschützt </span></td>\n   <td><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Boolean\" title=\"The Boolean object is an object wrapper for a boolean value.\"><code>Boolean</code></a></td>\n   <td>Whether the event normally bubbles or not.</td>\n  </tr>\n  <tr>\n   <td><code>cancelable</code> <span title=\"Dieser Wert kann nicht verändert werden.\" class=\"badge inline readonly\">Schreibgeschützt </span></td>\n   <td><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Boolean\" title=\"The Boolean object is an object wrapper for a boolean value.\"><code>Boolean</code></a></td>\n   <td>Whether the event is cancellable or not.</td>\n  </tr>\n  <tr>\n   <td><code>view</code> <span title=\"Dieser Wert kann nicht verändert werden.\" class=\"badge inline readonly\">Schreibgeschützt </span></td>\n   <td><a class=\"new page-not-created\" href=\"/en-US/docs/Web/API/WindowProxy\" rel=\"nofollow\" title=\"This is a link to an unwritten page\"><code>WindowProxy</code></a></td>\n   <td><a href=\"/en-US/docs/Web/API/Document/defaultView\" title=\"In browsers, document.defaultView returns the window object associated with a document, or null if none is available.\"><code>