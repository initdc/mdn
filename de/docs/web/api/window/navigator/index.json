sets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Window/vrdisplayconnect_event\"><code>vrdisplayconnect</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Window/vrdisplaydeactivate_event\"><code>vrdisplaydeactivate</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Window/vrdisplaydisconnect_event\"><code>vrdisplaydisconnect</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Window/vrdisplayfocus_event\"><code>vrdisplayfocus</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Window/vrdisplaypointerrestricted_event\"><code>vrdisplaypointerrestricted</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Window/vrdisplaypointerunrestricted_event\"><code>vrdisplaypointerunrestricted</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Window/vrdisplaypresentchange_event\"><code>vrdisplaypresentchange</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Vererbung:</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/EventTarget\"><code>EventTarget</code> <small>(en-US)</small></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p>Die Schreibgeschützte<code> Window.navigator</code> Eigenschaft liefert eine Referenz des <a href=\"/de/docs/Web/API/Navigator\"><code>Navigator</code></a> Objekts, das Informationen über die Anwendung die das Skript ausführt liefern kann.</p>"}},{"type":"prose","value":{"id":"example","title":"Syntax","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><em>navigatorObject<code> = window.navigator</code></em></pre>"}},{"type":"prose","value":{"id":"specification","title":"Beispiele","isH3":false,"content":""}},{"type":"prose","value":{"id":"beispiel_1_browsererkennung_und_ausgabe_eines_texts.","title":"Beispiel #1: Browsererkennung und Ausgabe eines Texts.","isH3":true,"content":"<pre class=\"notranslate\"><code>var sBrowser, sUsrAg = navigator.userAgent;\n\n// The order matters here, and this may report false positives for unlisted browsers.\n\nif (sUsrAg.indexOf(\"Firefox\") &gt; -1) {\n  sBrowser = \"Mozilla Firefox\";\n  // \"Mozilla/5.0 (X11; Ubuntu; Linux x86_64; rv:61.0) Gecko/20100101 Firefox/61.0\"\n} else if (sUsrAg.indexOf(\"Opera\") &gt; -1 || sUsrAg.indexOf(\"OPR\") &gt; -1) {\n  sBrowser = \"Opera\";\n  //\"Mozilla/5.0 (Macintosh; Intel Mac OS X 10_14_0) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/70.0.3538.102 Safari/537.36 OPR/57.0.3098.106\"\n} else if (sUsrAg.indexOf(\"Trident\") &gt; -1) {\n  sBrowser = \"Microsoft Internet Explorer\";\n  // \"Mozilla/5.0 (Windows NT 10.0; WOW64; Trident/7.0; .NET4.0C; .NET4.0E; Zoom 3.6.0; wbx 1.0.0; rv:11.0) like Gecko\"\n} else if (sUsrAg.indexOf(\"Edge\") &gt; -1) {\n  sBrowser = \"Microsoft Edge\";\n  // \"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/58.0.3029.110 Safari/537.36 Edge/16.16299\"\n} else if (sUsrAg.indexOf(\"Chrome\") &gt; -1) {\n  sBrowser = \"Google Chrome or Chromium\";\n  // \"Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Ubuntu Chromium/66.0.3359.181 Chrome/66.0.3359.181 Safari/537.36\"\n} else if (sUsrAg.indexOf(\"Safari\") &gt; -1) {\n  sBrowser = \"Apple Safari\";\n  // \"Mozilla/5.0 (iPhone; CPU iPhone OS 11_4 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/11.0 Mobile/15E148 Safari/604.1 980x1306\"\n} else {\n  sBrowser = \"unknown\";\n}\n\nalert(\"Sie verwenden: \" + sBrowser);</code></pre>"}},{"type":"prose","value":{"id":"beispiel_2_browsererkennung_und_rückgabe_eines_index.","title":"Beispiel #2: Browsererkennung und Rückgabe eines Index.","isH3":true,"content":"<pre class=\"notranslate\"><code>function getBrowserId () {\n  var aKeys = [\"MSIE\", \"Firefox\", \"Safari\", \"Chrome\", \"Opera\"],\n      sUsrAg = navigator.userAgent,\n      nIdx = aKeys.length - 1;\n\n  for (nIdx; nIdx &gt; -1 &amp;&amp; sUsrAg.indexOf(aKeys[nIdx]) === -1; nIdx--);\n\n  return nIdx;\n}\n\nconsole.log(getBrowserId());</code></pre>"}},{"type":"prose","value":{"id":"specification_2","title":"Spezifikation","isH3":false,"content":"<table>\n <thead>\n  <tr>\n   <th scope=\"col\">Specification</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Comment</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"https://html.spec.whatwg.org/multipage/#dom-navigator\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML Living Standard<br><small lang=\"de\">Die Definition von 'Window: navigator' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-living\">Lebender Standard</span></td>\n   <td><br>\n    &nbsp;</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"\n Browserkompatibilität","id":"see_also","isH3":false,"query":"api.Window.navigator","dataURL":"/de/docs/Web/API/Window/navigator/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}}],"toc":[{"text":"Syntax","id":"example"},{"text":"Beispiele","id":"specification"},{"text":"Spezifikation","id":"specification_2"},{"text":"\n Browserkompatibilität","id":"see_also"}],"summary":"Die Schreibgeschützte Window.navigator Eigenschaft liefert eine Referenz des Navigator Objekts, das Informationen über die Anwendung die das Skript ausführt liefern kann.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Window.navigator","locale":"en-US","native":"English (US)"},{"title":"Window.navigator","locale":"es","native":"Español"},{"title":"Window.navigator","locale":"fr","native":"Français"},{"title":"window.navigator","locale":"ja","native":"日本語"},{"title":"Window.navigator","locale":"ko","native":"한국어"},{"title":"window.navigator","locale":"pl","native":"Polski"},{"title":"Window.navigator","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Window.navigator","locale":"ru","native":"Русский"},{"title":"window.navigator","locale":"zh-CN","native":"中文 (简体)"},{"title":"Window.navigator","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"de/web/api/window/navigator","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/api/window/navigator/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/API","title":"Web API Referenz"},{"uri":"/de/docs/Web/API/Window","title":"Window"},{"uri":"/de/docs/Web/API/Window/navigator","title":"Window.navigator"}],"pageTitle":"Window.navigator - Web API Referenz | MDN","noIndexing":false}}