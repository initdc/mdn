eb/API/Window/console\"><code>Window.console</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/WorkerGlobalScope/console\"><code>WorkerGlobalScope.console</code> <small>(en-US)</small></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p>Stopt einen Timer, der zuvor mit <a href=\"/de/docs/Web/API/Console/time\"><code>console.time()</code></a> gestartet wurde.</p>\n\n<p>Siehe auch&nbsp;<a href=\"/en-US/docs/Web/API/console#timers\">Timer</a>&nbsp;in der Dokumentation für mehr&nbsp;Details und Beispiele</p>\n\n<p></p><div class=\"notecard note\" id=\"sect2\">\n  <p><strong>Hinweis:</strong> Dieses Feature ist in <a href=\"/de/docs/Web/API/Web_Workers_API\">Web Workers</a> verfügbar</p>\n</div><p></p>"}},{"type":"prose","value":{"id":"syntax","title":"Syntax","isH3":false,"content":"<pre class=\"syntaxbox notranslate\">console.timeEnd(<em>Bezeichnung</em>);\n</pre>"}},{"type":"prose","value":{"id":"parameter","title":"Parameter","isH3":true,"content":"<dl>\n <dt id=\"bezeichnung\"><code>Bezeichnung</code></dt>\n <dd>Der Name des zu stoppenden&nbsp;Timers. Nachdem der Timer gestoppt&nbsp;wurde, wird die verstrichene Zeit automatisch in der&nbsp;<a href=\"https://firefox-source-docs.mozilla.org/devtools-user/web_console/index.html\" class=\"external\" rel=\" noopener\">Web Konsole</a>&nbsp;ausgegeben.</dd>\n</dl>"}},{"type":"prose","value":{"id":"specifications","title":"Specifications","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">Specification</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Comment</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"https://console.spec.whatwg.org/#timeend\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">Console API<br><small lang=\"de\">Die Definition von 'console.timeEnd()' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-living\">Lebender Standard</span></td>\n   <td>Initial definition</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"Browser compatibility","id":"browser_compatibility","isH3":false,"data":null,"query":"api.Console.timeEnd","browsers":null}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect3\">\n\n\n<p></p><p></p>\n</div>"}},{"type":"prose","value":{"id":"see_also","title":"See also","isH3":false,"content":"<ul>\n <li><a href=\"https://www.opera.com/dragonfly/documentation/console/\" class=\"external\" rel=\" noopener\">Opera Dragonfly documentation: Console</a></li>\n</ul>"}}],"toc":[{"text":"Syntax","id":"syntax"},{"text":"Specifications","id":"specifications"},{"text":"Browser compatibility","id":"browser_compatibility"},{"text":"See also","id":"see_also"}],"summary":"Stopt einen Timer, der zuvor mit console.time() gestartet wurde.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"console.timeEnd()","locale":"en-US","native":"English (US)"},{"title":"Console.timeEnd()","locale":"es","native":"Español"},{"title":"console.timeEnd","locale":"fr","native":"Français"},{"title":"console.timeEnd()","locale":"ja","native":"日本語"},{"title":"console.timeEnd()","locale":"ko","native":"한국어"},{"title":"Console.timeEnd()","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Console.timeEnd","locale":"ru","native":"Русский"},{"title":"Console.timeEnd()","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"de/web/api/console/timeend","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/api/console/timeend/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/API","title":"Web API Refere