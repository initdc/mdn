{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"WebSocket.protocol","mdn_url":"/de/docs/Web/API/WebSocket/protocol","locale":"de","native":"Deutsch","sidebarHTML":"<ol><li><strong><a href=\"/de/docs/Web/API/WebSocket\"><code>WebSocket</code></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>Konstruktor</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/WebSocket/WebSocket\"><code>WebSocket()</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Eigenschaften</summary><ol><li><a href=\"/de/docs/Web/API/WebSocket/binaryType\"><code>binaryType</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/WebSocket/bufferedAmount\"><code>bufferedAmount</code> <small>(en-US)</small></a></li><li><a href=\"/de/docs/Web/API/WebSocket/extensions\"><code>extensions</code></a></li><li><em><code>protocol</code></em></li><li><a href=\"/de/docs/Web/API/WebSocket/readyState\"><code>readyState</code></a></li><li><a href=\"/de/docs/Web/API/WebSocket/url\"><code>url</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Methoden</summary><ol><li><a href=\"/de/docs/Web/API/WebSocket/close\"><code>close()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/WebSocket/send\"><code>send()</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Ereignisse</summary><ol><li><a href=\"/de/docs/Web/API/WebSocket/close_event\"><code>close</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/WebSocket/error_event\"><code>error</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\