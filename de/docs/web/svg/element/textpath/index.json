n-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feComposite\"><code>&lt;feComposite&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feConvolveMatrix\"><code>&lt;feConvolveMatrix&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feDiffuseLighting\"><code>&lt;feDiffuseLighting&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feDisplacementMap\"><code>&lt;feDisplacementMap&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feDistantLight\"><code>&lt;feDistantLight&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feFlood\"><code>&lt;feFlood&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feFuncA\"><code>&lt;feFuncA&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feFuncB\"><code>&lt;feFuncB&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feFuncG\"><code>&lt;feFuncG&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feFuncR\"><code>&lt;feFuncR&