/a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feTile\"><code>&lt;feTile&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feTurbulence\"><code>&lt;feTurbulence&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/filter\"><code>&lt;filter&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/font\"><code>&lt;font&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/font-face\"><code>&lt;font-face&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/font-face-format\"><code>&lt;font-face-format&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/font-face-name\"><code>&lt;font-face-name&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/font-face-src\"><code>&lt;font-face-src&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/font-face-uri\"><code>&lt;font-face-uri&gt;</code> <small>(en-US)</small></a></li>\n     <li><a href=\"/de/docs/Web/SVG/Element/foreignObject\"><code>&lt;foreignObject&gt;</code></a></li>\n   </ol>\n </li>\n <li>G\n   <ol>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/g\"><code>&lt;g&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/glyph\"><code>&lt;glyph&gt;</code> <small>(en-US)</small></a></li>\n     <li class=\"deprecatedElement\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/glyphRef\"><code>&lt;glyphRef&gt;</code> <small>(en-US)</small></a></li>\n   </ol>\n </li>\n <li>H\n   <ol>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/hkern\"><code>&lt;hkern&gt;</code> <small>(en-US)</small></a></li>\n   </ol>\n </li>\n <li>I\n   <ol>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/image\"><code>&lt;image&gt;</code> <small>(en-US)</small></a></li>\n   </ol>\n </li>\n <li>J-L\n   <ol>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/line\"><code>&lt;line&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/linearGradient\"><code>&lt;linearGradient&gt;</code> <small>(en-US)</small></a></li>\n   </ol>\n </li>\n <li>M\n   <ol>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/marker\"><code>&lt;marker&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/mask\"><code>&lt;mask&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/metadata\"><code>&lt;metadata&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/missing-glyph\"><code>&lt;missing-glyph&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/mpath\"><code>&lt;mpath&gt;</code> <small>(en-US)</small></a></li>\n   </ol>\n </li>\n <li>N-P\n   <ol>\n     <li><a href=\"/de/docs/Web/SVG/Element/path\"><code>&lt;path&gt;</code></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/pattern\"><code>&lt;pattern&gt;</code> <small>(en-US)</small></a></li>\n     <li><a href=\"/de/docs/Web/SVG/Element/polygon\"><code>&lt;polygon&gt;</code></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/polyline\"><code>&lt;polyline&gt;</code> <small>(en-US)</small></a></li>\n   </ol>\n </li>\n <li>Q-R\n   <ol>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/radialGradient\"><code>&lt;radialGradient&gt;</code> <small>(en-US)</small></a></li>\n     <li><a href=\"/de/docs/Web/SVG/Element/rect\"><code>&lt;rect&gt;</code></a></li>\n   </ol>\n </li>\n <li>S\n   <ol>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/script\"><code>&lt;script&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/set\"><code>&lt;set&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/stop\"><code>&lt;stop&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/style\"><code>&lt;style&gt;</code> <small>(en-US)</small></a></li>\n     <li><a href=\"/de/docs/Web/SVG/Element/svg\"><code>&lt;svg&gt;</code></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/switch\"><code>&lt;switch&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/symbol\"><code>&lt;symbol&gt;</code> <small>(en-US)</small></a></li>\n   </ol>\n </li>\n <li>T\n   <ol>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/text\"><code>&lt;text&gt;</code> <small>(en-US)</small></a></li>\n     <li><a href=\"/de/docs/Web/SVG/Element/textPath\"><code>&lt;textPath&gt;</code></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/title\"><code>&lt;title&gt;</code> <small>(en-US)</small></a></li>\n     <li class=\"deprecatedElement\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/tref\"><code>&lt;tref&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/tspan\"><code>&lt;tspan&gt;</code> <small>(en-US)</small></a></li>\n   </ol>\n </li>\n <li>U\n   <ol>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/use\"><code>&lt;use&gt;</code> <small>(en-US)</small></a></li>\n   </ol>\n </li>\n <li>V-Z\n   <ol>\n     <li><a href=\"/de/docs/Web/SVG/Element/view\"><code>&lt;view&gt;</code></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/vkern\"><code>&lt;vkern&gt;</code> <small>(en-US)</small></a></li>\n   </ol>\n </li>\n   </ol></details></li>\n   </ol>\n  </section></div>\n\n<p>Das&nbsp;<code>animate</code> Element wird innerhalb eines Shape Elements angelegt und definiert, wie ein Attribut des Elements sich durch die Animation verändert.Das Attribut wird sich innerhalb der angegebenen Dauer vom initialen- zum End-Wert ändern.</p>\n\n<p>Es wird normalerweise innerhalb des Elements eingefügt, oder referenziert von einem <code>href</code> attribut des Zielelements.</p>"}},{"type":"prose","value":{"id":"usage_context","title":"Usage context","isH3":false,"content":"<p><table class=\"properties\"><tbody><tr><th scope=\"row\">Kategorien</th><td>Animationselement</td></tr><tr><th scope=\"row\">Erlaubter Inhalt</th><td>Beliebige Anzahl der folgenden Elemente, in beliebiger Reihenfolge:<br><a href=\"/de/docs/Web/SVG/Element#descriptive_elements\">Beschreibende Elemente</a></td></tr></tbody></table></p>"}},{"type":"prose","value":{"id":"attribute","title":"Attribute","isH3":false,"content":""}},{"type":"prose","value":{"id":"globale_attribute","title":"Globale Attribute","isH3":true,"content":"<ul>\n <li><a href=\"/en-US/docs/Web/SVG/Attribute#conditionalproccessing\" title=\"SVG/Attribute#ConditionalProccessing\">Conditional processing attributes</a>&nbsp;»</li>\n <li><a href=\"/en-US/docs/Web/SVG/Attribute#core\" title=\"SVG/Attribute#Core\">Core attributes</a>&nbsp;»</li>\n <li><a href=\"/en-US/docs/Web/SVG/Attribute#animationevent\" title=\"SVG/Attribute#AnimationEvent\">Animation event attributes</a>&nbsp;»</li>\n <li><a href=\"/en-US/docs/Web/SVG/Attribute#xlink\" title=\"SVG/Attribute#XLink\">Xlink attributes</a>&nbsp;»</li>\n <li><a href=\"/en-US/docs/Web/SVG/Attribute#animationattributetarget\" title=\"SVG/Attribute#AnimationAttributeTarget\">Animation attribute target attributes</a>&nbsp;»</li>\n <li><a href=\"/en-US/docs/Web/SVG/Attribute#animationtiming\" title=\"SVG/Attribute#AnimationTiming\">Animation timing attributes</a>&nbsp;»</li>\n <li><a href=\"/en-US/docs/Web/SVG/Attribute#animationvalue\" title=\"SVG/Attribute#AnimationValue\">Animation value attributes</a>&nbsp;»</li>\n <li><a href=\"/en-US/docs/Web/SVG/Attribute#animationaddition\" title=\"SVG/Attribute#AnimationAddition\">Animation addition attributes</a>&nbsp;»</li>\n <li><code><a href=\"/de/docs/Web/SVG/Attribute/externalResourcesRequired\" class=\"page-not-created\" title=\"This is a link to an unwritten page\">externalResourcesRequired</a></code></li>\n</ul>"}},{"type":"prose","value":{"id":"spezifische_attribute","title":"Spezifische Attribute","isH3":true,"content":"<ul>\n <li><code><a href=\"/en-US/docs/Web/SVG/Attribute/attributeName\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">attributeName (en-US)</a></code></li>\n <li><code><a href=\"/en-US/docs/Web/SVG/Attribute/attributeType\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">attributeType (en-US)</a></code></li>\n <li><code><a href=\"/en-US/docs/Web/SVG/Attribute/From\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">from (en-US)</a></code></li>\n <li><code><a href=\"/en-US/docs/Web/SVG/Attribute/To\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">to (en-US)</a></code></li>\n <li><code><a href=\"/en-US/docs/Web/SVG/Attribute/dur\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">dur (en-US)</a></code></li>\n <li><code><a href=\"/en-US/docs/Web/SVG/Attribute/repeatCount\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">repeatCount (en-US)</a></code></li>\n</ul>"}},{"type":"prose","value":{"id":"dom_schnittstelle","title":"DOM Schnittstelle","isH3":false,"content":"<p>Dieses Element implementiert die <code><a href=\"/en-US/docs/Web/API/SVGAnimateElement\" title=\"DOM/SVGAElement\">SVGAnimateElement</a></code> Schnittstelle.</p>"}},{"type":"prose","value":{"id":"beispiel","title":"Beispiel","isH3":false,"content":""}},{"type":"prose","value":{"id":"svg","title":"SVG","isH3":true,"content":"<div class=\"code-example\"><pre class=\"brush: html; highlight[6-7] notranslate\"><code><span class=\"token prolog\">&lt;?xml version=\"1.0\"?&gt;</span>\n<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>svg</span> <span class=\"token attr-name\">width</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>120<span class=\"token punctuation\">\"</span></span> <span class=\"token attr-name\">height</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>120<span class=\"token punctuation\">\"</span></span> <span class=\"token attr-name\">viewBox</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>0 0 120 120<span class=\"token punctuation\">\"</span></span> <span class=\"token attr-name\">version</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>1.1<span class=\"token punctuation\">\"</span></span>\n     <span class=\"token attr-name\">xmlns</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>http://www.w3.org/2000/svg<span class=\"token punctuation\">\"</span></span><span class=\"token punctuation\">&gt;</span></span>\n\n  <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>rect</span> <span class=\"token attr-name\">x</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>10<span class=\"token punctuation\">\"</span></span> <span class=\"token attr-name\">y</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>10<span class=\"token punctuation\">\"</span></span> <span class=\"token attr-name\">width</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>100<span class=\"token punctuation\">\"</span></span> <span class=\"token attr-name\">height</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>100<span class=\"token punctuation\">\"</span></span><span class=\"token punctuation\">&gt;</span></span>\n    <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>animate</span> <span class=\"token attr-name\">attributeType</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>XML<span class=\"token punctuation\">\"</span></span> <span class=\"token attr-name\">attributeName</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>x<span class=\"token punctuation\">\"</span></span> <span class=\"token attr-name\">from</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>-100<span class=\"token punctuation\">\"</span></span> <span class=\"token attr-name\">to</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>120<span class=\"token punctuation\">\"</span></span>\n        <span class=\"token attr-name\">dur</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>10s<span class=\"token punctuation\">\"</span></span> <span class=\"token attr-name\">repeatCount</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>indefinite<span class=\"token punctuation\">\"</span></span><span class=\"token punctuation\">/&gt;</span></span>\n  <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>rect</span><span class=\"token punctuation\">&gt;</span></span>\n<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>svg</span><span class=\"token punctuation\">&gt;</span></span></code></pre></div>"}},{"type":"prose","value":{"id":"ergebnis","title":"Ergebnis","isH3":true,"content":"<p><iframe class=\"sample-code-frame\" title=\"Beispiel\" id=\"frame_example\" width=\"120\" height=\"120\" src=\"https://yari-demos.prod.mdn.mozit.cloud/de/docs/Web/SVG/Element/animate/_sample_.example.html\" loading=\"lazy\"></iframe></p>"}},{"type":"prose","value":{"id":"bedenken_bezüglich_der_barrierefreiheit","title":"Bedenken bezüglich der Barrierefreiheit","isH3":false,"content":"<p>Blinkende und blitzende Animation kann für Menschen mit kognitiven Problemen wie Aufmerksamkeitsdefizit Hyperaktivitätsstörung (ADHS) problematisch sein. Darüber hinaus können bestimmte Arten von Bewegungen ein Auslöser für vestibuläre Störungen, Epilepsie, Migräne und skotopische Empfindlichkeit sein.</p>\n\n<p>Erwägen Sie, einen Mechanismus zum Anhalten oder Deaktivieren der Animation vorzusehen, sowie die <a href=\"/en-US/docs/Web/CSS/@media/prefers-reduced-motion\">Reduced Motion Media Query</a> zu verwenden, um eine komplementäre Erfahrung für Benutzer zu schaffen, die eine Präferenz für keine Animationen haben.</p>\n\n<ul>\n <li><a href=\"https://alistapart.com/article/designing-safer-web-animation-for-motion-sensitivity\" class=\"external\" rel=\" noopener\">Designen von sicheren Web Animationen für Bewegungsempfindlichkeit - Ein Artikel der Extraklasse</a></li>\n <li><a href=\"https://css-tricks.com/introduction-reduced-motion-media-query/\" class=\"external\" rel=\" noopener\">Eine Einführung in die Reduced Motion Media Query | CSS-Tricks</a></li>\n <li><a href=\"https://webkit.org/blog/7551/responsive-design-for-motion/\" class=\"external\" rel=\" noopener\">Responsives Design für Bewegungen | WebKit</a></li>\n <li><a href=\"/en-US/docs/Web/Accessibility/Understanding_WCAG/Operable#Guideline_2.2_%E2%80%94_Enough_Time_Provide_users_enough_time_to_read_and_use_content\">MDN Verstehen der WCAG, Guideline 2.2 Erklärungen</a></li>\n <li><a href=\"https://www.w3.org/TR/UNDERSTANDING-WCAG20/time-limits-pause.html\" class=\"external\" rel=\" noopener\">Verstehen der Erfolgskriteren 2.2.2&nbsp; | W3C Understanding WCAG 2.0</a></li>\n</ul>"}},{"type":"prose","value":{"id":"spezifikationen","title":"Spezifikationen","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">Spezifikation</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Kommentar</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"https://svgwg.org/specs/animations/#AnimateElement\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">SVG Animations Level&nbsp;2<br><small lang=\"de\">Die Definition von '&lt;animate&gt;' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-ed\">Bearbeiterentwurf</span></td>\n   <td>Keine Änderung</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.w3.org/TR/SVG11/animate.html#AnimateElement\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">Scalable Vector Graphics (SVG) 1.1 (Second Edition)<br><small lang=\"de\">Die Definition von '&lt;animate&gt;' in dieser Spezifikation.</small></a></td>\n   <td><span class=\"spec-rec\">Empfehlung</span></td>\n   <td>Initiale Definition</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"Browser Kompatiblität","id":"browser_kompatiblität","isH3":false,"query":"svg.elements.animate","dataURL":"/de/docs/Web/SVG/Element/animate/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect2\">\n<p></p><p></p>\n</div>\n\n<p>&nbsp;</p>"}}],"toc":[{"text":"Usage context","id":"usage_context"},{"text":"Attribute","id":"attribute"},{"text":"DOM Schnittstelle","id":"dom_schnittstelle"},{"text":"Beispiel","id":"beispiel"},{"text":"Bedenken bezüglich der Barrierefreiheit","id":"bedenken_bezüglich_der_barrierefreiheit"},{"text":"Spezifikationen","id":"spezifikationen"},{"text":"Browser Kompatiblität","id":"browser_kompatiblität"}],"summary":"Das animate Element wird innerhalb eines Shape Elements angelegt und definiert, wie ein Attribut des Elements sich durch die Animation verändert.Das Attribut wird sich innerhalb der angegebenen Dauer vom initialen- zum End-Wert ändern.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"<animate>","locale":"en-US","native":"English (US)"},{"title":"<animate>","locale":"es","native":"Español"},{"title":"<animate>","locale":"fr","native":"Français"},{"title":"<animate>","locale":"ja","native":"日本語"},{"title":"animate","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"<animate>","locale":"ru","native":"Русский"},{"title":"<animate>","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"de/web/svg/element/animate","github_url":"https://github.com/mdn/translated-content/blob/main/files/de/web/svg/element/animate/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/de/docs/Web","title":"Webtechnologien für Entwickler"},{"uri":"/de/docs/Web/SVG","title":"SVG"},{"uri":"/de/docs/Web/SVG/Element","title":"SVG Elementreferenz"},{"uri":"/de/docs/Web/SVG/Element/animate","title":"animate"}],"pageTitle":"animate - SVG | MDN","noIndexing":false}}