{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"<svg>","mdn_url":"/de/docs/Web/SVG/Element/svg","locale":"de","native":"Deutsch","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"><section class=\"Quick_links\" id=\"quick_links\">\n  <ol>\n   \n            <li><a href=\"/de/docs/Web/SVG/Element/svg\" aria-current=\"page\"><code>&lt;svg&gt;</code></a></li>\n  \n   <li><details><summary>SVG Elements</summary><ol>\n <li>A\n   <ol>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/a\"><code>&lt;a&gt;</code> <small>(en-US)</small></a></li>\n     <li class=\"deprecatedElement\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/altGlyph\"><code>&lt;altGlyph&gt;</code> <small>(en-US)</small></a></li>\n     <li class=\"deprecatedElement\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/altGlyphDef\"><code>&lt;altGlyphDef&gt;</code> <small>(en-US)</small></a></li>\n     <li class=\"deprecatedElement\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/altGlyphItem\"><code>&lt;altGlyphItem&gt;</code> <small>(en-US)</small></a></li>\n     <li><a href=\"/de/docs/Web/SVG/Element/animate\"><code>&lt;animate&gt;</code></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/animate\"><code>&lt;animateColor&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/animateMotion\"><code>&lt;animateMotion&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/animateTransform\"><code>&lt;animateTransform&gt;</code> <small>(en-US)</small></a></li>\n   </ol>\n </li>\n <li>B-C\n   <ol>\n     <li><a href=\"/de/docs/Web/SVG/Element/circle\"><code>&lt;circle&gt;</code></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/clipPath\"><code>&lt;clipPath&gt;</code> <small>(en-US)</small></a></li>\n     <li class=\"deprecatedElement\"><a class=\"page-not-created\" title=\"Die Beschreibung hierüber wurde bisher noch nicht geschrieben. Bitte überlege, mitzuwirken!\"><code>&lt;color-profile&gt;</code></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/cursor\"><code>&lt;cursor&gt;</code> <small>(en-US)</small></a></li>\n   </ol>\n </li>\n <li>D\n   <ol>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/defs\"><code>&lt;defs&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/desc\"><code>&lt;desc&gt;</code> <small>(en-US)</small></a></li>\n   </ol>\n </li>\n <li>E\n   <ol>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/ellipse\"><code>&lt;ellipse&gt;</code> <small>(en-US)</small></a></li>\n   </ol>\n </li>\n <li>F\n   <ol>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feBlend\"><code>&lt;feBlend&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feColorMatrix\"><code>&lt;feColorMatrix&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feComponentTransfer\"><code>&lt;feComponentTransfer&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feComposite\"><code>&lt;feComposite&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feConvolveMatrix\"><code>&lt;feConvolveMatrix&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feDiffuseLighting\"><code>&lt;feDiffuseLighting&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feDisplacementMap\"><code>&lt;feDisplacementMap&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feDistantLight\"><code>&lt;feDistantLight&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feFlood\"><code>&lt;feFlood&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feFuncA\"><code>&lt;feFuncA&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feFuncB\"><code>&lt;feFuncB&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/SVG/Element/feFuncG\"><code>&lt;feFuncG&gt;</code> <small>(en-US)</small></a></li>\n     <li><a class=\"only-in-en-us\" titl