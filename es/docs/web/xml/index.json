{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"XML: Extensible Markup Language","mdn_url":"/es/docs/Web/XML","locale":"es","native":"Español","sidebarHTML":"\n<ol></ol>\n","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>\n\n<p class=\"summary\">The <strong>Extensible Markup Language</strong> is&nbsp;a&nbsp;strict serialisation of&nbsp;the&nbsp;<a href=\"/en-US/docs/Web/API/Document_Object_Model\">Document Object Model</a>.</p>\n\n<p></p><div class=\"row topicpage-table\" id=\"sect1\">\n    <div class=\"section\" id=\"sect2\"><dl><dl><dt <=\"\" dl=\"\" id=\"sect3\"></dt></dl></dl></div>\n    <div class=\"section\" id=\"sect4\"><dl><dt class=\"landingPageList\" id=\"introducción_a_xml\"><a href=\"/es/docs/Web/XML/XML_introduction\">Introducción a XML</a></dt><dd class=\"landingPageList\">XML es un lenguaje de marcado similar a HTML. Significa Extensible Markup Language (Lenguaje de Marcado Extensible)&nbsp;y es una especificación de&nbsp;<a class=\"external\" href=\"https://www.w3.org/TR/xml/\" rel=\" noopener\">W3C</a>&nbsp;como lenguaje de marcado de propósito general. Esto significa que, a diferencia de otros lenguajes de marcado, XML no está predefinido, por lo que debes definir tus propias etiquetas. El propósito principal del lenguaje es compartir datos a través de diferentes sistemas, como Internet.</dd></dl></div>\n    </div><p></p>"}}],"toc":[],"summary":"The Extensible Markup Language is a strict serialisation of the Document Object Model.","popularity":0.0003,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"XML: Extensible Markup Language","locale":"de","native":"Deutsch"},{"title":"XML: Extensible Markup Language","locale":"en-US","native":"English (US)"},{"title":"XML: Extensible Markup Language","locale":"fr","native":"Français"},{"title":"XML: Extensible Markup Language","locale":"ja","native":"日本語"},{"title":"XML: Extensible Markup Language","locale":"ko","native":"한국어"},{"title":"XML: Rozszerzalny Język Znaczników","locale":"pl","native":"Polski"},{"title":"XML: Extensible Markup Language","locale":"ru","native":"Русский"},{"title":"XML (可扩展标记语言)","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"es/web/xml","github_url":"https://github.com/mdn/translated-content/blob/main/files/es/web/xml/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/es/docs/Web","title":"Tecnología para desarrolladores web"},{"uri":"/es/docs/Web/XML","title":"XML: Extensible Markup Language"}],"pageTitle":"XML: Extensible Markup Language | MDN","noIndexing":false}}