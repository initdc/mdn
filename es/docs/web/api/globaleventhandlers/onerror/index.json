{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"GlobalEventHandlers.onerror","mdn_url":"/es/docs/Web/API/GlobalEventHandlers/onerror","locale":"es","native":"Español","sidebarHTML":"<ol><li><strong><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/HTML_DOM_API\">HTML DOM API <small>(en-US)</small></a></strong></li><li><strong><a href=\"/es/docs/Web/API/GlobalEventHandlers\"><code>GlobalEventHandlers</code></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>Propiedades</summary><ol><li><em><code>onerror</code></em></li><li><a href=\"/es/docs/Web/API/GlobalEventHandlers/ongotpointercapture\"><code>ongotpointercapture</code></a></li><li><a href=\"/es/docs/Web/API/GlobalEventHandlers/onload\"><code>onload</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/onloadeddata\"><code>onloadeddata</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/onloadedmetadata\"><code>onloadedmetadata</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/onloadend\"><code>onloadend</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/onloadstart\"><code>onloadstart</code> <small>(en-US)</small></a></li><li><a href=\"/es/docs/Web/API/GlobalEventHandlers/onlostpointercapture\"><code>onlostpointercapture</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/onpause\"><code>onpause</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only avai