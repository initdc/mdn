{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"Animation","mdn_url":"/es/docs/Web/API/Animation","locale":"es","native":"Español","sidebarHTML":"<ol><li><strong><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Web_Animations_API\">Web Animations API <small>(en-US)</small></a></strong></li><li><strong><a href=\"/es/docs/Web/API/Animation\"><code>Animation</code></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>Constructor</summary><ol><li><a href=\"/es/docs/Web/API/Animation/Animation\"><code>Animation()</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Propiedades</summary><ol><li><a href=\"/es/docs/Web/API/Animation/currentTime\"><code>currentTime</code></a></li><li><a href=\"/es/docs/Web/API/Animation/effect\"><code>effect</code></a></li><li><a href=\"/es/docs/Web/API/Animation/finished\"><code>finished</code></a></li><li><a href=\"/es/docs/Web/API/Animation/id\"><code>id</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Animation/pending\"><code>pending</code> <small>(en-US)</small></a></li><li><a href=\"/es/docs/Web/API/Animation/playbackRate\"><code>playbackRate</code></a></li><li><a href=\"/es/docs/Web/API/Animation/playState\"><code>playState</code></a></li><li><a href=\"/es/docs/Web/API/Animation/ready\"><code>ready</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Animation/replaceState\"><code>replaceState</code> <small>(en-US)</small></a></li><li><a href=\"/es/docs/Web/API/Animation/startTime\"><code>startTime</code></a></li><li><a href=\"/es/docs/Web/API/Animation/timeline\"><code>timeline</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Métodos</summary><ol><li><a href=\"/es/docs/Web/API/Animation/cancel\"><code>cancel()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Animation/commitStyles\"><code>commitStyles()</code> <small>(en-US)</small></a></li><li><a href=\"/es/docs/Web/API/Animation/finish\"><code>finish()</code></a></li><li><a href=\"/es/docs/Web/API/Animation/pause\"><code>pause()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Animation/persist\"><code>persist()</code> <small>(en-US)</small></a></li><li><a href=\"/es/docs/Web/API/Animation/play\"><code>play()</code></a></li><li><a href=\"/es/docs/Web/API/Animation/reverse\"><code>reverse()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Animation/updatePlaybackRate\"><code>updatePlaybackRate()</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Eventos</summary><ol><li><a href=\"/es/docs/Web/API/Animation/cancel_event\"><code>cancel</code></a></li><li><a href=\"/es/docs/Web/API/Animation/finish_event\"><code>finish</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Animation/remove_event\"><code>remove</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Herencia</summary><ol><li><a href=\"/es/docs/Web/API/EventTarget\"><code>EventTarget</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Páginas relacionadas a Web Animations</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/AnimationEffect\"><code>AnimationEffect</code> <small>(en-US)</small></a></li><li><a href=\"/es/docs/Web/API/AnimationEvent\"><code>AnimationEvent</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/AnimationPlaybackEvent\"><code>AnimationPlaybackEvent</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/AnimationTimeline\"><code>AnimationTimeline</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/getAnimations\"><code>Document.getAnimations()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/timeline\"><code>Document.timeline</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/DocumentTimeline\"><code>DocumentTimeline</code> <small>(en-US)</small></a></li><li><a href=\"/es/docs/Web/API/Element/animate\"><code>Element.animate()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/KeyframeEffect\"><code>KeyframeEffect</code> <small>(en-US)</small></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"><div class=\"notecard experimental\" id=\"sect2\"><p><strong>Experimental:</strong> <strong>Esta es una <a href=\"/en-US/docs/MDN/Guidelines/Conventions_definitions#experimental\">tecnología experimental</a></strong><br>Comprueba la <a href=\"#browser_compatibility\">Tabla de compabilidad de navegadores</a> cuidadosamente antes de usarla en producción.</p></div></div>\n\n<p>La interfaz <strong><code>Animation</code></strong> de la&nbsp; <a href=\"/en-US/docs/Web/API/Web_Animations_API\">Web Animations API</a> representa un reproductor de animación y proporciona controles de reproducción y una línea de tiempo para un nodo o una fuente de animación.</p>"}},{"type":"prose","value":{"id":"constructor","title":"Constructor","isH3":false,"content":"<dl>\n <dt id=\"animation\"><a href=\"/es/docs/Web/API/Animation/Animation\" title=\"Animation()\"><code>Animation()</code></a></dt>\n <dd>Crea una nueva instancia de objeto <code>Animation</code>.</dd>\n</dl>"}},{"type":"prose","value":{"id":"propiedades","title":"Propiedades","isH3":false,"content":"<dl>\n <dt id=\"animation.currenttime\"><a href=\"/es/docs/Web/API/Animation/currentTime\"><code>Animation.currentTime</code></a></dt>\n <dd>El valor del tiempo de la animación actual en milisegundos , ya sea en ejecución o en pausa. Si la animación carece de <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/AnimationTimeline\"><code>timeline</code> <small>(en-US)</small></a>, está inactivo, o no se ha reproducido todavía, su valor es <code>null</code>.</dd>\n</dl>\n\n<dl>\n <dt id=\"animation.effect\"><a href=\"/es/docs/Web/API/Animation/effect\"><code>Animation.effect</code></a></dt>\n <dd>Obtiene y establece el <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/AnimationEffect\"><code>AnimationEffectReadOnly</code> <small>(en-US)</small></a> asociado con esta animación. Normalmente, este será un objeto <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/KeyframeEffect\"><code>KeyframeEffect</code> <small>(en-US)</small></a>.</dd>\n <dt id=\"animation.finished\"><a href=\"/es/docs/Web/API/Animation/finished\"><code>Animation.finished</code></a> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></dt>\n <dd>Devuelve la Promesa actual terminada para esta animación.</dd>\n</dl>\n\n<dl>\n <dt id=\"animation.id\"><a href=\"/es/docs/Web/API/Animation/id\"><code>Animation.id</code></a></dt>\n <dd>Obtiene y establece la&nbsp;<code>String</code> usada&nbsp;para identificar la animación.</dd>\n <dt id=\"animation.playstate\"><a href=\"/es/docs/Web/API/Animation/playState\"><code>Animation.playState</code></a> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></dt>\n <dd>Devuelve un valor enumerado que describe el estado de la reproducción de una animación.</dd>\n</dl>\n\n<dl>\n <dt id=\"animation.playbackrate\"><a href=\"/es/docs/Web/API/Animation/playbackRate\"><code>Animation.playbackRate</code></a></dt>\n <dd>Obtiene o establece la velocidad de reproducción de la animación.</dd>\n</dl>\n\n<dl>\n <dt id=\"animation.ready\"><a href=\"/es/docs/Web/API/Animation/ready\"><code>Animation.ready</code></a> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></dt>\n <dd>Devuelve la Promesa actual lista para esta animación.</dd>\n</dl>\n\n<dl>\n <dt id=\"animation.starttime\"><a href=\"/es/docs/Web/API/Animation/startTime\"><code>Animation.startTime</code></a></dt>\n <dd>Obiene o establece la hora programada en la que debe comenzar la reproducción de la animación.</dd>\n</dl>\n\n<dl>\n <dt id=\"animation.timeline\"><a href=\"/es/docs/Web/API/Animation/timeline\"><code>Animation.timeline</code></a></dt>\n <dd>Obtiene o establece el&nbsp; <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/AnimationTimeline\"><code>timeline</code> <small>(en-US)</small></a> asociado con esta animación.</dd>\n</dl>"}},{"type":"prose","value":{"id":"manejadores_de_eventos","title":"Manejadores de eventos","isH3":true,"content":"<dl>\n <dt id=\"animation.oncancel\"><a href=\"/es/docs/Web/API/Animation/cancel_event\"><code>Animation.oncancel</code></a></dt>\n <dd>Obtiene y establece en manejador de eventos para el evento <code>cancel</code>.</dd>\n <dt id=\"animation.onfinish\"><a href=\"/es/docs/Web/API/Animation/finish_event\"><code>Animation.onfinish</code></a></dt>\n <dd>Obtiene y establece en manejador de eventos para el evento <code>finish</code> .</dd>\n</dl>"}},{"type":"prose","value":{"id":"métodos","title":"Métodos","isH3":false,"content":"<dl>\n <dt id=\"animation.cancel\"><a href=\"/es/docs/Web/API/Animation/cancel\"><code>Animation.cancel()</code></a></dt>\n <dd>Borra todos los <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/KeyframeEffect\"><code>keyframeEffects</code> <small>(en-US)</small></a> causados por la animación y aborta su&nbsp;reproducción.</dd>\n</dl>\n\n<dl>\n <dt id=\"animation.finish\"><a href=\"/es/docs/Web/API/Animation/finish\"><code>Animation.finish()</code></a></dt>\n <dd>Busca cualquier final de una animación, dependiendo de si la animación se está reproduciendo o invirtiendo.</dd>\n</dl>\n\n<dl>\n <dt id=\"animation.pause\"><a href=\"/es/docs/Web/API/Animation/pause\"><code>Animation.pause()</code></a></dt>\n <dd>Pone la reproducción en pausa.</dd>\n</dl>\n\n<dl>\n <dt id=\"animation.play\"><a href=\"/es/docs/Web/API/Animation/play\"><code>Animation.play()</code></a></dt>\n <dd><span id=\"result_box\" lang=\"es\"><span>Busca el final de una animación, dependiendo de si la animación se está reproduciendo o si se está invirtiendo.</span></span></dd>\n</dl>\n\n<dl>\n <dt id=\"animation.reverse\"><a href=\"/es/docs/Web/API/Animation/reverse\"><code>Animation.reverse()</code></a></dt>\n <dd><span id=\"result_box\" lang=\"es\"><span>Invierte la dirección de reproducción, deteniéndose al comienzo de la animación</span></span>. Si la animación finaliza o no se activa, volverá a reproducirse desde el final al principio.</dd>\n</dl>\n\n<dl>\n <dt id=\"animation.updateplaybackrate_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Animation/updatePlaybackRate\"><code>Animation.updatePlaybackRate()</code> <small>(en-US)</small></a></dt>\n <dd>Establece la velocidad de la animación después de sincronizar por primera vez su posición de reproducción.</dd>\n</dl>"}},{"type":"prose","value":{"id":"problemas_de_accesibilidad","title":"Problemas de accesibilidad","isH3":false,"content":"<p>Las animaciones titilantes e intermitentes pueden causar dificultades a las personas con discapacidades cognitivas como Trastorno por Déficit de Atención con Hiperactividad (ADHD) además de causar ataques a personas con cinestosis, epilepsia, migranias o <span class=\"short_text\" id=\"result_box\" lang=\"es\"><span>síndrome de sensibilidad escotópica</span></span>.</p>\n\n<p>Considera ofrecer un mecanismo para pausar o deshabilitar las animaciones, así como utilizar&nbsp;<a href=\"/en-US/docs/Web/CSS/@media/prefers-reduced-motion\">Reduced Motion Media Query</a> para crear una experiencia complementaria para los usuarios que han expresado su preferencia por experiencias no animadas.</p>\n\n<ul>\n <li><a href=\"https://alistapart.com/article/designing-safer-web-animation-for-motion-sensitivity\" class=\"external\" rel=\" noopener\">Designing Safer Web Animation For Motion Sensitivity&nbsp;· An A List Apart Article&nbsp;</a></li>\n <li><a href=\"https://css-tricks.com/introduction-reduced-motion-media-query/\" class=\"external\" rel=\" noopener\">An Introduction to the Reduced Motion Media Query | CSS-Tricks</a></li>\n <li><a href=\"https://webkit.org/blog/7551/responsive-design-for-motion/\" class=\"external\" rel=\" noopener\">Responsive Design for Motion | WebKit</a></li>\n <li><a href=\"/en-US/docs/Web/Accessibility/Understanding_WCAG/Operable#Guideline_2.2_%E2%80%94_Enough_Time_Provide_users_enough_time_to_read_and_use_content\">MDN Understanding WCAG, Guideline 2.2 explanations</a></li>\n <li><a href=\"https://www.w3.org/TR/UNDERSTANDING-WCAG20/time-limits-pause.html\" class=\"external\" rel=\" noopener\">Understanding Success Criterion 2.2.2 &nbsp;| W3C Understanding WCAG 2.0</a></li>\n</ul>"}},{"type":"prose","value":{"id":"especificaciones","title":"Especificaciones","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Especificación</th>\n   <th scope=\"col\">Estado</th>\n   <th scope=\"col\">Comentario</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://drafts.csswg.org/web-animations-1/#the-animation-interface\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">Web Animations<br><small lang=\"es\">La definición de 'Animation' en esta especificación.</small></a></td>\n   <td><span class=\"spec-wd\">Working Draft</span></td>\n   <td>Definición inicial</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"Compatibilidad con navegadores","id":"compatibilidad_con_navegadores","isH3":false,"query":"api.Animation","dataURL":"/es/docs/Web/API/Animation/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"ver_también","title":"Ver también","isH3":false,"content":"<ul>\n <li><a href=\"/en-US/docs/Web/API/Web_Animations_API\">API de Animaciones Web</a></li>\n</ul>"}}],"toc":[{"text":"Constructor","id":"constructor"},{"text":"Propiedades","id":"propiedades"},{"text":"Métodos","id":"métodos"},{"text":"Problemas de accesibilidad","id":"problemas_de_accesibilidad"},{"text":"Especificaciones","id":"especificaciones"},{"text":"Compatibilidad con navegadores","id":"compatibilidad_con_navegadores"},{"text":"Ver también","id":"ver_también"}],"summary":"La interfaz Animation de la  Web Animations API representa un reproductor de animación y proporciona controles de reproducción y una línea de tiempo para un nodo o una fuente de animación.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Animation","locale":"en-US","native":"English (US)"},{"title":"Animation","locale":"fr","native":"Français"},{"title":"Animation","locale":"ja","native":"日本語"},{"title":"Animation","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Animation","locale":"ru","native":"Русский"},{"title":"Animation","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"es/web/api/animation","github_url":"https://github.com/mdn/translated-content/blob/main/files/es/web/api/animation/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/es/docs/Web","title":"Tecnología para desarrolladores web"},{"uri":"/es/docs/Web/API","title":"Referencia de la API Web"},{"uri":"/es/docs/Web/API/Animation","title":"Animation"}],"pageTitle":"Animation - Referencia de la API Web | MDN","noIndexing":false}}