{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"load","mdn_url":"/es/docs/Web/API/Window/load_event","locale":"es","native":"Español","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p>El evento&nbsp;<code>load</code> se dispara cuando un recurso y sus recursos dependientes han terminado de cargar.</p>\n\n<p>&nbsp;</p>"}},{"type":"prose","value":{"id":"ejemplos","title":"Ejemplos","isH3":false,"content":""}},{"type":"prose","value":{"id":"window","title":"Window","isH3":true,"content":"<div class=\"code-example\"><pre class=\"brush: html notranslate\"><code><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>script</span><span class=\"token punctuation\">&gt;</span></span><span class=\"token script\"><span class=\"token language-javascript\">\n  window<span class=\"token punctuation\">.</span><span class=\"token function\">addEventListener</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"load\"</span><span class=\"token punctuation\">,</span> <span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">event</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n    console<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"'Todos los recursos terminaron de cargar!\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n  <span class=\"token punctuation\">}</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n</span></span><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>script</span><span class=\"token punctuation\">&gt;</span></span></code></pre></div>"}},{"type":"prose","value":{"id":"elemento_script","title":"Elemento <code>script</code>","isH3":true,"content":"<div class=\"code-example\"><pre class=\"brush: html notranslate\"><code><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>script</span><span class=\"token punctuation\">&gt;</span></span><span class=\"token script\"><span class=\"token language-javascript\">\n  <span class=\"token keyword\">var</span> script <span class=\"token operator\">=</span> document<span class=\"token punctuation\">.</span><span class=\"token function\">createElement</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"script\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n  script<span class=\"token punctuation\">.</span><span class=\"token function\">addEventListener</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"load\"</span><span class=\"token punctuation\">,</span> <span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">event</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n    console<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"Script terminó de cargarse y ejecutarse\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n  <span class=\"token punctuation\">}</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n  script<span class=\"token punctuation\">.</span>src <span class=\"token operator\">=</span> <span class=\"token string\">\"http://example.com/example.js\"</span><span class=\"token punctuation\">;</span>\n  script<span class=\"token punctuation\">.</span>async <span class=\"token operator\">=</span> <span class=\"token boolean\">true</span><span class=\"token punctuation\">;</span>\n  document<span class=\"token punctuation\">.</span><span class=\"token function\">getElementsByTagName</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"script\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">[</span><span class=\"token number\">0</span><span class=\"token punctuation\">]</span><span class=\"token punctuation\">.</span>parentNode<span class=\"token punctuation\">.</span><span class=\"token function\">appendChild</span><span class=\"token punctuation\">(</span>script<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n</span></span><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>script</span><span class=\"token punctuation\">&gt;</span></span></code></pre></div>","titleAsText":"Elemento script"}},{"type":"prose","value":{"id":"información_general","title":"Información general","isH3":false,"content":"<dl>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"especificación\">Especificación</dt>\n <dd style=\"margin: 0 0 0 120px;\"><a class=\"external\" href=\"https://www.w3.org/TR/DOM-Level-3-Events/#event-type-load\" rel=\" noopener\">DOM L3</a></dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"interfaz\">Interfaz</dt>\n <dd style=\"margin: 0 0 0 120px;\">UIEvent</dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"propagación\">Propagación</dt>\n <dd style=\"margin: 0 0 0 120px;\">No</dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"cancelable\">Cancelable</dt>\n <dd style=\"margin: 0 0 0 120px;\">No</dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"objetivo\">Objetivo</dt>\n <dd style=\"margin: 0 0 0 120px;\">Window,Document,Element</dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"por_defecto_acción\">Por defecto Acción</dt>\n <dd style=\"margin: 0 0 0 120px;\">None.</dd>\n</dl>"}},{"type":"prose","value":{"id":"propiedades","title":"Propiedades","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">Propiedad</th>\n   <th scope=\"col\">Tipo</th>\n   <th scope=\"col\">Descripción</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><code>target</code> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></td>\n   <td><code><a href=\"/es/docs/Web/API/EventTarget\"><code>EventTarget</code></a></code></td>\n   <td>El objetivo del evento (el objetivo superior en el árbol DOM).</td>\n  </tr>\n  <tr>\n   <td><code>type</code> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></td>\n   <td><code><a href=\"/es/docs/conflicting/Web/JavaScript/Reference/Global_Objects/String\"><code>DOMString</code></a></code></td>\n   <td>El tipo de evento.</td>\n  </tr>\n  <tr>\n   <td><code>bubbles</code> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></td>\n   <td><code><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code> <small>(en-US)</small></a></code></td>\n   <td>Si el elemento normalmente se propaga (bubbles) o no.</td>\n  </tr>\n  <tr>\n   <td><code>cancelable</code> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></td>\n   <td><code><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code> <small>(en-US)</small></a></code></td>\n   <td>Si el evento es cancelable o no.</td>\n  </tr>\n  <tr>\n   <td><code>view</code> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></td>\n   <td><code><a class=\"page-not-created\" title=\"La documentación acerca de este tema no ha sido escrita todavía . ¡Por favor  considera contribuir !\"><code>WindowProxy</code></a></code></td>\n   <td><code><a href=\"/es/docs/Web/API/Document/defaultView\" title=\"document.defaultView\"><code>document.defaultView</code></a></code> (<code>window</code> del documento)</td>\n  </tr>\n  <tr>\n   <td><code>detail</code> <span title=\"This value may not be changed.\" class=\"badge inline readonly\">Read only </span></td>\n   <td><code>long</code> (<code>float</code>)</td>\n   <td>0.</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"especificaciones","title":"Especificaciones","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Especificación</th>\n   <th scope=\"col\">Estado</th>\n   <th scope=\"col\">Comentario</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://w3c.github.io/uievents/#event-type-load\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">UI Events<br><small lang=\"es\">La definición de 'load' en esta especificación.</small></a></td>\n   <td><span class=\"spec-wd\">Working Draft</span></td>\n   <td>&nbsp;</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://html.spec.whatwg.org/multipage/parsing.html#the-end:event-load\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML Living Standard<br><small lang=\"es\">La definición de 'Load event' en esta especificación.</small></a></td>\n   <td><span class=\"spec-living\">Living Standard</span></td>\n   <td>Esto enlaza con la sección en los pasos que se llevan a cabo al final de cargar un documento. Los eventos 'load' también se disparan a muchos elementos. Y tenga en cuenta que hay muchos lugares en la especificación que hacen referencia a cosas que pueden \"<a href=\"https://html.spec.whatwg.org/multipage/parsing.html#delay-the-load-event\" class=\"external\" rel=\" noopener\">retrasar el evento de carga</a>\".</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"eventos_relacionados","title":"Eventos relacionados","isH3":false,"content":"<ul>\n <li><code><a href=\"/en-US/docs/Web/API/Window/DOMContentLoaded_event\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">DOMContentLoaded (en-US)</a></code></li>\n <li><code><a href=\"/en-US/docs/Web/API/Document/readystatechange_event\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">readystatechange (en-US)</a></code></li>\n <li><code><a href=\"/es/docs/Web/API/Window/load_event\" title=\"/es/docs/Web/Reference/Events/load\">load</a></code></li>\n <li><code><a href=\"/es/docs/Web/API/Window/beforeunload_event\" title=\"/es/docs/Web/Reference/Events/beforeunload\">beforeunload</a></code></li>\n <li><code><a href=\"/en-US/docs/Web/API/Window/unload_event\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">unload (en-US)</a></code></li>\n</ul>"}}],"toc":[{"text":"Ejemplos","id":"ejemplos"},{"text":"Información general","id":"información_general"},{"text":"Propiedades","id":"propiedades"},{"text":"Especificaciones","id":"especificaciones"},{"text":"Eventos relacionados","id":"eventos_relacionados"}],"summary":"El evento load se dispara cuando un recurso y sus recursos dependientes han terminado de cargar.","popularity":0.0009,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"load","locale":"de","native":"Deutsch"},{"title":"Window: load event","locale":"en-US","native":"English (US)"},{"title":"load","locale":"fr","native":"Français"},{"title":"Window: load イベント","locale":"ja","native":"日本語"},{"title":"load","locale":"ko","native":"한국어"},{"title":"load","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"load","locale":"ru","native":"Русский"},{"title":"load","locale":"zh-CN","native":"中文 (简体)"},{"title":"load","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"es/web/api/window/load_event","github_url":"https://github.com/mdn/translated-content/blob/main/files/es/web/api/window/load_event/index.h