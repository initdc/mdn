{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"Mozilla Firefox","mdn_url":"/es/docs/Glossary/Mozilla_Firefox","locale":"es","native":"Español","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p><span style=\"line-height: 1.5;\">Mozilla Firefox es un&nbsp;<a class=\"page-not-created\" title=\"La documentación acerca de este tema no ha sido escrita todavía . ¡Por favor  considera contribuir !\">navegador</a> gratuito de codigo abierto cuyo desarrollo es supervisado por Mozilla Corporation. Firefox functiona sobre Windows, OS X, Linus y Android.</span></p>\n\n<p><span style=\"line-height: 1.5;\">First released in November 2004, Firefox is completely customizable with themes, plug-ins, and <a href=\"/en-US/Add-ons\">add-ons</a>. &nbsp;Firefox uses <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Glossary/Gecko\">Gecko <small>(en-US)</small></a> to render webpages, and implements both current and upcoming Web standards.</span></p>\n\n<p><span style=\"line-height: 1.5;\">Lanzado en Noviembre del 2014, Firefox es completamente personalizable con temas y <a href=\"/es/Add-ons\">complementos</a>. Firefox usa&nbsp;<a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Glossary/Gecko\">Gecko <small>(en-US)</small></a> para renderizar paginas webs, e implementa tanto actuales como próximos estandares Web.</span></p>"}},{"type":"prose","value":{"id":"aprende_más","title":"<span style=\"line-height: 1.5;\">Aprende más</span>","isH3":false,"content":"","titleAsText":"Aprende más"}},{"type":"prose","value":{"id":"conocimientos_generales","title":"Conocimientos generales","isH3":true,"content":"<ul>\n <li><a href=\"https://www.firefox.com/\" class=\"external\" rel=\" noopener\">Sitio oficial de Mozilla Firefox</a></li>\n</ul>"}},{"type":"prose","value":{"id":"referencias_técnicas","title":"Referencias técnicas","isH3":true,"content":"<ul>\n <li><a href=\"/en-US/Firefox\">Documentación/Información para desarrolladores en MDN</a></li>\n</ul>"}}],"toc":[{"text":"<span style=\"line-height: 1.5;\">Aprende más</span>","id":"aprende_más"}],"summary":"Mozilla Firefox es un navegador gratuito de codigo abierto cuyo desarrollo es supervisado por Mozilla Corporation. Firefox functiona sobre Windows, OS X, Linus y Android.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Mozilla Firefox","locale":"de","native":"Deutsch"},{"title":"Mozilla Firefox","locale":"en-US","native":"English (US)"},{"title":"Mozilla Firefox","locale":"fr","native":"Français"},{"title":"Mozilla Firefox","locale":"ja","native":"日本語"},{"title":"Mozilla Firefox","locale":"ko","native":"한국어"},{"title":"Mozilla Firefox","locale":"pl","native":"Polski"},{"title":"Mozilla Firefox","locale":"pt-BR","native":"Português (do Brasil)"}],"source":{"folder":"es/glossary/mozilla_firefox","github_url":"https://github.com/mdn/translated-content/blob/main/files/es/glossary/mozilla_firefox/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/es/docs/Glossary","title":"Glosario"},{"uri":"/es/docs/Glossary/Mozilla_Firefox","title":"Mozilla Firefox"}],"pageTitle":"Mozilla Firefox - Glosario | MDN","noIndexing":false}}