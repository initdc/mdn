se","value":{"id":"przyk.c5.82ad","title":"Przykład","isH3":true,"content":"<pre class=\"eval notranslate\">alert(navigator.onLine&nbsp;? \"Jesteś online\"&nbsp;: \"Jesteś offline\");\n</pre>"}},{"type":"prose","value":{"id":"uwagi","title":"Uwagi","isH3":true,"content":"<p>Zobacz <a href=\"pl/Zdarzenia_Online%2f%2fOffline\">Zdarzenia Online/Offline‎</a>, aby uzyskać bardziej szczegółowy opis tej własności, jak również nowych funkcji związanych z trybem offline, wprowadzonych w Firefoksie 3.</p>"}},{"type":"prose","value":{"id":"specyfikacja","title":"Specyfikacja","isH3":true,"content":"<p>DOM Level 0. Nie jest częścią żadnego standardu.</p>\n\n<p>Opisana w <a class=\"external\" href=\"https://www.whatwg.org/specs/web-apps/current-work/#navigator.online\" rel=\" noopener\">szkicu roboczym HTML 5</a></p>\n\n<p>&nbsp;</p>\n\n<div class=\"noinclude\" id=\"sect1\">&nbsp;</div>\n\n<p></p>"}}],"toc":[],"summary":"Zwraca wartość logiczną wskazującą czy przeglądarka jest w trybie online, czy nie.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"NavigatorOnLine.onLine","locale":"de","native":"Deutsch"},{"title":"Navigator.onLine","locale":"es","native":"Español"},{"title":"Navigator.onLine","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"NavigatorOnLine.onLine","locale":"ru","native":"Русский"}],"source":{"folder":"pl/orphaned/web/api/navigatoronline/online","github_url":"https://github.com/mdn/translated-content/blob/main/files/pl/orphaned/web/api/navigatoronline/online/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pl/docs/orphaned/Web/API/NavigatorOnLine","title":"NavigatorOnLine"},{"uri":"/pl/docs/orphaned/Web/API/NavigatorOnLine/onLine","title":"NavigatorOnLine.onLine"}],"pageTitle":"NavigatorOnLine.onLine | MDN","noIndexing":true}}