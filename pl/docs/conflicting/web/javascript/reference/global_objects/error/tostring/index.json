ects/Object/constructor\"><code>Object.prototype.constructor</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/proto\"><code>Object.prototype.__proto__</code></a></li></ol></li><li><a href=\"#\"><strong>Metody</strong></a><ol><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineGetter__\"><code>Object.prototype.__defineGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineSetter__\"><code>Object.prototype.__defineSetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupGetter__\"><code>Object.prototype.__lookupGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupSetter__\"><code>Object.prototype.__lookupSetter__()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwnProperty\"><code>Object.prototype.hasOwnProperty()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/isPrototypeOf\"><code>Object.prototype.isPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/propertyIsEnumerable\"><code>Object.prototype.propertyIsEnumerable()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/setPrototypeOf\"><code>Object.setPrototypeOf()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/toLocaleString\"><code>Object.prototype.toLocaleString()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/valueOf\"><code>Object.prototype.valueOf()</code></a></li></ol></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"> <div class=\"notecard warning\" id=\"sect2\"><p><strong>Niestandardowy:</strong> This feature is non-standard and is not on a standards track. Do not use it on production sites facing the Web: it will not work for every user. There may also be large incompatibilities between implementations and the behavior may change in the future.</p></div></div>\n\n<p>Metoda <code><strong>toSource()</strong></code> zwraca kod, który możemethod returns code that could eval to the same error.</p>"}},{"type":"prose","value":{"id":"składnia","title":"Składnia","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><var>e</var>.toSource()</pre>"}},{"type":"prose","value":{"id":"zwracana_wartość","title":"Zwracana wartość","isH3":true,"content":"<p>Łańcuch znaków (<em>string</em>) zawierający kod źródłowy błędu.</p>"}},{"type":"prose","value":{"id":"przykłady","title":"Przykłady","isH3":false,"content":""}},{"type":"prose","value":{"id":"użycie_tosource","title":"Użycie toSource","isH3":true,"content":"<p>Wywołanie metody <code>toSource</code> instancji <a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Error\"><code>Error</code></a> (w tym <em><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Error#error_types\">NativeErrors</a></em>) zwróci łańcuch znaków zawierający kod źródłowy błędu. Zwrócony <em>string</em> może być ewaluowany do utworzenia (w przybliżeniu) takiego samego obiektu. Oczywiście ciąg znaków zawierający kod źródłowy jest zgodny ze strukturą konstruktora <a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Error\"><code>Error</code></a>. Przykładowo:</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token punctuation\">(</span><span class=\"token function\">newname</span><span class=\"token punctuation\">(</span>message<span class=\"token punctuation\">,</span> nazwaPliku<span class=\"token punctuation\">,</span> numerLinii<span class=\"token punctuation\">)</span><span class=\"token punctuation\">)</span>\n</code></pre></div>\n\n<p>gdzie wymienione atrybuty odpowiadają właściwym własnościom instancji błędu.</p>\n\n<div class=\"note notecard\" id=\"sect3\">\n<p><strong>Uwaga:</strong> należy pamiętać, że własności używanen przez metodę <code>toSource</code> podczas tworzenia tego ciągu znaków są modyfikowalne i mogą nie odzwierciedlać dokładnie funkcji użytej do stworzenia instancji błędu lub nazwy pliku czy numeru linii gdzie wystąpił dany błąd.</p>\n</div>"}},{"type":"prose","value":{"id":"specyfikacje","title":"Specyfikacje","isH3":false,"content":"<p>Nie należy do żadnego standardu.</p>"}},{"type":"browser_compatibility","value":{"title":"Wsparcie przeglądarek","id":"wsparcie_przeglądarek","isH3":false,"query":"javascript.builtins.Error.toSource","dataURL":"/pl/docs/conflicting/Web/JavaScript/Reference/Global_Objects/Error/toString/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect4\">\n<div id=\"sect5\">\n\n\n<p></p><p></p>\n</div>\n</div>"}},{"type":"prose","value":{"id":"zobacz_też","title":"Zobacz też","isH3":false,"content":"<ul>\n <li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Error/fileName\"><code>Error.prototype.fileName</code></a></li>\n <li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Error/lineNumber\"><code>Error.prototype.lineNumber</code></a></li>\n <li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Error/message\"><code>Error.prototype.message</code></a></li>\n <li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Error/name\"><code>Error.prototype.name</code></a></li>\n <li><a href=\"/pl/docs/conflicting/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toSource()</code></a></li>\n</ul>"}}],"toc":[{"text":"Składnia","id":"składnia"},{"text":"Przykłady","id":"przykłady"},{"text":"Specyfikacje","id":"specyfikacje"},{"text":"Wsparcie przeglądarek","id":"wsparcie_przeglądarek"},{"text":"Zobacz też","id":"zobacz_też"}],"summary":"Metoda toSource() zwraca kod, który możemethod returns code that could eval to the same error.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Error.prototype.toSource()","locale":"de","native":"Deutsch"},{"title":"Error.prototype.toSource()","locale":"es","native":"Español"},{"title":"Error.prototype.toSource()","locale":"ja","native":"日本語"},{"title":"Error.prototype.toSource()","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Error.prototype.toSource()","locale":"ru","native":"Русский"},{"title":"Error.prototype.toSource()","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"pl/conflicting/web/javascript/reference/global_objects/error/tostring","githu