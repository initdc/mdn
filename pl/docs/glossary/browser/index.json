{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"Przeglądarka","mdn_url":"/pl/docs/Glossary/Browser","locale":"pl","native":"Polski","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p><strong>Przeglądarka</strong> <strong>internetowa</strong> lub&nbsp;<strong>przeglądarka</strong>&nbsp;to program, który pobiera i wyświetla strony internetowe z <a href=\"/pl/docs/Glossary/World_Wide_Web\">Sieci Web</a> i umożliwia dostęp do kolejnych stron poprzez <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Glossary/Hyperlink\">hiperłącza <small>(en-US)</small></a>. Przeglądarka jest najbardziej znanym typem <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Glossary/User_agent\">agenta użytkownika <small>(en-US)</small></a>.</p>"}},{"type":"prose","value":{"id":"dowiedz_się_więcej","title":"Dowiedz się więcej","isH3":false,"content":""}},{"type":"prose","value":{"id":"wiedza_ogólna","title":"Wiedza ogólna","isH3":true,"content":"<ul>\n <li><a href=\"https://pl.wikipedia.org/wiki/Przeglądarka_internetowa\" class=\"external\" rel=\" noopener\">Przeglądarka internetowa</a>&nbsp;na Wikipedii</li>\n <li><a href=\"http://www.evolutionoftheweb.com/\" rel=\"external noopener\" class=\"external\">Ewolucja sieci internetowej</a></li>\n</ul>"}},{"type":"prose","value":{"id":"pobierz_przeglądarkę","title":"Pobierz przeglądarkę","isH3":true,"content":"<ul>\n <li><a href=\"https://www.mozilla.org/pl/firefox/\" class=\"external\" rel=\" noopener\">Mozilla Firefox</a></li>\n <li><a href=\"https://www.google.com/chrome/\" rel=\"external noopener\" class=\"external\">Google Chrome</a></li>\n <li><a href=\"https://www.microsoft.com/pl-pl/windows/microsoft-edge\" rel=\"external noopener\" class=\"external\">Microsoft Edge</a></li>\n <li><a href=\"https://www.opera.com/\" rel=\"external noopener\" class=\"external\">Opera</a></li>\n</ul>"}}],"toc":[{"text":"Dowiedz się więcej","id":"dowiedz_się_więcej"}],"summary":"Przeglądarka internetowa lub przeglądarka to program, który pobiera i wyświetla strony internetowe z Sieci Web i umożliwia dostęp do kolejnych stron poprzez hiperłącza (en-US). Przeglądarka jest najbardziej znanym typem agenta użytkownika (en-US).","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Browser","locale":"de","native":"Deutsch"},{"title":"Browser","locale":"en-US","native":"English (US)"},{"title":"Navegador","locale":"es","native":"Español"},{"title":"Navigateur","locale":"fr","native":"Français"},{"title":"Browser (ブラウザー)","locale":"ja","native":"日本語"},{"title":"브라우저","locale":"ko","native":"한국어"},{"title":"Navegador","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Браузер","locale":"ru","native":"Русский"},{"title":"浏览器","locale":"zh-CN","native":"中文 (简体)"},{"title":"瀏覽器","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"pl/glossary/browser","github_url":"https://github.com/mdn/translated-content/blob/main/files/pl/glossary/browser/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pl/docs/Glossary","title":"Glossary"},{"uri":"/pl/docs/Glossary/Browser","title":"Przeglądarka"}],"pageTitle":"Przeglądarka - Glossary | MDN","noIndexing":false}}