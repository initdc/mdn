{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"ASCII","mdn_url":"/pl/docs/Glossary/ASCII","locale":"pl","native":"Polski","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p><strong>ASCII</strong> (<em>American Standard Code for Information Interchange</em>) jest jednym z najpopularniejszych standardów kodowania używanym przez komputery. Służy do zamiany liter, cyfr oraz kodów kontrolnych do zapisu binarnego. Od 2007 roku, <a href=\"/pl/docs/Glossary/UTF-8\">UTF-8</a> zastąpiło ASCII.</p>"}},{"type":"prose","value":{"id":"learn_more","title":"Learn more","isH3":false,"content":""}},{"type":"prose","value":{"id":"general_knowledge","title":"General knowledge","isH3":true,"content":"<p><a title=\"ASCII\" href=\"https://pl.wikipedia.org/wiki/ASCII\" class=\"external\" rel=\" noopener\">ASCII</a> on Wikipedia</p>"}}],"toc":[{"text":"Learn more","id":"learn_more"}],"summary":"ASCII (American Standard Code for Information Interchange) jest jednym z najpopularniejszych standardów kodowania używanym przez komputery. Służy do zamiany liter, cyfr oraz kodów kontrolnych do zapisu binarnego. Od 2007 roku, UTF-8 zastąpiło ASCII.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"ASCII","locale":"de","native":"Deutsch"},{"title":"ASCII","locale":"en-US","native":"English (US)"},{"title":"ASCII","locale":"es","native":"Español"},{"title":"ASCII","locale":"fr","native":"Français"},{"title":"ASCII","locale":"ja","native":"日本語"},{"title":"ASCII","locale":"ko","native":"한국어"},{"title":"ASCII","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"ASCII","locale":"ru","native":"Русский"},{"title":"ASCII","locale":"zh-CN","native":"中文 (简体)"},{"title":"ASCII","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"pl/glossary/ascii","github_url":"https://github.com/mdn/translated-content/blob/main/files/pl/glossary/ascii/index.html","last_commit_url":"https://