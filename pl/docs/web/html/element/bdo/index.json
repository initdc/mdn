{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"bdo","mdn_url":"/pl/docs/Web/HTML/Element/bdo","locale":"pl","native":"Polski","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p>\n</p><p><br>\n</p>"}},{"type":"prose","value":{"id":"podsumowanie","title":" Podsumowanie ","isH3":true,"content":"<p>Element <code>&lt;bdo&gt;</code> jest używany do unieważnienia aktualnego kierunku tekstu. Powoduje to zignorowanie kierunku znaków na rzecz zdefiniowanego kierunku.\n</p>"}},{"type":"prose","value":{"id":"przyk.c5.82ad","title":" Przykład ","isH3":true,"content":"<pre class=\"notranslate\">    &lt;!-- Przełącz kierunek tekstu --&gt;\n    &lt;bdo dir=\"rtl\"&gt;Ten tekst będzie biegł od prawej do lewej.&lt;/bdo&gt;\n</pre>"}},{"type":"prose","value":{"id":"notatki","title":" Notatki ","isH3":true,"content":"<p>Specyfikacja HTML 4 nie określa zdarzeń dla tego elementu; zostały one dodane w XHTML. Bardzo prawdopodobnie jest to przeoczenie.\n</p><p><br>\n{{ HTML:Element_Navigation() }}\n</p>"}}],"toc":[],"summary":"Element <bdo> jest używany do unieważnienia aktualnego kierunku tekstu. Powoduje to zignorowanie kierunku znaków na rzecz zdefiniowanego kierunku.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"<bdo>","locale":"de","native":"Deutsch"},{"title":"<bdo>: The Bidirectional Text Override element","locale":"en-US","native":"English (US)"},{"title":"bdo","locale":"es","native":"Español"},{"title":"<bdo> : l'élément de remplacement bidirectionnelle","locale":"fr","native":"Français"},{"title":"<bdo>: 双方向文字列上書き要素","locale":"ja","native":"日本語"},{"title":"<bdo>: 양방향 텍스트 재정의 요소","locale":"ko","native":"한국어"},{"title":"<bdo>","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"<bdo>: The Bidirectional Text Override element","locale":"ru","native":"Русский"},{"title":"<bdo>: 双向文本替代元素","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"pl/web/h