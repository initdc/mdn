{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"cite","mdn_url":"/pl/docs/Web/HTML/Element/cite","locale":"pl","native":"Polski","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p>\n</p>"}},{"type":"prose","value":{"id":"podsumowanie","title":" Podsumowanie ","isH3":true,"content":"<p>Element <code>&lt;cite&gt;</code> zawiera cytowanie lub odwołanie do innych zasobów.\n</p>\n<ul><li> Typ elementu: <a href=\"pl/HTML/Elementy_liniowe\">inline</a>\n</li><li> Dozwolona zawartość: <a href=\"pl/HTML/Elementy_liniowe\">inline</a>\n</li></ul>"}},{"type":"prose","value":{"id":"przyk.c5.82ad","title":" Przykład ","isH3":true,"content":"<h4 id=\"oznaczanie_autora_cytatu\" name=\"Oznaczanie_autora_cytatu\"> Oznaczanie autora cytatu </h4>\n<pre class=\"notranslate\">  As &lt;cite&gt;Harry S. Truman&lt;/cite&gt; said, &lt;q&gt;The buck stops here.&lt;/q&gt;\n</pre>\n<p>Powyższy HTML daje w efekcie:\n</p><p><img alt=\"Image:HTML-cite.png\" loading=\"lazy\">\n</p>\n<h4 id=\"oznaczanie_.c5.bar.c3.b3d.c5.82a\" name=\"Oznaczanie_.C5.BAr.C3.B3d.C5.82a\"> Oznaczanie źródła </h4>\n<pre class=\"notranslate\">  Więcej informacji można znaleźć w &lt;cite&gt;[ISO-0000]&lt;/cite&gt;\n</pre>\n<p>Powyższy HTML daje w efekcie:\n</p><p>Więcej informacji można znaleźć w <cite>[ISO-0000]</cite>\n</p>"}},{"type":"prose","value":{"id":"notatki","title":" Notatki ","isH3":true,"content":"<p>Aby usunąć kursywę z elementu <code>&lt;cite&gt;</code>, użyj własności <a href=\"pl/CSS\">CSS</a> <a href=\"pl/CSS/font-style\">font-style</a>.\n</p>"}},{"type":"prose","value":{"id":"zobacz_tak.c5.bce","title":" Zobacz także ","isH3":true,"content":"<ul><li> <a href=\"pl/HTML/Element/q\">Znacznik <code>&lt;q&gt;</code></a>\n</li><li> <a href=\"pl/HTML/Element/blockquote\">Znacznik <code>&lt;blockquote&gt;</code></a>\n</li></ul>\n<p><br>\n{{ HTML:Element_Navigation() }}\n</p>"}}],"toc":[],"summary":"Element <cite> zawiera cytowani