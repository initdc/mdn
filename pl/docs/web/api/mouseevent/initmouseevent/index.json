{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"event.initMouseEvent","mdn_url":"/pl/docs/Web/API/MouseEvent/initMouseEvent","locale":"pl","native":"Polski","sidebarHTML":"<ol><li><strong><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/MouseEvent\"><code>MouseEvent</code> <small>(en-US)</small></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>Constructor</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/MouseEvent/MouseEvent\"><code>MouseEvent()</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Własności</summary><ol><li><a href=\"/pl/docs/Web/API/MouseEvent/altKey\"><code>altKey</code></a></li><li><a href=\"/pl/docs/Web/API/MouseEvent/button\"><code>button</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/MouseEvent/buttons\"><code>buttons</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/API/MouseEvent/clientX\"><code>clientX</code></a></li><li><a href=\"/pl/docs/Web/API/MouseEvent/clientY\"><code>clientY</code></a></li><li><a href=\"/pl/docs/Web/API/MouseEvent/ctrlKey\"><code>ctrlKey</code></a></li><li><a href=\"/pl/docs/Web/API/MouseEvent/layerX\"><code>layerX</code></a></li><li><a href=\"/pl/docs/Web/API/MouseEvent/layerY\"><code>layerY</code></a></li><li><a href=\"/pl/docs/Web/API/MouseEvent/metaKey\"><code>metaKey</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/MouseEvent/movementX\"><code>movementX</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/MouseEvent/movementY\"><code>movementY</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/MouseEvent/mozInputSource\"><code>mozInputSource</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/MouseEvent/offsetX\"><code>offsetX</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/MouseEvent/offsetY\"><code>offsetY</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/API/MouseEvent/pageX\"><code>pageX</code></a></li><li><a href=\"/pl/docs/Web/API/MouseEvent/pageY\"><code>pageY</code></a></li><li><a href=\"/pl/docs/Web/API/MouseEvent/relatedTarget\"><code>relatedTarget</code></a></li><li><a href=\"/pl/docs/Web/API/MouseEvent/screenX\"><code>screenX</code></a></li><li><a href=\"/pl/docs/Web/API/MouseEvent/screenY\"><code>screenY</code></a></li><li><a href=\"/pl/docs/Web/API/MouseEvent/shiftKey\"><code>shiftKey</code></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/MouseEvent/WEBKIT_FORCE_AT_FORCE_MOUSE_DOWN\"><code>WEBKIT_FORCE_AT_FORCE_MOUSE_DOWN</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/MouseEvent/WEBKIT_FORCE_AT_MOUSE_DOWN\"><code>WEBKIT_FORCE_AT_MOUSE_DOWN</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/MouseEvent/webkitForce\"><code>webkitForce</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/MouseEvent/x\"><code>x</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/MouseEvent/y\"><code>y</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Metody</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/MouseEvent/getModifierState\"><code>getModifierState()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><em><code>initMouseEvent()</code></em></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Inheritance:</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/UIEvent\"><code>UIEvent</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/API/Event\"><code>Event</code></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"podsumowanie","title":"Podsumowanie","isH3":true,"content":"<p>Inicjuje zdarzenie myszy po jego utworzeniu (za pomocą metody <a href=\"pl/DOM/document.createEvent\">createEvent</a> interfejsu <code>DocumentEvent</code>).</p>"}},{"type":"prose","value":{"id":"sk.c5.82adnia","title":"Składnia","isH3":true,"content":"<pre class=\"eval notranslate\"><i>event</i>.initMouseEvent(<i>type</i>,<i>canBubble</i>,<i>cancelable</i>,<i>view</i>,<i>detail</i>,<i>screenX</i>,<i>screenY</i>,<i>clientX</i>,<i>clientY</i>,<i>ctrlKey</i>,<i>altKey</i>,<i>shiftKey</i>,<i>metaKey</i>,<i>button</i>,<i>relatedTarget</i>);\n</pre>\n<dl>\n <dt id=\"sect1\">\n  <code>type</code></dt>\n <dd>\n  łańcuch znaków do ustawienia <a href=\"pl/DOM/event.type\">typu</a> zdarzeń. Możliwe typy dla zdarzeń myszy: <code>click</code>, <code>mousedown</code>, <code>mouseup</code>, <code>mouseover</code>, <code>mousemove</code>, <code>mouseout</code>.</dd>\n <dt id=\"sect2\">\n  <code>canBubble</code></dt>\n <dd>\n  czy zdarzenie bąbelkuje. Ustawia wartość <a href=\"pl/DOM/event.bubbles\">event.bubbles</a>.</dd>\n <dt id=\"sect3\">\n  <code>cancelable</code></dt>\n <dd>\n  czy domyślna akcja zdarzenia może być anulowana. Ustawia Ustawia wartość <a href=\"pl/DOM/event.cancelable\">event.cancelable</a>.</dd>\n <dt id=\"sect4\">\n  <code>view</code></dt>\n <dd>\n  AbstractView zdarzenia. You should pass the <a href=\"pl/DOM/window\">window</a> object here. Ustawia wartość <a href=\"pl/DOM/event.view\">event.view</a>.</dd>\n <dt id=\"sect5\">\n  <code>detail</code></dt>\n <dd>\n  wartość licznika kliknięć myszą. Ustawia wartość <a href=\"pl/DOM/event.detail\">event.detail</a>.</dd>\n <dt id=\"sect6\">\n  <code>screenX</code></dt>\n <dd>\n  współrzędna x względem ekranu. Ustawia wartość <a href=\"pl/DOM/event.screenX\">event.screenX</a>.</dd>\n <dt id=\"sect7\">\n  <code>screenY</code></dt>\n <dd>\n  współrzędna y względem ekranu. Ustawia wartość <a href=\"pl/DOM/event.screenY\">event.screenY</a>.</dd>\n <dt id=\"sect8\">\n  <code>clientX</code></dt>\n <dd>\n  współrzędna x w obszarze klienta. Ustawia wartość <a href=\"pl/DOM/event.clientX\">event.clientX</a>.</dd>\n <dt id=\"sect9\">\n  <code>clientY</code></dt>\n <dd>\n  współrzędna y w obszarze klienta. Ustawia wartość <a href=\"pl/DOM/event.clientY\">event.clientY</a>.</dd>\n <dt id=\"sect10\">\n  <code>ctrlKey</code></dt>\n <dd>\n  czy klawisz control był wciśnięty podczas zdarzenia. Ustawia wartość <a href=\"pl/DOM/event.ctrlKey\">event.ctrlKey</a>.</dd>\n <dt id=\"sect11\">\n  <code>altKey</code></dt>\n <dd>\n  czy klawisz alt był wciśnięty podczas zdarzenia. Ustawia wartość <a href=\"pl/DOM/event.altKey\">event.altKey</a>.</dd>\n <dt id=\"sect12\">\n  <code>shiftKey</code></dt>\n <dd>\n  czy klawisz shift był wciśnięty podczas zdarzenia. Ustawia wartość <a href=\"pl/DOM/event.shiftKey\">event.shiftKey</a>.</dd>\n <dt id=\"sect13\">\n  <code>metaKey</code></dt>\n <dd>\n  czy klawisz meta był wciśnięty podczas zdarzenia. Ustawia wartość <a href=\"pl/DOM/event.metaKey\">event.metaKey</a>.</dd>\n <dt id=\"sect14\">\n  <code>button</code></dt>\n <dd>\n  zdarzenie myszy <a href=\"pl/DOM/event.button\">event.button</a>.</dd>\n <dt id=\"sect15\">\n  <code>relatedTarget</code></dt>\n <dd>\n  zdarzenie <a href=\"pl/DOM/event.relatedTarget\">related EventTarget</a>. Stosowane tylko z kilkoma typami zdarzeń (np. <code>mouseover</code> i <code>mouseout</code>). W innych przypadkach, zwraca <code>null</code>.</dd>\n</dl>"}},{"type":"prose","value":{"id":"przyk.c5.82ad","title":"Przykład","isH3":true,"content":"<p>&nbsp;</p>"}},{"type":"prose","value":{"id":"specyfikacja","title":"Specyfikacja","isH3":true,"content":"<p><a class=\"external\" href=\"https://www.w3.org/TR/DOM-Level-2-Events/events.html#Events-Event-initMouseEvent\" rel=\" noopener\">DOM Level 2 Events: initMouseEvent</a></p>\n<p>&nbsp;</p>\n<div class=\"noinclude\" id=\"sect16\">\n &nbsp;</div>\n<p></p>"}}],"toc":[],"summary":"Inicjuje zdarzenie myszy po jego utworzeniu (za pomocą metody createEvent interfejsu DocumentEvent).","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"MouseEvent.initMouseEvent()","locale":"en-US","native":"English (US)"},{"title":"event.initMouseEvent","locale":"es","native":"Español"},{"title":"MouseEvent.initMouseEvent()","locale":"ja","native":"日本語"},{"title":"MouseEvent.initMouseEvent()","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"pl/web/api/mouseevent/initmouseevent","github_url":"https://github.com/mdn/translated-content/blob/main/files/pl/web/api/mouseevent/initmouseevent/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pl/docs/Web","title":"Technologie Internetowe dla developerów"},{"uri":"/pl/docs/Web/API","title":"Lista Web API"},{"uri":"/pl/docs/Web/API/MouseEvent/initMouseEvent","title":"event.initMouseEvent"}],"pageTitle":"event.initMouseEvent - Lista Web API | MDN","noIndexing":false}}