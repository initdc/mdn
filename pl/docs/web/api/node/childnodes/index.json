{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"element.childNodes","mdn_url":"/pl/docs/Web/API/Node/childNodes","locale":"pl","native":"Polski","sidebarHTML":"<ol><li><strong><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node\"><code>Node</code> <small>(en-US)</small></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>Własności</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/baseURI\"><code>baseURI</code> <small>(en-US)</small></a></li><li><em><code>childNodes</code></em></li><li><a href=\"/pl/docs/Web/API/Node/firstChild\"><code>firstChild</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/isConnected\"><code>isConnected</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/API/Node/lastChild\"><code>lastChild</code></a></li><li><a href=\"/pl/docs/Web/API/Node/nextSibling\"><code>nextSibling</code></a></li><li><a href=\"/pl/docs/Web/API/Node/nodeName\"><code>nodeName</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/nodeType\"><code>nodeType</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/API/Node/nodeValue\"><code>nodeValue</code></a></li><li><a href=\"/pl/docs/Web/API/Node/ownerDocument\"><code>ownerDocument</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/parentElement\"><code>parentElement</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/API/Node/parentNode\"><code>parentNode</code></a></li><li><a href=\"/pl/docs/Web/API/Node/previousSibling\"><code>previousSibling</code></a></li><li><a href=\"/pl/docs/Web/API/Node/textContent\"><code>textContent</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Metody</summary><ol><li><a href=\"/pl/docs/Web/API/Node/appendChild\"><code>appendChild()</code></a></li><li><a href=\"/pl/docs/Web/API/Node/cloneNode\"><code>cloneNode()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/compareDocumentPosition\"><code>compareDocumentPosition()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/contains\"><code>contains()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/getRootNode\"><code>getRootNode()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/API/Node/hasChildNodes\"><code>hasChildNodes()</code></a></li><li><a href=\"/pl/docs/Web/API/Node/insertBefore\"><code>insertBefore()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/isDefaultNamespace\"><code>isDefaultNamespace()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/isEqualNode\"><code>isEqualNode()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/isSameNode\"><code>isSameNode()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/isSupported\"><code>isSupported()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/lookupNamespaceURI\"><code>lookupNamespaceURI()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node/lookupPrefix\"><code>lookupPrefix()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/API/Node/normalize\"><code>normalize()</code></a></li><li><a href=\"/pl/docs/Web/API/Node/removeChild\"><code>removeChild()</code></a></li><li><a href=\"/pl/docs/Web/API/Node/replaceChild\"><code>replaceChild()</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Inheritance:</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/EventTarget\"><code>EventTarget</code> <small>(en-US)</small></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"podsumowanie","title":"Podsumowanie","isH3":true,"content":"<p><b>childNodes </b> zwraca kolekcję węzłów-dzieci elementu.</p>"}},{"type":"prose","value":{"id":"sk.c5.82adnia_i_warto.c5.9bci","title":"Składnia i wartości","isH3":true,"content":"<pre class=\"eval notranslate\">var <var>listaWęzłów</var> = referencjaDoWęzłaElementu.childNodes;\n</pre>\n<p><var>listaWęzłów</var> to uporządkowana kolekcja obiektów węzłów, będącymi dziećmi bieżącego elementu. Jeśli element nie ma dzieci, <var>listaWęzłów</var> jest pusta.</p>\n<p><var>listaWęzłów</var> to zmienna przechowująca listę węzłów. Lista taka ma typ <a class=\"external\" href=\"https://www.w3.org/TR/2004/REC-DOM-Level-3-Core-20040407/core.html#ID-536297177\" rel=\" noopener\">NodeList</a>. Właściwość <code>childNodes</code> jest tylko do odczytu.</p>"}},{"type":"prose","value":{"id":"przyk.c5.82ad","title":"Przykład","isH3":true,"content":"<pre class=\"notranslate\">// parg to referencja do obiektu elementu &lt;p&gt;\nif (parg.hasChildNodes())\n// sprawdzamy czy obiekt nie jest pusty - czy ma dzieci\n {\n   var children = parg.childNodes;\n   for (var i = 0; i &lt; children.length; i++)\n   {\n   // zrob cos z kazdym dzieckiem jako children[i]\n   // uwaga: lista \"żyje\", dodawanie bądź usuwanie dzieci ją zmieni\n   };\n };\n</pre>\n<pre class=\"notranslate\">// sposób na usunięcie wszystkich dzieci węzła\n// box to referencja do obiektu elementu, który ma dzieci\nwhile (box.firstChild)\n {\n    //lista jest \"żywa\", więc będzie przeindeksowana po każdym wywołaniu\n    box.removeChild(box.firstChild);\n };\n</pre>"}},{"type":"prose","value":{"id":"uwagi","title":"Uwagi","isH3":true,"content":"<p>Elementy kolekcji węzłów są obiektami, a nie łańcuchami. By pobrać dane z tych obiektów, musisz użyć ich atrybutów (np. <code>referencjaDoWęzłaElementu.childNodes[1].nodeName</code> by pobrać nazwę).</p>\n<p>Obiekt <code>document</code> ma dwoje dzieci: deklarację DOCTYPE i element <code>HTML</code>.</p>"}},{"type":"prose","value":{"id":"specyfikacja","title":"Specyfikacja","isH3":true,"content":"<ul>\n <li><a class=\"external\" href=\"https://www.w3.org/TR/2000/REC-DOM-Level-2-Core-20001113/core.html#ID-1451460987\" rel=\" noopener\">W3C DOM 2 Core: childNodes</a></li>\n <li><a class=\"external\" href=\"https://www.w3.org/TR/2004/REC-DOM-Level-3-Core-20040407/core.html#ID-1451460987\" rel=\" noopener\">W3C DOM 3 Core: childNodes</a></li>\n <li><a class=\"external\" href=\"https://www.w3.org/TR/2004/REC-DOM-Level-3-Core-20040407/core.html#ID-536297177\" rel=\" noopener\">W3C DOM 3 NodeList interface</a></li>\n</ul>\n<p></p>"}}],"toc":[],"summary":"childNodes  zwraca kolekcję węzłów-dzieci elementu.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Node.childNodes","locale":"de","native":"Deutsch"},{"title":"Node.childNodes","locale":"en-US","native":"English (US)"},{"title":"Node.childNodes","locale":"es","native":"Español"},{"title":"element.childNodes","locale":"fr","native":"Français"},{"title":"Node.childNodes","locale":"ja","native":"日本語"},{"title":"element.childNodes","locale":"ko","native":"한국어"},{"title":"Node.childNodes","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Node.childNodes","locale":"ru","native":"Русский"},{"title":"Node.childNodes","locale":"zh-CN","native":"中文 (简体)"},{"title":"Node.childNodes","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"pl/web/api/node/childnodes","github_url":"https://github.com/mdn/translated-content/blob/main/files/pl/web/api/node/childnodes/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pl/docs/Web","title":"Technologie Internetowe dla developerów"},{"uri":"/pl/docs/Web/API","title":"Lista Web API"},{"uri":"/pl/docs/Web/API/Node/childNodes","title":"element.childNodes"}],"pageTitle":"element.childNodes - Lista Web API | MDN","noIndexing":false}}