{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"stylesheet.cssRules","mdn_url":"/pl/docs/Web/API/CSSRuleList","locale":"pl","native":"Polski","sidebarHTML":"<ol><li><strong><a href=\"/pl/docs/Web/API/CSSRuleList\"><code>CSSRuleList</code></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>Własności</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CSSRuleList/length\"><code>length</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Metody</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CSSRuleList/item\"><code>item()</code> <small>(en-US)</small></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"podsumowanie","title":"Podsumowanie","isH3":true,"content":"<p>Zwraca wszystkie reguły/zasady CSS w arkuszu stylów jako <a href=\"/pl/docs/Web/API/CSSRuleList\" aria-current=\"page\"><code>CSSRuleList</code></a>, tablico-podobny obiekt.</p>"}},{"type":"prose","value":{"id":"sk.c5.82adnia","title":"Składnia","isH3":true,"content":"<pre class=\"eval notranslate\"><i>rules</i> = stylesheet.cssRules\n</pre>\n\n<p><code>rules</code> jest tablicą <a href=\"/pl/docs/Web/API/CSSRuleList\" aria-current=\"page\"><code>CSSRuleList</code></a> indywidualnych obiektów <code>cssRule</code>. Pojedynczy obiekt <code>cssRule</code> może odwołać się do jednego z następujących obiektów:</p>\n\n<ul>\n <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CSSStyleRule\"><code>CSSStyleRule</code> <small>(en-US)</small></a></li>\n <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CSSMediaRule\"><code>CSSMediaRule</code> <small>(en-US)</small></a></li>\n <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CSSFontFaceRule\"><code>CSSFontFaceRule</code> <small>(en-US)</small></a></li>\n <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CSSPageRule\"><code>CSSPageRule</code> <small>(en-US)</small></a></li>\n <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/CSSImportRule\"><code>CSSImportRule</code> <small>(en-US)</small></a></li>\n <li><a class=\"page-not-created\" title=\"The documentation about this has not yet been written; please consider contributing!\"><code>CSSCharsetRule</code></a></li>\n <li><a class=\"page-not-created\" title=\"The documentation about this has not yet been written; please consider contributing!\"><code>CSSUnknownRule</code></a></li>\n</ul>"}},{"type":"prose","value":{"id":"przyk.c5.82ad","title":"Przykład","isH3":true,"content":"<pre class=\"eval notranslate\">// pobiera pierwszą zasadę\nfirst_rule = document.styleSheets[0].cssRules[0];\n</pre>"}},{"type":"prose","value":{"id":"uwagi","title":"Uwagi","isH3":true,"content":"<p>Zobacz obiekt DOM <a href=\"/pl/docs/Web/API/CSSRule\"><code>cssRule</code></a>.</p>"}},{"type":"prose","value":{"id":"specyfikacja","title":"Specyfikacja","isH3":true,"content":"<p><a class=\"external\" href=\"https://www.w3.org/TR/DOM-Level-2-Style/css.html#CSS-CSSStyleSheet-cssRules\" rel=\" noopener\">DOM Level 2 Style: CSSStyleSheet.cssRules</a></p>"}}],"toc":[],"summary":"Zwraca wszystkie reguły/zasady CSS w arkuszu stylów jako CSSRuleList, tablico-podobny obiekt.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"CSSRuleList","locale":"en-US","native":"English (US)"},{"title":"CSSRuleList","locale":"fr","native":"Français"},{"title":"CSSRuleList","locale":"ja","native":"日本語"},{"title":"CSSRuleList","locale":"zh-CN","native":"中文 (简