{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"element.length","mdn_url":"/pl/docs/Web/API/NodeList/length","locale":"pl","native":"Polski","sidebarHTML":"<ol><li><strong><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/NodeList\"><code>NodeList</code> <small>(en-US)</small></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>Własności</summary><ol><li><em><code>length</code></em></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Metody</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/NodeList/entries\"><code>entries()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/NodeList/forEach\"><code>forEach()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/NodeList/item\"><code>item()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/NodeList/keys\"><code>keys()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/NodeList/values\"><code>values()</code> <small>(en-US)</small></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"podsumowanie","title":"Podsumowanie","isH3":true,"content":"<p><b>length</b> zwraca liczbę elementów listy.</p>"}},{"type":"prose","value":{"id":"sk.c5.82adnia","title":"Składnia","isH3":true,"content":"<pre class=\"eval notranslate\"><i>liczbaElementów</i> = nodeList.length\n</pre>"}},{"type":"prose","value":{"id":"parametry","title":"Parametry","isH3":true,"co