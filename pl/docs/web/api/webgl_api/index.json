, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.khronos.org/registry/gles/extensions/OES/OES_texture_float.txt\" class=\"external\" rel=\" noopener\"><code>OES_texture_float</code></a></td>\n   <td>6.0 (6.0)</td>\n   <td>25</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.khronos.org/registry/webgl/extensions/OES_standard_derivatives/\" class=\"external\" rel=\" noopener\"><code>OES_standard_derivatives</code></a></td>\n   <td>10.0 (10.0)</td>\n   <td>25</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n  <tr>\n   <td><a href=\"/en-US/docs/Web/API/WebGL_API/Using_Extensions#ext_texture_filter_anisotropic\" title=\"WebGL/Using_Extensions#EXT_texture_filter_anisotropic\"><code>EXT_texture_filter_anisotropic</code></a></td>\n   <td>13.0 (13.0)</td>\n   <td>25</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n  <tr>\n   <td><code>OES_element_index_uint</code></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td>25</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n  <tr>\n   <td><code>OES_vertex_array_object</code></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td>25</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n  <tr>\n   <td><a href=\"/en-US/docs/Web/API/WebGL_API/Using_Extensions#webgl_compressed_texture_s3tc\" title=\"WebGL/Using_Extensions#WEBGL_compressed_texture_s3tc\"><code>WEBGL_compressed_texture_s3tc</code></a></td>\n   <td>15.0 (15.0)</td>\n   <td>25<br>\n    prefixed with&nbsp;<span style=\"color: rgb(34, 34, 34); font-family: courier new,monospace; font-size: 12.66px; line-height: normal; white-space: pre-wrap;\">WEBKIT_</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n  <tr>\n   <td><code>WEBKIT_EXT_texture_filter_nisotropic</code></td>\n   <td><span style=\"color:#f00;\">No&nbsp;support</span></td>\n   <td>25</td>\n   <td><span style=\"color:#f00;\">No&nbsp;support</span></td>\n   <td><span style=\"color:#f00;\">No&nbsp;support</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n </tbody>\n</table>\n</div>"}},{"type":"prose","value":{"id":"compatibility_notes","title":"Compatibility notes","isH3":true,"content":"<p>In addition to the browser, the GPU itself also needs to support the feature. So, for example, S3 Texture Compression (S3TC) is only available on Tegra-based tablets. Most browsers make the WebGL context available through the <code>webgl</code> context name, but older ones need <code>experimental-webgl</code> as well. In addition, the upcoming WebGL 2 is fully backwards-compatible and will have the context name <code>experimental-webgl2</code> in the future for testing.</p>"}},{"type":"prose","value":{"id":"gecko_notes","title":"Gecko notes","isH3":true,"content":"<h4 id=\"webgl_debugging_and_testing\">WebGL debugging and testing</h4>\n\n<p>Starting with Gecko 10.0 (Firefox 10.0 / Thunderbird 10.0 / SeaMonkey 2.7), there are two preferences available which let you control the capabilities of WebGL for testing purposes:</p>\n\n<dl>\n <dt id=\"webgl.min_capability_mode\"><code>webgl.min_capability_mode</code></dt>\n <dd>Boolean-owska stała, oznaczająca tryb w którym włączenie jej na true, przyczynia się do włączenia minimum kompatybilności. Kiedy ten tryb jest włączony, WebGL jest skonfigurowany w taki sposób, aby wspomagał w minimalnym zakresie jego możliwości, wymagane przez specyfikacje. Tryb ten zapewnia możliwość pracy kodu WebGL na urządzeniach i przeglądarkach niezależnie od ich kompatybilności. Opcja <code>false</code> jest ustawiona domyślnie.</dd>\n <dt id=\"sect9\">&nbsp;</dt>\n <dt id=\"webgl.disable_extensions\"><code>webgl.disable_extensions</code></dt>\n <dd>Boolean-owska stała, oznaczająca tryb w którym ustawienie jej na true, powoduje zamknięcie wszystkich rozszerzeń WebGL. Wartość <code>false</code> jest ustawiona domyślnie.</dd>\n</dl>"}}],"toc":[{"text":"Tematy","id":"tematy"},{"text":"Browser compatibility","id":"browser_compatibility"}],"summary":"WebGL (Web Graphics Library) to API języka JavaScript służące do renderowania (rysowania) interaktywnej grafiki 3D i 2D poprzez kompatybilną przeglądarkę bez używania pluginów. WebGL został oparty na API OpenGL ES 2.0 i może zostać wykorzystany do pracy z elementem <canvas> (en-US).","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"WebGL","locale":"de","native":"Deutsch"},{"title":"WebGL: 2D and 3D graphics for the web","locale":"en-US","native":"English (US)"},{"title":"WebGL","locale":"es","native":"Español"},{"title":"L'API WebGL : graphismes 2D et 3D pour le web","locale":"fr","native":"Français"},{"title":"WebGL: ウェブの 2D および 3D グラフィック","locale":"ja","native":"日本語"},{"title":"WebGL","locale":"ko","native":"한국어"},{"title":"WebGL","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"WebGL","locale":"ru","native":"Русский"},{"title":"WebGL","locale":"zh-CN","native":"中文 (简体)"},{"title":"WebGL","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"pl/web/api/webgl_api","github_url":"https://github.com/mdn/translated-content/blob/main/files/pl/web/api/webgl_api/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pl/docs/Web","title":"Technologie Internetowe dla developerów"},{"uri":"/pl/docs/Web/API","title":"Lista Web API"},{"uri":"/pl/docs/Web/API/WebGL_API","title":"WebGL"}],"pageTitle":"WebGL - Lista Web API | MDN","noIndexing":false}}