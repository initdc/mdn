n-US/docs/Web/API/Node\"><code>Node</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/NodeIterator\"><code>NodeIterator</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/NodeList\"><code>NodeList</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/ProcessingInstruction\"><code>ProcessingInstruction</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/API/Range\"><code>Range</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/StaticRange\"><code>StaticRange</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Text\"><code>Text</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/TextDecoder\"><code>TextDecoder</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/TextEncoder\"><code>TextEncoder</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/TimeRanges\"><code>TimeRanges</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/TreeWalker\"><code>TreeWalker</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLDocument\"><code>XMLDocument</code> <small>(en-US)</small></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>\n\n<p>Zwraca element <a href=\"/pl/docs/Web/HTML/Element/head\"><code>&lt;head&gt;</code></a> aktualnego dokumentu. Jeżeli występuje&nbsp;więcej niż jeden element&nbsp;<code>&lt;head&gt;</code>, zwrócony zostanie tylko pierwszy.</p>"}},{"type":"prose","value":{"id":"syntax","title":"Syntax","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><em>var objRef</em> = document.head;\n</pre>"}},{"type":"prose","value":{"id":"example","title":"Przykład","isH3":false,"content":"<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token comment\">// in HTML: &lt;head id=\"my-document-head\"&gt;</span>\n<span class=\"token keyword\">var</span> aHead <span class=\"token operator\">=</span> document<span class=\"token punctuation\">.</span>head<span class=\"token punctuation\">;</span>\n\n<span class=\"token function\">alert</span><span class=\"token punctuation\">(</span>aHead<span class=\"token punctuation\">.</span>id<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// \"my-document-head\";</span>\n\n<span class=\"token function\">alert</span><span class=\"token punctuation\">(</span> document<span class=\"token punctuation\">.</span>head <span class=\"token operator\">===</span> document<span class=\"token punctuation\">.</span><span class=\"token function\">querySelector</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"head\"</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// true</span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"example_2","title":"Uwagi","isH3":false,"content":"<p><code>document.head</code>&nbsp;jest atrybutem tylko do odczytu. Próby przypisania mu wartości nie spowodują żadnego efektu czy&nbsp;skutku ubocznego (przejdą 'po cichu')&nbsp;lub, jeżeli pracujemy w&nbsp;<a href=\"/en-US/docs/Web/JavaScript/Reference/Strict_mode\">ECMAScript Strict Mode</a> w przeglądarce Gecko, zostanie rzucony&nbsp;<a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/TypeError\"><code>TypeError</code></a>.</p>"}},{"type":"prose","value":{"id":"specyfikacje","title":"Specyfikacje","isH3":false,"content":"<table class=\"spectable standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Specification</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Comment</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://html.spec.whatwg.org/multipage/dom.html#dom-document-head\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML Living Standard<br><small lang=\"pl\">The definition of 'Document.head' in that specification.</small></a></td>\n   <td><span class=\"spec-living\">Living Standard</span></td>\n   <td>Initial definition.</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.w3.org/TR/html51/dom.html#dom-document-head\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML 5.1<br><small lang=\"pl\">The definition of 'Document.head' in that specification.</small></a></td>\n   <td><span class=\"spec-rec\">Recommendation</span></td>\n   <td>&nbsp;</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.w3.org/TR/html52/dom.html#dom-document-head\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML5<br><small lang=\"pl\">The definition of 'Document.head' in that specification.</small></a></td>\n   <td><span class=\"spec-rec\">Recommendation</span></td>\n   <td>&nbsp;</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"kompatybilność_z_przeglądarkami","title":"Kompatybilność z przeglądarkami","isH3":false,"content":"<div id=\"sect1\"><div class=\"notecard note\" id=\"sect2\"><strong><a href=\"https://github.com/mdn/browser-compat-data\" class=\"external\" rel=\" noopener\">We're converting our compatibility data into a machine-readable JSON format</a></strong>.\n            This compatibility table still uses the old format,\n            because we haven't yet converted the data it contains.\n            <strong><a href=\"/en-US/docs/MDN/Structures/Compatibility_tables\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">Find out how you can help! (en-US)</a></strong></div>\n\n<div class=\"htab\" id=\"sect3\">\n    <a id=\"AutoCompatibilityTable\" name=\"AutoCompatibilityTable\"></a>\n    <ul>\n        <li class=\"selected\"><a href=\"#compat-desktop\">Pulpit</a></li>\n        <li><a href=\"#compat-mobile\">Mobile</a></li>\n    </ul>\n</div></div>\n\n<div id=\"compat-desktop\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Chrome</th>\n   <th>Firefox (Gecko)</th>\n   <th>Internet Explorer</th>\n   <th>Opera</th>\n   <th>Safari</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td>4.0</td>\n   <td><a href=\"/en-US/docs/Mozilla/Firefox/Releases/4\" title=\"Released on 2011-03-22.\">4.0</a> (2)</td>\n   <td>9.0</td>\n   <td>11.0</td>\n   <td>5.0</td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<div id=\"compat-mobile\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Android</th>\n   <th>Firefox Mobile (Gecko)</th>\n   <th>IE Mobile</th>\n   <th>Opera Mobile</th>\n   <th>Safari Mobile</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td>4.0 (2)</td>\n   <td>9.0</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n  </tr>\n </tbody>\n</table>\n</div>"}},{"type":"prose","value":{"id":"zobacz_także","title":"Zobacz także","isH3":false,"content":"<ul>\n <li><a href=\"/pl/docs/Web/API/Document/body\"><code>document.body</code></a></li>\n</ul>"}}],"toc":[{"text":"Syntax","id":"syntax"},{"text":"Przykład","id":"example"},{"text":"Uwagi","id":"example_2"},{"text":"Specyfikacje","id":"specyfikacje"},{"text":"Kompatybilność z przeglądarkami","id":"kompatybilność_z_przeglądarkami"},{"text":"Zobacz także","id":"zobacz_także"}],"summary":"Zwraca element <head> aktualnego dokumentu. Jeżeli występuje więcej niż jeden element <head>, zwrócony zostanie tylko pierwszy.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Document.head","locale":"de","native":"Deutsch"},{"title":"Document.head","locale":"en-US","native":"English (US)"},{"title":"Document.head","locale":"es","native":"Español"},{"title":"document.head","locale":"fr","native":"Français"},{"title":"Document.head","locale":"ja","native":"日本語"},{"title":"Document.head","locale":"ko","native":"한국어"},{"title":"Document.head","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Document.head","locale":"ru","native":"Русский"},{"title":"Document.head","locale":"zh-CN","native":"中文 (简体)"},{"title":"Document.head","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"pl/web/api/document/head","github_url":"https://github.com/mdn/translated-content/blob/main/files/pl/web/api/document/head/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pl/docs/Web","title":"Technologie Internetowe dla developerów"},{"uri":"/pl/docs/Web/API","title":"Lista Web API"},{"uri":"/pl/docs/Web/API/Document","title":"document"},{"uri":"/pl/docs/Web/API/Document/head","title":"Document.head"}],"pageTitle":"Document.head - Lista Web API | MDN","noIndexing":false}}