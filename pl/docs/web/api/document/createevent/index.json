nt/fullscreenerror_event\"><code>fullscreenerror</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/gotpointercapture_event\"><code>gotpointercapture</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/lostpointercapture_event\"><code>lostpointercapture</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/mssitemodejumplistitemremoved_event\"><code>mssitemodejumplistitemremoved</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/msthumbnailclick_event\"><code>msthumbnailclick</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/paste_event\"><code>paste</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointercancel_event\"><code>pointercancel</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointerdown_event\"><code>pointerdown</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointerenter_event\"><code>pointerenter</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointerleave_event\"><code>pointerleave</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointerlockchange_event\"><code>pointerlockchange</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointerlockerror_event\"><code>pointerlockerror</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointermove_event\"><code>pointermove</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointerout_event\"><code>pointerout</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointerover_event\"><code>pointerover</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointerup_event\"><code>pointerup</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/readystatechange_event\"><code>readystatechange</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/scroll_event\"><code>scroll</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/selectionchange_event\"><code>selectionchange</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/selectstart_event\"><code>selectstart</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/touchcancel_event\"><code>touchcancel</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/touchend_event\"><code>touchend</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/touchmove_event\"><code>touchmove</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/touchstart_event\"><code>touchstart</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/visibilitychange_event\"><code>visibilitychange</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Inheritance:</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Node\"><code>Node</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/EventTarget\"><code>EventTarget</code> <small>(en-US)</small></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"podsumowanie","title":"Podsumowanie","isH3":true,"content":"<p>Tworzy obiekt obsługi <a href=\"pl/DOM/event\">zdarzenia</a> o określonym typie. Utworzony obiekt powinien zostać najpierw zainicjalizowany, a następnie przekazany do metody <a href=\"pl/DOM/element.dispatchEvent\">dispatchEvent</a> elementu.</p>"}},{"type":"prose","value":{"id":"sk.c5.82adnia","title":"Składnia","isH3":true,"content":"<pre class=\"eval notranslate\"><i>var zdarzenie</i> =<i>document</i>.createEvent(<i>typ);</i>\n</pre>\n<ul>\n <li><code>zdarzenie</code> to utworzony obiekt <a href=\"pl/DOM/event\">Event</a>.</li>\n <li><code>typ</code> to ciąg oznaczający typ tworzonego zdarzenia. Możliwe typy to m.in.: <code>\"UIEvents\"</code>, <code>\"MouseEvents\"</code>, <code>\"MutationEvents\"</code>, i <code>\"HTMLEvents\"</code>. Zob. <a href=\"#uwagi\">Uwagi</a>.</li>\n</ul>"}},{"type":"prose","value":{"id":"przyk.c5.82ad","title":"Przykład","isH3":true,"content":"<p><a href=\"/pl/docs/DOM/dispatchEvent_-_przyk%C5%82ad\" title=\"This is a link to an unwritten page\" class=\"page-not-created\">dispatchEvent - przykład [pl]</a></p>"}},{"type":"prose","value":{"id":"uwagi","title":"Uwagi","isH3":true,"content":"<p>Nazwy typów zdarzeń, które można przekazać do <code>createEvent</code> określane są przez\n <i>\n  moduły zdarzeń</i>\n . Niektóre moduły zdarzeń zdefiniowane są w specyfikacjach DOM Events, niektóre moduły w innych specyfikacjach (jak np. SVG), a pewne typy zdarzeń są specyficzne dla Gecko.</p>\n<p>Szczegóły znajdziesz w poniższej tabeli.</p>\n<table class=\"fullwidth-table\">\n <tbody>\n  <tr>\n   <th>Moduł zdarzeń</th>\n   <th>Typ do przekazania w <code>createEvent</code></th>\n   <th>Metoda używana do inicjalizacji zdarzenia</th>\n  </tr>\n  <tr style=\"background-color: #eee;\">\n   <td colspan=\"3\"><a class=\"external\" href=\"https://www.w3.org/TR/DOM-Level-2-Events/events.html#Events-eventgroupings\" rel=\" noopener\">DOM Level 2 Events</a></td>\n  </tr>\n  <tr>\n   <td>Moduł zdarzeń interfejsu użytkownika</td>\n   <td><code>\"UIEvents\"</code></td>\n   <td><a href=\"pl/DOM/event.initUIEvent\">event.initUIEvent</a></td>\n  </tr>\n  <tr>\n   <td>Moduł zdarzeń myszy</td>\n   <td><code>\"MouseEvents\"</code></td>\n   <td><a href=\"pl/DOM/event.initMouseEvent\">event.initMouseEvent</a></td>\n  </tr>\n  <tr>\n   <td>Moduł zdarzeń mutacji</td>\n   <td><code>\"MutationEvents\"</code></td>\n   <td><a href=\"pl/DOM/event.initMutationEvent\">event.initMutationEvent</a></td>\n  </tr>\n  <tr>\n   <td>Moduł zdarzeń HTML</td>\n   <td><code>\"HTMLEvents\"</code></td>\n   <td><a href=\"pl/DOM/event.initEvent\">event.initEvent</a></td>\n  </tr>\n  <tr style=\"background-color: #eee;\">\n   <td colspan=\"3\"><a class=\"external\" href=\"https://www.w3.org/TR/DOM-Level-3-Events/events.html#Events-eventgroupings\" rel=\" noopener\">DOM Level 3 Events</a></td>\n  </tr>\n  <tr>\n   <td>Moduł zdarzeń interfejsu użytkownika</td>\n   <td><code>\"UIEvent\"</code>, <code>\"UIEvents\"</code></td>\n   <td><a href=\"pl/DOM/event.initUIEvent\">event.initUIEvent</a></td>\n  </tr>\n  <tr>\n   <td>Moduł zdarzeń myszy</td>\n   <td><code>\"MouseEvent\"</code>, <code>\"MouseEvents\"</code></td>\n   <td><a href=\"pl/DOM/event.initMouseEvent\">event.initMouseEvent</a></td>\n  </tr>\n  <tr>\n   <td>Moduł zdarzeń mutacji</td>\n   <td><code>\"MutationEvent\"</code>, <code>\"MutationEvents\"</code></td>\n   <td><a href=\"pl/DOM/event.initMutationEvent\">event.initMutationEvent</a></td>\n  </tr>\n  <tr>\n   <td>Moduł zdarzeń mutacji nazw (nie zaimplementowany przez Gecko - czerwiec 2006)</td>\n   <td><code>\"MutationNameEvent\"</code></td>\n   <td><a href=\"pl/DOM/event.initMutationNameEvent\">event.initMutationNameEvent</a></td>\n  </tr>\n  <tr>\n   <td>Moduł zdarzeń tekstowych</td>\n   <td><code>\"TextEvent\"</code> (Gecko obsługuje też <code>\"TextEvents\"</code>)</td>\n   <td><a href=\"pl/DOM/event.initTextEvent\">event.initTextEvent</a></td>\n  </tr>\n  <tr>\n   <td>Moduł zdarzeń klawiatury</td>\n   <td><code>\"KeyboardEvent\"</code> (Gecko obsługuje też <code>\"KeyEvents\"</code>)</td>\n   <td><a href=\"pl/DOM/event.initKeyboardEvent\">event.initKeyboardEvent</a></td>\n  </tr>\n  <tr>\n   <td>Moduł podstawowych zdarzeń</td>\n   <td><code>\"Event\"</code> (Gecko obsługuje też <code>\"Events\"</code>)</td>\n   <td><a href=\"pl/DOM/event.initEvent\">event.initEvent</a></td>\n  </tr>\n  <tr style=\"background-color: #eee;\">\n   <td colspan=\"3\"><a class=\"external\" href=\"https://www.w3.org/TR/SVG/script.html#DOMInterfaces\" rel=\" noopener\">SVG 1.1 Scripting</a></td>\n  </tr>\n  <tr>\n   <td rowspan=\"2\">SVG</td>\n   <td><code>\"SVGEvents\"</code> (Gecko obsługuje też <code>\"SVGEvent\"</code>)</td>\n   <td><a href=\"pl/DOM/event.initEvent\">event.initEvent</a></td>\n  </tr>\n  <tr>\n   <td><code>\"SVGZoomEvents\"</code> (Gecko obsługuje też <code>\"SVGZoomEvent\"</code>)</td>\n   <td><a href=\"pl/DOM/event.initUIEvent\">event.initUIEvent</a></td>\n  </tr>\n  <tr style=\"background-color: #eee;\">\n   <td colspan=\"3\">Inne typy zdarzeń obsługiwane przez Gecko <span class=\"comment\">Gecko-related information is taken from nsEventDispatcher::CreateEvent code - see lxr.m.o</span></td>\n  </tr>\n  <tr>\n   <td rowspan=\"3\">-</td>\n   <td><code>\"MouseScrollEvents\"</code>, <code>\"PopupEvents\"</code></td>\n   <td><a href=\"pl/DOM/event.initMouseEvent\">event.initMouseEvent</a></td>\n  </tr>\n  <tr>\n   <td><code>\"PopupBlockedEvents\"</code></td>\n   <td><a href=\"pl/DOM/event.initPopupBlockedEvent\">event.initPopupBlockedEvent</a></td>\n  </tr>\n  <tr>\n   <td><code>\"XULCommandEvent\"</code>, <code>\"XULCommandEvents\"</code></td>\n   <td><a href=\"pl/DOM/event.initCommandEvent\">event.initCommandEvent</a></td>\n  </tr>\n </tbody>\n</table>\n<p>Niektóre zdarzenia mogą być tworzone przy użyciu dwóch nazw typów, ponieważ w specyfikacji DOM Level 3 Events zmieniono nazwy z liczby mnogiej na pojedynczą, pozostawiając nazwy w liczbie mnogiej dla zgodności wstecznej.</p>"}},{"type":"prose","value":{"id":"specyfikacja","title":"Specyfikacja","isH3":true,"content":"<p><a class=\"external\" href=\"https://www.w3.org/TR/DOM-Level-2-Events/events.html#Events-DocumentEvent-createEvent\" rel=\" noopener\">DOM Level 2 Events: createEvent</a></p>\n<p><a class=\"external\" href=\"https://www.w3.org/TR/DOM-Level-3-Events/events.html#Events-DocumentEvent-createEvent\" rel=\" noopener\">DOM Level 3 Events: createEvent</a></p>\n<p>&nbsp;</p>\n<div class=\"noinclude\" id=\"sect1\">\n &nbsp;</div>\n<p></p>"}}],"toc":[],"summary":"Tworzy obiekt obsługi zdarzenia o określonym typie. Utworzony obiekt powinien zostać najpierw zainicjalizowany, a następnie przekazany do metody dispatchEvent elementu.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Document.createEvent()","locale":"en-US","native":"English (US)"},{"title":"Event.createEvent()","locale":"es","native":"Español"},{"title":"Document.createEvent()","locale":"fr","native":"Français"},{"title":"Document.createEvent()","locale":"ja","native":"日本語"},{"title":"Event.createEvent()","locale":"ko","native":"한국어"},{"title":"Document.createEvent()","locale":"zh-CN","native":"中文 (简体)"},{"title":"Event.createEvent()","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"pl/web/api/document/createevent","github_url":"https://github.com/mdn/translated-content/blob/main/files/pl/web/api/document/createevent/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pl/docs/Web","title":"Technologie Internetowe dla developerów"},{"uri":"/pl/docs/Web/API","title":"Lista Web API"},{"uri":"/pl/docs/Web/API/Document","title":"document"},{"uri":"/pl/docs/Web/API/Document/createEvent","title":"document.createEvent"}],"pageTitle":"document.createEvent - Lista Web API | MDN","noIndexing":false}}