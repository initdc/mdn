{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"WindowBase64","mdn_url":"/pl/docs/Web/API/WindowOrWorkerGlobalScope","locale":"pl","native":"Polski","sidebarHTML":"<ol><li><strong><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/HTML_DOM_API\">HTML DOM API <small>(en-US)</small></a></strong></li><li><strong><a href=\"/pl/docs/Web/API/WindowOrWorkerGlobalScope\"><code>WindowOrWorkerGlobalScope</code></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>Related pages for HTML DOM</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/BeforeUnloadEvent\"><code>BeforeUnloadEvent</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/DOMStringMap\"><code>DOMStringMap</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/ErrorEvent\"><code>ErrorEvent</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/API/GlobalEventHandlers\"><code>GlobalEventHandlers</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/HTMLAnchorElement\"><code>HTMLAnchorElement</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/HTMLAreaElement\"><code>HTMLAreaElement</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/HTMLAudioElement\"><code>HTMLAudioElement</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/HTMLBRElement\"><code>HTMLBRElement</code> <small>(en-US)</small></a></li><li><a