{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"window.onload","mdn_url":"/pl/docs/Web/API/GlobalEventHandlers/onload","locale":"pl","native":"Polski","sidebarHTML":"<ol><li><strong><a href=\"/pl/docs/Web/API/GlobalEventHandlers\"><code>GlobalEventHandlers</code></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>Własności</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/onerror\"><code>onerror</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/ongotpointercapture\"><code>ongotpointercapture</code> <small>(en-US)</small></a></li><li><em><code>onload</code></em></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/onloadeddata\"><code>onloadeddata</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/onloadedmetadata\"><code>onloadedmetadata</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/onloadend\"><code>onloadend</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/onloadstart\"><code>onloadstart</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/onlostpointercapture\"><code>onlostpointercapture</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/onpause\"><code>onpause</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/onplay\"><code>onplay</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/onplaying\"><code>onplaying</code> <small>(en-US)</small></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"podsumowanie","title":"Podsumowanie","isH3":true,"content":"<p>Uchwyt zdarzenia dla zdarzenia wczytywania okna (<a href=\"/pl/docs/Web/API/Window\" title=\"pl/DOM/window\">window</a>).</p>"}},{"type":"prose","value":{"id":"sk.c5.82adnia","title":"Składnia","isH3":true,"content":"<pre class=\"eval notranslate\">window.onload = <em>funcRef</em>;\n</pre>\n\n<ul>\n <li><code>funcRef</code> jest funkcją uchwytu.</li>\n</ul>"}},{"type":"prose","value":{"id":"przyk.c5.82ad","title":"Przykład","isH3":true,"content":"<pre class=\"notranslate\">window.onload = function() {\n  init();\n  doSomethingElse();\n};\n</pre>\n\n<pre class=\"notranslate\">&lt;html&gt;\n&lt;head&gt;\n\n&lt;title&gt;Test onload&lt;/title&gt;\n\n&lt;script type=\"text/javascript\"&gt;\n\nwindow.onload = load;\n\nfunction load()\n{\n alert(\"Wykryto zdarzenie load!\");\n}\n&lt;/script&gt;\n&lt;/head&gt;\n\n&lt;body&gt;\n&lt;p&gt;Zdarzenie load występuje w momencie zakończenia ładowania dokumentu!&lt;/p&gt;\n&lt;/body&gt;\n&lt;/html&gt;\n</pre>"}},{"type":"prose","value":{"id":"uwagi","title":"Uwagi","isH3":true,"content":"<p>Zdarzenie load wywoływane jest na końcu procesu ładowania dokumentu. W momencie wystąpienia zdarzenia, DOM zawiera już wszystkie obiekty zawarte w dokumencie oraz zakończone zostało wczytywanie obrazków oraz ramek.<br>\n <br>\n Istnieje także zdarzenie <code>DOMContentLoaded</code> (które można zarejestrować za pomocą <code>addEventListener</code>) występujące w momencie gdy DOM dla danej strony został zbudowany ale bez czekania na zakończenie ładowania pozostałych zasobów.</p>"}}],"toc":[],"summary":"Uchwyt zdarzenia dla zdarzenia wczytywania okna (window).","popularity":0.0006,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"GlobalEventHandlers.onload","locale":"de","native":"Deutsch"},{"title":"GlobalEventHandlers.onload","locale":"en-US","native":"English (US)"},{"title":"window.onload","locale":"es","native":"Español"},{"title":"window.onload","locale":"fr","native":"Français"},{"title":"GlobalEventHandlers.onload","locale":"ja","native":"日本語"},{"title":"GlobalEventHandlers.onload","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"GlobalEventHandlers.onload","locale":"ru","native":"Русский"},{"title":"GlobalEventHandlers.onload","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"pl/web/api/globaleventhandlers/onload","github_url":"https://github.com/mdn/translated-content/blob/main/files/pl/web/api/globaleventhandlers/onload/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pl/docs/Web","title":"Technologie Internetowe dla developerów"},{"uri":"/pl/docs/Web/API","title":"Lista Web API"},{"uri":"/pl/docs/Web/API/GlobalEventHandlers","title":"GlobalEventHandlers"},{"uri":"/pl/docs/Web/API/GlobalEventHandlers/onload","title":"window.onload"}],"pageTitle":"window.onload - Lista Web API | MDN","noIndexing":false}}