{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"event.initUIEvent","mdn_url":"/pl/docs/Web/API/UIEvent/initUIEvent","locale":"pl","native":"Polski","sidebarHTML":"<ol><li><strong><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/UIEvent\"><code>UIEvent</code> <small>(en-US)</small></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>Constructor</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/UIEvent/UIEvent\"><code>UIEvent()</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Własności</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/UIEvent/detail\"><code>detail</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/UIEvent/sourceCapabilities\"><code>sourceCapabilities</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/API/UIEvent/view\"><code>view</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/UIEvent/which\"><code>which</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Metody</summary><ol><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><em><code>initUIEvent</code></em></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Events</summary><ol><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><em><code>initUIEvent</code></em></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Inheritance:</summary><ol><li><a href=\"/pl/docs/Web/API/Event\"><code>Event</code></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"podsumowanie","title":"Podsumowanie","isH3":true,"content":"<p>Inicjalizuje utworzone wcześniej zdarzenie interfejsu użytkownika.</p>"}},{"type":"prose","value":{"id":"sk.c5.82adnia","title":"Składnia","isH3":true,"content":"<pre class=\"eval notranslate\">event.initUIEvent(<i>type</i>,<i>canBubble</i>,<i>cancelable</i>,<i>view</i>,<i>detail</i>)\n</pre>"}},{"type":"prose","value":{"id":"parametry","title":"Parametry","isH3":true,"content":"<dl>\n <dt id=\"sect1\">\n  <code>type</code></dt>\n <dd>\n  typ zdarzenia</dd>\n <dt id=\"sect2\">\n  <code>canBubble</code></dt>\n <dd>\n  Wartość logiczna wskazująca, czy zdarzenie ma bąbelkować czy nie (zob. <a href=\"pl/DOM/event.bubbles\">bubbles</a>).</dd>\n <dt id=\"sect3\">\n  <code>cancelable</code></dt>\n <dd>\n  Wartość logiczna wskazująca, czy zdarzenie może zostać anulowane (zob. <a href=\"pl/DOM/event.cancelable\">cancelable</a>).</dd>\n <dt id=\"sect4\">\n  <code>view</code></dt>\n <dd>\n  widok (<a href=\"pl/DOM/AbstractView\">AbstractView</a>) powiązany z tym zdarzeniem</dd>\n <dt id=\"sect5\">\n  <code>detail</code></dt>\n <dd>\n  liczba określająca szczegółową informację dla tego zdarzenia; dla zdarzeń myszy jest to liczba kliknięć w danym miejscu ekranu (zwykle 1).</dd>\n</dl>"}},{"type":"prose","value":{"id":"przyk.c5.82ad","title":"Przykład","isH3":true,"content":"<pre class=\"eval notranslate\">e = document.createEvent(\"UIEvents\");\n// tworzy zdarzenie kliknięcia, które bąbelkuje, może być\n// anulowane i którego widok i szczegółowa informacja\n// to odpowiednio window i 1\ne.initUIEvent(\"click\", true, true, window, 1);\n</pre>"}},{"type":"prose","value":{"id":"specyfikacja","title":"Specyfikacja","isH3":true,"content":"<p><a class=\"external\" href=\"https://www.w3.org/TR/2001/WD-DOM-Level-3-Events-20010823/events.html#Events-Event-initUIEvent\" rel=\" noopener\">initUIEvent </a></p>\n<p></p>"}}],"toc":[],"summary":"Inicjalizuje utworzone wcześniej zdarzenie interfejsu użytkownika.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"UIEvent.initUIEvent()","locale":"en-US","native":"English (US)"},{"title":"UIEvent.initUIEvent()","locale":"ja","native":"日本語"}],"source":{"folder":"pl/web/api/uievent/inituievent","github_url":"https://github.com/mdn/translated-content/blob/main/files/pl/web/api/uievent/inituievent/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pl/docs/Web","title":"Technologie Internetowe dla developerów"},{"uri":"/pl/docs/Web/API","title":"Lista Web API"},{"uri":"/pl/docs/Web/API/UIEvent/initUIEvent","title":"event.initUIEvent"}],"pageTitle":"event.initUIEvent - Lista Web API | MDN","noIndexing":false}}