{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"range","mdn_url":"/pl/docs/Web/API/Range","locale":"pl","native":"Polski","sidebarHTML":"<ol><li><strong><a href=\"/pl/docs/Web/API/Document_Object_Model\">Document Object Model</a></strong></li><li><strong><a href=\"/pl/docs/Web/API/Range\"><code>Range</code></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>Constructor</summary><ol><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Range/Range\"><code>Range()</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Własności</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Range/collapsed\"><code>collapsed</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Range/commonAncestorContainer\"><code>commonAncestorContainer</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Range/endContainer\"><code>endContainer</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Range/endOffset\"><code>endOffset</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Range/startContainer\"><code>startContainer</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Range/startOffset\"><code>startOffset</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"t