{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"return","mdn_url":"/pl/docs/Web/JavaScript/Reference/Statements/return","locale":"pl","native":"Polski","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p>\n</p>"}},{"type":"prose","value":{"id":"podsumowanie","title":" Podsumowanie ","isH3":true,"content":"<p>Określa wartość, która ma być zwrócona przez funkcję.\n</p>\n<table class=\"fullwidth-table\">\n<tbody><tr>\n<td class=\"header\" colspan=\"2\">Polecenie</td>\n</tr>\n<tr>\n<td>Zaimplementowane w:</td>\n<td>JavaScript 1.0, NES 2.0</td>\n</tr>\n<tr>\n<td>Wersja ECMA:</td>\n<td>ECMA-262</td>\n</tr>\n</tbody></table>"}},{"type":"prose","value":{"id":"sk.c5.82adnia","title":" Składnia ","isH3":true,"content":"<p><code>\nreturn <i>wyrażenie</i>;\n</code>\n</p>"}},{"type":"prose","value":{"id":"parametry","title":" Parametry ","isH3":true,"content":"<dl><dt id=\"sect1\"> <code>wyrażenie</code>&nbsp;</dt><dd> wyrażenie, którego wynik ma być zwrócony.\n</dd></dl>"}},{"type":"prose","value":{"id":"przyk.c5.82ady","title":" Przykłady ","isH3":true,"content":"<h4 id=\"przyk.c5.82ad_zastosowanie_return\" name=\"Przyk.C5.82ad:_Zastosowanie_return\"> Przykład: Zastosowanie <code>return</code> </h4>\n<p>Poniższa funkcja zwraca kwadrat swojego argumentu <code>x</code> (gdzie <code>x</code> jest liczbą).\n</p>\n<pre class=\"notranslate\">function kwadrat(x) {\n   return x * x;\n}\n</pre>\n<p><br>\n</p><p><br>\n</p>\n<div class=\"noinclude\" id=\"sect2\">\n</div>"}}],"toc":[],"summary":"Określa wartość, która ma być zwrócona przez funkcję.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"return","locale":"de","native":"Deutsch"},{"title":"return","locale":"en-US","native":"English (US)"},{"title":"return","locale":"es","native":"Español"},{"title":"return","locale":"fr","native":"Français"},{"title":"return","locale":"ja","native":"日本語"},{"title":"return","loca