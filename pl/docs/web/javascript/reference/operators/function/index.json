 wewnątrz wyrażenia.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Funktionsausdruck","locale":"de","native":"Deutsch"},{"title":"Function expression","locale":"en-US","native":"English (US)"},{"title":"function","locale":"es","native":"Español"},{"title":"L'opérateur function","locale":"fr","native":"Français"},{"title":"関数式","locale":"ja","native":"日本語"},{"title":"함수 표현식","locale":"ko","native":"한국어"},{"title":"Expressão de função (function expression)","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Функциональное выражение","locale":"ru","native":"Русский"},{"title":"函数表达式","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"pl/web/javascript/reference/operators/function","github_url":"https://github.com/mdn/translated-content/blob/main/files/pl/web/javascript/reference/operators/function/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pl/docs/Web","title":"Technologie Internetowe dla developerów"},{"uri":"/pl/docs/Web/JavaScript","title":"JavaScript"},{"uri":"/pl/docs/Web/JavaScript/Reference","title":"Dokumentacja referencyjna JavaScript"},{"uri":"/pl/docs/Web/JavaScript/Reference/Operators","title":"Operatory"},{"uri":"/pl/docs/Web/JavaScript/Reference/Operators/function","title":"Operator function"}],"pageTitle":"Operator function - JavaScript | MDN","noIndexing":false}}