{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"BigInt.prototype.toString()","mdn_url":"/pl/docs/Web/JavaScript/Reference/Global_Objects/BigInt/toString","locale":"pl","native":"Polski","sidebarHTML":"<ol><li><strong><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects\">Obiekty</a></strong></li><li><strong><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/BigInt\"><code>BigInt</code></a></strong></li><li data-default-state=\"open\"><a href=\"#\"><strong>Metody</strong></a><ol><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/BigInt/asIntN\"><code>BigInt.asIntN()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/BigInt/asUintN\"><code>BigInt.asUintN()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/BigInt/toLocaleString\"><code>BigInt.prototype.toLocaleString()</code> <small>(en-US)</small></a></li><li><em><code>BigInt.prototype.toString()</code></em></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/BigInt/valueOf\"><code>BigInt.prototype.valueOf()</code></a></li></ol></li><li><strong>Inheritance:</strong></li><li><strong><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Function\"><code>Function</code></a></strong></li><li><a href=\"#\"><strong>Własności</strong></a><ol><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Function/arguments\"><code>Function.prototype.arguments</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Function/caller\"><code>Function.prototype.caller</code></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Function/displayName\"><code>Function.prototype.displayName</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Function/length\"><code>Function.prototype.length</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Function/name\"><code>Function.prototype.name</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Function/prototype\"><code>Function.prototype.prototype</code> <small>(en-US)</small></a></li></ol></li><li><a href=\"#\"><strong>Metody</strong></a><ol><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Function/apply\"><code>Function.prototype.apply()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Function/bind\"><code>Function.prototype.bind()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Function/call\"><code>Function.prototype.call()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Function/toString\"><code>Function.prototype.toString()</code></a></li></ol></li><li><strong><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object\"><code>Object</code></a></strong></li><li><a href=\"#\"><strong>Własności</strong></a><ol><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/constructor\"><code>Object.prototype.constructor</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/proto\"><code>Object.prototype.__proto__</code></a></li></ol></li><li><a href=\"#\"><strong>Metody</strong></a><ol><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineGetter__\"><code>Object.prototype.__defineGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineSetter__\"><code>Object.prototype.__defineSetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupGetter__\"><code>Object.prototype.__lookupGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupSetter__\"><code>Object.prototype.__lookupSetter__()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwnProperty\"><code>Object.prototype.hasOwnProperty()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/isPrototypeOf\"><code>Object.prototype.isPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/propertyIsEnumerable\"><code>Object.prototype.propertyIsEnumerable()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/setPrototypeOf\"><code>Object.setPrototypeOf()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/toLocaleString\"><code>Object.prototype.toLocaleString()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/valueOf\"><code>Object.prototype.valueOf()</code></a></li></ol></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p>Metoda <strong><code>toString()</code></strong> zwraca ciąg znaków (<em>string</em>), reprezentujący dany obiekt <a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/BigInt\"><code>BigInt</code></a>. Końcowy znak \"n\" nie jest częścią wynikowego ciągu znaków.</p>\n\n<div id=\"sect2\"><iframe class=\"interactive\" height=\"490\" src=\"https://interactive-examples.mdn.mozilla.net/pages/js/bigint-tostring.html\" title=\"MDN Web Docs Interactive Example\" loading=\"lazy\"></iframe></div>"}},{"type":"prose","value":{"id":"składnia","title":"Składnia","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><code><var>bigIntObj</var>.toString([podstawa])</code></pre>"}},{"type":"prose","value":{"id":"parametry","title":"Parametry","isH3":true,"content":"<dl>\n <dt id=\"podstawa\"><code>podstawa</code><span class=\"badge inline optional\">Optional</span></dt>\n <dd>Argument opcjonalny. Liczba całkowita w zakresie od 2 do 36, reprezentująca bazę systemu liczbowego, w którym ma być przedstawiona dana wartość <a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/BigInt\"><code>BigInt</code></a>.</dd>\n</dl>"}},{"type":"prose","value":{"id":"zwracana_wartość","title":"Zwracana wartość","isH3":true,"content":"<p>Ciąg znaków reprezentujący dany obiekt <a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/BigInt\"><code>BigInt</code></a>.</p>"}},{"type":"prose","value":{"id":"wyjątki","title":"Wyjątki","isH3":true,"content":"<dl>\n <dt id=\"rangeerror\"><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/RangeError\"><code>RangeError</code></a></dt>\n <dd>Jeśli do metody <code>toString()</code> przekazana jest podstawa systemu mniejsza niż 2 lub większa niż 36, wyrzucany jest błąd <a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/RangeError\"><code>RangeError</code></a>.</dd>\n</dl>"}},{"type":"prose","value":{"id":"opis","title":"Opis","isH3":false,"content":"<p>Obiekt <a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/BigInt\"><code>BigInt</code></a> nadpisuje metodę <code>toString()</code> obiektu <a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object\"><code>Object</code></a>; nie dziedziczy metody <a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a>. Dla obiektów <a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/BigInt\"><code>BigInt</code></a>, metoda <code>toString()</code> zwraca ciąg znaków reprezentujący daną wartość w systemie pozycyjnym o zadanej bazie.</p>\n\n<p>Metoda <code>toString()</code> parsuje pierwszy argument i próbuje zwrócić ciąg znaków reprezentujący daną wartość w systemie o zadanej podstawie (bazie). Dla systemów o podstawie większej niż 10, do reprezentacji cyfr większych niż 9 używane są kolejne litery alfabetu łacińskiego. Przykładowo, dla wartości w systemie szesnastkowym (o podstawie równej 16), używane są litery od <code>a</code> do <code>f</code>.</p>\n\n<p>Jeśli <code>podstawa</code> nie jest podana, zakłada się, że preferowaną bazą systemu jest 10.</p>\n\n<p>Jeśli wartość <code>bigIntObj</code> jest ujemna, znak jest zachowywany. Dzieje się tak nawet wtedy, gdy podstawą jest 2; zwracany ciąg cyfr jest dodatnią reprezentacją <code>bigIntObj</code>, poprzedzoną znakiem <code>-</code>, <strong>nie</strong> dopełnieniem dwójkowym <code>bigIntObj</code>.</p>"}},{"type":"prose","value":{"id":"przykłady","title":"Przykłady","isH3":false,"content":""}},{"type":"prose","value":{"id":"użycie_tostring","title":"Użycie <code>toString</code>","isH3":true,"content":"<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token number\">17n</span><span class=\"token punctuation\">.</span><span class=\"token function\">toString</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>      <span class=\"token comment\">// '17'</span>\n<span class=\"token number\">66n</span><span class=\"token punctuation\">.</span><span class=\"token function\">toString</span><span class=\"token punctuation\">(</span><span class=\"token number\">2</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>     <span class=\"token comment\">// '1000010'</span>\n<span class=\"token number\">254n</span><span class=\"token punctuation\">.</span><span class=\"token function\">toString</span><span class=\"token punctuation\">(</span><span class=\"token number\">16</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>   <span class=\"token comment\">// 'fe'</span>\n<span class=\"token operator\">-</span><span class=\"token number\">10n</span><span class=\"token punctuation\">.</span><span class=\"token function\">toString</span><span class=\"token punctuation\">(</span><span class=\"token number\">2</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>    <span class=\"token comment\">// -1010'</span>\n<span class=\"token operator\">-</span><span class=\"token number\">0xffn</span><span class=\"token punctuation\">.</span><span class=\"token function\">toString</span><span class=\"token punctuation\">(</span><span class=\"token number\">2</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>  <span class=\"token comment\">// '-11111111'</span>\n</code></pre></div>","titleAsText":"Użycie toString"}},{"type":"prose","value":{"id":"bigint_z_ujemnym_zerem","title":"<code>BigInt</code> z ujemnym zerem","isH3":true,"content":"<p>Nie ma obiektów <code>BigInt</code> reprezentujących ujemne zero, tak jak nie ma ujemnych zer wśród liczb całkowitych.. <code>-0.0</code> jest zmiennoprzecinkową koncepcją zmiennoprzecinkową IEEE, która pojawia się w języku JavaScript jedynie w typie <a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Number\"><code>Number</code></a>.</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token punctuation\">(</span><span class=\"token operator\">-</span><span class=\"token number\">0n</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">.</span><span class=\"token function\">toString</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>      <span class=\"token comment\">// '0'</span>\n<span class=\"token function\">BigInt</span><span class=\"token punctuation\">(</span><span class=\"token operator\">-</span><span class=\"token number\">0</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">.</span><span class=\"token function\">toString</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// '0'</span></code></pre></div>","titleAsText":"BigInt z ujemnym zerem"}},{"type":"prose","value":{"id":"specyfikacje","title":"Specyfikacje","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Specyfikacja</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://tc39.es/ecma262/#sec-bigint.prototype.tostring\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript (ECMA-262)<br><small lang=\"pl\">The definition of 'BigInt.prototype.toString()' in that specification.</small></a></td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"Wsparcie przeglądarek","id":"wsparcie_przeglądarek","isH3":false,"query":"javascript.builtins.BigInt.toString","dataURL":"/pl/docs/Web/JavaScript/Reference/Global_Objects/BigInt/toString/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"zobacz_też","title":"Zobacz też","isH3":false,"content":"<ul>\n <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/BigInt/toLocaleString\"><code>BigInt.prototype.toLocaleString()</code> <small>(en-US)</small></a></li>\n <li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/BigInt/valueOf\"><code>BigInt.prototype.valueOf()</code></a></li>\n <li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Number/toString\"><code>Number.prototype.toString()</code></a></li>\n</ul>"}}],"toc":[{"text":"Składnia","id":"składnia"},{"text":"Opis","id":"opis"},{"text":"Przykłady","id":"przykłady"},{"text":"Specyfikacje","id":"specyfikacje"},{"text":"Wsparcie przeglądarek","id":"wsparcie_przeglądarek"},{"text":"Zobacz też","id":"zobacz_też"}],"summary":"Metoda toString() zwraca ciąg znaków (string), reprezentujący dany obiekt BigInt. Końcowy znak \"n\" nie jest częścią wynikowego ciągu znaków.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"BigInt.prototype.toString()","locale":"en-US","native":"English (US)"},{"title":"BigInt.prototype.toString()","locale":"fr","native":"Français"},{"title":"BigInt.prototype.toString()","locale":"ja","native":"日本語"},{"title":"BigInt.prototype.toString()","locale":"ko","native":"한국어"},{"title":"BigInt.prototype.toString()","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"pl/web/javascript/reference/global_objects/bigint/tostring","github_url":"https://github.com/mdn/translated-content/blob/main/files/pl/web/javascript/reference/global_objects/bigint/tostring/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pl/docs/Web","title":"Technologie Internetowe dla developerów"},{"uri":"/pl/docs/Web/JavaScript","title":"JavaScript"},{"uri":"/pl/docs/Web/JavaScript/Reference","title":"Dokumentacja referencyjna JavaScript"},{"uri":"/pl/docs/Web/JavaScript/Reference/Global_Objects","title":"Obiekty"},{"uri":"/pl/docs/Web/JavaScript/Reference/Global_Objects/BigInt","title":"BigInt"},{"uri":"/pl/docs/Web/JavaScript/Reference/Global_Objects/BigInt/toString","title":"BigInt.prototype.toString()"}],"pageTitle":"BigInt.prototype.toString() - JavaScript | MDN","noIndexing":false}}