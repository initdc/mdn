{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"Object.getOwnPropertyDescriptor()","mdn_url":"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/getOwnPropertyDescriptor","locale":"pl","native":"Polski","sidebarHTML":"<ol><li><strong><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects\">Obiekty</a></strong></li><li><strong><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object\"><code>Object</code></a></strong></li><li data-default-state=\"open\"><a href=\"#\"><strong>Własności</strong></a><ol><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/constructor\"><code>Object.prototype.constructor</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/proto\"><code>Object.prototype.__proto__</code></a></li></ol></li><li data-default-state=\"open\"><a href=\"#\"><strong>Metody</strong></a><ol><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineGetter__\"><code>Object.prototype.__defineGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineSetter__\"><code>Object.prototype.__defineSetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupGetter__\"><code>Object.prototype.__lookupGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupSetter__\"><code>Object.prototype.__lookupSetter__()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/assign\"><code>Object.assign()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/create\"><code>Object.create()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/defineProperties\"><code>Object.defineProperties()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/defineProperty\"><code>Object.defineProperty()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/entries\"><code>Object.entries()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/freeze\"><code>Object.freeze()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/fromEntries\"><code>Object.fromEntries()</code> <small>(en-US)</small></a></li><li><em><code>Object.getOwnPropertyDescriptor()</code></em></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/getOwnPropertyDescriptors\"><code>Object.getOwnPropertyDescriptors()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/getOwnPropertyNames\"><code>Object.getOwnPropertyNames()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/getOwnPropertySymbols\"><code>Object.getOwnPropertySymbols()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/getPrototypeOf\"><code>Object.getPrototypeOf()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwn\"><code>Object.hasOwn()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwnProperty\"><code>Object.prototype.hasOwnProperty()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/is\"><code>Object.is()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/isExtensible\"><code>Object.isExtensible()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/isFrozen\"><code>Object.isFrozen()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/isPrototypeOf\"><code>Object.prototype.isPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/isSealed\"><code>Object.isSealed()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/keys\"><code>Object.keys()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/preventExtensions\"><code>Object.preventExtensions()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/propertyIsEnumerable\"><code>Object.prototype.propertyIsEnumerable()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/seal\"><code>Object.seal()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/setPrototypeOf\"><code>Object.setPrototypeOf()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/toLocaleString\"><code>Object.prototype.toLocaleString()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/valueOf\"><code>Object.prototype.valueOf()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/values\"><code>Object.values()</code> <small>(en-US)</small></a></li></ol></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p>Metoda&nbsp;<code><strong>Object.getOwnPropertyDescriptor()</strong></code>&nbsp;zwraca deskryptor definiujący stan właściwości&nbsp;(właściwość musi być&nbsp;zdefiniowana&nbsp;bezpośrednio na&nbsp;obiekcie, ponieważ metoda nie sprawdza właściwości w łańcuchu prototypów obiektu) dla podanego obiektu.</p>"}},{"type":"prose","value":{"id":"składnia","title":"Składnia","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><code>Object.getOwnPropertyDescriptor(<var>obj</var>, <var>prop</var>)</code></pre>"}},{"type":"prose","value":{"id":"argumenty","title":"Argumenty","isH3":true,"content":"<dl>\n <dt id=\"obj\"><code>obj</code></dt>\n <dd>Obiekt, w którym będzie poszukiwana&nbsp;właściwość.</dd>\n <dt id=\"prop\"><code>prop</code></dt>\n <dd>Nazwa właściwości, dla&nbsp;której będzie pobrany deskryptor.</dd>\n</dl>"}},{"type":"prose","value":{"id":"wartość_zwracana","title":"Wartość zwracana","isH3":true,"content":"<p>Jeżeli obiekt posiada podaną&nbsp;właściwość, wówczas zostanie zwrócony&nbsp;jej deskryptor, w przeciwnym razie zostanie zwrócony <a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/undefined\"><code>undefined</code></a>.</p>"}},{"type":"prose","value":{"id":"opis","title":"Opis","isH3":false,"content":"<p>Metoda ta pozwala na dokładne zbadanie stanu właściwości. W rzeczywistości właściwość obiektu w JavaScript to nie tylko jej nazwa oraz wartość&nbsp;ale również odpowiadający jej deskryptor. Więcej informacji o atrybutach deskryptora można znaleźć w&nbsp;<a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/defineProperty\"><code>Object.defineProperty()</code> <small>(en-US)</small></a>.</p>\n\n<p>Deskryptor właściwości jest obiektem zawierającym&nbsp;poniższe&nbsp;atrybuty:</p>\n\n<dl>\n <dt id=\"value\"><code>value</code></dt>\n <dd>Wartość związana z odpowiadającą właściwością&nbsp;(tylko dla deskryptorów danych).</dd>\n <dt id=\"writable\"><code><strong>writable</strong></code></dt>\n <dd>Jeżeli <code>true</code>&nbsp;odpowiadająca wartość właściwości może być zmieniona&nbsp;(tylko dla deskryptorów danych).</dd>\n <dt id=\"get\"><code>get</code></dt>\n <dd>Funkcja, która zwraca getter dla odpowiadającej właściwości lub&nbsp;<a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/undefined\"><code>undefined</code></a> jeżeli getter nie występuje (tylko dla deskryptorów dostępowych).</dd>\n <dt id=\"set\"><code>set</code></dt>\n <dd>Funkcja, która zwraca setter dla odpowiadającej właściwości lub&nbsp;<a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/undefined\"><code>undefined</code></a> jeżeli setter nie występuje (tylko dla deskryptorów dostępowych).</dd>\n <dt id=\"configurable\"><code>configurable</code></dt>\n <dd>Jeżeli <code>true</code>&nbsp;odpowiadająca wartość właściwości może być zmieniona (również ich rodzaj - z właściwości danych na właściwość funkcji dostępowych, i odwrotnie) oraz usunięta z odopowiadającego obiektu.</dd>\n <dt id=\"enumerable\"><code>enumerable</code></dt>\n <dd>Jeżeli <code>true</code>&nbsp;odpowiadająca wartość właściwości&nbsp;będzie dostępna podczas iteracji po właściwosciach odpowiadającego obiektu.</dd>\n</dl>"}},{"type":"prose","value":{"id":"przykłady","title":"Przykłady","isH3":false,"content":"<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> o<span class=\"token punctuation\">,</span> d<span class=\"token punctuation\">;</span>\n\no <span class=\"token operator\">=</span> <span class=\"token punctuation\">{</span> <span class=\"token keyword\">get</span> <span class=\"token function\">foo</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span> <span class=\"token keyword\">return</span> <span class=\"token number\">17</span><span class=\"token punctuation\">;</span> <span class=\"token punctuation\">}</span> <span class=\"token punctuation\">}</span><span class=\"token punctuation\">;</span>\nd <span class=\"token operator\">=</span> Object<span class=\"token punctuation\">.</span><span class=\"token function\">getOwnPropertyDescriptor</span><span class=\"token punctuation\">(</span>o<span class=\"token punctuation\">,</span> <span class=\"token string\">'foo'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// d is { configurable: true, enumerable: true, get: /*the getter function*/, set: undefined }</span>\n\no <span class=\"token operator\">=</span> <span class=\"token punctuation\">{</span> <span class=\"token literal-property property\">bar</span><span class=\"token operator\">:</span> <span class=\"token number\">42</span> <span class=\"token punctuation\">}</span><span class=\"token punctuation\">;</span>\nd <span class=\"token operator\">=</span> Object<span class=\"token punctuation\">.</span><span class=\"token function\">getOwnPropertyDescriptor</span><span class=\"token punctuation\">(</span>o<span class=\"token punctuation\">,</span> <span class=\"token string\">'bar'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// d is { configurable: true, enumerable: true, value: 42, writable: true }</span>\n\no <span class=\"token operator\">=</span> <span class=\"token punctuation\">{</span><span class=\"token punctuation\">}</span><span class=\"token punctuation\">;</span>\nObject<span class=\"token punctuation\">.</span><span class=\"token function\">defineProperty</span><span class=\"token punctuation\">(</span>o<span class=\"token punctuation\">,</span> <span class=\"token string\">'baz'</span><span class=\"token punctuation\">,</span> <span class=\"token punctuation\">{</span> <span class=\"token literal-property property\">value</span><span class=\"token operator\">:</span> <span class=\"token number\">8675309</span><span class=\"token punctuation\">,</span> <span class=\"token literal-property property\">writable</span><span class=\"token operator\">:</span> <span class=\"token boolean\">false</span><span class=\"token punctuation\">,</span> <span class=\"token literal-property property\">enumerable</span><span class=\"token operator\">:</span> <span class=\"token boolean\">false</span> <span class=\"token punctuation\">}</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\nd <span class=\"token operator\">=</span> Object<span class=\"token punctuation\">.</span><span class=\"token function\">getOwnPropertyDescriptor</span><span class=\"token punctuation\">(</span>o<span class=\"token punctuation\">,</span> <span class=\"token string\">'baz'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// d is { value: 8675309, writable: false, enumerable: false, configurable: false }</span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"uwagi","title":"Uwagi","isH3":false,"content":"<p>W ES5, jeżeli pierwszy argument dla podanej metody nie jest obiektem&nbsp;(jest typem prostym), wówczas zostanie wyrzucony wyjątek&nbsp;<a class=\"page-not-created\" title=\"The documentation about this has not yet been written; please consider contributing!\"><code>TypeError</code></a>. Natomiast w&nbsp;ES2015, na typie prymitywnym najpierw zostanie wykonana koercja do obiektu.</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code>Object<span class=\"token punctuation\">.</span><span class=\"token function\">getOwnPropertyDescriptor</span><span class=\"token punctuation\">(</span><span class=\"token string\">'foo'</span><span class=\"token punctuation\">,</span> <span class=\"token number\">0</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// TypeError: \"foo\" is not an object  // ES5 code</span>\n\nObject<span class=\"token punctuation\">.</span><span class=\"token function\">getOwnPropertyDescriptor</span><span class=\"token punctuation\">(</span><span class=\"token string\">'foo'</span><span class=\"token punctuation\">,</span> <span class=\"token number\">0</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// {configurable:false, enumerable:true, value:\"f\", writable:false}  // ES2015 code</span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"specyfikacje","title":"Specyfikacje","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Specification</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Comment</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.ecma-international.org/ecma-262/5.1/#sec-15.2.3.3\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript 5.1 (ECMA-262)<br><small lang=\"pl\">The definition of 'Object.getOwnPropertyDescriptor' in that specification.</small></a></td>\n   <td><span class=\"spec-standard\">Standard</span></td>\n   <td>Initial definition. Implemented in JavaScript 1.8.5.</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.ecma-international.org/ecma-262/6.0/#sec-object.getownpropertydescriptor\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript 2015 (6th Edition, ECMA-262)<br><small lang=\"pl\">The definition of 'Object.getOwnPropertyDescriptor' in that specification.</small></a></td>\n   <td><span class=\"spec-standard\">Standard</span></td>\n   <td>&nbsp;</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://tc39.es/ecma262/#sec-object.getownpropertydescriptor\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript (ECMA-262)<br><small lang=\"pl\">The definition of 'Object.getOwnPropertyDescriptor' in that specification.</small></a></td>\n   <td><span class=\"spec-living\">Living Standard</span></td>\n   <td>&nbsp;</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"Kompatybilność przeglądarkowa","id":"kompatybilność_przeglądarkowa","isH3":false,"query":"javascript.builtins.Object.getOwnPropertyDescriptor","dataURL":"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/getOwnPropertyDescriptor/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect2\">\n<div id=\"sect3\">\n\n\n<p></p><p></p>\n</div>\n</div>\n\n<p>&nbsp;</p>"}},{"type":"prose","value":{"id":"zobacz_również","title":"Zobacz również","isH3":false,"content":"<ul>\n <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/defineProperty\"><code>Object.defineProperty()</code> <small>(en-US)</small></a></li>\n <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/getOwnPropertyDescriptor\"><code>Reflect.getOwnPropertyDescriptor()</code> <small>(en-US)</small></a></li>\n</ul>"}}],"toc":[{"text":"Składnia","id":"składnia"},{"text":"Opis","id":"opis"},{"text":"Przykłady","id":"przykłady"},{"text":"Uwagi","id":"uwagi"},{"text":"Specyfikacje","id":"specyfikacje"},{"text":"Kompatybilność przeglądarkowa","id":"kompatybilność_przeglądarkowa"},{"text":"Zobacz również","id":"zobacz_również"}],"summary":"Metoda Object.getOwnPropertyDescriptor() zwraca deskryptor definiujący stan właściwości (właściwość musi być zdefiniowana bezpośrednio na obiekcie, ponieważ metoda nie sprawdza właściwości w łańcuchu prototypów obiektu) dla podanego obiektu.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Object.getOwnPropertyDescriptor()","locale":"en-US","native":"English (US)"},{"title":"Object.getOwnPropertyDescriptor()","locale":"es","native":"Español"},{"title":"Object.getOwnPropertyDescriptor()","locale":"fr","native":"Français"},{"title":"Object.getOwnPropertyDescriptor()","locale":"ja","native":"日本語"},{"title":"Object.getOwnPropertyDescriptor()","locale":"ko","native":"한국어"},{"title":"Object.getOwnPropertyDescriptor()","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Object.getOwnPropertyDescriptor()","locale":"ru","native":"Русский"},{"title":"Object.getOwnPropertyDescriptor()","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"pl/web/javascript/reference/global_objects/object/getownpropertydescriptor","github_url":"https://github.com/mdn/translated-content/blob/main/files/pl/web/javascript/reference/global_objects/object/getownpropertydescriptor/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pl/docs/Web","title":"Technologie Internetowe dla developerów"},{"uri":"/pl/docs/Web/JavaScript","title":"JavaScript"},{"uri":"/pl/docs/Web/JavaScript/Reference","title":"Dokumentacja referencyjna JavaScript"},{"uri":"/pl/docs/Web/JavaScript/Reference/Global_Objects","title":"Obiekty"},{"uri":"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object","title":"Object"},{"uri":"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/getOwnPropertyDescriptor","title":"Object.getOwnPropertyDescriptor()"}],"pageTitle":"Object.getOwnPropertyDescriptor() - JavaScript | MDN","noIndexing":false}}