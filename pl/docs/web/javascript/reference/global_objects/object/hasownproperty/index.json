{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"Object.prototype.hasOwnProperty()","mdn_url":"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwnProperty","locale":"pl","native":"Polski","sidebarHTML":"<ol><li><strong><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects\">Obiekty</a></strong></li><li><strong><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object\"><code>Object</code></a></strong></li><li data-default-state=\"open\"><a href=\"#\"><strong>Własności</strong></a><ol><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/constructor\"><code>Object.prototype.constructor</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/proto\"><code>Object.prototype.__proto__</code></a></li></ol></li><li data-default-state=\"open\"><a href=\"#\"><strong>Metody</strong></a><ol><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineGetter__\"><code>Object.prototype.__defineGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineSetter__\"><code>Object.prototype.__defineSetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupGetter__\"><code>Object.prototype.__lookupGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupSetter__\"><code>Object.prototype.__lookupSetter__()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/assign\"><code>Object.assign()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/create\"><code>Object.create()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/defineProperties\"><code>Object.defineProperties()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/defineProperty\"><code>Object.defineProperty()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/entries\"><code>Object.entries()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/freeze\"><code>Object.freeze()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/fromEntries\"><code>Object.fromEntries()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/getOwnPropertyDescriptor\"><code>Object.getOwnPropertyDescriptor()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/getOwnPropertyDescriptors\"><code>Object.getOwnPropertyDescriptors()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/getOwnPropertyNames\"><code>Object.getOwnPropertyNames()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/getOwnPropertySymbols\"><code>Object.getOwnPropertySymbols()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/getPrototypeOf\"><code>Object.getPrototypeOf()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-experimental\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-experimental\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwn\"><code>Object.hasOwn()</code> <small>(en-US)</small></a></li><li><em><code>Object.prototype.hasOwnProperty()</code></em></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/is\"><code>Object.is()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/isExtensible\"><code>Object.isExtensible()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/isFrozen\"><code>Object.isFrozen()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/isPrototypeOf\"><code>Object.prototype.isPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/isSealed\"><code>Object.isSealed()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/keys\"><code>Object.keys()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/preventExtensions\"><code>Object.preventExtensions()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/propertyIsEnumerable\"><code>Object.prototype.propertyIsEnumerable()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/seal\"><code>Object.seal()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/setPrototypeOf\"><code>Object.setPrototypeOf()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/toLocaleString\"><code>Object.prototype.toLocaleString()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/valueOf\"><code>Object.prototype.valueOf()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/values\"><code>Object.values()</code> <small>(en-US)</small></a></li></ol></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>"}},{"type":"prose","value":{"id":"summary","title":"Wstęp","isH3":false,"content":"<p>Metoda&nbsp;<code><strong>hasOwnProperty()</strong></code> zwraca wartość <code>true</code> jeśli obiekt, na którym została wywołana posiada konkretną własność.</p>"}},{"type":"prose","value":{"id":"syntax","title":"Składnia","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><code><var>obj</var>.hasOwnProperty(<var>prop</var>)</code></pre>"}},{"type":"prose","value":{"id":"parameters","title":"Parametry","isH3":true,"content":"<dl>\n <dt id=\"prop\"><code>prop</code></dt>\n <dd>Nazwa (<a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/String\"><code>String</code></a>) własności lub <a href=\"/en-US/docs/Glossary/Symbol\">Symbol</a>, do sprawdzenia.</dd>\n</dl>"}},{"type":"prose","value":{"id":"wartość_zwracana","title":"Wartość zwracana","isH3":true,"content":"<p><span class=\"tlid-translation translation\"><span class=\"alt-edited\">A <a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code></a> wskazujący, czy obiekt zawiera w sobie określoną właściwość.</span></span></p>"}},{"type":"prose","value":{"id":"description","title":"Opis","isH3":false,"content":"<p>Każdy obiekt pochodzący od <a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object\"><code>Object</code></a> dziedziczy metodę&nbsp;<code>hasOwnProperty</code>. Może być ona użyta do stwierdzenia czy obiekt posiada określoną własność, jako bezpośrednią (direct) własność. W przeciwieństwie do&nbsp;&nbsp;operatora <a href=\"/pl/docs/Web/JavaScript/Reference/Operators/in\"><code>in</code></a>,&nbsp;metoda&nbsp;<code style=\"font-style: normal;\">hasOwnProperty</code>&nbsp;nie sprawdza <u>w głąb łańcucha</u> własności obiektu.</p>"}},{"type":"prose","value":{"id":"examples","title":"Notatka","isH3":false,"content":"<p><span class=\"tlid-translation translation\"><span title=\"\"><code>hasOwnProperty</code> zwraca <code>true</code>, nawet jeśli wartość właściwości to <code>null</code> lub <code>undefined</code>.</span></span></p>\n\n<div class=\"code-example\"><pre class=\"brush: js line-numbers  language-js notranslate\"><code>o <span class=\"token operator\">=</span> <span class=\"token keyword\">new</span> <span class=\"token class-name\">Object</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\no<span class=\"token punctuation\">.</span>propOne <span class=\"token operator\">=</span> <span class=\"token keyword\">null</span><span class=\"token punctuation\">;</span>\no<span class=\"token punctuation\">.</span><span class=\"token function\">hasOwnProperty</span><span class=\"token punctuation\">(</span><span class=\"token string\">'propOne'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>   <span class=\"token comment\">// zwraca true</span>\no<span class=\"token punctuation\">.</span>propTwo <span class=\"token operator\">=</span> <span class=\"token keyword\">undefined</span><span class=\"token punctuation\">;</span>\no<span class=\"token punctuation\">.</span><span class=\"token function\">hasOwnProperty</span><span class=\"token punctuation\">(</span><span class=\"token string\">'propTwo'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>   <span class=\"token comment\">// zwraca true</span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"examples_2","title":"Przykłady","isH3":false,"content":""}},{"type":"prose","value":{"id":"example_using_hasownproperty_to_test_for_a_property.27s_existence","title":"Użycie&nbsp;<code>hasOwnProperty</code> do testowania istnienia własności","isH3":true,"content":"<p>Poniższy przykład&nbsp;określa&nbsp;czy obiekt&nbsp;<code>o</code>&nbsp;posiada własność&nbsp;o nazwie&nbsp;<code>prop</code>:</p>\n\n<div class=\"code-example\"><pre class=\"brush: js line-numbers  language-js notranslate\"><code>o <span class=\"token operator\">=</span> <span class=\"token keyword\">new</span> <span class=\"token class-name\">Object</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\no<span class=\"token punctuation\">.</span><span class=\"token function\">hasOwnProperty</span><span class=\"token punctuation\">(</span><span class=\"token string\">'prop'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>   <span class=\"token comment\">// zwraca false</span>\no<span class=\"token punctuation\">.</span>prop <span class=\"token operator\">=</span> <span class=\"token string\">'istnieje'</span><span class=\"token punctuation\">;</span>\no<span class=\"token punctuation\">.</span><span class=\"token function\">hasOwnProperty</span><span class=\"token punctuation\">(</span><span class=\"token string\">'prop'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>   <span class=\"token comment\">// zwraca true</span></code></pre></div>","titleAsText":"Użycie hasOwnProperty do testowania istnienia własności"}},{"type":"prose","value":{"id":"example_direct_versus_inherited_properties","title":"Własności bezpośrednie kontra odziedziczone","isH3":true,"content":"<p>Poniższy przykład rozróżnia bezpośrednie właściwości z właściwościami dziedziczonymi w łańcuchu prototypów:</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code>o <span class=\"token operator\">=</span> <span class=\"token keyword\">new</span> <span class=\"token class-name\">Object</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\no<span class=\"token punctuation\">.</span>prop <span class=\"token operator\">=</span> <span class=\"token string\">'istnieje'</span><span class=\"token punctuation\">;</span>\no<span class=\"token punctuation\">.</span><span class=\"token function\">hasOwnProperty</span><span class=\"token punctuation\">(</span><span class=\"token string\">'prop'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>             <span class=\"token comment\">// zwraca true</span>\no<span class=\"token punctuation\">.</span><span class=\"token function\">hasOwnProperty</span><span class=\"token punctuation\">(</span><span class=\"token string\">'toString'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>         <span class=\"token comment\">// zwraca false</span>\no<span class=\"token punctuation\">.</span><span class=\"token function\">hasOwnProperty</span><span class=\"token punctuation\">(</span><span class=\"token string\">'hasOwnProperty'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>   <span class=\"token comment\">// zwraca false</span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"example_itarate_over_properties_not_considering_inherited_properties","title":"Iterowanie przez właściwości obiektu","isH3":true,"content":"<p><span class=\"tlid-translation translation\"><span title=\"\">Poniższy przykład ilustruje sposób iteracji po właściwościach obiektu bez wykonywania iteracji na dziedziczonych właściwościach.</span></span></p>\n\n<pre class=\"notranslate\">const obj = {\n  prop: 'Wartość',\n  secondProp: 'Wartość 2'\n}\n\nfor (const name in obj) {\n  if (obj.hasOwnProperty(name)) {\n    console.log('Znaleziono własność ' + name + ' o wartości ' + obj[name])\n  } else {\n    console.log('Brak własności: ', name)\n  }\n}</pre>\n\n<div class=\"warning notecard\" id=\"sect2\">\n<p><span class=\"tlid-translation translation\"><span title=\"\">Zwróć uwagę, że pętla </span></span><a href=\"/pl/docs/Web/JavaScript/Reference/Statements/for...in\"><code>for...in</code></a><span class=\"tlid-translation translation\"><span title=\"\"> tylko iteruje właściwości przeliczalne</span></span>, a <a href=\"http://zduck.com/2013/non-enumerable-properties-in-javascript/\" class=\"external\" rel=\" noopener\">nieprzeliczanych</a> nie zauważa.</p>\n</div>"}},{"type":"prose","value":{"id":"używanie_hasownproperty_jako_nazwy_właściwości","title":"<span class=\"tlid-translation translation\"><span title=\"\">Używanie <code>hasOwnProperty</code> jako nazwy właściwości</span></span>","isH3":true,"content":"<p><span class=\"tlid-translation translation\"><span title=\"\">JavaScript nie chroni nazwy właściwości <code>hasOwnProperty</code>;</span> <span title=\"\">tak więc, jeśli istnieje możliwość, że obiekt może mieć właściwość o tej nazwie, konieczne jest użycie zewnętrznej właściwości <code>hasOwnProperty</code>, aby uzyskać poprawne wyniki:</span></span></p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">const</span> obj <span class=\"token operator\">=</span> <span class=\"token punctuation\">{</span>\n  <span class=\"token function-variable function\">hasOwnProperty</span><span class=\"token operator\">:</span> <span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n    <span class=\"token keyword\">return</span> <span class=\"token boolean\">false</span><span class=\"token punctuation\">;</span>\n  <span class=\"token punctuation\">}</span><span class=\"token punctuation\">,</span>\n  <span class=\"token literal-property property\">prop</span><span class=\"token operator\">:</span> <span class=\"token string\">'Kolejna właściwość'</span>\n<span class=\"token punctuation\">}</span><span class=\"token punctuation\">;</span>\n\nobj<span class=\"token punctuation\">.</span><span class=\"token function\">hasOwnProperty</span><span class=\"token punctuation\">(</span><span class=\"token string\">'prop'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// zawsze zwróci false</span>\n\n<span class=\"token comment\">// Użyj właściwości hasOwnProperty innego obiektu i wywołaj ją, ustawiając \"this\" na obj</span>\n<span class=\"token punctuation\">(</span><span class=\"token punctuation\">{</span><span class=\"token punctuation\">}</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">.</span><span class=\"token function\">hasOwnProperty</span><span class=\"token punctuation\">.</span><span class=\"token function\">call</span><span class=\"token punctuation\">(</span>obj<span class=\"token punctuation\">,</span> <span class=\"token string\">'prop'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// zwraca true</span>\n\n<span class=\"token comment\">// W tym celu można również użyć własności hasOwnProperty z prototypu Object</span>\n<span class=\"token class-name\">Object</span><span class=\"token punctuation\">.</span>prototype<span class=\"token punctuation\">.</span><span class=\"token function\">hasOwnProperty</span><span class=\"token punctuation\">.</span><span class=\"token function\">call</span><span class=\"token punctuation\">(</span>obj<span class=\"token punctuation\">,</span> <span class=\"token string\">'prop'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// zwraca true</span>\n</code></pre></div>\n\n<p><span class=\"tlid-translation translation\"><span title=\"\">Zwróć uwagę, że w ostatnim przypadku nie ma żadnych nowo utworzonych obiektów.</span></span></p>","titleAsText":"Używanie hasOwnProperty jako nazwy właściwości"}},{"type":"prose","value":{"id":"specyfikacja","title":"Specyfikacja","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Specification</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Comment</th>\n  </tr>\n  <tr>\n   <td>ECMAScript 3rd Edition.</td>\n   <td>Standard</td>\n   <td>Initial definition. Implemented in JavaScript 1.5.</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.ecma-international.org/ecma-262/5.1/#sec-15.2.4.5\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript 5.1 (ECMA-262)<br><small lang=\"pl\">The definition of 'Object.prototype.hasOwnProperty' in that specification.</small></a></td>\n   <td><span class=\"spec-standard\">Standard</span></td>\n   <td></td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.ecma-international.org/ecma-262/6.0/#sec-object.prototype.hasownproperty\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript 2015 (6th Edition, ECMA-262)<br><small lang=\"pl\">The definition of 'Object.prototype.hasOwnProperty' in that specification.</small></a></td>\n   <td><span class=\"spec-standard\">Standard</span></td>\n   <td></td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"Wsparcie przeglądarek","id":"wsparcie_przeglądarek","isH3":false,"query":"javascript.builtins.Object.hasOwnProperty","dataURL":"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwnProperty/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect4\"></div>"}},{"type":"prose","value":{"id":"see_also","title":"Zobacz także","isH3":false,"content":"<ul>\n <li><a href=\"/en-US/docs/Web/JavaScript/Enumerability_and_ownership_of_properties\">Enumerability and ownership of properties</a></li>\n <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/getOwnPropertyNames\"><code>Object.getOwnPropertyNames()</code> <small>(en-US)</small></a></li>\n <li><a href=\"/pl/docs/Web/JavaScript/Reference/Statements/for...in\"><code>for...in</code></a></li>\n <li><a href=\"/pl/docs/Web/JavaScript/Reference/Operators/in\"><code>in</code></a></li>\n <li><a href=\"/en-US/docs/Web/JavaScript/Inheritance_and_the_prototype_chain\">JavaScript Guide: Inheritance revisited</a></li>\n</ul>"}}],"toc":[{"text":"Wstęp","id":"summary"},{"text":"Składnia","id":"syntax"},{"text":"Opis","id":"description"},{"text":"Notatka","id":"examples"},{"text":"Przykłady","id":"examples_2"},{"text":"Specyfikacja","id":"specyfikacja"},{"text":"Wsparcie przeglądarek","id":"wsparcie_przeglądarek"},{"text":"Zobacz także","id":"see_also"}],"summary":"Metoda hasOwnProperty() zwraca wartość true jeśli obiekt, na którym została wywołana posiada konkretną własność.","popularity":0.0004,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Object.prototype.hasOwnProperty()","locale":"de","native":"Deutsch"},{"title":"Object.prototype.hasOwnProperty()","locale":"en-US","native":"English (US)"},{"title":"Object.prototype.hasOwnProperty()","locale":"es","native":"Español"},{"title":"Object.prototype.hasOwnProperty()","locale":"fr","native":"Français"},{"title":"Object.prototype.hasOwnProperty()","locale":"ja","native":"日本語"},{"title":"Object.prototype.hasOwnProperty()","locale":"ko","native":"한국어"},{"title":"Object.prototype.hasOwnProperty()","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Object.prototype.hasOwnProperty()","locale":"ru","native":"Русский"},{"title":"Object.prototype.hasOwnProperty()","locale":"zh-CN","native":"中文 (简体)"},{"title":"Object.prototype.hasOwnProperty()","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"pl/web/javascript/reference/global_objects/object/hasownproperty","github_url":"https://github.com/mdn/translated-content/blob/main/files/pl/web/javascript/reference/global_objects/object/hasownproperty/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pl/docs/Web","title":"Technologie Internetowe dla developerów"},{"uri":"/pl/docs/Web/JavaScript","title":"JavaScript"},{"uri":"/pl/docs/Web/JavaScript/Reference","title":"Dokumentacja referencyjna JavaScript"},{"uri":"/pl/docs/Web/JavaScript/Reference/Global_Objects","title":"Obiekty"},{"uri":"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object","title":"Object"},{"uri":"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwnProperty","title":"Object.prototype.hasOwnProperty()"}],"pageTitle":"Object.prototype.hasOwnProperty() - JavaScript | MDN","noIndexing":false}}