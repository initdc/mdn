totype.find()","locale":"es","native":"Español"},{"title":"Array.prototype.find()","locale":"fr","native":"Français"},{"title":"Array.prototype.find()","locale":"ja","native":"日本語"},{"title":"Array.prototype.find()","locale":"ko","native":"한국어"},{"title":"Array.prototype.find()","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Array.prototype.find()","locale":"ru","native":"Русский"},{"title":"Array.prototype.find()","locale":"zh-CN","native":"中文 (简体)"},{"title":"Array.prototype.find()","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"pl/web/javascript/reference/global_objects/array/find","github_url":"https://github.com/mdn/translated-content/blob/main/files/pl/web/javascript/reference/global_objects/array/find/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pl/docs/Web","title":"Technologie Internetowe dla developerów"},{"uri":"/pl/docs/Web/JavaScript","title":"JavaScript"},{"uri":"/pl/docs/Web/JavaScript/Reference","title":"Dokumentacja referencyjna JavaScript"},{"uri":"/pl/docs/Web/JavaScript/Reference/Global_Objects","title":"Obiekty"},{"uri":"/pl/docs/Web/JavaScript/Reference/Global_Objects/Array","title":"Array"},{"uri":"/pl/docs/Web/JavaScript/Reference/Global_Objects/Array/find","title":"Array.prototype.find()"}],"pageTitle":"Array.prototype.find() - JavaScript | MDN","noIndexing":false}}