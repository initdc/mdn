{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"Date","mdn_url":"/pl/docs/Web/JavaScript/Reference/Global_Objects/Date","locale":"pl","native":"Polski","sidebarHTML":"<ol><li><strong><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects\">Obiekty</a></strong></li><li><strong><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Date\"><code>Date</code></a></strong></li><li data-default-state=\"open\"><a href=\"#\"><strong>Metody</strong></a><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Date/@@toPrimitive\"><code>Date.prototype[@@toPrimitive]</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Date/getDate\"><code>Date.prototype.getDate()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Date/getDay\"><code>Date.prototype.getDay()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Date/getFullYear\"><code>Date.prototype.getFullYear()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Date/getHours\"><code>Date.prototype.getHours()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Date/getMilliseconds\"><code>Date.prototype.getMilliseconds()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Date/getMinutes\"><code>Date.prototype.getMinutes()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Date/getMonth\"><code>Date.prototype.getMonth()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Date/getSeconds\"><code>Date.prototype.getSeconds()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Date/getTime\"><code>Date.prototype.getTime()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Date/getTimezoneOffset\"><code>Date.prototype.getTim