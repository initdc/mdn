docs/Web/JavaScript/Reference/Global_Objects/Object/constructor\"><code>Object.prototype.constructor</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/proto\"><code>Object.prototype.__proto__</code></a></li></ol></li><li><a href=\"#\"><strong>Metody</strong></a><ol><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineGetter__\"><code>Object.prototype.__defineGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineSetter__\"><code>Object.prototype.__defineSetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupGetter__\"><code>Object.prototype.__lookupGetter__()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupSetter__\"><code>Object.prototype.__lookupSetter__()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwnProperty\"><code>Object.prototype.hasOwnProperty()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/isPrototypeOf\"><code>Object.prototype.isPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/propertyIsEnumerable\"><code>Object.prototype.propertyIsEnumerable()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object/setPrototypeOf\"><code>Object.setPrototypeOf()</code> <small>(en-US)</small></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/toLocaleString\"><code>Object.prototype.toLocaleString()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a></li><li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Object/valueOf\"><code>Object.prototype.valueOf()</code></a></li></ol></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><div class=\"notecard deprecated\" id=\"sect1\"><p><strong>Wycofywany:</strong> This feature has been removed from the Web standards. Though some browsers may still support it, it is in the process of being dropped. Do not use it in old or new projects. Pages or Web apps using it may break at any time.</p></div><p></p>"}},{"type":"prose","value":{"id":"podsumowanie","title":"Podsumowanie","isH3":false,"content":"<p>Zwraca rok dla określonej daty w zależności od czasu lokalnego. Metoda <code>getYear</code> nie jest dłużej wykorzystywana i została zastąpiona metodą <a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Date/getFullYear\"><code>getFullYear()</code></a>.</p>"}},{"type":"prose","value":{"id":"sk.c5.82adnia","title":"Składnia","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><code><var>dateObj</var>.getYear()</code></pre>"}},{"type":"prose","value":{"id":"parametry","title":"Parametry","isH3":true,"content":"<p>Brak.</p>"}},{"type":"prose","value":{"id":"opis","title":"Opis","isH3":false,"content":"<p>Metoda <code>getYear</code> zwraca rok minus 1900; tak więc:</p>\n\n<ul>\n <li>Dla lat późniejszych lub równych 2000, wartość zwracana przez <code>getYear</code> wynosi 100 lub więcej. Przykładowo, dla roku 2026, <code>getYear</code> zwraca 126.</li>\n</ul>\n\n<ul>\n <li>Dla lat pomiędzy i włącznie z latami 1900 i 1999, wartość zwracana przez <code>getYear</code> zawiera się w przedziale od 0 do 99. Na przykład, jeśli mamy rok 1976, <code>getYear</code> zwraca 76.</li>\n</ul>\n\n<ul>\n <li>Dla lat wcześniejszych niż 1900, wartość zwracana przez <code>getYear</code> jest mniejsza niż 0. Na przykład, dla roku 1800, <code>getYear</code> zwraca -100.</li>\n</ul>\n\n<p>Aby obsłużyć lata zarówno przed jak i po roku 2000, należy zamiast <code>getYear</code> użyć metody <a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Date/getFullYear\"><code>getFullYear()</code></a>, która zwraca pełną liczbę określającą rok.</p>"}},{"type":"prose","value":{"id":"kompatybilno.c5.9b.c4.87_wsteczna","title":"Kompatybilność wstecz","isH3":false,"content":""}},{"type":"prose","value":{"id":"javascript_1.2_i_wersje_wcze.c5.9bniejsze","title":"JavaScript 1.2 i wersje wcześniejsze","isH3":true,"content":"<p>Metoda <code>getYear()</code> zwraca rok w formacie 2-cyfrowym lub 4-cyfrowym:</p>\n\n<ul>\n <li>Dla roczników pomiędzy i włącznie z latami 1900 i 1999, wartość zwracana przez <code>getYear</code> jest to rok minus 1900. Na przykład, dla roku 1976 będzie to liczba 76.</li>\n</ul>\n\n<ul>\n <li>Dla roczników niższych niż 1900 lub wyższych niż 1999, wartość zwracana przez <code>getYear</code> jest cztero-cyfrowa. Na przykład, dla roku 1856, wartość jest równa 1856. Dla roku 2026, wartość wynosi 2026.</li>\n</ul>"}},{"type":"prose","value":{"id":"przyk.c5.82ady","title":"Przykłady","isH3":false,"content":""}},{"type":"prose","value":{"id":"przyk.c5.82ad_lata_pomi.c4.99dzy_1900_i_1999","title":"Przykład: Lata pomiędzy 1900 i 1999","isH3":true,"content":"<p>Druga instrukcja przypisuje wartość 95 do zmiennej <code>year</code>.</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> Xmas <span class=\"token operator\">=</span> <span class=\"token keyword\">new</span> <span class=\"token class-name\">Date</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"December 25, 1995 23:15:00\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token keyword\">var</span> year <span class=\"token operator\">=</span> Xmas<span class=\"token punctuation\">.</span><span class=\"token function\">getYear</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// zwraca 95</span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"przyk.c5.82ad_lata_powy.c5.bcej_1999","title":"Przykład: Lata powyżej 1999","isH3":true,"content":"<p>Druga instrukcja przypisuje wartość 100 do zmiennej <code>year</code>.</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> Xmas <span class=\"token operator\">=</span> <span class=\"token keyword\">new</span> <span class=\"token class-name\">Date</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"December 25, 2000 23:15:00\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token keyword\">var</span> year <span class=\"token operator\">=</span> Xmas<span class=\"token punctuation\">.</span><span class=\"token function\">getYear</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// zwraca 100</span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"przyk.c5.82ad_lata_powy.c5.bcej_1900","title":"Przykład: Lata poniżej 1900","isH3":true,"content":"<p>Druga instrukcja przypisuje wartość -100 do zmiennej <code>year</code>.</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> Xmas <span class=\"token operator\">=</span> <span class=\"token keyword\">new</span> <span class=\"token class-name\">Date</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"December 25, 1800 23:15:00\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token keyword\">var</span> year <span class=\"token operator\">=</span> Xmas<span class=\"token punctuation\">.</span><span class=\"token function\">getYear</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// zwraca -100</span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"przyk.c5.82ad_ustawienie_i_pobieranie_lat_pomi.c4.99dzy_1900_i_1999","title":"Przykład: Ustawianie i pobieranie roku pomiędzy 1900 i 1999","isH3":true,"content":"<p>Druga instrukcja przypisuje wartość 95 do zmiennej <code>year</code>, reprezentując rok 1995.</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> Xmas<span class=\"token punctuation\">.</span><span class=\"token function\">setYear</span><span class=\"token punctuation\">(</span><span class=\"token number\">95</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token keyword\">var</span> year <span class=\"token operator\">=</span> Xmas<span class=\"token punctuation\">.</span><span class=\"token function\">getYear</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// zwraca 95</span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"zobacz_tak.c5.bce","title":"Zobacz także","isH3":false,"content":"<ul>\n <li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Date/getFullYear\"><code>Date.prototype.getFullYear()</code></a></li>\n <li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Date/getUTCFullYear\"><code>Date.prototype.getUTCFullYear()</code></a></li>\n <li><a href=\"/pl/docs/Web/JavaScript/Reference/Global_Objects/Date/setYear\"><code>Date.prototype.setYear()</code></a></li>\n</ul>"}}],"toc":[{"text":"Podsumowanie","id":"podsumowanie"},{"text":"Składnia","id":"sk.c5.82adnia"},{"text":"Opis","id":"opis"},{"text":"Kompatybilność wstecz","id":"kompatybilno.c5.9b.c4.87_wsteczna"},{"text":"Przykłady","id":"przyk.c5.82ady"},{"text":"Zobacz także","id":"zobacz_tak.c5.bce"}],"summary":"Zwraca rok dla określonej daty w zależności od czasu lokalnego. Metoda getYear nie jest dłużej wykorzystywana i została zastąpiona metodą getFullYear().","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Date.prototype.getYear()","locale":"de","native":"Deutsch"},{"title":"Date.prototype.getYear()","locale":"en-US","native":"English (US)"},{"title":"Date.prototype.getYear()","locale":"fr","native":"Français"},{"title":"Date.prototype.getYear()","locale":"ja","native":"日本語"},{"title":"Date.prototype.getYear()","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Date.prototype.getYear()","locale":"ru","native":"Русский"},{"title":"Date.prototype.getYear()","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"pl/web/javascript/reference/global_objects/date/getyear","github_url":"https://github.com/mdn/translated-content/blob/main/fi