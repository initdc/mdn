{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"false","mdn_url":"/pl/docs/Web/XPath/Functions/false","locale":"pl","native":"Polski","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p>\n</p><div style=\"background:#f5f5f5; margin: 5px 0;\" id=\"sect1\">\n    <b><a href=\"/pl/docs/Web/XSLT/Transforming_XML_with_XSLT/The_Netscape_XSLT_XPath_Reference\">Dokumentacja XSLT/XPath</a></b>: <a href=\"/pl/docs/Web/XSLT/Element\">Elementy XSLT</a>, <a href=\"/pl/docs/Web/EXSLT\">Funkcje EXSLT</a>, <a href=\"/pl/docs/Web/XPath/Functions\">Funkcje XPath</a>, <a href=\"/pl/docs/Web/XPath/Axes\">Osie XPath</a>\n</div>\n<p></p><p><br>\nFunkcja <code>false</code> zwraca wartość logiczną <i>fałsz</i>.\n</p>"}},{"type":"prose","value":{"id":"sk.c5.82adnia","title":" Składnia ","isH3":true,"content":"<pre class=\"eval notranslate\">false()\n</pre>"}},{"type":"prose","value":{"id":"zwraca","title":" Zwraca ","isH3":true,"content":"<p>Wartość logiczną <code>false</code>.\n</p>"}},{"type":"prose","value":{"id":"uwagi","title":" Uwagi ","isH3":true,"content":"<p>Ta funkcja jest użyteczna jako część porównania:\n</p>\n<pre class=\"eval notranslate\">&lt;xsl:if test=\"boolean((1 &amp;gt; 2) = false())\"&gt;\n Wyrażenie jest ocenione jako true\n&lt;/xsl:if&gt;\n</pre>"}},{"type":"prose","value":{"id":"definicja","title":" Definicja ","isH3":true,"content":"<p><a href=\"https://www.w3.org/TR/xpath#function-false\" class=\"external\" rel=\" noopener\">XPath 1.0 4.3</a>\n</p>"}},{"type":"prose","value":{"id":"gecko","title":" Gecko ","isH3":true,"content":"<p>Obsługuje.\n</p>\n<div class=\"noinclude\" id=\"sect2\">\n</div>"}}],"toc":[],"summary":"Funkcja false zwraca wartość logiczną fałsz.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"false","locale":"en-US","native":"English (US)"},{"title":"false","locale":"fr","native":"Français"},{"title":"false","locale":"ja","nati