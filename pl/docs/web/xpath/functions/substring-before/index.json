{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"substring-before","mdn_url":"/pl/docs/Web/XPath/Functions/substring-before","locale":"pl","native":"Polski","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p>\n</p><div style=\"background:#f5f5f5; margin: 5px 0;\" id=\"sect1\">\n    <b><a href=\"/pl/docs/Web/XSLT/Transforming_XML_with_XSLT/The_Netscape_XSLT_XPath_Reference\">Dokumentacja XSLT/XPath</a></b>: <a href=\"/pl/docs/Web/XSLT/Element\">Elementy XSLT</a>, <a href=\"/pl/docs/Web/EXSLT\">Funkcje EXSLT</a>, <a href=\"/pl/docs/Web/XPath/Functions\">Funkcje XPath</a>, <a href=\"/pl/docs/Web/XPath/Axes\">Osie XPath</a>\n</div>\n<p></p><p><br>\nFunkcja <code>substring-before</code> zwraca łańcuch znaków będący resztą podanego łańcucha znaków przed danym podciągiem. </p>"}},{"type":"prose","value":{"id":"sk.c5.82adnia","title":" Składnia ","isH3":true,"content":"<pre class=\"eval notranslate\">substring-before( <i>stóg siana</i> , <i>igła</i> )\n</pre>"}},{"type":"prose","value":{"id":"argumenty","title":" Argumenty ","isH3":true,"content":"<dl><dt id=\"stóg_siana\"><i><code>stóg siana</code></i>\n</dt><dd>Oceniany łańcuch znaków. Zostanie zwrócona część tego łańcucha. </dd></dl>\n<dl><dt id=\"igła\"><i><code>igła</code></i>\n</dt><dd>Szukany podciąg. Zostanie zwrócone wszystko przed pierwszym wystąpieniem <i><code>igła</code></i> w łańcuchu <i><code>stóg siana</code></i>.\n</dd></dl>"}},{"type":"prose","value":{"id":"zwraca","title":" Zwraca ","isH3":true,"content":"<p>Łańcuch znaków.\n</p>"}},{"type":"prose","value":{"id":"przyk.c5.82ady","title":" Przykłady ","isH3":true,"content":"<table class=\"standard-table\"> <tbody><tr> <th>Przykład XPath</th> <th>Wyświetli</th> </tr> <tr> <td><code>substring-before('aa-bb','-')</code></td> <td><code>aa</code></td> </tr> <tr> <td><code>substring-before('aa-bb','a')</code></td> <td><code>(empty string)</code></td> </tr> <tr> <td><code>substring-before('aa-bb','b')</code></td> <td><code>aa-</code></td> </tr> <tr> <td><code>substring-before('aa-bb','q')</code></td> <td>(pusty łańcuch znaków)</td> </tr>\n</tbody></table>"}},{"type":"prose","value":{"id":"definicja","title":" Definicja ","isH3":true,"content":"<p><a href=\"https://www.w3.org/TR/xpath#function-substring-before\" class=\"external\" rel=\" noopener\">XPath 1.0 4.2</a>\n</p>"}},{"type":"prose","value":{"id":"gecko","title":" Gecko ","isH3":true,"content":"<p>Obsługuje.\n</p>\n<div class=\"noinclude\" id=\"sect2\">\n</div>"}}],"toc":[],"summary":"Funkcja substring-before zwraca łańcuch znaków będący resztą podanego łańcucha znaków przed danym podciągiem.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"substring-before","locale":"en-US","native":"English (US)"},{"title":"substring-before","locale":"fr","native":"Français"},{"title":"substring-before","locale":"ja","native":"日本語"},{"title":"substring-before","locale":"ko","native":"한국어"}],"source":{"folder":"pl/web/xpath/functions/substring-before","github_url":"https://github.com/mdn/translated-content/blob/main/files/pl/web/xpath/functions/substring-before/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pl/docs/Web","title":"Technologie Internetowe dla developerów"},{"uri":"/pl/docs/Web/XPath","title":"XPath"},{"uri":"/pl/docs/Web/XPath/Functions","title":"Funkcje"},{"uri":"/pl/docs/Web/XPath/Functions/substring-before","title":"substring-before"}],"pageTitle":"substring-before - XPath | MDN","noIndexing":false}}