{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":false,"flaws":{},"title":"position","mdn_url":"/pl/docs/Web/XPath/Functions/position","locale":"pl","native":"Polski","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><div style=\"background:#f5f5f5; margin: 5px 0;\" id=\"sect1\">\n    <b><a href=\"/pl/docs/Web/XSLT/Transforming_XML_with_XSLT/The_Netscape_XSLT_XPath_Reference\">Dokumentacja XSLT/XPath</a></b>: <a href=\"/pl/docs/Web/XSLT/Element\">Elementy XSLT</a>, <a href=\"/pl/docs/Web/EXSLT\">Funkcje EXSLT</a>, <a href=\"/pl/docs/Web/XPath/Functions\">Funkcje XPath</a>, <a href=\"/pl/docs/Web/XPath/Axes\">Osie XPath</a>\n</div><p></p>\n\n<p><br>\n Funkcja <code>position</code> zwraca liczbę równą pozycji kontekstu z kontekstu oceny wyrażenia.</p>"}},{"type":"prose","value":{"id":"sk.c5.82adnia","title":"Składnia","isH3":true,"content":"<pre class=\"eval notranslate\">position()\n</pre>"}},{"type":"prose","value":{"id":"zwraca","title":"Zwraca","isH3":true,"content":"<p>Liczbę całkowitą równą pozycji kontekstu z kontekstu oceny wyrażenia.</p>"}},{"type":"prose","value":{"id":"uwagi","title":"Uwagi","isH3":true,"content":"<ul>\n <li>Należy zauważyć, że pozycja węzła w kontekście nie zaczyna się od zera. Pierwszy węzeł ma pozycję 1.</li>\n <li>Kontekst jest określony przez resztę ścieżki.</li>\n</ul>\n\n<pre class=\"eval notranslate\">&lt;xsl:template match=\"//a[position() = 5]\"&gt;\n &lt;!-- ten szablon odpowiada piątemu elementowi 'a' gdziekolwiek\n      w dokumencie. --&gt;\n&lt;/xsl:template&gt;\n</pre>\n\n<pre class=\"eval notranslate\">&lt;xsl:template match=\"//div[@class='foo']/bar[position() = 1]\"&gt;\n &lt;!-- ten szablon odpowiada pierwszemu elementowi 'bar' będącemu\n      potomkiem elementu 'div' z atrybutem class równym 'foo' --&gt;\n&lt;/xsl:template&gt;\n</pre>"}},{"type":"prose","value":{"id":"definicja","title":"Definicja","isH3":true,"content":"<p><a class=\"external\" href=\"https://www.w3.org/TR/xpath#function-position\" rel=\" noopener\">XPath 1.0 4.1</a></p>"}},{"type":"prose","value":{"id":"gecko","title":"Gecko","isH3":true,"content":"<p>Obsługuje.</p>\n\n<div class=\"noinclude\" id=\"sect2\"></div>\n\n<p></p>"}}],"toc":[],"summary":"Funkcja position zwraca liczbę równą pozycji kontekstu z kontekstu oceny wyrażenia.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"position","locale":"en-US","native":"English (US)"},{"title":"position","locale":"fr","native":"Français"},{"title":"position","locale":"ja","native":"日本語"},{"title":"position","locale":"ko","native":"한국어"}],"source":{"folder":"pl/web/xpath/functions/position","github_url":"https://github.com/mdn/translated-content/blob/main/files/pl/web/xpath/functions/position/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pl/docs/Web","title":"Technologie Internetowe dla developerów"},{"uri":"/pl/docs/Web/XPath","title":"XPath"},{"uri":"/pl/docs/Web/XPath/Functions","title":"Funkcje"},{"uri":"/pl/docs/Web/XPath/Functions/position","title":"position"}],"pageTitle":"position - XPath | MDN","noIndexing":false}}