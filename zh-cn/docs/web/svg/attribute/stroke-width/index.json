{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"stroke-width","mdn_url":"/zh-CN/docs/Web/SVG/Attribute/stroke-width","locale":"zh-CN","native":"中文 (简体)","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p>« <a href=\"/en-US/SVG/Attribute\" title=\"en/SVG/Attribute\">SVG 属性参考主页</a></p>\n\n<p><code>stroke-width</code>属性指定了当前对象的轮廓的宽度。它的默认值是<strong>1</strong>。如果使用了一个&lt;percentage&gt;，这个值代表当前视口的百分比。如果使用了<strong>0</strong>值，则将不绘制轮廓。</p>\n\n<p>作为一个外观属性，它可以直接用作 CSS 样式表内部的属性。</p>"}},{"type":"prose","value":{"id":"用法","title":"用法","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"row\">类别</th>\n   <td>外观属性</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">值</th>\n   <td><a href=\"/en-US/SVG/Content_type#length\" title=\"en/SVG/Content_type#Length\">&lt;length&gt;</a> | <a href=\"/en-US/SVG/Content_type#percentage\" title=\"en/SVG/Content_type#Percentage\">&lt;percentage&gt;</a> | inherit</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">可变性</th>\n   <td>Yes</td>\n  </tr>\n  <tr>\n   <th scope=\"row\">规范文档</th>\n   <td><a class=\"external\" href=\"https://www.w3.org/TR/SVG/painting.html#StrokeWidthProperty\" rel=\" noopener\">SVG 1.1 (2nd Edition)</a></td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"示例","title":"示例","isH3":false,"content":""}},{"type":"prose","value":{"id":"元素","title":"元素","isH3":false,"content":"<p>下列元素可以使用<code>stroke-width</code>属性：</p>\n\n<ul>\n <li><a href=\"/en-US/SVG/Element#shape\" title=\"en/SVG/Element#Shape\">形状元素</a>&nbsp;»</li>\n <li><a href=\"/en-US/SVG/Element#textcontent\" title=\"en/SVG/Element#TextContent\">文本内容元素</a>&nbsp;»</li>\n</ul>"}}],"toc":[{"text":"用法","id":"用法"},{"text":"示例","id":"示例"},{"text":"元素","id":"元素"}],"summary":"« SVG 属性参考主页","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"stroke-width","locale":"en-US","native":"English (US)"},{"title":"stroke-width","locale":"fr","native":"Français"},{"title":"stroke-width","locale":"ru","native":"Русский"}],"source":{"folder":"zh-cn/web/svg/attribute/stroke-width","github_url":"https://github.com/mdn/translated-content/blob/main/files/zh-cn/web/svg/attribute/stroke-width/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/zh-CN/docs/Web","title":"Web 开发技术"},{"uri":"/zh-CN/docs/Web/SVG","title":"SVG"},{"uri":"/zh-CN/docs/Web/SVG/Attribute","title":"SVG 属性参考"},{"uri":"/zh-CN/docs/Web/SVG/Attribute/stroke-width","title":"stroke-width"}],"pageTitle":"stroke-width - SVG | MDN","noIndexing":false}}