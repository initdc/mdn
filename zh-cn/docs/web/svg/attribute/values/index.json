ode>&lt;feMorphology&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/feOffset\"><code>&lt;feOffset&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/fePointLight\"><code>&lt;fePointLight&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/feSpecularLighting\"><code>&lt;feSpecularLighting&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/feSpotLight\"><code>&lt;feSpotLight&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/feTile\"><code>&lt;feTile&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/feTurbulence\"><code>&lt;feTurbulence&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/filter\"><code>&lt;filter&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/font\"><code>&lt;font&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/font-face\"><code>&lt;font-face&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/font-face-format\"><code>&lt;font-face-format&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/font-face-name\"><code>&lt;font-face-name&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/font-face-src\"><code>&lt;font-face-src&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/font-face-uri\"><code>&lt;font-face-uri&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/foreignObject\"><code>&lt;foreignObject&gt;</code></a></li>\n   </ol>\n </li>\n <li>G\n   <ol>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/g\"><code>&lt;g&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/glyph\"><code>&lt;glyph&gt;</code></a></li>\n     <li class=\"deprecatedElement\"><a href=\"/zh-CN/docs/Web/SVG/Element/glyphRef\"><code>&lt;glyphRef&gt;</code></a></li>\n   </ol>\n </li>\n <li>H\n   <ol>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/hkern\"><code>&lt;hkern&gt;</code></a></li>\n   </ol>\n </li>\n <li>I\n   <ol>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/image\"><code>&lt;image&gt;</code></a></li>\n   </ol>\n </li>\n <li>J-L\n   <ol>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/line\"><code>&lt;line&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/linearGradient\"><code>&lt;linearGradient&gt;</code></a></li>\n   </ol>\n </li>\n <li>M\n   <ol>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/marker\"><code>&lt;marker&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/mask\"><code>&lt;mask&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/metadata\"><code>&lt;metadata&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/missing-glyph\"><code>&lt;missing-glyph&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/mpath\"><code>&lt;mpath&gt;</code></a></li>\n   </ol>\n </li>\n <li>N-P\n   <ol>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/path\"><code>&lt;path&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/pattern\"><code>&lt;pattern&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/polygon\"><code>&lt;polygon&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/polyline\"><code>&lt;polyline&gt;</code></a></li>\n   </ol>\n </li>\n <li>Q-R\n   <ol>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/radialGradient\"><code>&lt;radialGradient&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/rect\"><code>&lt;rect&gt;</code></a></li>\n   </ol>\n </li>\n <li>S\n   <ol>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/script\"><code>&lt;script&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/set\"><code>&lt;set&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/stop\"><code>&lt;stop&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/style\"><code>&lt;style&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/svg\"><code>&lt;svg&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/switch\"><code>&lt;switch&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/symbol\"><code>&lt;symbol&gt;</code></a></li>\n   </ol>\n </li>\n <li>T\n   <ol>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/text\"><code>&lt;text&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/textPath\"><code>&lt;textPath&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/title\"><code>&lt;title&gt;</code></a></li>\n     <li class=\"deprecatedElement\"><a href=\"/zh-CN/docs/Web/SVG/Element/tref\"><code>&lt;tref&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/tspan\"><code>&lt;tspan&gt;</code></a></li>\n   </ol>\n </li>\n <li>U\n   <ol>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/use\"><code>&lt;use&gt;</code></a></li>\n   </ol>\n </li>\n <li>V-Z\n   <ol>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/view\"><code>&lt;view&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/vkern\"><code>&lt;vkern&gt;</code></a></li>\n   </ol>\n </li>\n   </ol></details></li>\n   </ol>\n  </section></div>\n\n<p>values 属性具有不同的含义，具体取决于使用的上下文，它可以定义在动画过程中使用的值序列，或者它是颜色矩阵的数字列表，根据颜色类型的不同，它们的解释也不同。 要执行的颜色更改。</p>\n\n<p>五个元素正在使用此属性: <a href=\"/zh-CN/docs/Web/SVG/Element/animate\"><code>&lt;animate&gt;</code></a>, <a href=\"/zh-CN/docs/Web/SVG/Element/animate\"><code>&lt;animateColor&gt;</code></a>, <a href=\"/zh-CN/docs/Web/SVG/Element/animateMotion\"><code>&lt;animateMotion&gt;</code></a>, <a href=\"/zh-CN/docs/Web/SVG/Element/animateTransform\"><code>&lt;animateTransform&gt;</code></a>, and <a href=\"/zh-CN/docs/Web/SVG/Element/feColorMatrix\"><code>&lt;feColorMatrix&gt;</code></a></p>"}},{"type":"prose","value":{"id":"animate_animatecolor_animatemotion_animatetransform","title":"animate, animateColor, animateMotion, animateTransform","isH3":false,"content":"<p>对于 <a href=\"/zh-CN/docs/Web/SVG/Element/animate\"><code>&lt;animate&gt;</code></a>, <a href=\"/zh-CN/docs/Web/SVG/Element/animate\"><code>&lt;animateColor&gt;</code></a>, <a href=\"/zh-CN/docs/Web/SVG/Element/animateMotion\"><code>&lt;animateMotion&gt;</code></a>, 和 <a href=\"/zh-CN/docs/Web/SVG/Element/animateTransform\"><code>&lt;animateTransform&gt;</code></a>, <code>values</code>是一个列表 定义动画过程中的值序列的值。 如果指定了此属性，则将忽略在元素上设置的任何 <code><a href=\"/zh-CN/docs/Web/SVG/Attribute/From\">from</a></code>, <code><a href=\"/en-US/docs/Web/SVG/Attribute/To\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">to (en-US)</a></code>, 和&nbsp;<code><a href=\"/en-US/docs/Web/SVG/Attribute/by\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">by (en-US)</a></code> 属性值。</p>\n\n<table class=\"properties\">\n <tbody>\n  <tr>\n   <th scope=\"row\">Value</th>\n   <td><code><a href=\"/en-US/docs/Web/SVG/Content_type#list-of-ts\">&lt;list-of-values&gt;</a></code></td>\n  </tr>\n  <tr>\n   <th scope=\"row\">Default value</th>\n   <td><em>None</em></td>\n  </tr>\n  <tr>\n   <th scope=\"row\">Animatable</th>\n   <td>No</td>\n  </tr>\n </tbody>\n</table>\n\n<dl>\n <dt id=\"list-of-values\"><code>&lt;list-of-values&gt;</code></dt>\n <dd>该值包含一个或多个值的分号分隔列表。 值的类型由 <code><a href=\"/en-US/docs/Web/SVG/Attribute/href\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">href (en-US)</a></code> 和 <code><a href=\"/zh-CN/docs/Web/SVG/Attribute/attributeName\">attributeName</a></code> 属性定义。</dd>\n</dl>"}},{"type":"prose","value":{"id":"fecolormatrix","title":"feColorMatrix","isH3":false,"content":"<p>对于 <a href=\"/zh-CN/docs/Web/SVG/Element/feColorMatrix\"><code>&lt;feColorMatrix&gt;</code></a> 元素，值是根据 <code><a href=\"/zh-CN/docs/Web/SVG/Attribute/type\">type</a></code> 属性值不同解释的数字列表。</p>\n\n<table class=\"properties\">\n <tbody>\n  <tr>\n   <th scope=\"row\">Value</th>\n   <td><code><a href=\"/en-US/docs/Web/SVG/Content_type#list-of-ts\">&lt;list-of-numbers&gt;</a></code></td>\n  </tr>\n  <tr>\n   <th scope=\"row\">Default value</th>\n   <td><em>If <code>type=\"matrix\"</code>, identity matrix,<br>\n    if <code>type=\"saturate\"</code>, <code>1</code>, resulting in identity matrix,<br>\n    if <code>type=\"hueRotate\"</code>, <code>0</code>, resulting in identity matrix</em></td>\n  </tr>\n  <tr>\n   <th scope=\"row\">Animatable</th>\n   <td>Yes</td>\n  </tr>\n </tbody>\n</table>\n\n<dl>\n <dt id=\"list-of-numbers\"><code>&lt;list-of-numbers&gt;</code></dt>\n <dd>\n <p>该值是一个数字列表，根据 type 属性的值来定义不同解释：</p>\n\n <ul>\n  <li>For <code>type=\"matrix\"</code>, <code>values</code> 是 20 个矩阵值（a00 a01 a02 a03 a04 a10 a11 ... a34）的列表，以空格和/或逗号分隔。</li>\n  <li>For <code>type=\"saturate\"</code>, <code>values</code> 是单个实数值（0 到 1）。</li>\n  <li>For <code>type=\"hueRotate\"</code>, <code>values</code> 是一个单一的实数值（度）。.</li>\n  <li>For <code>type=\"luminanceToAlpha\"</code>, <code>values</code> 不适用。</li>\n </ul>\n </dd>\n</dl>"}},{"type":"prose","value":{"id":"specifications","title":"Specifications","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">Specification</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Comment</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"https://drafts.fxtf.org/filter-effects/#element-attrdef-fecolormatrix-values\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">Filter Effects Module Level 1<br><small lang=\"zh-CN\">values for &lt;feColorMatrix&gt;</small></a></td>\n   <td><span class=\"spec-wd\">Working Draft</span></td>\n   <td>No change</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://svgwg.org/specs/animations/#ValuesAttribute\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">SVG Animations Level&nbsp;2<br><small lang=\"zh-CN\">values for &lt;animate&gt;, &lt;animateColor&gt;, &lt;animateMotion&gt;, and &lt;animateTransform&gt;</small></a></td>\n   <td><span class=\"spec-ed\">Editor's Draft</span></td>\n   <td>No change</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.w3.org/TR/SVG11/filters.html#feColorMatrixValuesAttribute\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">Scalable Vector Graphics (SVG) 1.1 (Second Edition)<br><small lang=\"zh-CN\">values for &lt;feColorMatrix&gt;</small></a></td>\n   <td><span class=\"spec-rec\">Recommendation</span></td>\n   <td>Initial definition for <code>&lt;feColorMatrix&gt;</code></td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.w3.org/TR/SVG11/animate.html#ValuesAttribute\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">Scalable Vector Graphics (SVG) 1.1 (Second Edition)<br><small lang=\"zh-CN\">values for &lt;animate&gt;, &lt;animateColor&gt;, &lt;animateMotion&gt;, and &lt;animateTransform&gt;</small></a></td>\n   <td><span class=\"spec-rec\">Recommendation</span></td>\n   <td>Initial definition for <code>&lt;animate&gt;</code>, <code>&lt;animateColor&gt;</code>, <code>&lt;animateMotion&gt;</code>, and <code>&lt;animateTransform&gt;</code></td>\n  </tr>\n </tbody>\n</table>"}}],"toc":[{"text":"animate, animateColor, animateMotion, animateTransform","id":"animate_animatecolor_animatemotion_animatetransform"},{"text":"feColorMatrix","id":"fecolormatrix"},{"text":"Specifications","id":"specifications"}],"summary":"values 属性具有不同的含义，具体取决于使用的上下文，它可以定义在动画过程中使用的值序列，或者它是颜色矩阵的数字列表，根据颜色类型的不同，它们的解释也不同。 要执行的颜色更改。","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"values","locale":"en-US","native":"English (US)"},{"title":"values","locale":"ko","native":"한국어"},{"title":"values","locale":"ru","native":"Русский"}],"source":{"folder":"zh-cn/web/svg/attribute/values","github_url":"https://github.com/mdn/translated-content/blob/main/files/zh-cn/web/svg/attribute/values/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/zh-CN/docs/Web","title":"Web 开发技术"},{"uri":"/zh-CN/docs/Web/SVG","title":"SVG"},{"uri":"/zh-CN/docs/Web/SVG/Attribute","title":"SVG 属性参考"},{"uri":"/zh-CN/docs/Web/SVG/Attribute/values","title":"values"}],"pageTitle":"values - SVG | MDN","noIndexing":false}}