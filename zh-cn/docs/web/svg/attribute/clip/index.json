{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"clip","mdn_url":"/zh-CN/docs/Web/SVG/Attribute/clip","locale":"zh-CN","native":"中文 (简体)","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"><section class=\"Quick_links\" id=\"quick_links\">\n  <ol>\n   \n   <li><details><summary>SVG Elements</summary><ol>\n <li>A\n   <ol>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/a\"><code>&lt;a&gt;</code></a></li>\n     <li class=\"deprecatedElement\"><a href=\"/zh-CN/docs/Web/SVG/Element/altGlyph\"><code>&lt;altGlyph&gt;</code></a></li>\n     <li class=\"deprecatedElement\"><a href=\"/zh-CN/docs/Web/SVG/Element/altGlyphDef\"><code>&lt;altGlyphDef&gt;</code></a></li>\n     <li class=\"deprecatedElement\"><a href=\"/zh-CN/docs/Web/SVG/Element/altGlyphItem\"><code>&lt;altGlyphItem&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/animate\"><code>&lt;animate&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/animate\"><code>&lt;animateColor&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/animateMotion\"><code>&lt;animateMotion&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/animateTransform\"><code>&lt;animateTransform&gt;</code></a></li>\n   </ol>\n </li>\n <li>B-C\n   <ol>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/circle\"><code>&lt;circle&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/clipPath\"><code>&lt;clipPath&gt;</code></a></li>\n     <li class=\"deprecatedElement\"><a class=\"page-not-created\" title=\"此页面仍未被本地化, 期待您的翻译!\"><code>&lt;color-profile&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/cursor\"><code>&lt;cursor&gt;</code></a></li>\n   </ol>\n </li>\n <li>D\n   <ol>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/defs\"><code>&lt;defs&gt;</code></a></li>\n     <li><a href=\"/zh-CN/docs/Web/SVG/Element/desc\"><code>&lt;desc&gt;</code></a></li>\n   <