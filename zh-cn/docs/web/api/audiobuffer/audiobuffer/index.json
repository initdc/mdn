b/API/AudioBuffer\"><code>AudioBuffer</code></a>&nbsp;对象。</p>"}},{"type":"prose","value":{"id":"语法","title":"语法","isH3":false,"content":"<pre class=\"syntaxbox notranslate\">var audioBuffer = new AudioBuffer([options]);\nvar audioBuffer = new AudioBuffer(context[, options]);</pre>"}},{"type":"prose","value":{"id":"参数","title":"参数","isH3":true,"content":"<p><em>继承参数自&nbsp;<a href=\"/zh-CN/docs/conflicting/Web/API/AudioNode\"><code>AudioNodeOptions</code></a>&nbsp;字典</em>.</p>\n\n<dl>\n <dt id=\"context\"><em>context</em> <svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg></dt>\n <dd>一个 <a href=\"/zh-CN/docs/Web/API/AudioContext\"><code>AudioContext</code></a>&nbsp;对象. (这个参数已经被标准移除，&nbsp;详细信息请参阅浏览器兼容性部分.)</dd>\n <dt id=\"options\"><em>options</em> <span class=\"badge inline optional\">可选</span></dt>\n <dd>Options are as follows:\n <ul>\n  <li><code>length</code>: buffer 中采样帧的长度。</li>\n  <li><code>numberOfChannels</code>: buffer 的通道数.&nbsp;默认值为 1.&nbsp;</li>\n  <li><code>sampleRate</code>:&nbsp;buffer 的采样率 (Hz).&nbsp;默认值为构造此对象时使用的&nbsp;<code>context</code>&nbsp;的采样率。</li>\n </ul>\n </dd>\n</dl>"}},{"type":"prose","value":{"id":"返回值","title":"返回值","isH3":true,"content":"<p>一个新的 <a href=\"/zh-CN/docs/Web/API/AudioBuffer\"><code>AudioBuffer</code></a>&nbsp;对象实例。</p>"}},{"type":"specifications","value":{"title":"规范","id":"规范","isH3":false,"specifications":[{"bcdSpecificationURL":"https://webaudio.github.io/web-audio-api/#dom-audiobuffer-audiobuffer","title":"Web Audio API"}],"query":"api.AudioBuffer.AudioBuffer"}},{"type":"browser_compatibility","value":{"title":"浏览器兼容性","id":"浏览器兼容性","isH3":false,"query":"api.AudioBuffer.AudioBuffer","dataURL":"/zh-CN/docs/Web/API/AudioBuffer/AudioBuffer/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect2\">\n\n\n<p></p><p></p>\n</div>"}}],"toc":[{"text":"语法","id":"语法"},{"text":"规范","id":"规范"},{"text":"浏览器兼容性","id":"浏览器兼容性"}],"summary":"Web Audio API 的 AudioBuffer 构造函数将创建一个新的 AudioBuffer 对象。","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"AudioBuffer()","locale":"en-US","native":"English (US)"},{"title":"AudioBuffer()","locale":"fr","native":"Français"},{"title":"AudioBuffer()","locale":"ja","native":"日本語"}],"source":{"folder":"zh-cn/web/api/audiobuffer/audiobuffer","github_url":"https://github.com/mdn/translated-content/blob/main/files/zh-cn/web/api/audiobuffer/audiobuffer/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/zh-CN/docs/Web","title":"Web 开发技术"},{"uri":"/zh-CN/docs/Web/API","title":"Web API 接口参考"},{"uri":"/zh-CN/docs/Web/API/AudioBuffer","title":"AudioBuffer"},{"uri":"/zh-CN/docs/Web/API/AudioBuffer/AudioBuffer","title":"AudioBuffer()"}],"pageTitle":"AudioBuffer() - Web API 接口参考 | MDN","noIndexing":false}}