{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"PaymentAddress","mdn_url":"/zh-CN/docs/Web/API/PaymentAddress","locale":"zh-CN","native":"中文 (简体)","sidebarHTML":"<ol><li><strong><a href=\"/zh-CN/docs/Web/API/Payment_Request_API\">Payment Request API</a></strong></li><li><strong><a href=\"/zh-CN/docs/Web/API/PaymentAddress\"><code>PaymentAddress</code></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>属性</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/addressLine\"><code>addressLine</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/city\"><code>city</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/country\"><code>country</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/dependentLocality\"><code>dependentLocality</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/organization\"><code>organization</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/phone\"><code>phone</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/postalCode\"><code>postalCode</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/recipient\"><code>recipient</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/region\"><code>region</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/sortingCode\"><code>sortingCode</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/toJSON\"><code>toJSON()</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Related pages for Payment Request API</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/HTMLIFrameElement/allowPaymentRequest\"><code>HTMLIFrameElement.allowPaymentRequest</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/MerchantValidationEvent\"><code>MerchantValidationEvent</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentMethodChangeEvent\"><code>PaymentMethodChangeEvent</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentRequest\"><code>PaymentRequest</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentRequestUpdateEvent\"><code>PaymentRequestUpdateEvent</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentResponse\"><code>PaymentResponse</code> <small>(en-US)</small></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><div class=\"notecard experimental\" id=\"sect1\"><p><strong>Experimental:</strong> <strong>这是一个实验中的功能</strong><br>此功能某些浏览器尚在开发中，请参考<a href=\"#browser_compatibility\">浏览器兼容性表格</a>以得到在不同浏览器中适合使用的前缀。由于该功能对应的标准文档可能被重新修订，所以在未来版本的浏览器中该功能的语法和行为可能随之改变。</p></div><p></p>\n\n<p>The <strong><code>PaymentAddress</code></strong> interface of the&nbsp;<a href=\"/en-US/docs/Web/API/Payment_Request_API\">Payment Request API</a>&nbsp;stores address information.</p>"}},{"type":"prose","value":{"id":"properties","title":"Properties","isH3":false,"content":"<dl>\n\t<dt id=\"paymentaddress.country_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/country\"><code>PaymentAddress.country</code> <small>(en-US)</small></a> <span title=\"该属性的值无法更改\" class=\"badge inline readonly\">只读 </span>&nbsp;</dt>\n\t<dd>The Common Locale Data Repository region code. For example, US, GB, CN, etc.</dd>\n\t<dt id=\"paymentaddress.addressline_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/addressLine\"><code>PaymentAddress.addressLine</code> <small>(en-US)</small></a>&nbsp;<span title=\"该属性的值无法更改\" class=\"badge inline readonly\">只读 </span></dt>\n\t<dd>An array of strings describing the address. The exact size and content varies by country or location and can include,&nbsp;for example, a street name, house number, apartment number, rural delivery route, descriptive instructions, or post office box number.</dd>\n\t<dt id=\"paymentaddress.region_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/region\"><code>PaymentAddress.region</code> <small>(en-US)</small></a>&nbsp;<span title=\"该属性的值无法更改\" class=\"badge inline readonly\">只读 </span></dt>\n\t<dd>The top level administrative subdivision of the country, for example,&nbsp;a state,&nbsp;province,&nbsp;oblast, or prefecture.</dd>\n\t<dt id=\"paymentaddress.city_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/city\"><code>PaymentAddress.city</code> <small>(en-US)</small></a>&nbsp;<span title=\"该属性的值无法更改\" class=\"badge inline readonly\">只读 </span></dt>\n\t<dd>The city or town portion of the address.</dd>\n\t<dt id=\"paymentaddress.dependentlocality_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/dependentLocality\"><code>PaymentAddress.dependentLocality</code> <small>(en-US)</small></a>&nbsp;<span title=\"该属性的值无法更改\" class=\"badge inline readonly\">只读 </span></dt>\n\t<dd>The dependent locality or sublocality within a city, for example, a neighborhood, borough, district, or UK dependent locality.</dd>\n\t<dt id=\"paymentaddress.postalcode_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/postalCode\"><code>PaymentAddress.postalCode</code> <small>(en-US)</small></a>&nbsp;<span title=\"该属性的值无法更改\" class=\"badge inline readonly\">只读 </span></dt>\n\t<dd>A code used by a jurisdiction for mail routing, for example, the ZIP code in the United States or the PIN code in India.</dd>\n\t<dt id=\"paymentaddress.sortingcode_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/sortingCode\"><code>PaymentAddress.sortingCode</code> <small>(en-US)</small></a>&nbsp;<span title=\"该属性的值无法更改\" class=\"badge inline readonly\">只读 </span></dt>\n\t<dd>A postal sorting code such as is used in France.</dd>\n\t<dt id=\"paymentaddress.languagecode_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/languageCode\"><code>PaymentAddress.languageCode</code> <small>(en-US)</small></a>&nbsp;<span title=\"该属性的值无法更改\" class=\"badge inline readonly\">只读 </span></dt>\n\t<dd>The BCP-47 language code for the address,&nbsp;used to determine the field separators and the order of fields when formatting the address for display.</dd>\n\t<dt id=\"paymentaddress.organization_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/organization\"><code>PaymentAddress.organization</code> <small>(en-US)</small></a>&nbsp;<span title=\"该属性的值无法更改\" class=\"badge inline readonly\">只读 </span></dt>\n\t<dd>The name of the organization, firm, company, or institution at the payment address.</dd>\n\t<dt id=\"paymentaddress.recipient_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/recipient\"><code>PaymentAddress.recipient</code> <small>(en-US)</small></a>&nbsp;<span title=\"该属性的值无法更改\" class=\"badge inline readonly\">只读 </span></dt>\n\t<dd>The name of the recipient, purchaser, or contact person at the payment address.</dd>\n\t<dt id=\"paymentaddress.careof\"><a class=\"page-not-created\" title=\"此页面仍未被本地化, 期待您的翻译!\"><code>PaymentAddress.careOf</code></a>&nbsp;<span title=\"该属性的值无法更改\" class=\"badge inline readonly\">只读 </span> <svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg></dt>\n\t<dd>The name of an intermediary party or entity responsible for transferring packages between the postal service and the recipient.</dd>\n\t<dt id=\"paymentaddress.phone_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PaymentAddress/phone\"><code>PaymentAddress.phone</code> <small>(en-US)</small></a>&nbsp;<span title=\"该属性的值无法更改\" class=\"badge inline readonly\">只读 </span></dt>\n\t<dd>The telephone number of the recipient or contact person.</dd>\n</dl>"}},{"type":"prose","value":{"id":"methods","title":"Methods","isH3":false,"content":"<p>None.</p>"}},{"type":"prose","value":{"id":"specifications","title":"Specifications","isH3":false,"content":"<table class=\"standard-table\">\n\t<tbody>\n\t\t<tr>\n\t\t\t<th scope=\"col\">Specification</th>\n\t\t\t<th scope=\"col\">Status</th>\n\t\t\t<th scope=\"col\">Comment</th>\n\t\t</tr>\n\t\t<tr>\n\t\t\t<td><a href=\"https://w3c.github.io/payment-request/#paymentaddress-interface\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">Payment Request API<br><small lang=\"zh-CN\">PaymentAddress</small></a></td>\n\t\t\t<td><span class=\"spec-cr\">Candidate Recommendation</span></td>\n\t\t\t<td>Initial definition.</td>\n\t\t</tr>\n\t</tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"Browser Compatibility","id":"browser_compatibility","isH3":false,"query":"api.PaymentAddress","dataURL":"/zh-CN/docs/Web/API/PaymentAddress/bcd.json"}}],"toc":[{"text":"Properties","id":"properties"},{"text":"Methods","id":"methods"},{"text":"Specifications","id":"specifications"},{"text":"Browser Compatibility","id":"browser_compatibility"}],"summary":"The PaymentAddress interface of the Payment Request API stores address information.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"PaymentAddress","locale":"en-US","native":"English (US)"}],"source":{"folder":"zh-cn/web/api/paymentaddress","github_url":"https://github.com/mdn/translated-content/blob/main/files/zh-cn/web/api/paymentaddress/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/zh-CN/docs/Web","title":"Web 开发技术"},{"uri":"/zh-CN/docs/Web/API","title":"Web API 接口参考"},{"uri":"/zh-CN/docs/Web/API/PaymentAddress","title":"PaymentAddress"}],"pageTitle":"PaymentAddress - Web API 接口参考 | MDN","noIndexing":false}}