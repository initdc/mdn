{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"History","mdn_url":"/zh-CN/docs/Web/API/History","locale":"zh-CN","native":"中文 (简体)","sidebarHTML":"<ol><li><strong><a href=\"/zh-CN/docs/Web/API/HTML_DOM_API\">HTML DOM API</a></strong></li><li><strong><a href=\"/zh-CN/docs/Web/API/History\"><code>History</code></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>属性</summary><ol><li><a href=\"/zh-CN/docs/Web/API/History/length\"><code>length</code></a></li><li><a href=\"/zh-CN/docs/Web/API/History/scrollRestoration\"><code>scrollRestoration</code></a></li><li><a href=\"/zh-CN/docs/Web/API/History/state\"><code>state</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>方法</summary><ol><li><a href=\"/zh-CN/docs/Web/API/History/back\"><code>back()</code></a></li><li><a href=\"/zh-CN/docs/Web/API/History/forward\"><code>forward()</code></a></li><li><a href=\"/zh-CN/docs/Web/API/History/go\"><code>go()</code></a></li><li><a href=\"/zh-CN/docs/Web/API/History/pushState\"><code>pushState()</code></a></li><li><a href=\"/zh-CN/docs/Web/API/History/replaceState\"><code>replaceState()</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Related pages for HTML DOM</summary><ol><li><a href=\"/zh-CN/docs/Web/API/BeforeUnloadEvent\"><code>BeforeUnloadEvent</code></a></li><li><a href=\"/zh-CN/docs/Web/API/DOMStringMap\"><code>DOMStringMap</code></a></li><li><a href=\"/zh-CN/docs/Web/API/ErrorEvent\"><code>ErrorEvent</code></a></li><li><a href=\"/zh-CN/docs/Web/API/GlobalEventHandlers\"><code>GlobalEventHandlers</code></a></li><li><a href=\"/zh-CN/docs/Web/API/HTMLAnchorElement\"><code>HTMLAnchorElement</code></a></li><li><a href=\"/zh-CN/docs/Web/API/HTMLAreaElement\"><code>HTMLAreaElement</code></a></li><li><a href=\"/zh-CN/docs/Web/API/HTMLAudioElement\"><code>HTMLAudioElement</code></a></li><li><a href=\"/zh-CN/docs/Web/API/HTMLBRElement\"><code>HTMLBRElement</code></a></