-CN/docs/Web/API/Event/returnValue\"><code>returnValue</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/zh-CN/docs/Web/API/Event/srcElement\"><code>srcElement</code></a></li><li><a href=\"/zh-CN/docs/Web/API/Event/target\"><code>target</code></a></li><li><a href=\"/zh-CN/docs/Web/API/Event/timeStamp\"><code>timeStamp</code></a></li><li><a href=\"/zh-CN/docs/Web/API/Event/type\"><code>type</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>方法</summary><ol><li><a href=\"/zh-CN/docs/Web/API/Event/composedPath\"><code>composedPath()</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/zh-CN/docs/Web/API/Event/initEvent\"><code>initEvent()</code></a></li><li><a href=\"/zh-CN/docs/Web/API/Event/preventDefault\"><code>preventDefault()</code></a></li><li><a href=\"/zh-CN/docs/Web/API/Event/stopImmediatePropagation\"><code>stopImmediatePropagation()</code></a></li><li><a href=\"/zh-CN/docs/Web/API/Event/stopPropagation\"><code>stopPropagation()</code></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p>&nbsp;<p></p>\n\n<p><code><strong>Event.cancelBubble</strong></code>&nbsp;属性是&nbsp;<a href=\"/zh-CN/docs/Web/API/Event/stopPropagation\"><code>Event.stopPropagation()</code></a>的一个曾用名。在从事件处理程序返回之前将其值设置为 true 可阻止事件的传播。</p>"}},{"type":"prose","value":{"id":"syntax","title":"语法","isH3":false,"content":"<pre class=\"syntaxbox notranslate\">event.cancelBubble = <em>bool;</em>\n<em>let bool</em> = event.cancelBubble;</pre>"}},{"type":"prose","value":{"id":"用例","title":"用例","isH3":false,"content":"<dl>\n <dt id=\"sect1\">\n <pre class=\"syntaxbox notranslate\">ele.onclick = function(e) {\n  // 在这儿可以做点儿有趣的事情\n&nbsp; e.cancelBubble = true;\n}</pre>\n </dt>\n</dl>"}},{"type":"prose","value":{"id":"规范","title":"规范","isH3":false,"content":"<p><em>这个属性的规范并未统一。</em>&nbsp;因为他还有其他标准 W3C 版：&nbsp;<a href=\"https://www.w3.org/TR/1999/WD-DOM-Level-2-19990304/events.html#attribute-cancelBubble\" class=\"external\" rel=\" noopener\">an old Working Draft of W3C DOM Level 2</a>. 微软版：&nbsp;<a href=\"https://msdn.microsoft.com/en-us/library/ms533545(v=vs.85).aspx\" class=\"external\" rel=\" noopener\">description of it on MSDN</a>.</p>"}},{"type":"browser_compatibility","value":{"title":"浏览器兼容","id":"browser_compatibility","isH3":false,"query":"api.Event.cancelBubble","dataURL":"/zh-CN/docs/Web/API/Event/cancelBubble/bcd.json"}},{"type":"prose","value":{"id":"参考","title":"参考","isH3":false,"content":"<ul>\n <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Event/cancelBubble\"><code>UIEvent.cancelBubble</code> <small>(en-US)</small></a></li>\n <li>translated by cnvoid</li>\n</ul>"}}],"toc":[{"text":"语法","id":"syntax"},{"text":"用例","id":"用例"},{"text":"规范","id":"规范"},{"text":"浏览器兼容","id":"browser_compatibility"},{"text":"参考","id":"参考"}],"summary":"Event.cancelBubble 属性是 Event.stopPropagation()的一个曾用名。在从事件处理程序返回之前将其值设置为 true 可阻止事件的传播。","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Event.cancelBubble","locale":"en-US","native":"English (US)"},{"title":"Event.cancelBubble","locale":"fr","native":"Français"},{"title":"Event.cancelBubble","locale":"ja","native":"日本語"},{"title":"Event.cancelBubble","locale":"ko","native":"한국어"}],"source":{"folder":"zh-cn/web/api/event/cancelbubble","github_url":"https://github.com/mdn/translated-content/blob/main/files/zh-cn/web/api/event/cancelbubble/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/zh-CN/docs/Web","title":"Web 开发技术"},{"uri":"/zh-CN/docs/Web/API","title":"Web API 接口参考"},{"uri":"/zh-CN/docs/Web/API/Event"