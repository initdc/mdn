-CN/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupSetter__\"><code>Object.prototype.__lookupSetter__()</code></a></li><li><a href=\"/zh-CN/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwnProperty\"><code>Object.prototype.hasOwnProperty()</code></a></li><li><a href=\"/zh-CN/docs/Web/JavaScript/Reference/Global_Objects/Object/isPrototypeOf\"><code>Object.prototype.isPrototypeOf()</code></a></li><li><a href=\"/zh-CN/docs/Web/JavaScript/Reference/Global_Objects/Object/propertyIsEnumerable\"><code>Object.prototype.propertyIsEnumerable()</code></a></li><li><a href=\"/zh-CN/docs/Web/JavaScript/Reference/Global_Objects/Object/setPrototypeOf\"><code>Object.setPrototypeOf()</code></a></li><li><a href=\"/zh-CN/docs/Web/JavaScript/Reference/Global_Objects/Object/toLocaleString\"><code>Object.prototype.toLocaleString()</code></a></li><li><a href=\"/zh-CN/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a></li><li><a href=\"/zh-CN/docs/Web/JavaScript/Reference/Global_Objects/Object/valueOf\"><code>Object.prototype.valueOf()</code></a></li></ol></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\">\n<div id=\"sect2\"> <div class=\"notecard warning\" id=\"sect3\"><p><strong>非标准:</strong> 该特性是非标准的，请尽量不要在生产环境中使用它！</p></div></div>\n</div>"}},{"type":"prose","value":{"id":"summary","title":"概述","isH3":false,"content":"<p>返回函数的源代码的字符串表示。</p>"}},{"type":"prose","value":{"id":"syntax","title":"语法","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><code><var>function</var>.toSource();\nFunction.toSource();\n</code></pre>"}},{"type":"prose","value":{"id":"parameters","title":"参数","isH3":true,"content":"<p>无</p>"}},{"type":"prose","value":{"id":"description","title":"描述","isH3":false,"content":"<p><code>toSource</code> 方法返回下面的值：</p>\n\n\n\n<ul>\n <li>对于内置的<code>Function</code>对象，<code>toSource</code>返回下面的字符串：</li>\n</ul>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">function</span> <span class=\"token function\">Function</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n    <span class=\"token punctuation\">[</span>native code<span class=\"token punctuation\">]</span>\n<span class=\"token punctuation\">}</span></code></pre></div>\n\n<ul>\n <li>对于自定义函数来说，<code>toSource 返回能定义该函数</code>的 Javascript 源码。</li>\n</ul>\n\n<p>该方法通常在引擎内部调用。你可以在调试的时候用该方法开查看一个函数的源代码。</p>"}},{"type":"prose","value":{"id":"see_also","title":"相关链接","isH3":false,"content":"<ul>\n <li><a href=\"/zh-CN/docs/Web/JavaScript/Reference/Global_Objects/Function/toString\" title=\"JavaScript/Reference/Global_Objects/Function/toString\">toString</a></li>\n <li><a href=\"/zh-CN/docs/Web/JavaScript/Reference/Global_Objects/Object/valueOf\" title=\"JavaScript/Reference/Global_Objects/Object/valueOf\">Object.prototype.valueOf</a></li>\n</ul>"}}],"toc":[{"text":"概述","id":"summary"},{"text":"语法","id":"syntax"},{"text":"描述","id":"description"},{"text":"相关链接","id":"see_also"}],"summary":"返回函数的源代码的字符串表示。","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Function.prototype.toSource()","locale":"de","native":"Deutsch"},{"title":"Function.prototype.toSource()","locale":"es","native":"Español"},{"title":"Function.prototype.toSource()","locale":"ja","native":"日本語"},{"title":"Function.prototype.toSource()","locale":"pt-BR","native":"Português (do Brasil)"},{"title":"Function.prototype.toSource()","locale":"ru","native":"Русский"}],"source":{"folder":"zh-cn/conflicting/web/javascript/reference/global_objects/function/tostring","github_url":"https://github.com/mdn/translated-content/blob/main/files/zh-cn/conflicting/web/javascript/reference/global_objects/function/tostring/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143