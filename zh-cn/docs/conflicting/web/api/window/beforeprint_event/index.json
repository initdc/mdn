es.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Window/vrdisplaydeactivate_event\"><code>vrdisplaydeactivate</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Window/vrdisplaydisconnect_event\"><code>vrdisplaydisconnect</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Window/vrdisplayfocus_event\"><code>vrdisplayfocus</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Window/vrdisplaypointerrestricted_event\"><code>vrdisplaypointerrestricted</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Window/vrdisplaypointerunrestricted_event\"><code>vrdisplaypointerunrestricted</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Window/vrdisplaypresentchange_event\"><code>vrdisplaypresentchange</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>继承</summary><ol><li><a href=\"/zh-CN/docs/Web/API/EventTarget\"><code>EventTarget</code></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<div id=\"sect2\"><a class=\"page-not-created\" title=\"此页面仍未被本地化, 期待您的翻译!\"><code>WindowEventHandlers</code></a>的<code><strong>onbeforeprint</strong></code>属性是用于处理当前窗口的<code><a href=\"/en-US/docs/Web/API/Window/beforeprint_event\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">beforeprint (en-US)</a></code>事件的<code><a href=\"/zh-CN/docs/Web/Reference/Events/Event_handlers\" title=\"This is a link to an unwritten page\" class=\"page-not-created\">event handler</a></code>。在打开打印对话窗口之前会触发这些事件。</div>\n\n\n\n<div id=\"sect3\"><font><font>在</font></font><code>beforeprint</code><font><font>和</font></font><code><a href=\"/en-US/docs/Web/API/Window/afterprint_event\" title=\"Currently only available in English (US)\" class=\"only-in-en-us\">afterprint (en-US)</a></code><font><font>事件允许网页在打印开始前更改他们的内容（例如：可能是删除一个横幅），然后在打印完成后恢复这些更改。通常，您应该更喜欢使用</font></font><code><a href=\"/en-US/docs/Web/CSS/Media_Queries/Using_media_queries#Media_types\">@media print</a></code><font><font>CSS规则，但是在某些情况下可能有必要使用这些事件。</font></font></div>"}},{"type":"prose","value":{"id":"语法","title":"语法","isH3":false,"content":"<pre class=\"syntaxbox notranslate\">window.addEventListener(\"beforeprint\", function(event) { ... });\nwindow.onbeforeprint = function(event) { ... };\n</pre>"}},{"type":"prose","value":{"id":"范例","title":"范例","isH3":false,"content":"<p><font><font>Safari没有实现这些事件，但是您可以使用创建与</font></font><code>beforeprint</code><font><font>事件</font><font>等效的结果</font><font>。</font></font><a href=\"/zh-CN/docs/Web/API/Window/matchMedia\"><code>window.matchMedia</code></a><code>('print')</code></p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> mediaQueryList <span class=\"token operator\">=</span> window<span class=\"token punctuation\">.</span><span class=\"token function\">matchMedia</span><span class=\"token punctuation\">(</span><span class=\"token string\">'print'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\nmediaQueryList<span class=\"token punctuation\">.</span><span class=\"token function\">addListener</span><span class=\"token punctuation\">(</span><span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">mql</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n  <span class=\"token keyword\">if</span><span class=\"token punctuation\">(</span>mql<span class=\"token punctuation\">.</span>matches<span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n    console<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span><span class=\"token string\">'webkit equivalent of onbeforeprint'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n  <span class=\"token punctuation\">}</span>\n<span class=\"token punctuation\">}</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span></code></pre></div>"}},{"type":"prose","value":{"id":"规范","title":"规范","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">规范</th>\n   <th scope=\"col\">状态</th>\n   <th scope=\"col\">注解</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"https://html.spec.whatwg.org/multipage/#handler-window-onbeforeprint\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML Living Standard<br><small lang=\"zh-CN\">onbeforeprint</small></a></td>\n   <td><span class=\"spec-living\">Living Standard</span></td>\n   <td></td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"浏览器兼容性","id":"浏览器兼容性","isH3":false,"query":"api.WindowEventHandlers.onbeforeprint","dataURL":"/zh-CN/docs/conflicting/Web/API/Window/beforeprint_event/bcd.json"}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}},{"type":"prose","value":{"id":"参阅","title":"参阅","isH3":false,"content":"<ul>\n <li><a href=\"/zh-CN/docs/Web/API/Window/print\"><code>Window.print()</code></a></li>\n <li><a href=\"/zh-CN/docs/conflicting/Web/API/Window/afterprint_event\"><code>WindowEventHandlers.onafterprint</code></a></li>\n <li><a href=\"/en-US/docs/Web/Guide/Printing\">Printing</a></li>\n</ul>"}}],"toc":[{"text":"语法","id":"语法"},{"text":"范例","id":"范例"},{"text":"规范","id":"规范"},{"text":"浏览器兼容性","id":"浏览器兼容性"},{"text":"参阅","id":"参阅"}],"summary":"Safari没有实现这些事件，但是您可以使用创建与beforeprint事件等效的结果。window.matchMedia('print')","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"WindowEventHandlers.onbeforeprint","locale":"ja","native":"日本語"}],"source":{"folder":"zh-cn/conflicting/web/api/window/beforeprint_event","github_url":"https://github.com/mdn/translated-content/blob/main/files/zh-cn/conflicting/web/api/window/beforeprint_event/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/zh-CN/docs/conflicting/Web/API","title":"指数"},{"uri":"/zh-CN/docs/conflicting/Web/API/Window","title":"window.minimize"},{"uri":"/zh-CN/docs/conflicting/Web/API/Window/beforeprint_event","title":"WindowEventHandlers.onbeforeprint"}],"pageTitle":"WindowEventHandlers.onbeforeprint | MDN","noIndexing":true}}