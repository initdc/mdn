Request/setRequestHeader\"><code>setRequestHeader()</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Events</summary><ol><li><a href=\"/zh-CN/docs/Web/API/XMLHttpRequest/abort_event\"><code>abort</code></a></li><li><a href=\"/zh-CN/docs/Web/API/XMLHttpRequest/error_event\"><code>error</code></a></li><li><a href=\"/zh-CN/docs/Web/API/XMLHttpRequest/load_event\"><code>load</code></a></li><li><a href=\"/zh-CN/docs/Web/API/XMLHttpRequest/loadend_event\"><code>loadend</code></a></li><li><a href=\"/zh-CN/docs/Web/API/XMLHttpRequest/loadstart_event\"><code>loadstart</code></a></li><li><em><code>progress</code></em></li><li><a href=\"/zh-CN/docs/Web/API/XMLHttpRequest/readystatechange_event\"><code>readystatechange</code></a></li><li><a href=\"/zh-CN/docs/Web/API/XMLHttpRequest/timeout_event\"><code>timeout</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>继承</summary><ol><li><a href=\"/zh-CN/docs/Web/API/XMLHttpRequestEventTarget\"><code>XMLHttpRequestEventTarget</code></a></li><li><a href=\"/zh-CN/docs/Web/API/EventTarget\"><code>EventTarget</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Related pages for XMLHttpRequest</summary><ol><li><a href=\"/zh-CN/docs/Web/API/FormData\"><code>FormData</code></a></li><li><a href=\"/zh-CN/docs/Web/API/ProgressEvent\"><code>ProgressEvent</code></a></li><li><a href=\"/zh-CN/docs/Web/API/XMLHttpRequestEventTarget\"><code>XMLHttpRequestEventTarget</code></a></li><li><a class=\"page-not-created\" title=\"此页面仍未被本地化, 期待您的翻译!\"><code>XMLHttpRequestUpload</code></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>\n\n<p><strong><code>XMLHttpRequestEventTarget.onprogress</code></strong>&nbsp;是在 <a href=\"/zh-CN/docs/Web/API/XMLHttpRequest\"><code>XMLHttpRequest</code></a> 完成之前周期性调用的函数。</p>"}},{"type":"prose","value":{"id":"syntax","title":"语法","isH3":false,"content":"<pre class=\"notranslate\"><em>XMLHttpRequest</em>.onprogress = <em>callback</em>;</pre>"}},{"type":"prose","value":{"id":"值","title":"值","isH3":true,"content":"<ul>\n <li><code><em>callback</em></code>&nbsp;在请求完成之前周期性调用的函数。</li>\n</ul>"}},{"type":"prose","value":{"id":"example","title":"事件","isH3":true,"content":"<ul>\n <li><em><code>event.loaded</code></em> &nbsp;已传输的数据量</li>\n <li><em><code>event.total</code></em> &nbsp;总共的数据量</li>\n</ul>\n\n<pre class=\"notranslate\">XMLHttpRequest.onprogress = function (event) {\n  event.loaded;\n  event.total;\n};</pre>"}},{"type":"prose","value":{"id":"example_2","title":"示例","isH3":false,"content":"<pre class=\"notranslate\">var xmlhttp = new XMLHttpRequest(),\n  method = 'GET',\n  url = 'https://developer.mozilla.org/';\n\nxmlhttp.open(<em>method</em>, <em>url</em>, true);\nxmlhttp.onprogress = function () {\n  //do something\n};\nxmlhttp.send();\n</pre>"}},{"type":"prose","value":{"id":"规范","title":"规范","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Specification</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Comment</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://xhr.spec.whatwg.org/#handler-xhr-onload\" hreflang=\"en\" lang=\"en\" class=\"external\" title=\"XMLHttpRequest\" rel=\" noopener\">XMLHttpRequest</a></td>\n   <td><span class=\"spec-living\">Living Standard</span></td>\n   <td>WHATWG living standard</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"浏览器兼容性","id":"浏览器兼容性","isH3":false,"data":null,"query":"api.XMLHttpRequestEventTarget.onprogress","browsers":null}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><p></p>"}}],"toc":[{"text":"语法","id":"syntax"},{"text":"示例","id":"example_2"},{"text":"规范","id":"规范"},{"text":"浏览器兼容性","id":"浏览器兼容性"}],"summary":"XMLHttpRequestEventTarget.onprogress 是在 XMLHttpRequest 完成之前周期性调用的函数。","popularity":0,"modified":"2022-07-19T02:29:32.000Z","source":{"folder":"zh-cn/conflicting/web/api/xmlhttprequest/progress_event","github_url":"https://github.com/mdn/translated-content/blob/main/files/zh-cn/conflicting/web/api/xmlhttprequest/progress_event/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/zh-CN/docs/conflicting/Web/API","title":"指数"},{"uri":"/zh-CN/docs/conflicting/Web/API/XMLHttpRequest/progress_event","title":"XMLHttpRequestEventTarget.onprogress"}],"pageTitle":"XMLHttpRequestEventTarget.onprogress | MDN","noIndexing":true}}