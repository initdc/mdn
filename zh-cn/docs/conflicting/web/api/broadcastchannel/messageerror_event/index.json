-CN/docs/Web/API/Plugin\"><code>Plugin</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PluginArray\"><code>PluginArray</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/PopStateEvent\"><code>PopStateEvent</code> <small>(en-US)</small></a></li><li><a href=\"/zh-CN/docs/Web/API/PromiseRejectionEvent\"><code>PromiseRejectionEvent</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/RadioNodeList\"><code>RadioNodeList</code> <small>(en-US)</small></a></li><li><a href=\"/zh-CN/docs/Web/API/ValidityState\"><code>ValidityState</code></a></li><li><a href=\"/zh-CN/docs/Web/API/Window\"><code>Window</code></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p>位于&nbsp;<a href=\"/zh-CN/docs/Web/API/BroadcastChannel\"><code>BroadcastChannel</code></a> 接口上的 <code><strong>onmessageerror</strong></code> 事件处理程序，它是一个 <a href=\"/zh-CN/docs/conflicting/Web/API/EventTarget/addEventListener_380cb5f366307beb2c072f74e561ee98\" title=\"事件监听器\"><code>事件监听器</code></a>。当&nbsp; <code>BroadcastChannel</code>&nbsp;接收到一条无法 <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Glossary/Deserialization\">反序列化 <small>(en-US)</small></a>的消息时，会触发类型为&nbsp;<a class=\"page-not-created\" title=\"此页面仍未被本地化, 期待您的翻译!\"><code>MessageError</code></a> 的 <a href=\"/zh-CN/docs/Web/API/MessageEvent\"><code>MessageEvent</code></a> 事件，此时会执行该事件处理程序。</p>\n\n<p></p><div class=\"notecard note\" id=\"sect2\">\n  <p><strong>Note:</strong> 此特性在 <a href=\"/zh-CN/docs/Web/API/Web_Workers_API\">Web Worker</a> 中可用</p>\n</div><p></p>"}},{"type":"prose","value":{"id":"语法","title":"语法","isH3":false,"content":"<pre class=\"syntaxbox notranslate\">bc.onmessageerror = function() { ... };</pre>"}},{"type":"prose","value":{"id":"规范","title":"规范","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">规范</th>\n   <th scope=\"col\">状态</th>\n   <th scope=\"col\">备注</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://html.spec.whatwg.org/multipage/#handler-broadcastchannel-onmessageerror\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML Living Standard<br><small lang=\"zh-CN\">onmessageerror</small></a></td>\n   <td><span class=\"spec-living\">Living Standard</span></td>\n   <td></td>\n  </tr>\n </tbody>\n</table>"}},{"type":"browser_compatibility","value":{"title":"浏览器兼容性","id":"浏览器兼容性","isH3":false,"data":null,"query":"api.BroadcastChannel.onmessageerror","browsers":null}},{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect3\">\n\n\n<p></p><p></p>\n</div>"}},{"type":"prose","value":{"id":"另见","title":"另见","isH3":false,"content":"<ul>\n <li><a href=\"/en-US/docs/Web/API/Channel_Messaging_API/Using_channel_messaging\">Using channel messaging</a></li>\n</ul>"}}],"toc":[{"text":"语法","id":"语法"},{"text":"规范","id":"规范"},{"text":"浏览器兼容性","id":"浏览器兼容性"},{"text":"另见","id":"另见"}],"summary":"位于 BroadcastChannel 接口上的 onmessageerror 事件处理程序，它是一个 事件监听器。当  BroadcastChannel 接收到一条无法 反序列化 (en-US)的消息时，会触发类型为 MessageError 的 MessageEvent 事件，此时会执行该事件处理程序。","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"BroadcastChannel.onmessageerror","locale":"ja","native":"日本語"}],"source":{"folder":"zh-cn/conflicting/web/api/broadcastchannel/messageerror_event","github_url":"https://github.com/mdn/translated-content/blob/main/files/zh-cn/conflicting/web/api/broadcastchannel/messageerror_event/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/zh-CN/docs/conflicting/Web/API","title":"指数"},{"uri":"/zh-CN/docs/conflicting/Web/API/BroadcastChannel/messageerror_event","title":"BroadcastChannel.onmessageerror"}],"pageTitle":"BroadcastChannel.onmessageerror | MDN","noIndexing":true}}