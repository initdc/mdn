":"prose","value":{"id":"parameters","title":"Parameters","isH3":true,"content":"<dl>\n  <dt id=\"mediakeysessiontype\"><code>mediaKeySessionType</code> <span class=\"badge inline optional\">Optional</span></dt>\n  <dd>\n    <p>A string. Either \"temporary\" or \"persistent-license\". The default value is \"temporary\".</p>\n  </dd>\n</dl>"}},{"type":"prose","value":{"id":"return_value","title":"Return value","isH3":true,"content":"<p>A new <a href=\"/en-US/docs/Web/API/MediaKeySession\"><code>MediaKeySession</code></a> object.</p>"}},{"type":"specifications","value":{"title":"Specifications","id":"specifications","isH3":false,"specifications":[{"bcdSpecificationURL":"https://w3c.github.io/encrypted-media/#dom-mediakeys-createsession","title":"Encrypted Media Extensions"}],"query":"api.MediaKeys.createSession"}},{"type":"browser_compatibility","value":{"title":"Browser compatibility","id":"browser_compatibility","isH3":false,"query":"api.MediaKeys.createSession","dataURL":"/en-US/docs/Web/API/MediaKeys/createSession/bcd.json"}}],"toc":[{"text":"Syntax","id":"syntax"},{"text":"Specifications","id":"specifications"},{"text":"Browser compatibility","id":"browser_compatibility"}],"summary":"The MediaKeys.createSession() method returns a new\n  MediaKeySession object, which represents a context for message exchange\n  with a content decryption module (CDM).","popularity":0,"modified":"2022-06-01T05:12:48.000Z","source":{"folder":"en-us/web/api/mediakeys/createsession","github_url":"https://github.com/mdn/content/blob/style/old/files/en-us/web/api/mediakeys/createsession/index.md","last_commit_url":"https://github.com/mdn/content/commit/c1f8207fa145db27da55bf832c85a63aeb7d24b7","filename":"index.md"},"parents":[{"uri":"/en-US/docs/Web","title":"Web technology for developers"},{"uri":"/en-US/docs/Web/API","title":"Web APIs"},{"uri":"/en-US/docs/Web/API/MediaKeys","title":"MediaKeys"},{"uri":"/en-US/docs/Web/API/MediaKeys/createSession","title":"MediaKeys.createSession()"}]