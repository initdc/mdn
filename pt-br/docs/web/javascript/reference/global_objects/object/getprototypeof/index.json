class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/getPrototypeOf\"><code>Reflect.getPrototypeOf()</code> <small>(en-US)</small></a></li>\n</ul>"}}],"toc":[{"text":"Sintaxe","id":"sintaxe"},{"text":"Exemplos","id":"exemplos"},{"text":"Notas","id":"notas"},{"text":"Especificação","id":"especificação"},{"text":"Compatibilidade com navegadores","id":"browser_compatibility"},{"text":"Notas específicas para o Opera","id":"notas_específicas_para_o_opera"},{"text":"Veja também","id":"veja_também"}],"summary":"O método Object.getPrototypeOf() retorna o prototype (isto é, o valor da propriedade interna [[Prototype]]) do objeto especificado.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Object.getPrototypeOf()","locale":"de","native":"Deutsch"},{"title":"Object.getPrototypeOf()","locale":"en-US","native":"English (US)"},{"title":"Object.getPrototypeOf()","locale":"es","native":"Español"},{"title":"Object.getPrototypeOf()","locale":"fr","native":"Français"},{"title":"Object.getPrototypeOf()","locale":"ja","native":"日本語"},{"title":"Object.getPrototypeOf()","locale":"ko","native":"한국어"},{"title":"Object.getPrototypeOf()","locale":"ru","native":"Русский"},{"title":"Object.getPrototypeOf()","locale":"zh-CN","native":"中文 (简体)"},{"title":"Object.getPrototypeOf()","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"pt-br/web/javascript/reference/global_objects/object/getprototypeof","github_url":"https://github.com/mdn/translated-content/blob/main/files/pt-br/web/javascript/reference/global_objects/object/getprototypeof/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pt-BR/docs/Web","title":"Tecnologia Web para desenvolvedores"},{"uri":"/pt-BR/docs/Web/JavaScript","title":"JavaScript"},{"uri":"/pt-BR/docs/Web/JavaScript/Reference"