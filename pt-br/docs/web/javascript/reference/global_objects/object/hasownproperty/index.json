JavaScript/Reference/Global_Objects/Object","title":"Object"},{"uri":"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwnProperty","title":"Object.prototype.hasOwnProperty()"}],"pageTitle":"Object.prototype.hasOwnProperty() - JavaScript | MDN","noIndexing":false}}