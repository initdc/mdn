{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"Reflect","mdn_url":"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Reflect","locale":"pt-BR","native":"Português (do Brasil)","sidebarHTML":"<ol><li><strong><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects\">Standard built-in objects</a></strong></li><li><strong><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Reflect\"><code>Reflect</code></a></strong></li><li data-default-state=\"open\"><a href=\"#\"><strong>Métodos</strong></a><ol><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Reflect/apply\"><code>Reflect.apply()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Reflect/construct\"><code>Reflect.construct()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Reflect/defineProperty\"><code>Reflect.defineProperty()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/deleteProperty\"><code>Reflect.deleteProperty()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/get\"><code>Reflect.get()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/getOwnPropertyDescriptor\"><code>Reflect.getOwnPropertyDescriptor()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/getPrototypeOf\"><code>Reflect.getPrototypeOf()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/has\"><code>Reflect.has()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/isExtensible\"><code>Reflect.isExtensible()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/ownKeys\"><code>Reflect.ownKeys()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/preventExtensions\"><code>Reflect.preventExtensions()</code> <small>(en-US)</small></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Reflect/set\"><code>Reflect.set()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/setPrototypeOf\"><code>Reflect.setPrototypeOf()</code> <small>(en-US)</small></a></li></ol></li><li><strong>Herança:</strong></li><li><strong><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object\"><code>Object</code></a></strong></li><li><a href=\"#\"><strong>Propriedades</strong></a><ol><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/constructor\"><code>Object.prototype.constructor</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/proto\"><code>Object.prototype.__proto__</code></a></li></ol></li><li><a href=\"#\"><strong>Métodos</strong></a><ol><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineGetter__\"><code>Object.prototype.__defineGetter__()</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineSetter__\"><code>Object.prototype.__defineSetter__()</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupGetter__\"><code>Object.prototype.__lookupGetter__()</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupSetter__\"><code>Object.prototype.__lookupSetter__()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwnProperty\"><code>Object.prototype.hasOwnProperty()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/isPrototypeOf\"><code>Object.prototype.isPrototypeOf()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/propertyIsEnumerable\"><code>Object.prototype.propertyIsEnumerable()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/setPrototypeOf\"><code>Object.setPrototypeOf()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/toLocaleString\"><code>Object.prototype.toLocaleString()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/valueOf\"><code>Object.prototype.valueOf()</code></a></li></ol></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p><strong>Reflect</strong> é um objeto nativo&nbsp;que&nbsp;provê&nbsp;métodos para operações&nbsp;JavaScript interceptáveis. Os métodos são&nbsp;os mesmos&nbsp;que o&nbsp;dos&nbsp;<a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Proxy\">manipuladores de Proxy</a>. <code>Reflect</code>&nbsp;não é&nbsp;um objeto de função, então não é&nbsp;construtível.</p>"}},{"type":"prose","value":{"id":"descrição","title":"Descrição","isH3":false,"content":"<p>Ao contrário&nbsp;da maioria dos&nbsp;objetos globais, <code>Reflect</code> não é um construtor. Você&nbsp;não pode usá-lo&nbsp;com o <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Operators/new\">operador&nbsp;new</a>&nbsp;ou invocar o objeto&nbsp;<code>Reflect</code>&nbsp;como uma&nbsp;função. Todas as&nbsp;propriedades&nbsp;e métodos&nbsp;do&nbsp;<code>Reflect</code> são estáticos&nbsp;(igual o objeto <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math\"><code>Math</code></a>).</p>\n\n<p>O objeto&nbsp;<code>Reflect</code> provê as seguintes funções estáticas as quais tem os mesmos nomes usados pelos métodos&nbsp;<a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Proxy\">manipuladores de Proxy</a>.</p>\n\n<p>Alguns deste métodos são também os mesmos correspondentes aos métodos em <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object\"><code>Object</code></a>, embora eles tenham diferenças sutis entre eles.</p>"}},{"type":"prose","value":{"id":"métodos","title":"Métodos","isH3":false,"content":"<dl>\n <dt id=\"reflect.applytarget_thisargument_argumentslist\"><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Reflect/apply\"><code>Reflect.apply(<var>target</var>,&nbsp;<var>thisArgument</var>,&nbsp;<var>argumentsList</var>)</code></a></dt>\n <dd>Chama&nbsp;uma função de destino com os argumentos, conforme especificado&nbsp;pelo parâmetro&nbsp;<em><code>argumentsList</code></em>. Veja também <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Function/apply\"><code>Function.prototype.apply()</code></a>.</dd>\n <dt id=\"reflect.constructtarget_argumentslist_newtarget\"><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Reflect/construct\"><code>Reflect.construct(<var>target</var>,&nbsp;<var>argumentsList</var>[,&nbsp;<var>newTarget</var>])</code></a></dt>\n <dd>&nbsp;O <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Operators/new\">operador new</a>&nbsp;como uma função. Equivalente a chamada&nbsp;<code>new target(...args)</code>. Também possui a opção de especificar um <code><em>prototype</em></code> diferente</dd>\n <dt id=\"reflect.definepropertytarget_propertykey_attributes\"><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Reflect/defineProperty\"><code>Reflect.defineProperty(<var>target</var>,&nbsp;<var>propertyKey</var>,&nbsp;<var>attributes</var>)</code></a></dt>\n <dd>Similar ao <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/defineProperty\"><code>Object.defineProperty()</code></a>. Retorna&nbsp;um <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code></a> com o valor <code>true</code><em> se a propriedade foi definida com sucesso</em>.</dd>\n <dt id=\"reflect.deletepropertytarget_propertykey_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/deleteProperty\"><code>Reflect.deleteProperty(<var>target</var>,&nbsp;<var>propertyKey</var>)</code> <small>(en-US)</small></a></dt>\n <dd>O <a href=\"/en-US/docs/Web/JavaScript/Reference/Operators/delete\">operador delete</a> como uma função. Equivalente a chamada <code>delete target[name]</code>.</dd>\n <dt id=\"reflect.get_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/get\"><code>Reflect.get()</code> <small>(en-US)</small></a>, \"Reflect.get(<var>target</var>,&nbsp;<var>propertyKey</var>[,&nbsp;<var>receiver</var>])\"}}</dt>\n <dd>Uma função&nbsp;que retorna&nbsp;o valor da&nbsp;propriedade. Funciona como obter uma propriedade de um objeto&nbsp;(<code>target[propertyKey]</code>) como uma função.</dd>\n <dt id=\"reflect.getownpropertydescriptortarget_propertykey_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/getOwnPropertyDescriptor\"><code>Reflect.getOwnPropertyDescriptor(<var>target</var>,&nbsp;<var>propertyKey</var>)</code> <small>(en-US)</small></a></dt>\n <dd>Similar ao <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/getOwnPropertyDescriptor\"><code>Object.getOwnPropertyDescriptor()</code></a>. Retorna um descritor de propriedade da propriedade dada se existir no objeto, <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/undefined\"><code>undefined</code></a> caso contrário.</dd>\n <dt id=\"reflect.getprototypeoftarget_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/getPrototypeOf\"><code>Reflect.getPrototypeOf(<var>target</var>)</code> <small>(en-US)</small></a></dt>\n <dd>Igual ao&nbsp;<a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/getPrototypeOf\"><code>Object.getPrototypeOf()</code></a>.</dd>\n <dt id=\"reflect.hastarget_propertykey_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/has\"><code>Reflect.has(<var>target, propertyKey</var>)</code> <small>(en-US)</small></a></dt>\n <dd>O <a href=\"/en-US/docs/Web/JavaScript/Reference/Operators/in\">operador in</a> como função. Retorna um <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code></a> indicando se existe uma propriedade própria ou herdada.</dd>\n <dt id=\"reflect.isextensibletarget_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/isExtensible\"><code>Reflect.isExtensible(<var>target</var>)</code> <small>(en-US)</small></a></dt>\n <dd>Igual ao <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/isExtensible\"><code>Object.isExtensible()</code></a>. Retorna&nbsp;um <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code></a> com o valor&nbsp;<code>true</code>&nbsp;se o destino (parâmetro target) for extensível.</dd>\n <dt id=\"reflect.ownkeystarget_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/ownKeys\"><code>Reflect.ownKeys(<var>target</var>)</code> <small>(en-US)</small></a></dt>\n <dd>Retorna uma matriz das chaves de propriedade do próprio objeto de destino (não herdadas).</dd>\n <dt id=\"reflect.preventextensionstarget_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/preventExtensions\"><code>Reflect.preventExtensions(<var>target</var>)</code> <small>(en-US)</small></a></dt>\n <dd>Similar ao <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/preventExtensions\"><code>Object.preventExtensions()</code></a>. Retorna&nbsp;um <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code></a> com o valor <code>true</code>&nbsp;se a atualização foi bem sucedida.</dd>\n <dt id=\"reflect.settarget_propertykey_value_receiver\"><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Reflect/set\"><code>Reflect.set(<var>target</var>,&nbsp;<var>propertyKey</var>,&nbsp;<var>value</var>[,&nbsp;<var>receiver</var>])</code></a></dt>\n <dd>Uma função que atribui valores a propriedades. Retorna um <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code></a>&nbsp;com o valor&nbsp;<code>true</code> se a atualização foi bem sucedida.</dd>\n <dt id=\"reflect.setprototypeoftarget_prototype_en-us\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Reflect/setPrototypeOf\"><code>Reflect.setPrototypeOf(<var>target</var>,&nbsp;<var>prototype</var>)</code> <small>(en-US)</small></a></dt>\n <dd>Uma função que define o <a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Object\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">protótipo de um objeto (en-US)</a>. Retorna um <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Boolean\"><code>Boolean</code></a>&nbsp;com o valor&nbsp;<code>true</code> se a atualização foi bem sucedida.</dd>\n <dt id=\"sect2\">\n <h2 id=\"exemplos\">Exemplos</h2>\n\n <h3 id=\"verificando_se_um_objeto_contém_determinadas_propriedades\">Verificando se um objeto contém determinadas propriedades</h3>\n\n <div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">const</span> duck <span class=\"token operator\">=</span> <span class=\"token punctuation\">{</span>\n  <span class=\"token literal-property property\">name</span><span class=\"token operator\">:</span> <span class=\"token string\">'Maurice'</span><span class=\"token punctuation\">,</span>\n  <span class=\"token literal-property property\">color</span><span class=\"token operator\">:</span> <span class=\"token string\">'white'</span><span class=\"token punctuation\">,</span>\n  <span class=\"token function-variable function\">greeting</span><span class=\"token operator\">:</span> <span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n    console<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span><span class=\"token template-string\"><span class=\"token template-punctuation string\">`</span><span class=\"token string\">Quaaaack! My name is </span><span class=\"token interpolation\"><span class=\"token interpolation-punctuation punctuation\">${</span><span class=\"token keyword\">this</span><span class=\"token punctuation\">.</span>name<span class=\"token interpolation-punctuation punctuation\">}</span></span><span class=\"token template-punctuation string\">`</span></span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n  <span class=\"token punctuation\">}</span>\n<span class=\"token punctuation\">}</span>\n\nReflect<span class=\"token punctuation\">.</span><span class=\"token function\">has</span><span class=\"token punctuation\">(</span>duck<span class=\"token punctuation\">,</span> <span class=\"token string\">'color'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// true</span>\nReflect<span class=\"token punctuation\">.</span><span class=\"token function\">has</span><span class=\"token punctuation\">(</span>duck<span class=\"token punctuation\">,</span> <span class=\"token string\">'haircut'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// false</span></code></pre></div>\n\n <h3 id=\"retornando_as_próprias_chaves_do_objeto\">Retornando as próprias chaves do objeto</h3>\n\n <div class=\"code-example\"><pre class=\"brush: js notranslate\"><code>Reflect<span class=\"token punctuation\">.</span><span class=\"token function\">ownKeys</span><span class=\"token punctuation\">(</span>duck<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// [ \"name\", \"color\", \"greeting\" ]</span></code></pre></div>\n\n <h3 id=\"adicionando_uma_nova_propriedade_ao_objeto\">Adicionando uma nova propriedade ao objeto</h3>\n\n <div class=\"code-example\"><pre class=\"brush: js notranslate\"><code>Reflect<span class=\"token punctuation\">.</span><span class=\"token function\">set</span><span class=\"token punctuation\">(</span>duck<span class=\"token punctuation\">,</span> <span class=\"token string\">'eyes'</span><span class=\"token punctuation\">,</span> <span class=\"token string\">'black'</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// returns \"true\" if successful</span>\n<span class=\"token comment\">// \"duck\" now contains the property \"eyes: 'black'\"</span></code></pre></div>\n </dt>\n</dl>"}},{"type":"prose","value":{"id":"especificações","title":"Especificações","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Especificação</th>\n   <th scope=\"col\">Situação</th>\n   <th scope=\"col\">Comentário</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.ecma-international.org/ecma-262/6.0/#sec-reflect-object\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript 2015 (6th Edition, ECMA-262)<br><small lang=\"pt-BR\">The definition of 'Reflect' in that specification.</small></a></td>\n   <td><span class=\"spec-standard\">Padrão</span></td>\n   <td>Definição Inicial</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://tc39.es/ecma262/#sec-reflect-object\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript (ECMA-262)<br><small lang=\"pt-BR\">The definition of 'Reflect' in that specification.</small></a></td>\n   <td><span class=\"spec-living\">Padrão em tempo real</span></td>\n   <td>Reflect.enumerate foi removido.</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"browser_compatibility","title":"Compatibilidade com navegadores","isH3":false,"content":"<p></p><div class=\"notecard note\" id=\"sect3\"><strong><a href=\"https://github.com/mdn/browser-compat-data\" class=\"external\" rel=\" noopener\">Estamos convertendo nossos dados de compatibilidade para o formato JSON</a></strong>.\n            Esta tabela de compatibilidade ainda usa o formato antigo,\n            pois ainda não convertemos os dados que ela contém.\n            <strong><a href=\"/en-US/docs/MDN/Structures/Compatibility_tables\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">Descubra como você pode ajudar! (en-US)</a></strong></div>\n\n<div class=\"htab\" id=\"sect4\">\n    <a id=\"AutoCompatibilityTable\" name=\"AutoCompatibilityTable\"></a>\n    <ul>\n        <li class=\"selected\"><a href=\"#compat-desktop\">Desktop</a></li>\n        <li><a href=\"#compat-mobile\">Dispositivo móvel</a></li>\n    </ul>\n</div><p></p>\n\n<div id=\"compat-desktop\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Chrome</th>\n   <th>Edge</th>\n   <th>Firefox (Gecko)</th>\n   <th>Internet Explorer</th>\n   <th>Opera</th>\n   <th>Safari</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td>49.0</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><a href=\"/en-US/docs/Mozilla/Firefox/Releases/42\" title=\"Released on 2015-11-03.\">42</a> (42)</td>\n   <td><span style=\"color:#f00;\">Não suportado</span></td>\n   <td><span style=\"color:#f00;\">Não suportado</span></td>\n   <td><span style=\"color:#f00;\">Não suportado</span></td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<div id=\"compat-mobile\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Android</th>\n   <th>Chrome for Android</th>\n   <th>Firefox Mobile (Gecko)</th>\n   <th>IE Mobile</th>\n   <th>Opera Mobile</th>\n   <th>Safari Mobile</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td>49.0</td>\n   <td>49.0</td>\n   <td>42.0 (42)</td>\n   <td><span style=\"color:#f00;\">Não suportado</span></td>\n   <td><span style=\"color:#f00;\">Não suportado</span></td>\n   <td><span style=\"color:#f00;\">Não suportado</span></td>\n  </tr>\n </tbody>\n</table>\n</div>"}},{"type":"prose","value":{"id":"veja_também","title":"Veja também","isH3":false,"content":"<ul>\n <li>The <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Proxy\"><code>Proxy</code></a> global object.</li>\n <li>The <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Proxy/Proxy\"><code>handler</code> <small>(en-US)</small></a> object.</li>\n</ul>"}}],"toc":[{"text":"Descrição","id":"descrição"},{"text":"Métodos","id":"métodos"},{"text":"Especificações","id":"especificações"},{"text":"Compatibilidade com navegadores","id":"browser_compatibility"},{"text":"Veja também","id":"veja_também"}],"summary":"Reflect é um objeto nativo que provê métodos para operações JavaScript interceptáveis. Os métodos são os mesmos que o dos manipuladores de Proxy. Reflect não é um objeto de função, então não é construtível.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Reflect","locale":"de","native":"Deutsch"},{"title":"Reflect","locale":"en-US","native":"English (US)"},{"title":"Reflect","locale":"es","native":"Español"},{"title":"Reflect","locale":"fr","native":"Français"},{"title":"Reflect","locale":"ja","native":"日本語"},{"title":"Reflect","locale":"ko","native":"한국어"},{"title":"Reflect","locale":"ru","native":"Русский"},{"title":"Reflect","locale":"zh-CN","native":"中文 (简体)"},{"title":"Reflect","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"pt-br/web/javascript/reference/global_objects/reflect","github_url":"https://github.com/mdn/translated-content/blob/main/files/pt-br/web/javascript/reference/global_objects/reflect/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pt-BR/docs/Web","title":"Tecnologia Web para desenvolvedores"},{"uri":"/pt-BR/docs/Web/JavaScript","title":"JavaScript"},{"uri":"/pt-BR/docs/Web/JavaScript/Reference","title":"Referência JavaScript"},{"uri":"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects","title":"Objetos Globais"},{"uri":"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Reflect","title":"Reflect"}],"pageTitle":"Reflect - JavaScript | MDN","noIndexing":false}}