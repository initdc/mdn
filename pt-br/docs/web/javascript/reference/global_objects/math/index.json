n\n<h2 id=\"see_also\" name=\"See_also\">Veja também</h2>\n\n<ul>\n <li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Number\"><code>Number</code></a></li>\n</ul>\n</div>\n\n<p>&nbsp;</p>"}}],"toc":[{"text":"Descrição","id":"description"},{"text":"Propriedades","id":"properties"},{"text":"Métodos","id":"methods"}],"summary":"Math é um objeto embutido que tem propriedades e métodos para constantes e funções matemáticas. Não é um objeto de função.","popularity":0.0031,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Math","locale":"de","native":"Deutsch"},{"title":"Math","locale":"en-US","native":"English (US)"},{"title":"Math","locale":"es","native":"Español"},{"title":"Math","locale":"fr","native":"Français"},{"title":"Math","locale":"ja","native":"日本語"},{"title":"Math","locale":"ko","native":"한국어"},{"title":"Math","locale":"pl","native":"Polski"},{"title":"Math","locale":"ru","native":"Русский"},{"title":"Math","locale":"zh-CN","native":"中文 (简体)"},{"title":"Math","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"pt-br/web/javascript/reference/global_objects/math","github_url":"https://github.com/mdn/translated-content/blob/main/files/pt-br/web/javascript/reference/global_objects/math/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pt-BR/docs/Web","title":"Tecnologia Web para desenvolvedores"},{"uri":"/pt-BR/docs/Web/JavaScript","title":"JavaScript"},{"uri":"/pt-BR/docs/Web/JavaScript/Reference","title":"Referência JavaScript"},{"uri":"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects","title":"Objetos Globais"},{"uri":"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math","title":"Math"}],"pageTitle":"Math - JavaScript | MDN","noIndexing":false}}