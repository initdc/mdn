es","id":"browser_compatibility"},{"text":"Veja também","id":"veja_também"}],"summary":"A função Math.log10() retorna o logaritmo de base 10 de um número, que é","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Math.log10()","locale":"de","native":"Deutsch"},{"title":"Math.log10()","locale":"en-US","native":"English (US)"},{"title":"Math.log10()","locale":"es","native":"Español"},{"title":"Math.log10()","locale":"fr","native":"Français"},{"title":"Math.log10()","locale":"ja","native":"日本語"},{"title":"Math.log10()","locale":"ru","native":"Русский"},{"title":"Math.log10()","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"pt-br/web/javascript/reference/global_objects/math/log10","github_url":"https://github.com/mdn/translated-content/blob/main/files/pt-br/web/javascript/reference/global_objects/math/log10/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pt-BR/docs/Web","title":"Tecnologia Web para desenvolvedores"},{"uri":"/pt-BR/docs/Web/JavaScript","title":"JavaScript"},{"uri":"/pt-BR/docs/Web/JavaScript/Reference","title":"Referência JavaScript"},{"uri":"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects","title":"Objetos Globais"},{"uri":"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math","title":"Math"},{"uri":"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math/log10","title":"Math.log10()"}],"pageTitle":"Math.log10() - JavaScript | MDN","noIndexing":false}}