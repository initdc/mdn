al_Objects/Math/log10\"><code>Math.log10()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math/log1p\"><code>Math.log1p()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math/log2\"><code>Math.log2()</code></a></li><li><em><code>Math.max()</code></em></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math/min\"><code>Math.min()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math/pow\"><code>Math.pow()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math/random\"><code>Math.random()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math/round\"><code>Math.round()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math/sign\"><code>Math.sign()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math/sin\"><code>Math.sin()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math/sinh\"><code>Math.sinh()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math/sqrt\"><code>Math.sqrt()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math/tan\"><code>Math.tan()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math/tanh\"><code>Math.tanh()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math/trunc\"><code>Math.trunc()</code></a></li></ol></li><li><strong>Herança:</strong></li><li><strong><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object\"><code>Object</code></a></strong></li><li><a href=\"#\"><strong>Propriedades</strong></a><ol><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/constructor\"><code>Object.prototype.constructor</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/proto\"><code>Object.prototype.__proto__</code></a></li></ol></li><li><a href=\"#\"><strong>Métodos</strong></a><ol><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineGetter__\"><code>Object.prototype.__defineGetter__()</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/__defineSetter__\"><code>Object.prototype.__defineSetter__()</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupGetter__\"><code>Object.prototype.__lookupGetter__()</code></a></li><li><svg class=\"icon icon-deprecated\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-deprecated\"></use>\n</svg><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/__lookupSetter__\"><code>Object.prototype.__lookupSetter__()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/hasOwnProperty\"><code>Object.prototype.hasOwnProperty()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/isPrototypeOf\"><code>Object.prototype.isPrototypeOf()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/propertyIsEnumerable\"><code>Object.prototype.propertyIsEnumerable()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/setPrototypeOf\"><code>Object.setPrototypeOf()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/toLocaleString\"><code>Object.prototype.toLocaleString()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/toString\"><code>Object.prototype.toString()</code></a></li><li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Object/valueOf\"><code>Object.prototype.valueOf()</code></a></li></ol></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>"}},{"type":"prose","value":{"id":"summary","title":"Sumário","isH3":false,"content":"<p>A função&nbsp;<code><strong>Math.max()</strong></code>&nbsp;retorna o maior de um ou mais números.</p>"}},{"type":"prose","value":{"id":"syntax","title":"Sintaxe","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><code>Math.max([<em>valor1</em>[,<em>valor2</em>, ...]]) </code></pre>"}},{"type":"prose","value":{"id":"parameters","title":"Parâmetros","isH3":true,"content":"<dl>\n <dt id=\"valor1_valor2_\"><code>valor1, valor2, ...</code></dt>\n <dd>Números.</dd>\n</dl>"}},{"type":"prose","value":{"id":"valor_de_retorno","title":"Valor de retorno","isH3":true,"content":"<p>O maior dos números passados como argumentos. Se pelo menos um dos argumentos não puder ser convertido para um número&nbsp;<a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/NaN\"><code>NaN</code></a> é retornado.</p>"}},{"type":"prose","value":{"id":"description","title":"Descrição","isH3":false,"content":"<p>Por&nbsp;<code>max</code> ser um método estático em&nbsp;<code>Math</code>, você sempre irá usá-lo da seguinte maneira&nbsp;<code>Math.max()</code>, e não como um método da classe&nbsp;<code>Math</code>&nbsp;que você tenha instanciado.</p>\n\n<p>Se nenhum argumento for passado o resultado sempre será - <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Infinity\"><code>Infinity</code></a>.</p>\n\n<p>Se um dos argumentos não puder ser convertido em um número, o resultado será <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/NaN\"><code>NaN</code></a>.</p>"}},{"type":"prose","value":{"id":"examples","title":"Exemplos","isH3":false,"content":""}},{"type":"prose","value":{"id":"example_using_math.max","title":"Usando&nbsp;<code>Math.max</code>","isH3":true,"content":"<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code>Math<span class=\"token punctuation\">.</span><span class=\"token function\">max</span><span class=\"token punctuation\">(</span><span class=\"token number\">10</span><span class=\"token punctuation\">,</span> <span class=\"token number\">20</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>   <span class=\"token comment\">//  20</span>\nMath<span class=\"token punctuation\">.</span><span class=\"token function\">max</span><span class=\"token punctuation\">(</span><span class=\"token operator\">-</span><span class=\"token number\">10</span><span class=\"token punctuation\">,</span> <span class=\"token operator\">-</span><span class=\"token number\">20</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span> <span class=\"token comment\">// -10</span>\nMath<span class=\"token punctuation\">.</span><span class=\"token function\">max</span><span class=\"token punctuation\">(</span><span class=\"token operator\">-</span><span class=\"token number\">10</span><span class=\"token punctuation\">,</span> <span class=\"token number\">20</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>  <span class=\"token comment\">//  20</span>\n</code></pre></div>","titleAsText":"Usando Math.max"}},{"type":"prose","value":{"id":"retornando_o_maior_elemento_de_um_array","title":"Retornando o maior elemento de um array","isH3":true,"content":"<p><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Array/Reduce\"><code>Array.reduce()</code></a> pode ser usada para encontrar o maior elemento em um vetor numérico, comparando cada valor:</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> arr <span class=\"token operator\">=</span> <span class=\"token punctuation\">[</span><span class=\"token number\">1</span><span class=\"token punctuation\">,</span> <span class=\"token number\">2</span><span class=\"token punctuation\">,</span> <span class=\"token number\">3</span><span class=\"token punctuation\">]</span><span class=\"token punctuation\">;</span>\n<span class=\"token keyword\">var</span> max <span class=\"token operator\">=</span> arr<span class=\"token punctuation\">.</span><span class=\"token function\">reduce</span><span class=\"token punctuation\">(</span><span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">a<span class=\"token punctuation\">,</span> b</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n  <span class=\"token keyword\">return</span> Math<span class=\"token punctuation\">.</span><span class=\"token function\">max</span><span class=\"token punctuation\">(</span>a<span class=\"token punctuation\">,</span> b<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token punctuation\">}</span><span class=\"token punctuation\">,</span> <span class=\"token operator\">-</span><span class=\"token number\">Infinity</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span></code></pre></div>\n\n<p>A função a seguir utiliza <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Function/apply\"><code>Function.prototype.apply()</code></a> para&nbsp;encontrar o elemento de maior valor dentro do array. <code>getMaxOfArray([1,2,3])</code>&nbsp;é equivalente a&nbsp;<code>Math.max(1, 2, 3)</code>, mas você pode usar <code>getMaxOfArray</code>&nbsp; em arrays construídos programaticamente e o ideal é utilizá-la somente em arrays com relativamente poucos elementos.</p>\n\n<div class=\"code-example\"><pre class=\"brush:js notranslate\"><code><span class=\"token keyword\">function</span> <span class=\"token function\">getMaxOfArray</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">numArray</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n    <span class=\"token keyword\">return</span> Math<span class=\"token punctuation\">.</span><span class=\"token function\">max</span><span class=\"token punctuation\">.</span><span class=\"token function\">apply</span><span class=\"token punctuation\">(</span><span class=\"token keyword\">null</span><span class=\"token punctuation\">,</span> numArray<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token punctuation\">}</span></code></pre></div>\n\n<p>O novo <a href=\"/en-US/docs/Web/JavaScript/Reference/Operators/Spread_syntax\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">operador spread (en-US)</a> é um modo curto de se escrever a solução com&nbsp;<code>apply</code> para retornar o maior valor de um array.</p>\n\n<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> arr <span class=\"token operator\">=</span> <span class=\"token punctuation\">[</span><span class=\"token number\">1</span><span class=\"token punctuation\">,</span> <span class=\"token number\">2</span><span class=\"token punctuation\">,</span> <span class=\"token number\">3</span><span class=\"token punctuation\">]</span><span class=\"token punctuation\">;</span>\n<span class=\"token keyword\">var</span> max <span class=\"token operator\">=</span> Math<span class=\"token punctuation\">.</span><span class=\"token function\">max</span><span class=\"token punctuation\">(</span><span class=\"token operator\">...</span>arr<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n<span class=\"token comment\">// max: 3</span></code></pre></div>\n\n<p>Entretanto, tanto&nbsp;spread(<code>...</code>) quanto <code>apply</code> irão ou falhar ou retornar o resultado errado caso o array tenha muitos elementos, porque eles tentam passar o array de elementos como parâmetros de funções. Veja <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Function/apply#usando_apply_e_funções_embutidas\">usando apply e funções embutidas</a> para mais detalhes. A solução com <code>reduce</code> não apresenta esse problema.</p>"}},{"type":"prose","value":{"id":"especificações","title":"Especificações","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Especificação</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Comentário</th>\n  </tr>\n  <tr>\n   <td>ECMAScript 1st Edition. Implemented in JavaScript 1.0</td>\n   <td>Standard</td>\n   <td>Initial definition.</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.ecma-international.org/ecma-262/6.0/#sec-15.8.2.11\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript 2015 (6th Edition, ECMA-262)<br><small lang=\"pt-BR\">The definition of 'Math.max' in that specification.</small></a></td>\n   <td><span class=\"spec-standard\">Padrão</span></td>\n   <td>&nbsp;</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.ecma-international.org/ecma-262/6.0/#sec-math.max\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">ECMAScript 2015 (6th Edition, ECMA-262)<br><small lang=\"pt-BR\">The definition of 'Math.max' in that specification.</small></a></td>\n   <td><span class=\"spec-standard\">Padrão</span></td>\n   <td>&nbsp;</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"browser_compatibility","title":"Compatibilidade com navegadores","isH3":false,"content":"<p></p><div class=\"notecard note\" id=\"sect2\"><strong><a href=\"https://github.com/mdn/browser-compat-data\" class=\"external\" rel=\" noopener\">Estamos convertendo nossos dados de compatibilidade para o formato JSON</a></strong>.\n            Esta tabela de compatibilidade ainda usa o formato antigo,\n            pois ainda não convertemos os dados que ela contém.\n            <strong><a href=\"/en-US/docs/MDN/Structures/Compatibility_tables\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">Descubra como você pode ajudar! (en-US)</a></strong></div>\n\n<div class=\"htab\" id=\"sect3\">\n    <a id=\"AutoCompatibilityTable\" name=\"AutoCompatibilityTable\"></a>\n    <ul>\n        <li class=\"selected\"><a href=\"#compat-desktop\">Desktop</a></li>\n        <li><a href=\"#compat-mobile\">Dispositivo móvel</a></li>\n    </ul>\n</div><p></p>\n\n<div id=\"compat-desktop\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Chrome</th>\n   <th>Firefox (Gecko)</th>\n   <th>Internet Explorer</th>\n   <th>Opera</th>\n   <th>Safari</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<div id=\"compat-mobile\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Android</th>\n   <th>Chrome for Android</th>\n   <th>Firefox Mobile (Gecko)</th>\n   <th>IE Mobile</th>\n   <th>Opera Mobile</th>\n   <th>Safari Mobile</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n  </tr>\n </tbody>\n</table>\n</div>"}},{"type":"prose","value":{"id":"see_also","title":"Veja também","isH3":false,"content":"<ul>\n <li>O objeto <a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math\"><code>Math</code></a> pertence a.</li>\n <li><a href=\"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math/min\"><code>Math.min()</code></a></li>\n</ul>"}}],"toc":[{"text":"Sumário","id":"summary"},{"text":"Sintaxe","id":"syntax"},{"text":"Descrição","id":"description"},{"text":"Exemplos","id":"examples"},{"text":"Especificações","id":"especificações"},{"text":"Compatibilidade com navegadores","id":"browser_compatibility"},{"text":"Veja também","id":"see_also"}],"summary":"A função Math.max() retorna o maior de um ou mais números.","popularity":0.0021,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Math.max()","locale":"de","native":"Deutsch"},{"title":"Math.max()","locale":"en-US","native":"English (US)"},{"title":"Math.max()","locale":"es","native":"Español"},{"title":"Math.max()","locale":"fr","native":"Français"},{"title":"Math.max()","locale":"ja","native":"日本語"},{"title":"Math.max()","locale":"ko","native":"한국어"},{"title":"Math.max()","locale":"pl","native":"Polski"},{"title":"Math.max()","locale":"ru","native":"Русский"},{"title":"Math.max()","locale":"zh-CN","native":"中文 (简体)"},{"title":"Math.max()","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"pt-br/web/javascript/reference/global_objects/math/max","github_url":"https://github.com/mdn/translated-content/blob/main/files/pt-br/web/javascript/reference/global_objects/math/max/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pt-BR/docs/Web","title":"Tecnologia Web para desenvolvedores"},{"uri":"/pt-BR/docs/Web/JavaScript","title":"JavaScript"},{"uri":"/pt-BR/docs/Web/JavaScript/Reference","title":"Referência JavaScript"},{"uri":"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects","title":"Objetos Globais"},{"uri":"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math","title":"Math"},{"uri":"/pt-BR/docs/Web/JavaScript/Reference/Global_Objects/Math/max","title":"Math.max()"}],"pageTitle":"Math.max() - JavaScript | MDN","noIndexing":false}}