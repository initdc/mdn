US/docs/Mozilla/Firefox/Releases/11\" title=\"Released on 2012-03-13.\">11.0</a> (11.0)</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n  <tr>\n   <td>Propriedade <code>played</code></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><a href=\"/en-US/docs/Mozilla/Firefox/Releases/15\" title=\"Released on 2012-08-28.\">15.0</a> (15.0)</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n  <tr>\n   <td>Atributo<code> preload</code></td>\n   <td>3.0</td>\n   <td><a href=\"/en-US/docs/Mozilla/Firefox/Releases/4\" title=\"Released on 2011-03-22.\">4.0</a> (2.0)</td>\n   <td>9.0</td>\n   <td>Supported under the older name <code>autobuffer</code></td>\n   <td>3.1</td>\n  </tr>\n  <tr>\n   <td>Atributo <code>src</code></td>\n   <td>3.0</td>\n   <td><a href=\"/en-US/docs/Mozilla/Firefox/Releases/3.5\" title=\"Released on 2009-06-30.\">3.5</a> (1.9.1)</td>\n   <td>9.0</td>\n   <td>10.5</td>\n   <td>3.1</td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<div id=\"compat-mobile\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Recurso</th>\n   <th>Android</th>\n   <th>Firefox Mobile (Gecko)</th>\n   <th>IE Mobile</th>\n   <th>Opera Mobile</th>\n   <th>Safari Mobile</th>\n  </tr>\n  <tr>\n   <td>Suporte Básico</td>\n   <td><span title=\"Compatibility unknown; please update this.\" st