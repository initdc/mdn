t-BR/docs/Web/HTML/Element/time\"><code>&lt;time&gt;</code></a></li>\n  <li><a href=\"/pt-BR/docs/Web/HTML/Element/title\"><code>&lt;title&gt;</code></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/tr\"><code>&lt;tr&gt;</code> <small>(en-US)</small></a></li>\n  <li class=\"html5\"><a href=\"/pt-BR/docs/Web/HTML/Element/track\"><code>&lt;track&gt;</code></a></li>\n  <li><s class=\"obsoleteElement\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/tt\"><code>&lt;tt&gt;</code> <small>(en-US)</small></a></s></li>\n </ol>\n </li><li>U\n <ol>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/u\"><code>&lt;u&gt;</code> <small>(en-US)</small></a></li>\n  <li><a href=\"/pt-BR/docs/Web/HTML/Element/ul\"><code>&lt;ul&gt;</code></a></li>\n </ol>\n </li><li>V\n <ol>\n  <li><a href=\"/pt-BR/docs/Web/HTML/Element/var\"><code>&lt;var&gt;</code></a></li>\n  <li class=\"html5\"><a href=\"/pt-BR/docs/Web/HTML/Element/Video\"><code>&lt;video&gt;</code></a></li>\n </ol>\n </li><li>W\n <ol>\n  <li class=\"html5\"><a href=\"/pt-BR/docs/Web/HTML/Element/wbr\"><code>&lt;wbr&gt;</code></a></li>\n </ol>\n </li><li>X Y Z\n <ol>\n  <li><s class=\"obsoleteElement\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/xmp\"><code>&lt;xmp&gt;</code> <small>(en-US)</small></a></s></li>\n </ol>\n    </li>\n   </ol>\n   </details></li>\n   </ol>\n  ","body":[{"type":"prose","value":{"id":"sumário","title":"Sumário","isH3":false,"content":"<p><span id=\"result_box\" lang=\"pt\"><span class=\"hps\">O</span>&nbsp;Elemento&nbsp;<span class=\"hps\">HTML</span> <span class=\"hps\">&lt;blockquote</span><span class=\"atn\">&gt; (</span><span>ou</span>&nbsp;Elemento <span class=\"hps\">HTML&nbsp;</span></span><span lang=\"pt\">de citação de bloco<span>) indica que o</span> <span class=\"hps\">texto incluído</span> <span class=\"hps\">é uma</span> <span class=\"hps\">longa citação</span><span>.</span> <span class=\"hps\">Normalmente</span><span>, este</span> <span class=\"hps\">é processado</span> <span class=\"hps\">visualmente</span> <span class=\"hps\">pelo</span> <span class=\"hps\">recuo</span> <span class=\"hps\">(ver <a href=\"/en-US/docs/HTML/Element/blockquote#Notes\">Notas</a></span> <span class=\"hps\">sobre como</span> <span class=\"hps\">mudá-lo</span><span>)</span><span>.</span> <span class=\"hps\">A</span> <span class=\"hps\">URL</span> <span class=\"hps\">para a</span> <span class=\"hps\">fonte da citação</span> <span class=\"hps\">pode ser dada</span>&nbsp;<span class=\"hps\">usando o atributo</span> <strong><span class=\"hps\">cite</span></strong><span>,</span> <span class=\"hps\">enquanto</span> <span class=\"hps\">uma representação de texto</span> <span class=\"hps\">da fonte</span> <span class=\"hps\">pode ser dada</span>&nbsp;<span class=\"hps\">usando o</span> </span><a href=\"/pt-BR/docs/Web/HTML/Element/cite\"><code>&lt;cite&gt;</code></a><span lang=\"pt\">&nbsp;<span class=\"hps\">elemento.</span></span></p>\n\n<ul class=\"htmlelt\">\n <li>&nbsp;</li>\n <li><dfn><a href=\"/en-US/docs/HTML/Content_categories\" title=\"HTML/Content_categories\">Categorias de conteúdo</a></dfn> <a href=\"/en-US/docs/HTML/Content_categories#Flow_content\" title=\"HTML/Content categories#Flow content\">Fluxo de conteúdo</a><span id=\"result_box\" lang=\"pt\"><span class=\"hps\">,</span> <span class=\"hps\">raiz</span> <span class=\"hps\">selecionamento</span><span>,</span> <span class=\"hps\">conteúdo</span> <span class=\"hps\">palpável.</span></span></li>\n <li><dfn>Conteúdo permitido</dfn> <a href=\"/en-US/docs/HTML/Content_categories#Flow_content\" title=\"HTML/Content_categories#Phrasing_content\">Fluxo de conteúdo</a>.</li>\n <li><dfn>Tag Omissão</dfn> None, both the starting and ending tag are mandatory.</li>\n <li><dfn>Elementos permitidos</dfn>\n  <div id=\"gt-src-tools\">\n  <div id=\"tts_button\"><span class=\"short_text\" id=\"result_box\" lang=\"pt\"><span class=\"hps\">Qualquer elemento</span> <span class=\"hps\">que aceita</span> <span class=\"hps\">o <a href=\"/en-US/docs/HTML/Content_categories#Flow_content\">fluxo de conteúdo.</a></span></span></div>\n  </div>\n </li>\n <li><dfn>Papéis ARIA permitidos</dfn>Qualquer</li>\n <li><dfn>Interface DOM</dfn> <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/HTMLQuoteElement\"><code>HTMLQuoteElement</code> <small>(en-US)</small></a></li>\n</ul>"}},{"type":"prose","value":{"id":"atributos","title":"Atributos","isH3":false,"content":"<p><span style=\"line-height: 21px;\">Este elemento inclui os <a href=\"/en-US/docs/HTML/Global_attributes\">atributos globais</a>.</span></p>\n\n<dl>\n <dt id=\"cite\"><a id=\"attr-cite\" href=\"#attr-cite\"><b><code>cite</code></b></a></dt>\n <dd><span id=\"result_box\" lang=\"pt\"><span class=\"hps\">Uma URL</span> <span class=\"hps\">que designa</span> <span class=\"hps\">um documento de origem</span> <span class=\"hps\">ou mensagem para</span> <span class=\"hps\">a informação</span> <span class=\"hps\">citada</span><span>.</span> <span class=\"hps\">Este atributo</span> <span class=\"hps\">destina-se a</span> <span class=\"hps\">apontar para</span> <span class=\"hps\">informações explicando</span> <span class=\"hps\">o contexto ou</span> <span class=\"hps\">a referência para a</span> <span class=\"hps\">cotação.</span></span></dd>\n</dl>"}},{"type":"prose","value":{"id":"notas","title":"Notas","isH3":false,"content":"<dl>\n <dd>\n <p>Para alterar o recuo de&nbsp;<code>&lt;blockquote&gt;</code>, use a propriedade&nbsp;<a href=\"/en-US/docs/CSS\">CSS</a>&nbsp;<a href=\"/pt-BR/docs/Web/CSS/margin\"><code>margin</code></a>.</p>\n\n <p>Para citações curtas, use o elemento <a href=\"/pt-BR/docs/Web/HTML/Element/q\"><code>&lt;q&gt;</code></a>.</p>\n </dd>\n</dl>"}},{"type":"prose","value":{"id":"exemplo","title":"Exemplo","isH3":false,"content":"<div class=\"code-example\"><pre class=\"brush: html  language-html notranslate\"><code><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>blockquote</span> <span class=\"token attr-name\">cite</span><span class=\"token attr-value\"><span class=\"token punctuation attr-equals\">=</span><span class=\"token punctuation\">\"</span>http://developer.mozilla.org<span class=\"token punctuation\">\"</span></span><span class=\"token punctuation\">&gt;</span></span>\n  <span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>p</span><span class=\"token punctuation\">&gt;</span></span>Esta é uma citação tirada da\n  Mozilla Developer Center.<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>p</span><span class=\"token punctuation\">&gt;</span></span>\n<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>blockquote</span><span class=\"token punctuation\">&gt;</span></span></code></pre></div>\n\n<p><span id=\"result_box\" lang=\"pt\"><span class=\"hps\">O código HTML acima vai resultar em:</span></span></p>\n\n<blockquote cite=\"http://developer.mozilla.org\">\n<p><span id=\"result_box\" lang=\"pt\"><span class=\"hps\">Esta&nbsp;é uma</span> <span class=\"hps\">citação</span> <span class=\"hps\">tirada</span> <span class=\"hps\">da</span> <span class=\"hps\">Mozilla Developer Center</span><span>.</span></span></p>\n</blockquote>"}},{"type":"prose","value":{"id":"specifications","title":"Especificação","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">Especificação</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Comentário</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"https://html.spec.whatwg.org/multipage/semantics.html#the-blockquote-element\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML Living Standard<br><small lang=\"pt-BR\">The definition of '&lt;blockquote&gt;' in that specification.</small></a></td>\n   <td><span class=\"spec-living\">Padrão em tempo real</span></td>\n   <td>&nbsp;</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.w3.org/TR/html52/grouping-content.html#the-blockquote-element\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML5<br><small lang=\"pt-BR\">The definition of '&lt;blockquote&gt;' in that specification.</small></a></td>\n   <td><span class=\"spec-rec\">Recomendação</span></td>\n   <td>&nbsp;</td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.w3.org/TR/html401/struct/text.html#h-9.2.2\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML 4.01 Specification<br><small lang=\"pt-BR\">The definition of '&lt;blockquote&gt;' in that specification.</small></a></td>\n   <td><span class=\"spec-rec\">Recomendação</span></td>\n   <td>&nbsp;</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"browser_compatibility","title":"Compatibilidade com navegadores","isH3":false,"content":"<p></p><div class=\"notecard note\" id=\"sect1\"><strong><a href=\"https://github.com/mdn/browser-compat-data\" class=\"external\" rel=\" noopener\">Estamos convertendo nossos dados de compatibilidade para o formato JSON</a></strong>.\n            Esta tabela de compatibilidade ainda usa o formato antigo,\n            pois ainda não convertemos os dados que ela contém.\n            <strong><a href=\"/en-US/docs/MDN/Structures/Compatibility_tables\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">Descubra como você pode ajudar! (en-US)</a></strong></div>\n\n<div class=\"htab\" id=\"sect2\">\n    <a id=\"AutoCompatibilityTable\" name=\"AutoCompatibilityTable\"></a>\n    <ul>\n        <li class=\"selected\"><a href=\"#compat-desktop\">Desktop</a></li>\n        <li><a href=\"#compat-mobile\">Dispositivo móvel</a></li>\n    </ul>\n</div><p></p>\n\n<div id=\"compat-desktop\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Recurso</th>\n   <th>Chrome</th>\n   <th>Firefox (Gecko)</th>\n   <th>Internet Explorer</th>\n   <th>Opera</th>\n   <th>Safari</th>\n  </tr>\n  <tr>\n   <td>Suporte básico</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td>1.0 (1.7 or earlier)</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<div id=\"compat-mobile\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Recurso</th>\n   <th>Android</th>\n   <th>Firefox Mobile (Gecko)</th>\n   <th>IE Mobile</th>\n   <th>Opera Mobile</th>\n   <th>Safari Mobile</th>\n  </tr>\n  <tr>\n   <td>Suporte básico</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td>1.0 (1.0)</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n  </tr>\n </tbody>\n</table>\n</div>"}},{"type":"prose","value":{"id":"sect1","title":"&nbsp;","isH3":false,"content":"","titleAsText":" "}},{"type":"prose","value":{"id":"veja_também","title":"Veja também","isH3":false,"content":"<ul>\n <li><span id=\"result_box\" lang=\"pt\"><span class=\"hps\">O elemento</span> <a href=\"/pt-BR/docs/Web/HTML/Element/q\"><code>&lt;q&gt;</code></a> <span class=\"hps\">para</span> <span class=\"hps\">citações em linha</span><span>.</span></span></li>\n <li><span lang=\"pt\"><span class=\"hps\">O elemento</span> </span><span id=\"result_box\" lang=\"pt\"><a href=\"/pt-BR/docs/Web/HTML/Element/q\"><code>&lt;q&gt;</code></a></span><span lang=\"pt\"> <span class=\"hps\">para citações</span> <span class=\"hps\">de origem.</span></span></li>\n</ul>\n\n<p></p><p></p>"}}],"toc":[{"text":"Sumário","id":"sumário"},{"text":"Atributos","id":"atributos"},{"text":"Notas","id":"notas"},{"text":"Exemplo","id":"exemplo"},{"text":"Especificação","id":"specifications"},{"text":"Compatibilidade com navegadores","id":"browser_compatibility"},{"text":"&nbsp;","id":"sect1"},{"text":"Veja também","id":"veja_também"}],"summary":"O Elemento HTML <blockquote> (ou Elemento HTML de citação de bloco) indica que o texto incluído é uma longa citação. Normalmente, este é processado visualmente pelo recuo (ver Notas sobre como mudá-lo). A URL para a fonte da citação pode ser dada usando o atributo cite, enquanto uma representação de texto da fonte pode ser dada usando o <cite> elemento.","popularity":0.0007,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"<blockquote>","locale":"de","native":"Deutsch"},{"title":"<blockquote>: The Block Quotation element","locale":"en-US","native":"English (US)"},{"title":"blockquote","locale":"es","native":"Español"},{"title":"<blockquote> : l'élément de bloc de citation","locale":"fr","native":"Français"},{"title":"<blockquote>: ブロック引用要素","locale":"ja","native":"日本語"},{"title":"<blockquote>: 인용 블록 요소","locale":"ko","native":"한국어"},{"title":"blockquote","locale":"pl","native":"Polski"},{"title":"<blockquote>","locale":"ru","native":"Русский"},{"title":"<blockquote>：块级引用元素","locale":"zh-CN","native":"中文 (简体)"},{"title":"<blockquote>","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"pt-br/web/html/element/blockquote","github_url":"https://github.com/mdn/translated-content/blob/main/files/pt-br/web/html/element/blockquote/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pt-BR/docs/Web","title":"Tecnologia Web para desenvolvedores"},{"uri":"/pt-BR/docs/Web/HTML","title":"HTML: Linguagem de Marcação de Hipertexto"},{"uri":"/pt-BR/docs/Web/HTML/Element","title":"Elementos HTML"},{"uri":"/pt-BR/docs/Web/HTML/Element/blockquote","title":"<blockquote>"}],"pageTitle":"<blockquote> - HTML: Linguagem de Marcação de Hipertexto | MDN","noIndexing":false}}