HTML/Element/time\"><code>&lt;time&gt;</code></a></li>\n  <li><a href=\"/pt-BR/docs/Web/HTML/Element/title\"><code>&lt;title&gt;</code></a></li>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/tr\"><code>&lt;tr&gt;</code> <small>(en-US)</small></a></li>\n  <li class=\"html5\"><a href=\"/pt-BR/docs/Web/HTML/Element/track\"><code>&lt;track&gt;</code></a></li>\n  <li><s class=\"obsoleteElement\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/tt\"><code>&lt;tt&gt;</code> <small>(en-US)</small></a></s></li>\n </ol>\n </li><li>U\n <ol>\n  <li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/u\"><code>&lt;u&gt;</code> <small>(en-US)</small></a></li>\n  <li><a href=\"/pt-BR/docs/Web/HTML/Element/ul\"><code>&lt;ul&gt;</code></a></li>\n </ol>\n </li><li>V\n <ol>\n  <li><a href=\"/pt-BR/docs/Web/HTML/Element/var\"><code>&lt;var&gt;</code></a></li>\n  <li class=\"html5\"><a href=\"/pt-BR/docs/Web/HTML/Element/Video\"><code>&lt;video&gt;</code></a></li>\n </ol>\n </li><li>W\n <ol>\n  <li class=\"html5\"><a href=\"/pt-BR/docs/Web/HTML/Element/wbr\"><code>&lt;wbr&gt;</code></a></li>\n </ol>\n </li><li>X Y Z\n <ol>\n  <li><s class=\"obsoleteElement\"><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/HTML/Element/xmp\"><code>&lt;xmp&gt;</code> <small>(en-US)</small></a></s></li>\n </ol>\n    </li>\n   </ol>\n   </details></li>\n   </ol>\n  ","body":[{"type":"prose","value":{"id":"resumo","title":"Resumo","isH3":false,"content":"<p><em>HTML texto preformatado</em>&nbsp;(<strong>&lt;pre&gt;</strong>) é a tag utilizada para&nbsp;representar texto pré-formatado.&nbsp;Um texto dentro desse elemento é tipicamente exibido&nbsp;em uma fonte não proporcional da mesma maneira em que o texto original foi disposto no arquivo. Espaços em branco&nbsp;são mantidos no texto da mesma forma em que este foi digitado.&nbsp;&nbsp;</p>\n\n<p><dfn><a href=\"/en-US/docs/Web/Guide/HTML/Content_categories\" title=\"HTML/Content_categories\">Content categories</a></dfn> <a href=\"/en-US/docs/Web/Guide/HTML/Content_categories#flow_content\" title=\"HTML/Content_categories#Phrasing_content\">Flow content</a>, palpable content.</p>\n\n<ul class=\"htmlelt\">\n <li><dfn>Conteúdo permitido</dfn> <a href=\"/en-US/docs/Web/Guide/HTML/Content_categories#phrasing_content\" title=\"/en-US/docs/HTML/Content_categories#Phrasing_content\">Phrasing content</a>.</li>\n <li><dfn>Tag omission</dfn> None, both the starting and ending tag are mandatory.</li>\n <li><dfn>Elementos pai permitidos</dfn> Any element that accepts <a href=\"/en-US/docs/Web/Guide/HTML/Content_categories#flow_content\" title=\"HTML/Content categories#flow content\">flow content</a>.</li>\n <li><dfn>interface DOM</dfn> <a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/HTMLPreElement\"><code>HTMLPreElement</code> <small>(en-US)</small></a></li>\n</ul>"}},{"type":"prose","value":{"id":"atributos","title":"Atributos","isH3":false,"content":"<p>Esse elemento apenas inclui atributos globais.</p>\n\n<p>This element only includes the&nbsp;<a href=\"/en-US/docs/HTML/Global_attributes\" title=\"HTML/Global attributes\">global attributes</a>.</p>\n\n<dl>\n <dt id=\"cols\"><a id=\"attr-cols\" href=\"#attr-cols\"><b><code>cols</code></b></a> <svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><svg class=\"icon obsolete\" viewBox=\"0 0 100 100\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\">\n    <title>This is an obsolete API and is no longer guaranteed to work.</title>\n    <path d=\"M38.75 78.13V36.88A1.85 1.85 0 0036.88 35h-3.75a1.85 1.85 0 00-1.88 1.88v41.25A1.85 1.85 0 0033.13 80h3.75a1.85 1.85 0 001.87-1.87zm15 0V36.88A1.85 1.85 0 0051.88 35h-3.75a1.85 1.85 0 00-1.88 1.88v41.25A1.85 1.85 0 0048.13 80h3.75a1.85 1.85 0 001.87-1.87zm15 0V36.88A1.85 1.85 0 0066.88 35h-3.75a1.85 1.85 0 00-1.88 1.88v41.25A1.85 1.85 0 0063.13 80h3.75a1.85 1.85 0 001.87-1.87zM36.88 20h26.25l-2.82-6.85a2.35 2.35 0 00-1-.65H40.74a2 2 0 00-1 .65zm54.37 1.88v3.75a1.85 1.85 0 01-1.87 1.87h-5.63v55.55c0 6.44-4.22 12-9.37 12H25.63c-5.16 0-9.38-5.27-9.38-11.72V27.5h-5.62a1.85 1.85 0 01-1.88-1.83v-3.8A1.85 1.85 0 0110.63 20h18.1l4.1-9.78A9.12 9.12 0 0140.63 5h18.75a9.1 9.1 0 017.79 5.22l4.1 9.78h18.11a1.85 1.85 0 011.87 1.87z\"></path>\n</svg></dt>\n <dd>Contains the <em>preferred</em> count of characters that a line should have. It was a non-standard synonym of <a href=\"/pt-BR/docs/Web/HTML/Element/pre#attr-width\" aria-current=\"page\"><code>width</code></a>. To achieve such an effect, use CSS styling instead.</dd>\n <dt id=\"width\"><a id=\"attr-width\" href=\"#attr-width\"><b><code>width</code></b></a> <svg class=\"icon obsolete\" viewBox=\"0 0 100 100\" xmlns=\"http://www.w3.org/2000/svg\" role=\"img\">\n    <title>This is an obsolete API and is no longer guaranteed to work.</title>\n    <path d=\"M38.75 78.13V36.88A1.85 1.85 0 0036.88 35h-3.75a1.85 1.85 0 00-1.88 1.88v41.25A1.85 1.85 0 0033.13 80h3.75a1.85 1.85 0 001.87-1.87zm15 0V36.88A1.85 1.85 0 0051.88 35h-3.75a1.85 1.85 0 00-1.88 1.88v41.25A1.85 1.85 0 0048.13 80h3.75a1.85 1.85 0 001.87-1.87zm15 0V36.88A1.85 1.85 0 0066.88 35h-3.75a1.85 1.85 0 00-1.88 1.88v41.25A1.85 1.85 0 0063.13 80h3.75a1.85 1.85 0 001.87-1.87zM36.88 20h26.25l-2.82-6.85a2.35 2.35 0 00-1-.65H40.74a2 2 0 00-1 .65zm54.37 1.88v3.75a1.85 1.85 0 01-1.87 1.87h-5.63v55.55c0 6.44-4.22 12-9.37 12H25.63c-5.16 0-9.38-5.27-9.38-11.72V27.5h-5.62a1.85 1.85 0 01-1.88-1.83v-3.8A1.85 1.85 0 0110.63 20h18.1l4.1-9.78A9.12 9.12 0 0140.63 5h18.75a9.1 9.1 0 017.79 5.22l4.1 9.78h18.11a1.85 1.85 0 011.87 1.87z\"></path>\n</svg></dt>\n <dd>Contains the <em>preferred</em> count of characters that a line should have. Though technically still implemented, this attribute has no visual effect; to achieve such an effect, use CSS styling instead.</dd>\n <dt id=\"wrap\"><a id=\"attr-wrap\" href=\"#attr-wrap\"><b><code>wrap</code></b></a> <svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg></dt>\n <dd>Is a <em>hint</em> indicating how the overflow must happen. In modern browser this hint is ignored and no visual effect results in its present; to achieve such an effect, use CSS styling instead.</dd>\n</dl>"}},{"type":"prose","value":{"id":"exemplos","title":"Exemplos","isH3":false,"content":"<div class=\"code-example\"><pre class=\"brush: html notranslate\"><code><span class=\"token comment\">&lt;!-- Um exemplo de código css --&gt;</span>\n<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>pre</span><span class=\"token punctuation\">&gt;</span></span>\nbody {\n  color:red;\n}\n<span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>pre</span><span class=\"token punctuation\">&gt;</span></span>\n</code></pre></div>"}},{"type":"prose","value":{"id":"resultado","title":"Resultado","isH3":true,"content":"<pre class=\"notranslate\">body {\n  color:red;\n}\n</pre>"}},{"type":"prose","value":{"id":"specifications","title":"Especificações","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">Especificação</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Comentário</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><a href=\"https://html.spec.whatwg.org/multipage/grouping-content.html#the-pre-element\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML Living Standard<br><small lang=\"pt-BR\">The definition of '&lt;pre&gt;' in that specification.</small></a></td>\n   <td><span class=\"spec-living\">Padrão em tempo real</span></td>\n   <td>Nenhuma mudança significante na <a href=\"https://html.spec.whatwg.org/multipage/\" hreflang=\"en\" lang=\"en\" class=\"external\" title=\"The 'HTML Living Standard' specification\" rel=\" noopener\">HTML Living Standard</a></td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.w3.org/TR/html52/grouping-content.html#the-pre-element\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML5<br><small lang=\"pt-BR\">The definition of '&lt;pre&gt;' in that specification.</small></a></td>\n   <td><span class=\"spec-rec\">Recomendação</span></td>\n   <td>Nenhuma mudança significante na <a href=\"https://www.w3.org/TR/html401/\" hreflang=\"en\" lang=\"en\" class=\"external\" title=\"The 'HTML 4.01 Specification' specification\" rel=\" noopener\">HTML 4.01 Specification</a></td>\n  </tr>\n  <tr>\n   <td><a href=\"https://www.w3.org/TR/html401/struct/text.html#h-9.3.4\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">HTML 4.01 Specification<br><small lang=\"pt-BR\">The definition of '&lt;dl&gt;' in that specification.</small></a></td>\n   <td><span class=\"spec-rec\">Recomendação</span></td>\n   <td><code>Atributto cols</code>&nbsp;obsoleto</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"browser_compatibility","title":"Compatibilidade de navegador","isH3":false,"content":"<p></p><div class=\"notecard note\" id=\"sect1\"><strong><a href=\"https://github.com/mdn/browser-compat-data\" class=\"external\" rel=\" noopener\">Estamos convertendo nossos dados de compatibilidade para o formato JSON</a></strong>.\n            Esta tabela de compatibilidade ainda usa o formato antigo,\n            pois ainda não convertemos os dados que ela contém.\n            <strong><a href=\"/en-US/docs/MDN/Structures/Compatibility_tables\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">Descubra como você pode ajudar! (en-US)</a></strong></div>\n\n<div class=\"htab\" id=\"sect2\">\n    <a id=\"AutoCompatibilityTable\" name=\"AutoCompatibilityTable\"></a>\n    <ul>\n        <li class=\"selected\"><a href=\"#compat-desktop\">Desktop</a></li>\n        <li><a href=\"#compat-mobile\">Dispositivo móvel</a></li>\n    </ul>\n</div><p></p>\n\n<div id=\"compat-desktop\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Chrome</th>\n   <th>Firefox (Gecko)</th>\n   <th>Internet Explorer</th>\n   <th>Opera</th>\n   <th>Safari (WebKit)</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td>1.0</td>\n   <td>1.0 (1.7 or earlier)</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n  </tr>\n  <tr>\n   <td><code>width</code></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span><br>\n    No layout effect</td>\n   <td>1.0 (1.7 or earlier)<br>\n    Layout effect removed in <a href=\"/en-US/docs/Mozilla/Firefox/Releases/29\" title=\"Released on 2014-04-29.\">29.0</a> (29.0)</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span><br>\n    No layout effect</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span><br>\n    No layout effect</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span><br>\n    No layout effect</td>\n  </tr>\n  <tr>\n   <td><code>cols</code></td>\n   <td><span style=\"color:#f00;\">Não suportado</span></td>\n   <td>1.0 (1.7 or earlier)<br>\n    Removed in <a href=\"/en-US/docs/Mozilla/Firefox/Releases/29\" title=\"Released on 2014-04-29.\">29.0</a> (29.0)</td>\n   <td><span style=\"color:#f00;\">Não suportado</span></td>\n   <td><span style=\"color:#f00;\">Não suportado</span></td>\n   <td><span style=\"color:#f00;\">Não suportado</span></td>\n  </tr>\n  <tr>\n   <td><code>wrap</code></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td>1.0 (1.7 or earlier)</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<div id=\"compat-mobile\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Android</th>\n   <th>Firefox Mobile (Gecko)</th>\n   <th>IE Phone</th>\n   <th>Opera Mobile</th>\n   <th>Safari Mobile</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td>1.0 (1.0)</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n  </tr>\n  <tr>\n   <td><code>width</code></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td>1.0 (1.0)<br>\n    Layout effect removed in 29.0 (29.0)</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n  <tr>\n   <td><code>cols</code></td>\n   <td><span style=\"color:#f00;\">Não suportado</span></td>\n   <td>1.0 (1.0)</td>\n   <td><span style=\"color:#f00;\">Não suportado</span></td>\n   <td><span style=\"color:#f00;\">Não suportado</span></td>\n   <td><span style=\"color:#f00;\">Não suportado</span></td>\n  </tr>\n  <tr>\n   <td><code>wrap</code></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td>1.0 (1.0)</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n </tbody>\n</table>\n</div>"}},{"type":"prose","value":{"id":"veja_mais","title":"Veja mais","isH3":false,"content":"<ul>\n <li>CSS: <a href=\"/pt-BR/docs/Web/CSS/white-space\"><code>white-space</code></a>, <a href=\"/pt-BR/docs/Web/CSS/word-break\"><code>word-break</code></a></li>\n</ul>\n\n<div id=\"sect3\"></div>"}}],"toc":[{"text":"Resumo","id":"resumo"},{"text":"Atributos","id":"atributos"},{"text":"Exemplos","id":"exemplos"},{"text":"Especificações","id":"specifications"},{"text":"Compatibilidade de navegador","id":"browser_compatibility"},{"text":"Veja mais","id":"veja_mais"}],"summary":"HTML texto preformatado (<pre>) é a tag utilizada para representar texto pré-formatado. Um texto dentro desse elemento é tipicamente exibido em uma fonte não proporcional da mesma maneira em que o texto original foi disposto no arquivo. Espaços em branco são mantidos no texto da mesma forma em que este foi digitado.","popularity":0.0006,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"pre","locale":"de","native":"Deutsch"},{"title":"<pre>: The Preformatted Text element","locale":"en-US","native":"English (US)"},{"title":"<pre>","locale":"es","native":"Español"},{"title":"<pre> : l'élément de texte préformaté","locale":"fr","native":"Français"},{"title":"<pre>: 整形済みテキスト要素","locale":"ja","native":"日本語"},{"title":"<pre>","locale":"ko","native":"한국어"},{"title":"<pre>: Предварительно отформатированный текстовый элемент","locale":"ru","native":"Русский"},{"title":"<pre>","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"pt-br/web/html/element/pre","github_url":"https://github.com/mdn/translated-content/blob/main/files/pt-br/web/html/element/pre/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pt-BR/docs/Web","title":"Tecnologia Web para desenvolvedores"},{"uri":"/pt-BR/docs/Web/HTML","title":"HTML: Linguagem de Marcação de Hipertexto"},{"uri":"/pt-BR/docs/Web/HTML/Element","title":"Elementos HTML"},{"uri":"/pt-BR/docs/Web/HTML/Element/pre","title":"<pre>"}],"pageTitle":"<pre> - HTML: Linguagem de Marcação de Hipertexto | MDN","noIndexing":false}}