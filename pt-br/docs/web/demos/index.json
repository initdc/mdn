.github.io/kaiopua/\" class=\"external\" rel=\" noopener\">Kai 'Opua</a> (<a href=\"https://github.com/collinhover/kaiopua\" class=\"external\" rel=\" noopener\">source code</a>)</p>\n </li>\n <li>\n  <p><a href=\"https://github.com/gustavoSoriano/game-canvas\" class=\"external\" rel=\" noopener\">Game canvas (source code)</a></p>\n </li>\n</ul>"}},{"type":"prose","value":{"id":"html","title":"HTML","isH3":false,"content":"<ul>\n <li>\n  <p>&nbsp;<a href=\"https://zenphoton.com\" class=\"external\" rel=\" noopener\">Zen Photon Garden </a>(<a href=\"https://github.com/scanlime/zenphoton\" class=\"external\" rel=\" noopener\">source code</a>)</p>\n </li>\n</ul>"}},{"type":"prose","value":{"id":"api_da_web","title":"API da Web","isH3":false,"content":"<ul>\n</ul>"}},{"type":"prose","value":{"id":"api_de_notificações","title":"API de notificações","isH3":true,"content":"<ul>\n <li>\n  <p><a href=\"http://elfoxero.github.io/html5notifications/\" class=\"external\" rel=\" noopener\">HTML5 Notifications</a> (<a href=\"https://github.com/elfoxero/html5notifications\" class=\"external\" rel=\" noopener\">source code</a>)</p>\n </li>\n</ul>\n\n<ul>\n</ul>"}},{"type":"prose","value":{"id":"api_de_áudio_da_web","title":"API de áudio da Web","isH3":true,"content":"<ul>\n <li>\n  <p><a href=\"http://ondras.github.io/fireworks-webgl/\" class=\"external\" rel=\" noopener\">Web Audio Fireworks</a></p>\n </li>\n <li>\n  <p><a href=\"http://ondras.github.io/oscope/\" class=\"external\" rel=\" noopener\">oscope.js - JavaScript oscilloscope</a></p>\n </li>\n <li>\n  <p><a href=\"http://nipe-systems.de/webapps/html5-web-audio/\" class=\"external\" rel=\" noopener\">HTML5 Web Audio Showcase</a> (<a href=\"https://github.com/NIPE-SYSTEMS/html5-web-audio-showcase\" class=\"external\" rel=\" noopener\">source code</a>)</p>\n </li>\n <li>\n  <p><a href=\"http://wayou.github.io/HTML5_Audio_Visualizer/\" class=\"external\" rel=\" noopener\">HTML5 Audio Visualizer</a> (<a href=\"https://github.com/Wayou/HTML5_Audio_Visualizer\" class=\"external\" rel=\" noopener\">source code</a>)</p>\n </li>\n <li>\n  <p><a href=\"https://carlosrafaelgn.com.br/GraphicalFilterEditor/\" class=\"external\" rel=\" noopener\">Graphical Filter Editor and Visualizer</a>&nbsp;(<a href=\"https://github.com/carlosrafaelgn/GraphicalFilterEditor\" class=\"external\" rel=\" noopener\">source code</a>)</p>\n </li>\n</ul>"}},{"type":"prose","value":{"id":"api_de_arquivos","title":"API de arquivos","isH3":true,"content":"<ul>\n <li>\n  <p><a href=\"http://palerdot.github.io/slide-my-text/\" class=\"external\" rel=\" noopener\">Slide My Text - presentation from plain text files</a></p>\n </li>\n</ul>"}},{"type":"prose","value":{"id":"unclassified","title":"Trabalhadores da Web","isH3":true,"content":"<ul>\n <li>\n  <p><a href=\"http://ondras.github.io/fractal/\" class=\"external\" rel=\" noopener\">Web Worker Fractals</a></p>\n </li>\n <li>\n  <p><a href=\"http://ondras.github.io/photo/\" class=\"external\" rel=\" noopener\">Photo editor</a></p>\n </li>\n <li>\n  <p><a href=\"http://ondras.github.io/coral/\" class=\"external\" rel=\" noopener\">Coral generator</a></p>\n </li>\n <li>\n  <p><a href=\"https://nerget.com/rayjs-mt/rayjs.html\" class=\"external\" rel=\" noopener\">Raytracer</a></p>\n </li>\n <li>\n  <p><a href=\"http://palerdot.github.io/hotcold/\" class=\"external\" rel=\" noopener\">HotCold Touch Typing</a></p>\n </li>\n</ul>"}}],"toc":[{"text":"Gráficos 2D","id":"gráficos_2d"},{"text":"Gráficos 3D","id":"gráficos_3d"},{"text":"CSS","id":"css"},{"text":"jogos","id":"jogos"},{"text":"HTML","id":"html"},{"text":"API da Web","id":"api_da_web"}],"summary":"A mozilla suporta uma grande variedade de tecnologias abertas da web aberta e nós encorajamos seu uso.Esta página oferece links para demonstrações interessantes dessas tecnologia.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Demos für Open Web Technologie","locale":"de","native":"Deutsch