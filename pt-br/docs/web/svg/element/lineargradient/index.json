US)\">xlink:href (en-US)</a></code></li>\n</ul>"}},{"type":"prose","value":{"id":"interface_dom","title":"Interface DOM","isH3":false,"content":"<p>Este elemento implementa a interface&nbsp;<code><a href=\"/en-US/DOM/SVGLinearGradientElement\" title=\"en/DOM/SVGLinearGradientElement\">SVGLinearGradientElement</a></code>.</p>"}},{"type":"prose","value":{"id":"browser_compatibility","title":"Compatibilidade com navegadores","isH3":false,"content":"<p></p><div class=\"notecard note\" id=\"sect2\"><strong><a href=\"https://github.com/mdn/browser-compat-data\" class=\"external\" rel=\" noopener\">Estamos convertendo nossos dados de compatibilidade para o formato JSON</a></strong>.\n            Esta tabela de compatibilidade ainda usa o formato antigo,\n            pois ainda não convertemos os dados que ela contém.\n            <strong><a href=\"/en-US/docs/MDN/Structures/Compatibility_tables\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">Descubra como você pode ajudar! (en-US)</a></strong></div>\n\n<div class=\"htab\" id=\"sect3\">\n    <a id=\"AutoCompatibilityTable\" name=\"AutoCompatibilityTable\"></a>\n    <ul>\n        <li class=\"selected\"><a href=\"#compat-desktop\">Desktop</a></li>\n        <li><a href=\"#compat-mobile\">Dispositivo móvel</a></li>\n    </ul>\n</div><p></p>\n\n<div id=\"compat-desktop\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Recurso</th>\n   <th>Chrome</th>\n   <th>Firefox (Gecko)</th>\n   <th>IE</th>\n   <th>Opera</th>\n   <th>Safari</th>\n  </tr>\n  <tr>\n   <td>Suporte básico</td>\n   <td>1.0</td>\n   <td><a href=\"/en-US/docs/Mozilla/Firefox/Releases/1.5\" title=\"Released on 2005-11-25.\">1.5</a> (1.8)</td>\n   <td>9.0</td>\n   <td>9.0</td>\n   <td>3.0.4</td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<div id=\"compat-mobile\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Recurso</th>\n   <th>Android</th>\n   <th>Firefox Mobile (Gecko)</th>\n   <th>IE&nbsp;Phone</th>\n   <th>Opera Mobile</th>\n   <th>Safari Mobile</th>\n  </tr>\n  <tr>\n   <td>Suporte básico</td>\n   <td>3.0</td>\n   <td>1.0 (1.8)</td>\n   <td><span style=\"color:#f00;\">Não suportado</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td>3.0.4</td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<p>Esta tabela é baseada&nbsp;<a href=\"/en-US/SVG/Compatibility_sources\" title=\"en/SVG/Compatibility sources\">nestas fontes</a>.</p>"}},{"type":"prose","value":{"id":"notas_específicas_para_webkit","title":"Notas específicas para WebKit","isH3":true,"content":"<p>Navegadores baseados no Webkit não suportam&nbsp;<code>spreadMethod</code> (<a class=\"link-https external\" href=\"https://bugs.webkit.org/show_bug.cgi?id=5968\" rel=\" noopener\">bug 5968</a>) e interpolação de cores (<a class=\"link-https external\" href=\"https://bugs.webkit.org/show_bug.cgi?id=6034\" rel=\" noopener\">bug 6034</a>).</p>"}},{"type":"prose","value":{"id":"veja_também","title":"Veja também","isH3":false,"content":"<ul>\n <li><a href=\"/pt-BR/docs/Web/SVG/Element/radialGradient\"><code>&lt;radialGradient&gt;</code></a></li>\n <li><a href=\"/pt-BR/docs/Web/SVG/Element/stop\"><code>&lt;stop&gt;</code></a></li>\n</ul>"}}],"toc":[{"text":"Usage context","id":"usage_context"},{"text":"Example","id":"example"},{"text":"Atributos","id":"atributos"},{"text":"Interface DOM","id":"interface_dom"},{"text":"Compatibilidade com navegadores","id":"browser_compatibility"},{"text":"Veja também","id":"veja_também"}],"summary":"O elemento linearGradient permite que os autores definam gradientes lineares para preenchimento (fill) ou contornos (stroke) de elementos gráficos.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"<linearGradient>","locale":"en-US","native":"English (US)"},{"title":"<linearGradient>","locale":"fr","native":"Français"},{"title":"linearGradient","locale":"ja","native":"日本語"},{"title":