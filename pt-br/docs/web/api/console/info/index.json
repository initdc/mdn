td>&nbsp;</td>\n      </tr>\n     </tbody>\n    </table>\n   </td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td>38.0 (38.0)</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n </tbody>\n</table>\n</div>"}},{"type":"prose","value":{"id":"veja_também","title":"Veja &nbsp;também","isH3":false,"content":"<ul>\n <li><a class=\"external\" href=\"https://www.opera.com/dragonfly/documentation/console/\" rel=\" noopener\">Opera Dragonfly documentation: Console</a></li>\n <li><a class=\"external\" href=\"http://msdn.microsoft.com/library/gg589530\" rel=\" noopener\">MSDN: Using the F12 Tools Console to View Errors and Status</a></li>\n</ul>","titleAsText":"Veja  também"}}],"toc":[{"text":"Sintaxe","id":"sintaxe"},{"text":"Parâmetros","id":"parâmetros"},{"text":"Especificações","id":"especificações"},{"text":"Compatibilidade com navegadores","id":"browser_compatibility"},{"text":"Veja &nbsp;também","id":"veja_também"}],"summary":"Apresenta uma mensagem de saída no console do navegador . No Firefox e Chrome , um pequeno ícone \"i\" e apresentado próximo aos items do log do console .","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"console.info()","locale":"en-US","native":"English (US)"},{"title":"Console.info()","locale":"es","native":"Español"},{"title":"Console.info()","locale":"fr","native":"Français"},{"title":"console.info()","locale":"ja","native":"日本語"},{"title":"Console.info()","locale":"ru","native":"Русский"},{"title":"Console.info()","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"pt-br/web/api/console/info","github_url":"https://github