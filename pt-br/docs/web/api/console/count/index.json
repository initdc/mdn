bile</th>\n   <th>Opera Mobile</th>\n   <th>Safari Mobile</th>\n  </tr>\n  <tr>\n   <td>Suporte básico</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td>30.0 (30.0)</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n  <tr>\n   <td>Disponível em Workers</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td>38.0 (38.0)</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n </tbody>\n</table>\n</div>"}}],"toc":[{"text":"Sintaxe","id":"sintaxe"},{"text":"Parâmetros","id":"parâmetros"},{"text":"Especificações","id":"especificações"},{"text":"Compatibilidade com navegadores","id":"browser_compatibility"}],"summary":"Exibe o número de vezes em que a chamada count() em particular foi invocada. Essa função recebe um argumento opcional label.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Console.count()","locale":"de","native":"Deutsch"},{"title":"console.count()","locale":"en-US","native":"English (US)"},{"title":"Console.count()","locale":"es","native":"Español"},{"title":"Console.count()","locale":"fr","native":"Français"},{"title":"console.count()","locale":"ja","native":"日本語"},{"title":"console.count()","locale":"ko","native":"한국어"},{"title":"Console.count()","locale":"ru","native":"Русский"},{"title":"Console.count()","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"pt-br/web/api/console/count","github_url":"https://github.com/mdn/translated-content/blob/main/files/pt-br/web/api/console/count/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pt-BR/docs/Web","title":"Tecnologia Web para desenvolvedores"},{"uri":"/pt-BR/docs/Web/API","title":"APIs da Web"},{"uri":"/pt-BR/docs/Web/API/Console","title":"Console"},{"uri":"/pt-BR/docs/Web/API/Console/count","title":"Console.count()"}],"pageTitle":"Console.count() - APIs da Web | MDN","noIndexing":false}}