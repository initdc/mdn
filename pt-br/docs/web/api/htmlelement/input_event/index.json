td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><a href=\"/en-US/docs/Mozilla/Firefox/Releases/12\" title=\"Released on 2012-04-24.\">12</a> (12)</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td>15</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n  </tr>\n  <tr>\n   <td>ao <code>contenteditable</code> do elemento</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><a href=\"/en-US/docs/Mozilla/Firefox/Releases/14\" title=\"Released on 2012-07-17.\">14</a> (14)</td>\n   <td><span style=\"color:#f00;\">Não suportado</span><sup>[4]</sup>\n    <p>&nbsp;</p>\n   </td>\n   <td>15</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n  </tr>\n  <tr>\n   <td>quando <code>designMode</code> está \"ativado\"</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><a href=\"/en-US/docs/Mozilla/Firefox/Releases/14\" title=\"Released on 2012-07-17.\">14</a> (14)</td>\n   <td><span style=\"color:#f00;\">Não suportado</span></td>\n   <td>15</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n  </tr>\n  <tr>\n   <td><code>data</code></td>\n   <td><span title=\"Compatibility unknown; ple