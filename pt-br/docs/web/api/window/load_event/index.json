{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"load","mdn_url":"/pt-BR/docs/Web/API/Window/load_event","locale":"pt-BR","native":"Português (do Brasil)","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<pre dir=\"ltr\" id=\"tw-target-text\" class=\"notranslate\">O evento de <code>load</code> é acionado quando um recurso e seus recursos\ndependentes terminaram de carregar.</pre>"}},{"type":"prose","value":{"id":"informações_gerais","title":"Informações Gerais","isH3":false,"content":"<dl>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"especificação\">Especificação</dt>\n <dd style=\"margin: 0 0 0 120px;\"><a class=\"external\" href=\"https://www.w3.org/TR/DOM-Level-3-Events/#event-type-load\" rel=\" noopener\">DOM L3</a></dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"interface\">Interface</dt>\n <dd style=\"margin: 0 0 0 120px;\">UIEvent</dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"bubbles\">Bubbles</dt>\n <dd style=\"margin: 0 0 0 120px;\">Não</dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"cancelavel\">Cancelavel</dt>\n <dd style=\"margin: 0 0 0 120px;\">Não</dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"alvo\">Alvo</dt>\n <dd style=\"margin: 0 0 0 120px;\">Window</dd>\n <dt style=\"float: left; text-align: right; width: 120px;\" id=\"ação_padrão\">Ação Padrão</dt>\n <dd style=\"margin: 0 0 0 120px;\">Nenhuma.</dd>\n</dl>"}},{"type":"prose","value":{"id":"propriedades","title":"Propriedades","isH3":false,"content":"<table class=\"standard-table\">\n <thead>\n  <tr>\n   <th scope=\"col\">Property</th>\n   <th scope=\"col\">Type</th>\n   <th scope=\"col\">Description</th>\n  </tr>\n </thead>\n <tbody>\n  <tr>\n   <td><code>target</code> <span title=\"Este valor não pode ser alterado.\" class=\"badge inline readonly\">Somente leitura </span></td>\n   <td><a href=\"/en-US/docs/Web/API/EventTarget\" title=\"EventTarget is an interface implemented by objects that can receive events and may have listeners for them.\"><code>EventTarget</code></a></td>\n   <td>The event target (the topmost target in the DOM tree).</td>\n  </tr>\n  <tr>\n   <td><code>type</code> <span title=\"Este valor não pode ser alterado.\" class=\"badge inline readonly\">Somente leitura </span></td>\n   <td><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/String\" title=\"DOMString is a UTF-16 String. As JavaScript already uses such strings, DOMString is mapped directly to a String.\"><code>DOMString</code></a></td>\n   <td>The type of event.</td>\n  </tr>\n  <tr>\n   <td><code>bubbles</code> <span title=\"Este valor não pode ser alterado.\" class=\"badge inline readonly\">Somente leitura </span></td>\n   <td><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Boolean\" title=\"The Boolean object is an object wrapper for a boolean value.\"><code>Boolean</code></a></td>\n   <td>Whether the event normally bubbles or not.</td>\n  </tr>\n  <tr>\n   <td><code>cancelable</code> <span title=\"Este valor não pode ser alterado.\" class=\"badge inline readonly\">Somente leitura </span></td>\n   <td><a href=\"/en-US/docs/Web/JavaScript/Reference/Global_Objects/Boolean\" title=\"The Boolean object is an object wrapper for a boolean value.\"><code>Boolean</code></a></td>\n   <td>Whether the event is cancellable or not.</td>\n  </tr>\n  <tr>\n   <td><code>view</code> <span title=\"Este valor não pode ser alterado.\" class=\"badge inline readonly\">Somente leitura </span></td>\n   <td><a class=\"new page-not-created\" href=\"/en-US/docs/Web/API/WindowProxy\" rel=\"nofollow\" title=\"This is a link to an unwritten page\"><code>WindowProxy</code></a></td>\n   <td><a href=\"/en-US/docs/Web/API/Document/defaultView\" title=\"In browsers, document.defaultView returns the window object associated with a document, or null if none is available.\"><code>document.defaultView</code></a> (<code>window</code> of the document)</td>\n  </tr>\n  <tr>\n   <td><code>detail</code> <span title=\"Este valor não pode ser alterado.\" class=\"badge inline readonly\">Somente leitura </span></td>\n   <td><code>long</code> (<code>float</code>)</td>\n   <td>0.</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"exemplo","title":"Exemplo","isH3":false,"content":"<div class=\"code-example\"><pre class=\"brush: html notranslate\"><code><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;</span>script</span><span class=\"token punctuation\">&gt;</span></span><span class=\"token script\"><span class=\"token language-javascript\">\n  window<span class=\"token punctuation\">.</span><span class=\"token function\">addEventListener</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"load\"</span><span class=\"token punctuation\">,</span> <span class=\"token keyword\">function</span><span class=\"token punctuation\">(</span><span class=\"token parameter\">event</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n    console<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span><span class=\"token string\">\"Todos os recursos terminaram o carregamento!\"</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n  <span class=\"token punctuation\">}</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n</span></span><span class=\"token tag\"><span class=\"token tag\"><span class=\"token punctuation\">&lt;/</span>script</span><span class=\"token punctuation\">&gt;</span></span>\n</code></pre></div>\n\n<p>&nbsp;</p>"}},{"type":"prose","value":{"id":"eventos_relacionados","title":"Eventos Relacionados","isH3":false,"content":"<ul>\n <li><code><a href=\"/en-US/docs/Web/API/Window/DOMContentLoaded_eve