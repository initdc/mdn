/td>\n   <td>2.0</td>\n   <td><span style=\"color:#f00;\">Não suportado</span></td>\n   <td><span style=\"color:#f00;\">Não suportado</span></td>\n   <td>7.1</td>\n  </tr>\n </tbody>\n</table>\n</div>"}},{"type":"prose","value":{"id":"veja_também","title":"Veja também","isH3":false,"content":"<ul>\n <li><a href=\"/en-US/docs/Web/API/Web_Speech_API\">Web Speech API</a></li>\n</ul>"}}],"toc":[{"text":"Sintaxe","id":"sintaxe"},{"text":"Exemplo","id":"exemplo"},{"text":"Especificações","id":"especificações"},{"text":"Compatiblidade dos navegadores","id":"compatiblidade_dos_navegadores"},{"text":"Veja também","id":"veja_também"}],"summary":"A propriedade voice  da interface SpeechSynthesisUtterance retorna e configura a voz que será usada para a fala.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"SpeechSynthesisUtterance.voice","locale":"en-US","native":"English (US)"},{"title":"SpeechSynthesisUtterance.voice","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"pt-br/web/api/speechsynthesisutterance/voice","github_url":"https://github.com/mdn/translated-content/blob/main/files/pt-br/web/api/speechsynthesisutterance/voice/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pt-BR/docs/Web","title":"Tecnologia Web para desenvolvedores"},{"uri":"/pt-BR/docs/Web/API","title":"APIs da Web"},{"uri":"/pt-BR/docs/Web/API/SpeechSynthesisUtterance","title":"SpeechSynthesisUtterance"},{"uri":"/pt-BR/docs/Web/API/SpeechSynthesisUtterance/voice","title":"SpeechSynthesisUtterance.voice"}],"pageTitle":"SpeechSynthesisUtterance.voice - APIs da Web | MDN","noIndexing":false}}