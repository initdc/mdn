{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"XMLHttpRequest.onreadystatechange","mdn_url":"/pt-BR/docs/Web/API/XMLHttpRequest/readystatechange_event","locale":"pt-BR","native":"Português (do Brasil)","sidebarHTML":"<ol><li><strong><a href=\"/pt-BR/docs/Web/API/XMLHttpRequest\"><code>XMLHttpRequest</code></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>Construtor</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/XMLHttpRequest\"><code>XMLHttpRequest()</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Propriedades</summary><ol><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/channel\"><code>channel</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/mozAnon\"><code>mozAnon</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/mozBackgroundRequest\"><code>mozBackgroundRequest</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/mozSystem\"><code>mozSystem</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/msCaching\"><code>msCaching</code> <small>(en-US)</small></a></li><li><a href=\"/pt-BR/docs/Web/API/XMLHttpRequest/readyState\"><code>readyState</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/response\"><code>response</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/responseText\"><code>responseText</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/responseType\"><code>responseType</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/responseURL\"><code>responseURL</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/responseXML\"><code>responseXML</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/status\"><code>status</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/statusText\"><code>statusText</code> <small>(en-US)</small></a></li><li><a href=\"/pt-BR/docs/Web/API/XMLHttpRequest/timeout\"><code>timeout</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/upload\"><code>upload</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/withCredentials\"><code>withCredentials</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Métodos</summary><ol><li><a href=\"/pt-BR/docs/Web/API/XMLHttpRequest/abort\"><code>abort()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/getAllResponseHeaders\"><code>getAllResponseHeaders()</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/getResponseHeader\"><code>getResponseHeader()</code> <small>(en-US)</small></a></li><li><svg class=\"icon icon-nonstandard\" tabindex=\"0\">\n    <use xlink:href=\"/assets/badges.svg#icon-nonstandard\"></use>\n</svg><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/msCachingEnabled\"><code>msCachingEnabled()</code> <small>(en-US)</small></a></li><li><a href=\"/pt-BR/docs/Web/API/XMLHttpRequest/open\"><code>open()</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/overrideMimeType\"><code>overrideMimeType()</code> <small>(en-US)</small></a></li><li><a href=\"/pt-BR/docs/Web/API/XMLHttpRequest/send\"><code>send()</code></a></li><li><a href=\"/pt-BR/docs/Web/API/XMLHttpRequest/setRequestHeader\"><code>setRequestHeader()</code></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Eventos</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/abort_event\"><code>abort</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/error_event\"><code>error</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/load_event\"><code>load</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/loadend_event\"><code>loadend</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/loadstart_event\"><code>loadstart</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/progress_event\"><code>progress</code> <small>(en-US)</small></a></li><li><em><code>readystatechange</code></em></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequest/timeout_event\"><code>timeout</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Herança:</summary><ol><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/XMLHttpRequestEventTarget\"><code>XMLHttpRequestEventTarget</code> <small>(en-US)</small></a></li><li><a href=\"/pt-BR/docs/Web/API/EventTarget\"><code>EventTarget</code></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<div id=\"sect1\"></div>\n\n<p>Um&nbsp;<a href=\"/en-US/docs/Web/API/EventHandler\" title=\"A possible way to get notified of Events of a particular type (such as click) for a given object is to specify an&nbsp;event handler using:\"><code>EventHandler</code></a>&nbsp;é chamado sempre que&nbsp;o atributo&nbsp;<code>readyState</code>&nbsp;é modificado. O callback é chamado a partir da interface do usuário. A propriedade&nbsp;<strong><code>XMLHttpRequest.onreadystatechange</code></strong>&nbsp;contém o manipulador de eventos que é&nbsp;chamado quando&nbsp;o evento <a href=\"/pt-BR/docs/Web/API/Document/readystatechange_event\">readystatechange</a> é disparado, ou seja, toda vez que a propriedade <a href=\"/pt-BR/docs/Web/API/XMLHttpRequest/readyState\" title=\"readyState\"><code>readyState</code></a> do <a href=\"/pt-BR/docs/Web/API/XMLHttpRequest\"><code>XMLHttpRequest</code></a> é modificada.</p>\n\n<div class=\"warning notecard\" id=\"sect2\">\n<p><strong>Atenção:</strong> Isso não deve ser usado com solicitações síncronas e não deve ser usado como&nbsp;código nativo.</p>\n</div>\n\n<p>O evento&nbsp;<code>readystatechange</code> não será chamado&nbsp;quando a&nbsp;<code>XMLHttpRequest</code> request for cancelada pelo método&nbsp;<a href=\"/pt-BR/docs/Web/API/XMLHttpRequest/abort\">abort()</a>.</p>\n\n<div class=\"note notecard\" id=\"sect3\">\n<p><strong>Atualização</strong>: Está disparando na última versão de navegadores&nbsp;(Firefox&nbsp;51.0.1, Opera&nbsp;43.0.2442.991, Safari&nbsp;10.0.3 (12602.4.8), Chrome&nbsp;54.0.2840.71,&nbsp;Edge, IE11). Exemplo&nbsp;<a href=\"https://jsfiddle.net/merksam/ve5oc0gn/\" class=\"external\" rel=\" noopener\">aqui</a>&nbsp;- <em>basta recarregar a página algumas vezes</em>.</p>\n</div>"}},{"type":"prose","value":{"id":"syntax","title":"Sitaxe","isH3":false,"content":"<pre class=\"syntaxbox notranslate\"><em>XMLHttpRequest</em>.onreadystatechange = <em>callback</em>;</pre>"}},{"type":"prose","value":{"id":"valores","title":"Valores","isH3":true,"content":"<ul>\n <li><code><em>callback</em></code>&nbsp;é&nbsp;a função que será executada quando o readyState mudar.</li>\n</ul>"}},{"type":"prose","value":{"id":"example","title":"Exemplo","isH3":false,"content":"<div class=\"code-example\"><pre class=\"brush: js notranslate\"><code><span class=\"token keyword\">var</span> xhr <span class=\"token operator\">=</span> <span class=\"token keyword\">new</span> <span class=\"token class-name\">XMLHttpRequest</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">,</span>\n    method <span class=\"token operator\">=</span> <span class=\"token string\">\"GET\"</span><span class=\"token punctuation\">,</span>\n    url <span class=\"token operator\">=</span> <span class=\"token string\">\"https://developer.mozilla.org/\"</span><span class=\"token punctuation\">;</span>\n\nxhr<span class=\"token punctuation\">.</span><span class=\"token function\">open</span><span class=\"token punctuation\">(</span>method<span class=\"token punctuation\">,</span> url<span class=\"token punctuation\">,</span> <span class=\"token boolean\">true</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\nxhr<span class=\"token punctuation\">.</span><span class=\"token function-variable function\">onreadystatechange</span> <span class=\"token operator\">=</span> <span class=\"token keyword\">function</span> <span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n        <span class=\"token keyword\">if</span><span class=\"token punctuation\">(</span>xhr<span class=\"token punctuation\">.</span>readyState <span class=\"token operator\">===</span> XMLHttpRequest<span class=\"token punctuation\">.</span><span class=\"token constant\">DONE</span> <span class=\"token operator\">&amp;&amp;</span> xhr<span class=\"token punctuation\">.</span>status <span class=\"token operator\">===</span> <span class=\"token number\">200</span><span class=\"token punctuation\">)</span> <span class=\"token punctuation\">{</span>\n            console<span class=\"token punctuation\">.</span><span class=\"token function\">log</span><span class=\"token punctuation\">(</span>xhr<span class=\"token punctuation\">.</span>responseText<span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span>\n        <span class=\"token punctuation\">}</span>\n    <span class=\"token punctuation\">}</span><span class=\"token punctuation\">;</span>\nxhr<span class=\"token punctuation\">.</span><span class=\"token function\">send</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span><span class=\"token punctuation\">;</span></code></pre></div>"}},{"type":"prose","value":{"id":"especificação","title":"Especificação","isH3":false,"content":"<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Especificação</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Comentário</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://xhr.spec.whatwg.org/#handler-xhr-onreadystatechange\" hreflang=\"en\" lang=\"en\" class=\"external\" title=\"The 'XMLHttpRequest' specification\" rel=\" noopener\">XMLHttpRequest</a></td>\n   <td><span class=\"spec-living\">Padrão em tempo real</span></td>\n   <td>WHATWG living standard</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"browser_compatibility","title":"Compatibilidade com navegadores","isH3":false,"content":"<p></p><div class=\"notecard note\" id=\"sect4\"><strong><a href=\"https://github.com/mdn/browser-compat-data\" class=\"external\" rel=\" noopener\">Estamos convertendo nossos dados de compatibilidade para o formato JSON</a></strong>.\n            Esta tabela de compatibilidade ainda usa o formato antigo,\n            pois ainda não convertemos os dados que ela contém.\n            <strong><a href=\"/en-US/docs/MDN/Structures/Compatibility_tables\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">Descubra como você pode ajudar! (en-US)</a></strong></div>\n\n<div class=\"htab\" id=\"sect5\">\n    <a id=\"AutoCompatibilityTable\" name=\"AutoCompatibilityTable\"></a>\n    <ul>\n        <li class=\"selected\"><a href=\"#compat-desktop\">Desktop</a></li>\n        <li><a href=\"#compat-mobile\">Dispositivo móvel</a></li>\n    </ul>\n</div><p></p>\n\n<div id=\"compat-desktop\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Chrome</th>\n   <th>Firefox (Gecko)</th>\n   <th>Internet Explorer</th>\n   <th>Opera</th>\n   <th>Safari</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td>1</td>\n   <td>1.0 (1.7 or earlier)</td>\n   <td>7<sup>[1]</sup></td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td>1.2</td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<div id=\"compat-mobile\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Feature</th>\n   <th>Android</th>\n   <th>Chrome for Android</th>\n   <th>Firefox Mobile (Gecko)</th>\n   <th>IE Mobile</th>\n   <th>Opera Mobile</th>\n   <th>Safari Mobile</th>\n  </tr>\n  <tr>\n   <td>Basic support</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td>1.0</td>\n   <td><span style=\"color: #888\" title=\"Please update this with the earliest version of support.\">(Yes)</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<p>[1] Internet Explorer versão 5 e 6 suportam chamadas&nbsp;ajax usando&nbsp;<code>ActiveXObject()</code>.</p>"}}],"toc":[{"text":"Sitaxe","id":"syntax"},{"text":"Exemplo","id":"example"},{"text":"Especificação","id":"especificação"},{"text":"Compatibilidade com navegadores","id":"browser_compatibility"}],"summary":"Um EventHandler é chamado sempre que o atributo readyState é modificado. O callback é chamado a partir da interface do usuário. A propriedade XMLHttpRequest.onreadystatechange contém o manipulador de eventos que é chamado quando o evento readystatechange é disparado, ou seja, toda vez que a propriedade readyState do XMLHttpRequest é modificada.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"XMLHttpRequest: readystatechange event","locale":"en-US","native":"English (US)"},{"title":"XMLHttpRequest.onreadystatechange","locale":"es","native":"Español"},{"title":"XMLHttpRequest.onreadystatechange","locale":"fr","native":"Français"},{"title":"XMLHttpRequest.onreadystatechange","locale":"ja","native":"日本語"},{"title":"XMLHttpRequest.onreadystatechange","locale":"ru","native":"Русский"},{"title":"XMLHttpRequest.onreadystatechange","locale":"zh-CN","native":"中文 (简体)"},{"title":"XMLHttpRequest.onreadystatechange","locale":"zh-TW","native":"正體中文 (繁體)"}],"source":{"folder":"pt-br/web/api/xmlhttprequest/readystatechange_event","github_url":"https://github.com/mdn/translated-content/blob/main/files/pt-br/web/api/xmlhttprequest/readystatechange_event/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pt-BR/docs/Web","title":"Tecnologia Web para desenvolvedores"},{"uri":"/pt-BR/docs/Web/API","title":"APIs da Web"},{"uri":"/pt-BR/docs/Web/API/XMLHttpRequest","title":"XMLHttpRequest"},{"uri":"/pt-BR/docs/Web/API/XMLHttpRequest/readystatechange_event","title":"XMLHttpRequest.onreadystatechange"}],"pageTitle":"XMLHttpRequest.onreadystatechange - APIs da Web | MDN","noIndexing":false}}