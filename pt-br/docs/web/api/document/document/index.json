US/docs/Web/API/Document/pointerover_event\"><code>pointerover</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/pointerup_event\"><code>pointerup</code> <small>(en-US)</small></a></li><li><a href=\"/pt-BR/docs/Web/API/Document/readystatechange_event\"><code>readystatechange</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/scroll_event\"><code>scroll</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/selectionchange_event\"><code>selectionchange</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/selectstart_event\"><code>selectstart</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/touchcancel_event\"><code>touchcancel</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/touchend_event\"><code>touchend</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/touchmove_event\"><code>touchmove</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/touchstart_event\"><code>touchstart</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/Document/visibilitychange_event\"><code>visibilitychange</code> <small>(en-US)</small></a></li></ol></details></li><li class=\"toggle\"><details open=\"\"><summary>Herança:</summary><ol><li><a href=\"/pt-BR/docs/Web/API/Node\"><code>Node</code></a></li><li><a href=\"/pt-BR/docs/Web/API/EventTarget\"><code>EventTarget</code></a></li></ol></details></li></ol>","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p></p><div class=\"notecard warning\" id=\"sect1\"><p><strong>Non-standard:</strong> This feature is non-standard and is not on a standards track. Do not use it on production sites facing the Web: it will not work for every user. There may also be large incompatibilities between implementations and the behavior may change in the future.</p></div><p></p>\n\n<p>O construtor&nbsp;<strong><code>Document</code></strong>&nbsp;cria um novo objeto&nbsp;<a href=\"/pt-BR/docs/Web/API/Document\"><code>Document</code></a>, &nbsp;o qual trata de&nbsp;uma página carregada no navegador servindo como porta de entrada para o conteúdo da página.</p>"}},{"type":"prose","value":{"id":"sintaxe","title":"Sintaxe","isH3":false,"content":"<pre class=\"syntaxbox notranslate\">var <em>document</em> = new Document()</pre>"}},{"type":"prose","value":{"id":"parâmetros","title":"Parâmetros","isH3":true,"content":"<p>Nenhum.</p>\n\n<p><span style=\"background-color: #333333; color: #ffffff; font-family: x-locale-heading-primary,zillaslab,Palatino,&quot;Palatino Linotype&quot;,x-locale-heading-secondary,serif; font-size: 1.5rem;\">Especificações</span></p>\n\n<table class=\"standard-table\">\n <tbody>\n  <tr>\n   <th scope=\"col\">Especificação</th>\n   <th scope=\"col\">Status</th>\n   <th scope=\"col\">Comentário</th>\n  </tr>\n  <tr>\n   <td><a href=\"https://dom.spec.whatwg.org/#interface-document\" hreflang=\"en\" lang=\"en\" class=\"external\" rel=\" noopener\">DOM<br><small lang=\"pt-BR\">The definition of 'Document' in that specification.</small></a></td>\n   <td><span class=\"spec-living\">Padrão em tempo real</span></td>\n   <td>Definição inicial</td>\n  </tr>\n </tbody>\n</table>"}},{"type":"prose","value":{"id":"browser_compatibility","title":"Compatibilidade com navegadores","isH3":false,"content":"<div id=\"sect2\"><div class=\"notecard note\" id=\"sect3\"><strong><a href=\"https://github.com/mdn/browser-compat-data\" class=\"external\" rel=\" noopener\">Estamos convertendo nossos dados de compatibilidade para o formato JSON</a></strong>.\n            Esta tabela de compatibilidade ainda usa o formato antigo,\n            pois ainda não convertemos os dados que ela contém.\n            <strong><a href=\"/en-US/docs/MDN/Structures/Compatibility_tables\" class=\"only-in-en-us\" title=\"Currently only available in English (US)\">Descubra como você pode ajudar! (en-US)</a></strong></div>\n\n<div class=\"htab\" id=\"sect4\">\n    <a id=\"AutoCompatibilityTable\" name=\"AutoCompatibilityTable\"></a>\n    <ul>\n        <li class=\"selected\"><a href=\"#compat-desktop\">Desktop</a></li>\n        <li><a href=\"#compat-mobile\">Dispositivo móvel</a></li>\n    </ul>\n</div></div>\n\n<div id=\"compat-desktop\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Navegador</th>\n   <th>Chrome</th>\n   <th>Firefox (Gecko)</th>\n   <th>Internet Explorer</th>\n   <th>Opera</th>\n   <th>Safari (WebKit)</th>\n  </tr>\n  <tr>\n   <td>Suporte</td>\n   <td>60</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td>47</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n </tbody>\n</table>\n</div>\n\n<div id=\"compat-mobile\">\n<table class=\"compat-table\">\n <tbody>\n  <tr>\n   <th>Navegador</th>\n   <th>Android Webview</th>\n   <th>Chrome for Android</th>\n   <th>Firefox Mobile (Gecko)</th>\n   <th>Firefox OS</th>\n   <th>IE Mobile</th>\n   <th>Opera Mobile</th>\n   <th>Safari Mobile</th>\n  </tr>\n  <tr>\n   <td>Suporte</td>\n   <td>60</td>\n   <td>60</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n   <td>47</td>\n   <td><span title=\"Compatibility unknown; please update this.\" style=\"color: rgb(255, 153, 0);\">?</span></td>\n  </tr>\n </tbody>\n</table>\n</div>"}}],"toc":[{"text":"Sintaxe","id":"sintaxe"},{"text":"Compatibilidade com navegadores","id":"browser_compatibility"}],"summary":"O construtor Document cria um novo objeto Document,  o qual trata de uma página carregada no navegador servindo como porta de entrada para o conteúdo da página.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Document()","locale":"de","native":"Deutsch"},{"title":"Document()","locale":"en-US","native":"English (US)"},{"title":"Document()","locale":"fr","native":"Français"},{"title":"Document()","locale":"ja","native":"日本語"},{"title":"Document()","locale":"ko","native":"한국어"},{"title":"Document()","locale":"ru","native":"Русский"},{"title":"Document()","locale":"zh-CN","native":"中文 (简体)"}],"source":{"folder":"pt-br/web/api/document/document","github_url":"https://github.com/mdn/translated-content/blob/main/files/pt-br/web/api/document/document/index.html","last_commit_url":"https://github.com/mdn/translated-content/commit/5fe4ab11259b37914fab41914e84897fea47d143","filename":"index.html"},"parents":[{"uri":"/pt-BR/docs/Web","title":"Tecnologia Web para desenvolvedores"},{"uri":"/pt-BR/docs/Web/API","title":"APIs da Web"},{"uri":"/pt-BR/docs/Web/API/Document","title":"Document"},{"uri":"/pt-BR/docs/Web/API/Document/Document","title":"Document()"}],"pageTitle":"Document() - APIs da Web | MDN","noIndexing":false}}