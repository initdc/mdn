{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"GlobalEventHandlers.onload","mdn_url":"/pt-BR/docs/Web/API/GlobalEventHandlers/onload","locale":"pt-BR","native":"Português (do Brasil)","sidebarHTML":"<ol><li><strong><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/HTML_DOM_API\">HTML DOM API <small>(en-US)</small></a></strong></li><li><strong><a href=\"/pt-BR/docs/Web/API/GlobalEventHandlers\"><code>GlobalEventHandlers</code></a></strong></li><li class=\"toggle\"><details open=\"\"><summary>Propriedades</summary><ol><li><a href=\"/pt-BR/docs/Web/API/GlobalEventHandlers/onerror\"><code>onerror</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/ongotpointercapture\"><code>ongotpointercapture</code> <small>(en-US)</small></a></li><li><em><code>onload</code></em></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/onloadeddata\"><code>onloadeddata</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/onloadedmetadata\"><code>onloadedmetadata</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/onloadend\"><code>onloadend</code> <small>(en-US)</small></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEventHandlers/onloadstart\"><code>onloadstart</code> <small>(en-US)</small></a></li><li><a href=\"/pt-BR/docs/Web/API/GlobalEventHandlers/onlostpointercapture\"><code>onlostpointercapture</code></a></li><li><a class=\"only-in-en-us\" title=\"Currently only available in English (US)\" href=\"/en-US/docs/Web/API/GlobalEven