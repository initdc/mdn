{"doc":{"isMarkdown":false,"isTranslated":true,"isActive":true,"flaws":{},"title":"Mozilla Firefox","mdn_url":"/pt-BR/docs/Glossary/Mozilla_Firefox","locale":"pt-BR","native":"Português (do Brasil)","sidebarHTML":"","body":[{"type":"prose","value":{"id":null,"title":null,"isH3":false,"content":"<p>Mozilla Firefox é um <span style=\"line-height: 1.5;\"><a href=\"/pt-BR/docs/Glossary/Browser\">browser</a> open-source cujo desenvolvimento é supervisionado pela Mozilla Corporation. Firefox roda em Windows, OS X, Linux, e Android.</span></p>\n\n<p><span style=\"line-height: 1.5;\">O primeiro lançamento foi em Novembro de 2004, Firefox é completamente customizável com temas, plug-ins, e <a href=\"/pt-BR/docs/Mozilla/Add-ons\">complementos</a>. &nbsp;Firefox usa o <a href=\"/pt-BR/docs/Glossary/Gecko\">Gecko</a> para renderizar páginas web, e implementa ambos padrões corrente e a vir da Web.</span></p>"}},{"type":"prose","value":{"id":"aprenda_mais","title":"<span style=\"line-height: 1.5;\">Aprenda mais</span>","isH3":false,"content":"","titleAsText":"Aprenda mais"}},{"type":"prose","value":{"id":"conhecimento_geral","title":"Conhecimento geral","isH3":true,"content":"<ul>\n <li><a href=\"https://www.firefox.com/\" class=\"external\" rel=\" noopener\">Site oficial do Mozilla Firefox</a></li>\n</ul>"}},{"type":"prose","value":{"id":"referência_técnica","title":"Referência técnica","isH3":true,"content":"<ul>\n <li><a href=\"/en-US/Firefox\">Informações de documentação/desenvolvimento na MDN</a></li>\n</ul>"}}],"toc":[{"text":"<span style=\"line-height: 1.5;\">Aprenda mais</span>","id":"aprenda_mais"}],"summary":"Mozilla Firefox é um browser open-source cujo desenvolvimento é supervisionado pela Mozilla Corporation. Firefox roda em Windows, OS X, Linux, e Android.","popularity":0,"modified":"2022-07-19T02:29:32.000Z","other_translations":[{"title":"Mozilla Firefox","locale":"de","native":"Deutsch"},{"title":"Mozilla Firefox","locale":"en-US","native":"English (US)"},{"title